---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import AuthModal from '@components/ui/AuthModal.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  showAuthModal?: boolean;
  showHeader?: boolean;
}

const { title, description, image, showAuthModal = true, showHeader = true } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  {showHeader && <Header slot="header" />}
  <slot />
  <Footer slot="footer" />
  {showAuthModal && <AuthModal slot="overlay" />}
</BaseLayout>
