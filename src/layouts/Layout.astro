---
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  showAuthModal?: boolean;
  showHeader?: boolean;
}

const { title, description, image, showAuthModal = true, showHeader = true } = Astro.props;
---

<SiteLayout title={title} description={description} image={image} showAuthModal={showAuthModal} showHeader={showHeader}>
  <slot />
</SiteLayout>
