---
import Layout from '@layouts/Layout.astro';
import HeroClaude from '@components/sections/Hero-Claude.astro';
import Features from '@components/sections/Features.astro';
import ContributionGraph from '@components/sections/ContributionGraph.astro';
import YearProgress from '@components/sections/YearProgress.astro';
import Activity from '@components/sections/Activity.astro';
import Research from '@components/sections/Research.astro';
import Safety from '@components/sections/Safety.astro';
import CTA from '@components/sections/CTA.astro';
---

<Layout 
  title="Maxwell.Science - Calm, capable AI for writing, research, and real work"
  description="Claude-inspired AI product design for chat, workspace, research, and practical daily workflows."
>
  <HeroClaude 
    title="Calm, capable AI for real work"
    subtitle="Maxwell AI"
    description="A steady workspace for writing, research, and everyday problem-solving. Less noise, more signal."
    ctaText="Start chatting"
    ctaHref="/chatbot"
    secondaryCtaText="Open workspace"
    secondaryCtaHref="/workspace"
  />
  <Features />
  <ContributionGraph />
  <YearProgress />
  <Activity />
  <Research />
  <Safety />
  <CTA />
</Layout>
