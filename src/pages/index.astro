---
import Layout from '@layouts/Layout.astro';
import ScrollAnimation from '@components/ui/ScrollAnimation.astro';
import HeroEnhanced from '@components/sections/Hero-Enhanced.astro';
import ContributionGraph from '@components/sections/ContributionGraph.astro';
import LottieShowcase from '@components/sections/LottieShowcase.astro';

// New dynamic components
import TabsShowcase from '@components/ui/TabsShowcase.astro';
import TypewriterDemo from '@components/ui/TypewriterDemo.astro';
import StackedCards from '@components/ui/StackedCards.astro';
import ChatPreviewMockup from '@components/ui/ChatPreviewMockup.astro';
import TextReveal from '@components/ui/TextReveal.astro';

const coreTabs = [
  {
    id: 'tab-code',
    label: 'Code Generation',
    contentTitle: 'Write, debug, and trace quantum circuits.',
    contentText: 'From single defect calculations to scalable HPC cluster deployments, bring a domain-expert partner directly into your Vim/VSCode workflow.'
  },
  {
    id: 'tab-write',
    label: 'Academic Writing',
    contentTitle: 'Draft with a thoughtful colleague.',
    contentText: 'Need a tone check, a creative spark for your introduction, or someone to restructure a long nature-style letter? MoonSun helps you write clearly.'
  },
  {
    id: 'tab-analyze',
    label: 'Data Analysis',
    contentTitle: 'Extract insights instantly.',
    contentText: 'Upload PDFs, Origin spreadsheets, or raw PPMS dat files. MoonSun parses complex transport information so you can reach conclusions faster.'
  }
];

const workflows = [
  {
    title: 'Break down physics problems',
    description: 'MoonSun builds on your Hamiltonian logic, expands on your derivations, and simplifies complexity one perturbation step at a time.',
    tag: 'Problem Solving',
    background: 'var(--bg-secondary)'
  },
  {
    title: 'Tackle your toughest synthesis',
    description: 'Provides expert-level collaboration on the things you need to get done—from planning a flux growth recipe to analyzing XRD patterns.',
    tag: 'Collaboration',
    background: 'var(--bg-tertiary)'
  },
  {
    title: 'Explore what’s next',
    description: 'Like an expert postdoc in your pocket, collaborating with MoonSun expands what you can discover on your own.',
    tag: 'Innovation',
    background: 'var(--card-bg-cream)'
  }
];
---

<Layout
  title="MoonSun.ai — AI that thinks. You decide."
  description="Write better, plan faster, research deeper. One place for chat, workspace, research, and a live gold price tracker."
>
  <!-- 1. The Hero Section -->
  <HeroEnhanced />

  <!-- 1.5. Visual App Mockup Section (Split Screen) -->
  <section class="claude-section container presentation-section presentation-section--workspace">
    <div class="split-layout">
      <div class="split-text">
        <TextReveal tag="h2" class="split-text__title" delay={100}>
          <span>Think fast,</span>
          <span>build faster</span>
        </TextReveal>
        <TextReveal
          tag="p"
          class="split-text__body"
          text="Brainstorm with MoonSun, execute locally with integrated workflows."
          delay={200}
        />
        <div class="split-actions">
          <a href="/downloads/" class="split-actions__btn split-actions__btn--primary">Download desktop app</a>
        </div>
      </div>
      <div class="split-visual">
        <ChatPreviewMockup />
      </div>
    </div>
  </section>

  <!-- 2. Dynamic Tabs Showcase (Replaces static Features) -->
  <section class="claude-section container presentation-section">
    <div class="claude-section-heading" style="margin: 0 auto 3rem; text-align: center;">
      <h2>Three surfaces. One steady workflow.</h2>
      <p style="margin: 0 auto;">Fewer tricks, better pacing, more room for the actual research.</p>
    </div>
    
    <ScrollAnimation rootMargin="-20px">
      <TabsShowcase tabs={coreTabs}>
        <div slot="tab-code" class="tab-demo-wrapper">
          <TypewriterDemo 
            text="def calc_berry_curvature(H, kx, ky):\n    '''Calculate Berry curvature for given Hamiltonian'''\n    eigenvals, eigenvecs = np.linalg.eigh(H(kx, ky))\n    # Summing over occupied bands...\n    omega = np.zeros(len(kx))\n    for n in range(n_occ):\n        for m in range(n_occ, n_tot):\n            numerator = np.imag(np.conj(velocity_x[n,m]) * velocity_y[m,n])\n            denominator = (eigenvals[n] - eigenvals[m])**2\n            omega += -2 * numerator / denominator\n    return omega" 
            speed={15}
          />
        </div>
        
        <div slot="tab-write" class="tab-demo-wrapper">
          <TypewriterDemo 
            text="Here is a revised draft of your Physical Review Letter abstract, incorporating a more authoritative tone and highlighting the long-term impact:\n\nThe emergence of a nonlinear Hall effect in the noncentrosymmetric magnetic Weyl semimetal CoNb3S6 fundamentally bridges the gap between band topology and correlation physics, offering an estimated 40% enhancement in room-temperature responsivity..." 
            speed={25}
          />
        </div>
        
        <div slot="tab-analyze" class="tab-demo-wrapper">
          <TypewriterDemo 
            text="Based on the uploaded PPMS transport data (Sample_A_300K.dat), here are the key takeaways:\n\n1. Longitudinal resistivity (rho_xx) shows metallic behavior down to 28K.\n2. A sharp anomaly near 28K coincides precisely with the onset of the AFM transition observed in your magnetization data.\n3. The Hall carrier concentration assumes a hole-dominated pocket at low T." 
            speed={20}
          />
        </div>
      </TabsShowcase>
    </ScrollAnimation>
  </section>

  <!-- 3. Lottie Animation Showcase -->
  <section class="claude-section container">
    <LottieShowcase />
  </section>

  <!-- 4. Stacked Cards Section (Engaging deep dive workflows) -->
  <section class="claude-section container">
    <div class="claude-section-heading" style="margin: 0 auto 1rem; text-align: center;">
      <h2>Built for deep exploration</h2>
    </div>
    <StackedCards cards={workflows} />
  </section>

  <!-- 5. Original Sections (Animated standard pieces) -->
  <section class="claude-section container">
    <ScrollAnimation rootMargin="-20px"><ContributionGraph /></ScrollAnimation>
  </section>
  
</Layout>

<style>
  .presentation-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  .presentation-section--workspace {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .tab-demo-wrapper {
    width: 100%;
    height: 100%;
  }

  .split-layout {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .split-layout {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 3rem;
    }
  }

  .split-text {
    display: flex;
    flex-direction: column;
  }

  .split-text__title {
    font-family: var(--font-editorial);
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    line-height: 1.05;
    margin-bottom: 0;
    font-weight: var(--font-normal);
    letter-spacing: 0;
    color: var(--text-primary);
    max-width: 11ch;
  }

  .split-text__title :global(> span) {
    display: block;
  }

  .split-text__body {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 1rem;
    margin-bottom: 2rem;
    max-width: 34rem;
  }

  .split-actions {
    display: flex;
    gap: 1rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.36s both;
  }

  .split-actions__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.72rem 1.45rem;
    border-radius: var(--radius-full);
    font-size: 0.92rem;
    font-weight: var(--font-medium);
    transition: all var(--duration-normal) var(--ease-default);
  }

  .split-actions__btn--primary {
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    box-shadow: var(--btn-primary-shadow);
  }

  .split-actions__btn--primary:hover {
    background: var(--btn-primary-hover);
    color: var(--btn-primary-text);
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg);
  }

  .split-visual {
    background: var(--bg-secondary);
    border-radius: 20px;
    padding: 2rem;
    /* subtle pattern behind the mock browser */
    background-image: radial-gradient(var(--border-primary) 1px, transparent 1px);
    background-size: 20px 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (min-width: 900px) {
    .split-text {
      max-width: 48rem;
      padding-left: clamp(3rem, 6.8vw, 6.8rem);
    }
  }

  @media (max-width: 899px) {
    .split-text__body {
      max-width: 34rem;
    }
  }
</style>
