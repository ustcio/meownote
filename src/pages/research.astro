---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';

const timeline = [
  {
    year: '2025',
    title: 'Claude 4 & GPT-5 Era',
    description: 'Anthropic Claude 4 和 OpenAI GPT-5 引领AGI探索，多模态能力达到新高度，AI代理开始大规模应用。',
    highlight: true
  },
  {
    year: '2024',
    title: 'Claude 3.5 & GPT-4o & Sora',
    description: 'Anthropic发布Claude 3.5 Sonnet，OpenAI发布多模态GPT-4o和文生视频模型Sora，开启AI视频生成时代。'
  },
  {
    year: '2023',
    title: 'GPT-4 & Claude 2 & Gemini',
    description: 'OpenAI发布GPT-4，Anthropic推出Claude 2，Google发布Gemini，大模型百花齐放。'
  },
  {
    year: '2022',
    title: 'ChatGPT 发布',
    description: 'OpenAI 发布 ChatGPT，两个月用户破亿，开启大语言模型时代。'
  },
  {
    year: '2021',
    title: 'DALL-E & GitHub Copilot',
    description: 'OpenAI发布DALL-E开启AI绘画时代，GitHub Copilot改变编程方式。'
  },
  {
    year: '2020',
    title: 'GPT-3 发布',
    description: 'OpenAI 发布 GPT-3，1750亿参数展示了大规模语言模型的惊人涌现能力。'
  },
  {
    year: '2019',
    title: 'GPT-2 & AlphaFold',
    description: 'OpenAI发布GPT-2，DeepMind发布AlphaFold解决蛋白质折叠难题。'
  },
  {
    year: '2017',
    title: 'Transformer 架构',
    description: 'Google发布"Attention Is All You Need"论文，奠定现代大模型基础架构。'
  },
  {
    year: '2016',
    title: 'AlphaGo 战胜李世石',
    description: 'DeepMind的AlphaGo在围棋比赛中4:1击败世界冠军李世石，震惊世界。'
  },
  {
    year: '2012',
    title: 'AlexNet 突破',
    description: 'AlexNet在ImageNet竞赛中将错误率从26%降至15%，开启深度学习时代。'
  },
];
---

<Layout 
  title={`${t('research.title')} - MoonSun.ai`}
  description={t('research.subtitle')}
>
  <section class="research">
    <div class="research-container">
      <div class="research-header">
        <span class="research-badge">{t('research.badge')}</span>
        <h1 class="research-title">{t('research.title')}</h1>
        <p class="research-subtitle">{t('research.subtitle')}</p>
      </div>
      
      <div class="timeline">
        {timeline.map((item, index) => (
          <div class:list={['timeline-item', { highlight: item.highlight }]}>
            <div class="timeline-marker">
              <div class:list={['timeline-dot', { pulse: item.highlight }]}></div>
              {index < timeline.length - 1 && <div class="timeline-line"></div>}
            </div>
            <div class="timeline-content hover-lift">
              <span class="timeline-year">{item.year}</span>
              <h3 class="timeline-item-title">{item.title}</h3>
              <p class="timeline-description">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="research-footer">
        <p class="research-footer-text">{t('research.footer')}</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .research {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-4)) var(--space-4) var(--space-8);
  }
  
  .research-container {
    max-width: var(--container-md);
    margin: 0 auto;
  }
  
  .research-header {
    text-align: left;
    margin-bottom: var(--space-8);
    max-width: 38rem;
  }
  
  .research-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    background: rgba(255, 253, 249, 0.75);
    border: 1px solid var(--border-primary);
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }
  
  .research-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 0.98;
  }
  
  @media (min-width: 768px) {
    .research-title {
      font-size: var(--text-4xl);
    }
  }
  
  .research-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 600px;
    margin: 0;
  }
  
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  
  .timeline-item {
    display: flex;
    gap: var(--space-4);
  }
  
  .timeline-item.highlight .timeline-content {
    background: var(--card-bg-hover);
    border-color: var(--color-primary);
  }
  
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  
  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--bg-primary);
    box-shadow: 0 0 0 4px rgba(217, 119, 87, 0.12);
  }
  
  .timeline-dot.pulse {
    width: 14px;
    height: 14px;
    background: var(--color-primary);
    animation: none;
  }
  
  .timeline-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--border-primary), var(--border-primary-alpha-50));
    margin-top: var(--space-2);
  }
  
  .timeline-content {
    flex: 1;
    padding: var(--space-5);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--card-shadow);
    margin-bottom: var(--space-2);
    transition: all 0.3s ease;
  }
  
  .timeline-content:hover {
    transform: translateX(2px);
    box-shadow: var(--card-shadow-hover);
  }
  
  .timeline-year {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }
  
  .timeline-item-title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }
  
  .timeline-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  
  .research-footer {
    text-align: center;
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-primary);
  }
  
  .research-footer-text {
    color: var(--text-tertiary);
    font-size: var(--text-sm);
  }
</style>
