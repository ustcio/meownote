---
import Layout from '@layouts/Layout.astro';
import { toolCategories } from '@data/tool-categories';

const goldTool = toolCategories[0].tools[0];
const pageTitle = 'Kit';
const pageDesc = 'A focused toolkit with one live gold price tracker.';
---

<Layout title={`${pageTitle} - Maxwell.Science`} description={pageDesc}>
  <section class="kit-page">
    <div class="container kit-shell">
      <div class="kit-hero">
        <span class="kit-kicker">Toolkit</span>
        <h1>One tool left, and it earns the space.</h1>
        <p>
          The kit section has been reduced to a single live market utility: a clean gold price tracker
          for domestic and international prices.
        </p>
      </div>

      <a href={goldTool.path} class="kit-feature-card">
        <div class="kit-feature-card__meta">
          <span class="kit-feature-card__icon">{toolCategories[0].icon}</span>
          <span class="kit-feature-card__label">{toolCategories[0].name}</span>
        </div>

        <div class="kit-feature-card__body">
          <h2>{goldTool.name}</h2>
          <p>{goldTool.desc}</p>
        </div>

        <div class="kit-feature-card__footer">
          <span class="kit-feature-card__status">Live</span>
          <span class="kit-feature-card__cta">Open tracker</span>
        </div>
      </a>
    </div>
  </section>
</Layout>

<style>
  .kit-page {
    min-height: 100vh;
    padding-top: calc(var(--header-height) + 2.5rem);
    padding-bottom: 5rem;
  }

  .kit-shell {
    max-width: 64rem;
    display: grid;
    gap: 2rem;
  }

  .kit-hero {
    max-width: 40rem;
    display: grid;
    gap: 0.8rem;
  }

  .kit-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-secondary);
    font-size: 0.72rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .kit-kicker::before {
    content: '';
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .kit-hero p {
    max-width: 36rem;
    font-size: 1rem;
    margin: 0;
  }

  .kit-feature-card {
    display: grid;
    gap: 1.4rem;
    padding: 1.6rem;
    border-radius: 1.5rem;
    border: 1px solid var(--border-primary);
    background:
      radial-gradient(circle at top right, rgba(217, 119, 87, 0.14), transparent 28%),
      var(--card-bg);
    box-shadow: 0 18px 46px rgba(60, 40, 22, 0.08);
    transition:
      transform var(--duration-normal) var(--ease-default),
      box-shadow var(--duration-normal) var(--ease-default),
      border-color var(--duration-normal) var(--ease-default);
  }

  .kit-feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow: 0 24px 56px rgba(60, 40, 22, 0.12);
  }

  .kit-feature-card__meta,
  .kit-feature-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .kit-feature-card__meta {
    color: var(--text-tertiary);
    font-size: 0.82rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .kit-feature-card__icon {
    font-size: 1.15rem;
  }

  .kit-feature-card__label {
    margin-left: auto;
  }

  .kit-feature-card__body {
    display: grid;
    gap: 0.5rem;
  }

  .kit-feature-card__body h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
  }

  .kit-feature-card__body p {
    margin: 0;
    max-width: 34rem;
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .kit-feature-card__status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.8rem;
    border-radius: var(--radius-full);
    background: rgba(106, 141, 123, 0.12);
    color: var(--color-success);
    font-size: 0.82rem;
    font-weight: var(--font-semibold);
  }

  .kit-feature-card__status::before {
    content: '';
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: currentColor;
  }

  .kit-feature-card__cta {
    color: var(--color-primary);
    font-size: 0.95rem;
    font-weight: var(--font-semibold);
  }

  @media (max-width: 767px) {
    .kit-page {
      padding-top: calc(var(--header-height) + 1.4rem);
      padding-bottom: 4rem;
    }

    .kit-feature-card {
      padding: 1.25rem;
      gap: 1.1rem;
    }

    .kit-feature-card__meta,
    .kit-feature-card__footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .kit-feature-card__label {
      margin-left: 0;
    }
  }
</style>
