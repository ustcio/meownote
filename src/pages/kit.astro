---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';

const tools = [
  {
    id: 'gold',
    href: '/kit/gold',
    icon: 'clock',
    title: t('kit.gold.title'),
    desc: t('kit.gold.desc')
  },
  {
    id: 'academic',
    href: '/kit/academic',
    icon: 'book',
    title: t('kit.academic.title'),
    desc: t('kit.academic.desc')
  },
  {
    id: 'password',
    href: '/kit/password',
    icon: 'key',
    title: t('password.title'),
    desc: t('password.subtitle')
  }
];
---

<Layout 
  title={`${t('kit.title')} - Maxwell.Science`}
  description={t('kit.subtitle')}
>
  <section class="kit">
    <div class="kit-container">
      <div class="kit-header">
        <span class="kit-kicker">Tool collection</span>
        <h1 class="kit-title">{t('kit.title')}</h1>
        <p class="kit-desc">{t('kit.subtitle')}</p>
      </div>
      
      <div class="tools-list">
        {tools.map(tool => (
          <a href={tool.href} class="tool-item">
            <div class="tool-icon">
              {tool.icon === 'clock' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
              )}
              {tool.icon === 'book' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
              )}
              {tool.icon === 'key' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                </svg>
              )}
            </div>
            <div class="tool-content">
              <span class="tool-title">{tool.title}</span>
              <span class="tool-desc">{tool.desc}</span>
            </div>
            <svg class="tool-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .kit {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-8)) var(--space-4) var(--space-16);
  }
  
  .kit-container {
    max-width: 640px;
    margin: 0 auto;
  }
  
  .kit-header {
    margin-bottom: var(--space-10);
    max-width: 38rem;
  }

  .kit-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-3);
    padding: 0.45rem 0.85rem;
    background: rgba(255, 253, 249, 0.75);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    color: var(--text-tertiary);
    font-size: 0.75rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  
  .kit-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    line-height: 0.98;
  }
  
  .kit-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  
  .tools-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  
  .tool-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    transition: all var(--duration-fast) var(--ease-default);
    box-shadow: var(--card-shadow);
  }
  
  .tool-item:hover {
    background: var(--card-bg-hover);
    border-color: var(--border-hover);
    transform: translateY(-1px);
  }
  
  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(244, 237, 228, 0.85);
    border-radius: var(--radius-lg);
    color: var(--text-secondary);
    flex-shrink: 0;
  }
  
  .tool-item:hover .tool-icon {
    color: var(--text-primary);
  }
  
  .tool-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  
  .tool-title {
    font-size: 1.05rem;
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }
  
  .tool-desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
  
  .tool-arrow {
    color: var(--text-tertiary);
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-default);
  }
  
  .tool-item:hover .tool-arrow {
    transform: translateX(4px);
    color: var(--text-secondary);
  }
</style>
