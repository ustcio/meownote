---
import Layout from '@layouts/Layout.astro';

const tools = [
  {
    id: 'qrcode',
    href: '/kit/qrcode',
    icon: 'qr',
    title: '二维码生成器',
    desc: '生成自定义样式的二维码，支持Logo、颜色设置'
  },
  {
    id: 'json',
    href: '/kit/json',
    icon: 'code',
    title: 'JSON 格式化',
    desc: 'JSON 格式化、压缩、校验，支持语法高亮'
  },
  {
    id: 'base64',
    href: '/kit/base64',
    icon: 'hash',
    title: 'Base64 编解码',
    desc: '文本和图片的 Base64 编码与解码'
  },
  {
    id: 'timestamp',
    href: '/kit/timestamp',
    icon: 'clock',
    title: '时间戳转换',
    desc: '时间戳与日期时间互相转换'
  },
  {
    id: 'color',
    href: '/kit/color',
    icon: 'palette',
    title: '颜色转换器',
    desc: 'HEX、RGB、HSL 颜色格式互转'
  },
  {
    id: 'text',
    href: '/kit/text',
    icon: 'type',
    title: '文本工具',
    desc: '字数统计、大小写转换、文本差异对比'
  },
  {
    id: 'url',
    href: '/kit/url',
    icon: 'link',
    title: 'URL 编解码',
    desc: 'URL 编码与解码，支持中文和特殊字符'
  },
  {
    id: 'regex',
    href: '/kit/regex',
    icon: 'search',
    title: '正则测试',
    desc: '在线测试正则表达式，实时匹配高亮'
  },
  {
    id: 'gold',
    href: '/kit/gold',
    icon: 'trending',
    title: '金价追踪',
    desc: '实时金价行情，国内外金价对比'
  },
  {
    id: 'image',
    href: '/kit/image',
    icon: 'image',
    title: '图片工具',
    desc: '图片压缩、格式转换、尺寸调整'
  },
  {
    id: 'password',
    href: '/kit/password',
    icon: 'key',
    title: '密码生成器',
    desc: '生成安全的随机密码'
  },
  {
    id: 'academic',
    href: '/kit/academic',
    icon: 'graduation',
    title: '学术工具',
    desc: 'DOI引用、BibTeX生成、影响因子查询'
  },
];
---

<Layout
  title="工具箱 - Maxwell.Science"
  description="实用在线工具集合：二维码生成、JSON格式化、Base64编解码、时间转换等"
>
  <section class="kit-page">
    <div class="container">
      <div class="kit-header">
        <span class="claude-kicker">Tool collection</span>
        <h1>工具箱</h1>
        <p class="kit-desc">
          精选实用在线工具，无需下载，即开即用。所有数据处理在本地完成，保护你的隐私。
        </p>
      </div>

      <div class="tools-grid">
        {tools.map(tool => (
          <a href={tool.href} class="tool-card">
            <div class="tool-icon" data-icon={tool.icon}>
              {tool.icon === 'qr' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="7" height="7"></rect>
                  <rect x="14" y="3" width="7" height="7"></rect>
                  <rect x="3" y="14" width="7" height="7"></rect>
                  <rect x="14" y="14" width="7" height="7"></rect>
                </svg>
              )}
              {tool.icon === 'code' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="16 18 22 12 16 6"></polyline>
                  <polyline points="8 6 2 12 8 18"></polyline>
                </svg>
              )}
              {tool.icon === 'hash' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="4" y1="9" x2="20" y2="9"></line>
                  <line x1="4" y1="15" x2="20" y2="15"></line>
                  <line x1="10" y1="3" x2="8" y2="21"></line>
                  <line x1="16" y1="3" x2="14" y2="21"></line>
                </svg>
              )}
              {tool.icon === 'clock' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              )}
              {tool.icon === 'palette' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"></circle>
                  <circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"></circle>
                  <circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"></circle>
                  <circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"></circle>
                  <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"></path>
                </svg>
              )}
              {tool.icon === 'type' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="4 7 4 4 20 4 20 7"></polyline>
                  <line x1="9" y1="20" x2="15" y2="20"></line>
                  <line x1="12" y1="4" x2="12" y2="20"></line>
                </svg>
              )}
              {tool.icon === 'link' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
              )}
              {tool.icon === 'search' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              )}
              {tool.icon === 'trending' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                  <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
              )}
              {tool.icon === 'image' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
              )}
              {tool.icon === 'key' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                </svg>
              )}
              {tool.icon === 'graduation' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                  <path d="M6 12v5c0 2 3 3 6 3s6-1 6-3v-5"></path>
                </svg>
              )}
            </div>
            <div class="tool-content">
              <span class="tool-title">{tool.title}</span>
              <span class="tool-desc">{tool.desc}</span>
            </div>
            <svg class="tool-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .kit-page {
    min-height: 100vh;
    padding: calc(var(--header-height) + 3rem) 0 5rem;
    background:
      radial-gradient(circle at 78% 8%, rgba(217, 119, 87, 0.08), transparent 28%),
      radial-gradient(circle at 12% 12%, rgba(180, 199, 192, 0.1), transparent 18%),
      linear-gradient(180deg, #fbf8f3 0%, var(--bg-primary) 30%, #f6f1e8 100%);
  }

  .kit-header {
    margin-bottom: 2.5rem;
    max-width: 38rem;
  }

  .kit-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.75rem;
  }

  .kit-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 1.25rem;
    background: #ffffff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.25rem;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.06);
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .tool-card:hover {
    border-color: rgba(71, 57, 44, 0.2);
    box-shadow: 0 8px 24px rgba(47, 35, 22, 0.1);
    transform: translateY(-2px);
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(217, 119, 87, 0.1);
    border-radius: 12px;
    color: #d97757;
    flex-shrink: 0;
  }

  .tool-card:hover .tool-icon {
    background: #d97757;
    color: white;
  }

  .tool-content {
    flex: 1;
    min-width: 0;
  }

  .tool-title {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: #171412;
    margin-bottom: 2px;
  }

  .tool-desc {
    display: block;
    font-size: 0.85rem;
    color: #8a7f74;
  }

  .tool-arrow {
    color: #b2a79a;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .tool-card:hover .tool-arrow {
    transform: translateX(4px);
    color: #d97757;
  }

  @media (max-width: 640px) {
    .kit-page {
      padding: calc(var(--header-height) + 2rem) 0 4rem;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
