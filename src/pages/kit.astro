---
import Layout from '@layouts/Layout.astro';
import { toolCategories } from '@data/tool-categories';

const pageTitle = '工具箱';
const pageDesc = '在线工具集合 - 日常应用、文字处理、图片处理、编程工具等';
---

<Layout title={`${pageTitle} - Maxwell.Science`} description={pageDesc}>
  <section class="darkBody kit-page">
    <div class="main-bg">
      <div class="img-bag"></div>
      <div class="main-bag-color"></div>
      <div class="main-bg-son-2"></div>
    </div>

    <div id="root-el">
      <!-- Top Bar -->
      <div class="main-top">
        <div class="logo is-nt-front">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
          <span>工具箱</span>
        </div>

        <div class="header-tab-tight-top">
          <div class="tab is-nt-front">
            <a href="/kit" class="tab-nuxt-link current">全部工具</a>
          </div>
        </div>

        <div class="header-top-view">
          <div class="TopBody is-nt-front">
            <div class="search-bar-container">
              <div class="search-input-wrapper">
                <svg class="el-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="kit-search-input" class="search-input" placeholder="搜索工具..." />
                <svg class="el-icon clear-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="search-clear" style="display:none;">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="main-content">
        <div class="main-content-son">
          <div class="middleViewCom">
            <div class="pc-container-dad">
              <div class="pc-wallpaper-main">
                <div class="masonry-div" id="masonry-grid">
                  {toolCategories.map(cat => (
                    <div class="kit-section" id={cat.id} data-category>
                      <div class="partition">
                        <div class="twoTopLable is-nt-front">
                          <span class="icon">{cat.icon}</span>
                          <span class="top-name">{cat.name}</span>
                        </div>
                      </div>
                      <div class="display-wrap">
                        {cat.tools.map(tool => (
                          <a href={tool.path} class="card" data-tool-id={tool.id} data-tool-name={tool.name} data-tool-desc={tool.desc}>
                            <div class="card-content hert-col">
                              <div class="fb-col-1">
                                <span class="title">{tool.name}</span>
                              </div>
                              <div class="fb-col-2">
                                <span class="cut-subject">{tool.desc}</span>
                              </div>
                              <div class="labelDiv">
                                {tool.status === 'todo' ? <span>开发中</span> : <span>免费</span>}
                              </div>
                              <div class="card-action">
                                <span class="cd2-1">
                                  <span class="small-icon">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                      <polyline points="9 18 15 12 9 6"></polyline>
                                    </svg>
                                  </span>
                                </span>
                              </div>
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== HaoWallpaper Design System - Exact Replication ===== */
  :root {
    --hao-font-size: 15px;
  }

  *, *:after, *:before {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    position: relative;
  }

  * {
    font-family: -apple-system, Arial, Helvetica, sans-serif;
    text-decoration: none;
  }

  :root {
    overflow-x: hidden;
    overflow-y: scroll;
  }

  /* ===== Dark Theme (haowallpaper default) ===== */
  .darkBody {
    --main-bg-tw: #191919;
    --tm-bg-ty: rgba(0,0,0,0.6);
    --frosted-bg: rgba(53,53,53,0.1);
    --color-background-vk: rgba(84,84,84,0.48);
    --color-background-one: #282828;
    --color-background-two: #000;
    --color-background-soft: #222;
    --color-background-mute: #282828;
    --color-ccc-mute: #565151;
    --color-border: rgba(84,84,84,0.48);
    --color-text: #fff;
    --color-cale-text: #b7b7b7;
    --color-tm-text: hsla(0,0%,100%,0.65);
    --color-darkgray-text: #dedede;
    --font-color-solid: #fff;
    --source-post-color: #ffdcc1;
    --color-background-cut: #282828;
    --color-background-webkit: #5d5d5d;
    --card-background-webkit: rgba(78,71,71,0.6);
    --card-bottom-bg: rgba(0,0,0,0.26);
    --fc-background-webkit: #fff1f1;
    --hao-dialog: #141313;
    --font-background-webkit: #fff;
    --shen-background-webkit: hsla(0,0%,44%,0.5);
    --tx-background-one: #d75151;
    --tx-background-two: #ff0;
    --lable-card-bag: hsla(0,0%,59%,0.26);
    --hao-bg-bag: rgba(0,0,0,0.6);
    --top-color: rgba(111,139,190,0.64);
    --svg-color: #666565;
    --switch-bt-color: rgba(65,65,79,0.95);
    --col-bg-nt: #282828;
    --col-bg-start: #191919;
    --col-bg-end: #514b51;
    --nt-c-white: #e0e0e0;
    --nt-box-white-start: #949494;
    --nt-box-white-end: #fff;
    --nt-box-dark-end: #514b51;
  }

  /* ===== Neumorphic Shadows ===== */
  .is-nt-front {
    box-shadow: 2px 2px 6px var(--col-bg-start), -2px -2px 6px var(--col-bg-end);
  }

  .is-nt-reverse {
    box-shadow: inset 3px 3px 10px var(--col-bg-start), inset -3px -3px 10px var(--col-bg-end);
  }

  .is-nt-reverse-small {
    box-shadow: inset 3px 3px 6px var(--col-bg-start), inset -3px -3px 6px var(--col-bg-end);
  }

  .nt-box-show {
    box-shadow: 3px 3px 10px var(--col-bg-start), -3px -3px 10px var(--col-bg-end);
  }

  /* ===== Page Base ===== */
  .kit-page {
    min-height: 100vh;
    background: var(--main-bg-tw);
    font-size: var(--hao-font-size);
    color: var(--color-text);
  }

  /* ===== Background ===== */
  .main-bg {
    position: fixed;
    left: 0;
    top: 0;
    min-width: 100vw;
    min-height: 100vh;
    background-size: cover;
    transition: background 1s;
    z-index: -2;
  }

  .main-bg .img-bag {
    position: fixed;
    left: 0;
    top: 0;
    min-width: 100vw;
    min-height: 100vh;
    background-color: rgba(0,0,0,0);
    z-index: -2;
  }

  .main-bg .main-bag-color {
    background-image: none;
    background-position: 50%;
    background-size: cover;
  }

  .main-bg .main-bg-son-2 {
    position: fixed;
    left: 0;
    top: 0;
    min-width: 100vw;
    min-height: 100vh;
    background: radial-gradient(circle, #b4b4b4, #f1f1f1);
    opacity: 0;
    transition: opacity 0.6s;
    z-index: -1;
  }

  /* ===== Root Layout ===== */
  #root-el {
    position: absolute;
    top: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 100vh;
    align-items: center;
    background: #232222;
    font-size: var(--hao-font-size);
  }

  /* ===== Top Bar ===== */
  .main-top {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-evenly;
    flex-wrap: wrap;
    margin-top: 0.3rem;
    min-height: 1.4rem;
    padding: 0.1rem;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 3.5rem;
    padding: 0.2rem;
    white-space: nowrap;
    backdrop-filter: blur(10px);
    border-radius: 40px;
    color: var(--color-text);
  }

  .logo svg {
    height: 0.9rem;
    width: 0.9rem;
    color: var(--svg-color);
  }

  .logo span {
    color: #837f84;
    font-size: 0.5rem;
    font-weight: 500;
    text-shadow: 0 0 30px #515050;
  }

  /* Tabs */
  .header-tab-tight-top {
    width: 3.5rem;
  }

  .tab {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    padding: 5px;
    width: 100%;
  }

  .tab-nuxt-link {
    color: var(--color-text);
    font-size: 0.3rem;
    text-decoration: none;
    padding: 5px 10px;
    border-radius: 50px;
    transition: all 0.2s;
  }

  .tab-nuxt-link.current {
    background: linear-gradient(to bottom, var(--color-background-one), var(--color-background-two));
    color: var(--font-background-webkit);
    text-shadow: 2px 2px 10px var(--fc-background-webkit);
  }

  .tab-nuxt-link:hover {
    color: var(--font-color-solid);
  }

  /* Search */
  .header-top-view {
    height: 100%;
    width: 65%;
    display: flex;
    justify-content: center;
    padding: 0.2rem;
  }

  .TopBody {
    width: 100%;
    display: flex;
    min-width: 80%;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    padding: 8px 16px;
    background: var(--frosted-bg);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--color-text);
    user-select: none;
    z-index: 110;
  }

  @media (max-width: 1100px) {
    .TopBody .tab {
      display: none !important;
    }
  }

  .search-bar-container {
    width: 100%;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-input-wrapper .el-icon {
    color: var(--svg-color);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-text);
    font-size: 0.3rem;
    outline: none;
  }

  .search-input::placeholder {
    color: var(--color-cale-text);
  }

  .clear-icon {
    cursor: pointer;
    color: var(--color-cale-text);
    transition: color 0.2s;
  }

  .clear-icon:hover {
    color: var(--color-text);
  }

  /* ===== Main Content ===== */
  .main-content {
    display: flex;
    justify-content: center;
    align-items: stretch;
    height: auto;
    max-width: 100vw;
    min-width: 100vw;
    min-height: 100vh;
    position: relative;
    top: 0;
  }

  .main-content-son {
    display: flex;
    justify-content: center;
    align-items: stretch;
    flex-grow: 1;
  }

  .middleViewCom {
    position: relative;
    margin-top: 20px;
    margin-bottom: 20px;
    width: 100%;
    max-width: 1400px;
    padding: 0 0.5rem;
  }

  .pc-wallpaper-main {
    width: 100%;
  }

  .masonry-div {
    border-radius: 30px;
  }

  .masonry-div .waterfall-content-k1 {
    border-radius: inherit;
  }

  /* ===== Section Partition ===== */
  .partition {
    margin-bottom: 0.5rem;
    margin-top: 1rem;
  }

  .partition:first-child {
    margin-top: 0;
  }

  .twoTopLable {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 0.35rem;
    color: var(--font-color-solid);
  }

  .twoTopLable .icon {
    font-size: 0.4rem;
  }

  .twoTopLable .top-name {
    font-weight: 500;
    text-shadow: 0 0 10px var(--fc-background-webkit);
  }

  /* ===== Card Grid ===== */
  .display-wrap {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.2vw;
  }

  @keyframes slideTop {
    0% {
      opacity: 0;
      transform: translate(10%, 50%) scale(.8);
    }
    to {
      opacity: 1;
      transform: translate(0);
    }
  }

  /* ===== Card ===== */
  .card {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
    width: 21.5%;
    min-width: 200px;
    aspect-ratio: 1 / .7;
    border-radius: 15px;
    background-color: #ffffff1a;
    border: 1px solid hsla(0, 0%, 100%, 0.5);
    border-bottom: none;
    border-right: none;
    box-shadow: 20px 20px 50px rgba(0, 0, 0, 0.5);
    text-decoration: none;
    animation-name: slideTop;
    animation-duration: 0.6s;
    animation-fill-mode: both;
  }

  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.2s; }
  .card:nth-child(5) { animation-delay: 0.25s; }
  .card:nth-child(6) { animation-delay: 0.3s; }
  .card:nth-child(7) { animation-delay: 0.35s; }
  .card:nth-child(8) { animation-delay: 0.4s; }
  .card:nth-child(n+9) { animation-delay: 0.45s; }

  .card:hover {
    box-shadow: 20px 20px 50px rgba(0, 0, 0, 0.5), 0 0 15px var(--fc-background-webkit);
  }

  .card:hover .card-content {
    box-shadow: 0 0 15px var(--fc-background-webkit);
    transform: translateY(0) !important;
    opacity: 1 !important;
  }

  .card.hidden {
    display: none;
  }

  /* Card Content - hidden by default, slides up on hover (haowallpaper style) */
  .card-content {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    background-color: var(--card-background-webkit);
    border-radius: 1.8vw;
    width: 90%;
    height: 80%;
    opacity: 0;
    transform: translateY(150px);
    transition: opacity 0.5s, transform 0.5s !important;
  }

  .hert-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.4rem 0;
  }

  .fb-col-1 {
    display: flex;
    justify-content: center;
  }

  .fb-col-1 .title {
    color: var(--font-color-solid);
    font-size: 0.35rem;
    font-weight: 500;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 90%;
    text-shadow: 0 0 10px var(--fc-background-webkit);
  }

  .fb-col-2 {
    display: flex;
    justify-content: center;
  }

  .fb-col-2 .cut-subject {
    color: var(--color-tm-text);
    font-size: 0.28rem;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 90%;
  }

  /* Label Div - circular neumorphic tags */
  .labelDiv {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.2rem;
    height: 70%;
    overflow: auto;
    width: 90%;
    margin-top: 0.2rem;
    text-shadow: 2px 2px 8px var(--fc-background-webkit);
  }

  .labelDiv span {
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid #ccc;
    border-radius: 50%;
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.5);
    color: var(--font-background-webkit);
    font-size: 0.25rem;
    font-weight: 500;
    padding: 2%;
  }

  /* Action Button (haowallpaper.com style - positioned at bottom of card) */
  .card-action {
    position: absolute;
    bottom: 15%;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cd2-1 {
    display: flex;
    align-items: center;
    position: relative;
  }

  .cd2-1 .small-icon {
    font-size: 1rem;
    color: var(--fc-background-webkit);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, color 0.3s;
    text-shadow: 0 0 8px var(--fc-background-webkit);
  }

  .card:hover .cd2-1 .small-icon {
    transform: scale(1.2);
  }

  .lableEnd {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
    font-size: 0.22rem;
    color: var(--color-cale-text);
    background: var(--lable-card-bag);
    padding: 2px 8px;
    border-radius: 20px;
    transition: color 0.3s ease, background-color 0.3s ease;
  }

  .card:hover .lableEnd {
    color: var(--font-background-webkit);
  }

  /* ===== Responsive ===== */
  @media screen and (max-width: 1100px) {
    .main-top .header-top-view {
      flex-grow: 1;
      overflow: auto;
      width: 100% !important;
      order: 3;
    }

    .main-top .header-top-view .TopBody {
      width: 100% !important;
    }

    .main-top .header-tab-tight-top,
    .main-top .logo {
      margin-bottom: 0.25rem;
    }
  }

  @media screen and (max-width: 900px) {
    .card {
      width: calc(33.333% - 0.2rem) !important;
      min-width: 180px;
    }

    .hert-col {
      border-radius: 20px !important;
    }

    .card-bottom .el-icon {
      width: 40% !important;
    }

    .cdn-3 {
      display: none !important;
    }

    .card-action {
      bottom: 35% !important;
    }
  }

  @media screen and (max-width: 600px) {
    .card {
      width: 46% !important;
      min-width: 160px;
    }

    .main-top {
      padding: 0.2rem;
    }

    .logo {
      width: auto;
    }

    .header-tab-tight-top {
      width: auto;
    }

    .header-top-view {
      padding: 0.1rem;
    }

    .fb-col-1 .title {
      font-size: 0.3rem;
    }

    .fb-col-2 .cut-subject {
      font-size: 0.24rem;
    }
  }

  @media screen and (max-width: 400px) {
    .card {
      width: 100% !important;
      min-width: auto;
    }
  }
</style>

<script>
  // Search
  const searchInput = document.getElementById('kit-search-input');
  const searchClear = document.getElementById('search-clear');
  const toolCards = document.querySelectorAll('.card');
  const sections = document.querySelectorAll('[data-category]');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    
    if (searchClear) {
      searchClear.style.display = query ? 'block' : 'none';
    }

    if (!query) {
      toolCards.forEach(card => card.classList.remove('hidden'));
      sections.forEach(section => section.style.display = '');
      return;
    }

    sections.forEach(section => {
      const sectionCards = section.querySelectorAll('.card');
      let hasVisible = false;
      
      sectionCards.forEach(card => {
        const name = (card.dataset.toolName || '').toLowerCase();
        const desc = (card.dataset.toolDesc || '').toLowerCase();
        const matches = name.includes(query) || desc.includes(query);
        
        card.classList.toggle('hidden', !matches);
        if (matches) hasVisible = true;
      });
      
      section.style.display = hasVisible ? '' : 'none';
    });
  });

  searchClear?.addEventListener('click', () => {
    if (searchInput) {
      searchInput.value = '';
      searchInput.dispatchEvent(new Event('input'));
      searchInput.focus();
    }
  });
</script>
