---
import Layout from '@layouts/Layout.astro';

const pageTitle = '编辑实验';
const pageDesc = '创建或编辑一条实验记录。';
---

<Layout title={`${pageTitle} - MoonSun.ai`} description={pageDesc} showHeader={false} showAuthModal={false} showFooter={false}>
  <section class="experiment-edit-page">
    <div class="container edit-shell">
      <!-- Header -->
      <header class="edit-header">
        <div class="edit-header__top">
          <a href="/experiments/" class="edit-back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"></path>
            </svg>
            <span>返回记录列表</span>
          </a>

        </div>
        <h1 id="page-title">新建实验记录</h1>
      </header>

      <!-- Form -->
      <div class="claude-surface edit-card">
        <form class="edit-form" id="experiment-form">
          <input type="hidden" id="record-id" />

          <div class="form-grid">
            <!-- Date & Time -->
            <div class="form-group form-group--wide">
              <label for="dateTime">
                日期时间
                <span class="required">*</span>
              </label>
              <input
                type="datetime-local"
                id="dateTime"
                name="dateTime"
                required
              />
            </div>

            <!-- User -->
            <div class="form-group">
              <label for="user">
                记录人
                <span class="required">*</span>
              </label>
              <input
                type="text"
                id="user"
                name="user"
                placeholder="例如：YangHao"
                required
              />
            </div>

            <!-- Target Batch -->
            <div class="form-group">
              <label for="targetBatch">
                靶材批次
                <span class="required">*</span>
              </label>
              <input
                type="text"
                id="targetBatch"
                name="targetBatch"
                placeholder="例如：CoNb3S6-2025-A"
                required
              />
            </div>

            <!-- Target Ratio -->
            <div class="form-group">
              <label for="targetRatio">
                靶材成分计量比
                <span class="required">*</span>
              </label>
              <input
                type="text"
                id="targetRatio"
                name="targetRatio"
                placeholder="例如：Co:Nb:S = 1:3:6"
                required
              />
            </div>

            <!-- Pressure -->
            <div class="form-group">
              <label for="pressure">
                气压 (Pa)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="pressure"
                name="pressure"
                step="any"
                placeholder="例如：0.0025"
                required
              />
              <span class="field-hint">沉积过程中的工作气压</span>
            </div>

            <!-- Gate Valve -->
            <div class="form-group">
              <label for="gateValve">
                闸板阀
                <span class="required">*</span>
              </label>
              <input
                type="text"
                id="gateValve"
                name="gateValve"
                placeholder="例如：50%"
                required
              />
            </div>

            <!-- Growth Temperature -->
            <div class="form-group">
              <label for="growthTemp">
                生长温度 (°C)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="growthTemp"
                name="growthTemp"
                step="1"
                placeholder="例如：850"
                required
              />
            </div>

            <!-- Annealing Temperature -->
            <div class="form-group">
              <label for="annealingTemp">
                退火温度 (°C)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="annealingTemp"
                name="annealingTemp"
                step="1"
                placeholder="例如：400"
                required
              />
            </div>

            <!-- Sample Height -->
            <div class="form-group">
              <label for="sampleHeight">
                样品高度 (mm)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="sampleHeight"
                name="sampleHeight"
                step="0.1"
                placeholder="例如：12.5"
                required
              />
            </div>

            <!-- Sample Thickness -->
            <div class="form-group">
              <label for="sampleThickness">
                样品厚度 (μm)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="sampleThickness"
                name="sampleThickness"
                step="0.01"
                placeholder="例如：0.18"
                required
              />
            </div>

            <!-- Remanence -->
            <div class="form-group">
              <label for="remanence">
                剩磁 (T)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="remanence"
                name="remanence"
                step="any"
                placeholder="例如：0.85"
                required
              />
            </div>

            <!-- Coercivity -->
            <div class="form-group">
              <label for="coercivity">
                矫顽力 (T)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="coercivity"
                name="coercivity"
                step="any"
                placeholder="例如：0.12"
                required
              />
            </div>

            <!-- Saturation Magnetization -->
            <div class="form-group">
              <label for="saturationMagnetization">
                饱和磁化强度 (T)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="saturationMagnetization"
                name="saturationMagnetization"
                step="any"
                placeholder="例如：1.25"
                required
              />
            </div>
          </div>

          <!-- Notes -->
          <div class="form-group form-group--wide">
            <label for="notes">备注</label>
            <textarea
              id="notes"
              name="notes"
              rows="5"
              placeholder="观察记录、衬底类型、薄膜厚度、XRD 结果等"
            ></textarea>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="submit" class="claude-button" id="save-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                <polyline points="17 21 17 13 7 13 7 21"></polyline>
                <polyline points="7 3 7 8 15 8"></polyline>
              </svg>
              保存记录
            </button>
            <a href="/experiments/" class="claude-button-secondary">取消</a>
          </div>
        </form>
      </div>
    </div>
    <!-- Performance Confirm Modal -->
    <div class="modal-overlay" id="performance-modal">
      <div class="modal-panel">
        <h3>样品性能确认</h3>
        <p>该样品性能是否符合预期？</p>
        <div class="modal-actions">
          <button class="claude-button-secondary" id="performance-no">不符合</button>
          <button class="claude-button" id="performance-yes">符合</button>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { experimentStorage } from '@/lib/experiments/storage';
    import type { ExperimentRecord } from '@/lib/experiments/types';

    experimentStorage.init();

    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('id');

    const form = document.getElementById('experiment-form') as HTMLFormElement;
    const pageTitle = document.getElementById('page-title');
    const recordIdInput = document.getElementById('record-id') as HTMLInputElement;

    function formatDateTimeLocal(iso: string): string {
      const d = new Date(iso);
      const year = d.getFullYear();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${year}-${month}-${day}T${hours}:${minutes}`;
    }

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      if (window.__meownoteToast) {
        window.__meownoteToast.show(message, type);
      } else {
        alert(message);
      }
    }

    if (editId) {
      const record = experimentStorage.get(editId);
      if (record) {
        if (pageTitle) pageTitle.textContent = '编辑实验记录';
        recordIdInput.value = record.id;

        (document.getElementById('dateTime') as HTMLInputElement).value = formatDateTimeLocal(record.dateTime);
        (document.getElementById('user') as HTMLInputElement).value = record.user;
        (document.getElementById('targetBatch') as HTMLInputElement).value = record.targetBatch;
        (document.getElementById('targetRatio') as HTMLInputElement).value = record.targetRatio;
        (document.getElementById('pressure') as HTMLInputElement).value = String(record.pressure);
        (document.getElementById('gateValve') as HTMLInputElement).value = record.gateValve;
        (document.getElementById('growthTemp') as HTMLInputElement).value = String(record.growthTemp);
        (document.getElementById('annealingTemp') as HTMLInputElement).value = String(record.annealingTemp);
        (document.getElementById('sampleHeight') as HTMLInputElement).value = String(record.sampleHeight);
        (document.getElementById('sampleThickness') as HTMLInputElement).value = String(record.sampleThickness);
        (document.getElementById('remanence') as HTMLInputElement).value = String(record.remanence);
        (document.getElementById('coercivity') as HTMLInputElement).value = String(record.coercivity);
        (document.getElementById('saturationMagnetization') as HTMLInputElement).value = String(record.saturationMagnetization);
        (document.getElementById('notes') as HTMLTextAreaElement).value = record.notes;
      } else {
        showToast('记录未找到', 'error');
        window.location.href = '/experiments/';
      }
    } else {
      const now = new Date();
      now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
      (document.getElementById('dateTime') as HTMLInputElement).value = now.toISOString().slice(0, 16);
    }

    const performanceModal = document.getElementById('performance-modal');
    const performanceYes = document.getElementById('performance-yes');
    const performanceNo = document.getElementById('performance-no');
    let pendingData: any = null;

    function closePerformanceModal() {
      performanceModal?.classList.remove('open');
      pendingData = null;
    }

    function submitData(performanceOk: boolean) {
      if (!pendingData) return;
      const data = { ...pendingData, performanceOk };
      const id = recordIdInput.value;
      if (id) {
        experimentStorage.update(id, data);
        showToast('记录已更新');
      } else {
        experimentStorage.create(data);
        showToast('记录已创建');
      }
      window.location.href = '/experiments/';
    }

    performanceYes?.addEventListener('click', () => submitData(true));
    performanceNo?.addEventListener('click', () => submitData(false));

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      pendingData = {
        dateTime: (formData.get('dateTime') as string) || new Date().toISOString(),
        user: (formData.get('user') as string).trim(),
        targetBatch: (formData.get('targetBatch') as string).trim(),
        targetRatio: (formData.get('targetRatio') as string).trim(),
        pressure: parseFloat(formData.get('pressure') as string),
        gateValve: (formData.get('gateValve') as string).trim(),
        growthTemp: parseInt(formData.get('growthTemp') as string, 10),
        annealingTemp: parseInt(formData.get('annealingTemp') as string, 10),
        sampleHeight: parseFloat(formData.get('sampleHeight') as string),
        sampleThickness: parseFloat(formData.get('sampleThickness') as string),
        remanence: parseFloat(formData.get('remanence') as string),
        coercivity: parseFloat(formData.get('coercivity') as string),
        saturationMagnetization: parseFloat(formData.get('saturationMagnetization') as string),
        notes: (formData.get('notes') as string).trim(),
      };

      performanceModal?.classList.add('open');
    });
  </script>

  <style>
    .experiment-edit-page {
      min-height: 100vh;
      padding: calc(var(--header-height) + 2rem) 0 4rem;
      background: var(--bg-primary);
    }

    .edit-shell {
      max-width: 760px;
      margin: 0 auto;
    }

    .edit-header {
      display: grid;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .edit-header__top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .edit-back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      width: fit-content;
      font-size: 0.84rem;
      font-weight: var(--font-medium);
      color: var(--text-tertiary);
      transition: color var(--duration-fast) var(--ease-default);
    }

    .edit-back-link:hover {
      color: var(--text-primary);
    }

    .edit-back-link svg {
      transition: transform var(--duration-fast) var(--ease-default);
    }

    .edit-back-link:hover svg {
      transform: translateX(-2px);
    }

    .edit-header h1 {
      font-size: clamp(1.75rem, 3.5vw, 2.25rem);
      line-height: 1.1;
      font-family: var(--font-editorial);
      font-weight: var(--font-medium);
      color: var(--text-primary);
    }

    .edit-card {
      padding: clamp(1.5rem, 3vw, 2.5rem);
    }

    .edit-form {
      display: grid;
      gap: 1.5rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }

    @media (max-width: 640px) {
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    .form-group {
      display: grid;
      gap: 0.4rem;
    }

    .form-group--wide {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-size: 0.85rem;
      font-weight: var(--font-semibold);
      color: var(--text-secondary);
      letter-spacing: 0.01em;
    }

    .form-group label .required {
      color: var(--color-danger);
      margin-left: 0.15rem;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--input-border);
      border-radius: var(--radius-lg);
      background: var(--input-bg);
      color: var(--text-primary);
      font-size: 0.95rem;
      font-family: var(--font-body);
      transition: all var(--duration-fast) var(--ease-default);
      outline: none;
      width: 100%;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--input-focus-ring);
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: var(--text-quaternary);
    }

    .field-hint {
      font-size: 0.78rem;
      color: var(--text-quaternary);
      font-weight: var(--font-regular);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
      line-height: 1.55;
    }

    .form-actions {
      display: flex;
      gap: 0.75rem;
      padding-top: 0.5rem;
    }
  </style>
</Layout>
