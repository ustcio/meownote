---
import Layout from '@layouts/Layout.astro';
import WorkspaceAuthGuard from '@components/workspace/WorkspaceAuthGuard.astro';

const pageTitle = 'Edit Experiment';
const pageDesc = 'Create or edit an experiment record.';
---

<Layout title={`${pageTitle} - MoonSun.ai`} description={pageDesc}>
  <WorkspaceAuthGuard />
  <section class="experiment-edit-page">
    <div class="container edit-shell">
      <!-- Header -->
      <header class="edit-header">
        <a href="/experiments/" class="edit-back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"></path>
          </svg>
          <span>Back to records</span>
        </a>
        <h1 id="page-title">New experiment record</h1>
      </header>

      <!-- Form -->
      <form class="edit-form" id="experiment-form">
        <input type="hidden" id="record-id" />

        <div class="form-grid">
          <!-- Date & Time -->
          <div class="form-group form-group--wide">
            <label for="dateTime">
              Date & Time
              <span class="required">*</span>
            </label>
            <input
              type="datetime-local"
              id="dateTime"
              name="dateTime"
              required
            />
          </div>

          <!-- Target Material -->
          <div class="form-group">
            <label for="target">
              Target Material
              <span class="required">*</span>
            </label>
            <input
              type="text"
              id="target"
              name="target"
              placeholder="e.g. CoNb3S6"
              required
            />
          </div>

          <!-- Pressure -->
          <div class="form-group">
            <label for="pressure">
              Pressure (Pa)
              <span class="required">*</span>
            </label>
            <input
              type="number"
              id="pressure"
              name="pressure"
              step="any"
              placeholder="e.g. 0.0025"
              required
            />
            <span class="field-hint">Working pressure during deposition</span>
          </div>

          <!-- Gate Valve -->
          <div class="form-group">
            <label for="gateValve">
              Gate Valve
              <span class="required">*</span>
            </label>
            <input
              type="text"
              id="gateValve"
              name="gateValve"
              placeholder="e.g. 50%"
              required
            />
          </div>

          <!-- Growth Temperature -->
          <div class="form-group">
            <label for="growthTemp">
              Growth Temperature (°C)
              <span class="required">*</span>
            </label>
            <input
              type="number"
              id="growthTemp"
              name="growthTemp"
              step="1"
              placeholder="e.g. 850"
              required
            />
          </div>

          <!-- Annealing Temperature -->
          <div class="form-group">
            <label for="annealingTemp">
              Annealing Temperature (°C)
              <span class="required">*</span>
            </label>
            <input
              type="number"
              id="annealingTemp"
              name="annealingTemp"
              step="1"
              placeholder="e.g. 400"
              required
            />
          </div>

          <!-- Sample Height -->
          <div class="form-group">
            <label for="sampleHeight">
              Sample Height (mm)
              <span class="required">*</span>
            </label>
            <input
              type="number"
              id="sampleHeight"
              name="sampleHeight"
              step="0.1"
              placeholder="e.g. 12.5"
              required
            />
          </div>
        </div>

        <!-- Notes -->
        <div class="form-group form-group--wide">
          <label for="notes">Notes</label>
          <textarea
            id="notes"
            name="notes"
            rows="5"
            placeholder="Observations, substrate type, film thickness, XRD results, etc."
          ></textarea>
        </div>

        <!-- Actions -->
        <div class="form-actions">
          <button type="submit" class="edit-btn edit-btn--primary" id="save-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
              <polyline points="17 21 17 13 7 13 7 21"></polyline>
              <polyline points="7 3 7 8 15 8"></polyline>
            </svg>
            Save record
          </button>
          <a href="/experiments/" class="edit-btn edit-btn--secondary">Cancel</a>
        </div>
      </form>
    </div>
  </section>

  <script>
    import { experimentStorage } from '@/lib/experiments/storage';
    import type { ExperimentRecord } from '@/lib/experiments/types';

    experimentStorage.init();

    // Check if editing existing record
    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('id');

    const form = document.getElementById('experiment-form') as HTMLFormElement;
    const pageTitle = document.getElementById('page-title');
    const recordIdInput = document.getElementById('record-id') as HTMLInputElement;

    function formatDateTimeLocal(iso: string): string {
      const d = new Date(iso);
      const year = d.getFullYear();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${year}-${month}-${day}T${hours}:${minutes}`;
    }

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      if (window.__meownoteToast) {
        window.__meownoteToast.show(message, type);
      } else {
        alert(message);
      }
    }

    if (editId) {
      const record = experimentStorage.get(editId);
      if (record) {
        if (pageTitle) pageTitle.textContent = 'Edit experiment record';
        recordIdInput.value = record.id;

        (document.getElementById('dateTime') as HTMLInputElement).value = formatDateTimeLocal(record.dateTime);
        (document.getElementById('target') as HTMLInputElement).value = record.target;
        (document.getElementById('pressure') as HTMLInputElement).value = String(record.pressure);
        (document.getElementById('gateValve') as HTMLInputElement).value = record.gateValve;
        (document.getElementById('growthTemp') as HTMLInputElement).value = String(record.growthTemp);
        (document.getElementById('annealingTemp') as HTMLInputElement).value = String(record.annealingTemp);
        (document.getElementById('sampleHeight') as HTMLInputElement).value = String(record.sampleHeight);
        (document.getElementById('notes') as HTMLTextAreaElement).value = record.notes;
      } else {
        showToast('Record not found', 'error');
        window.location.href = '/experiments/';
      }
    } else {
      // Default to current time for new record
      const now = new Date();
      now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
      (document.getElementById('dateTime') as HTMLInputElement).value = now.toISOString().slice(0, 16);
    }

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {
        dateTime: (formData.get('dateTime') as string) || new Date().toISOString(),
        target: (formData.get('target') as string).trim(),
        pressure: parseFloat(formData.get('pressure') as string),
        gateValve: (formData.get('gateValve') as string).trim(),
        growthTemp: parseInt(formData.get('growthTemp') as string, 10),
        annealingTemp: parseInt(formData.get('annealingTemp') as string, 10),
        sampleHeight: parseFloat(formData.get('sampleHeight') as string),
        notes: (formData.get('notes') as string).trim(),
      };

      const id = recordIdInput.value;
      if (id) {
        experimentStorage.update(id, data);
        showToast('Record updated successfully');
      } else {
        experimentStorage.create(data);
        showToast('Record created successfully');
      }

      window.location.href = '/experiments/';
    });
  </script>

  <style>
    .experiment-edit-page {
      padding: calc(var(--header-height) + 2.5rem) 0 4rem;
      min-height: 100vh;
      background: var(--bg-primary);
    }

    .edit-shell {
      max-width: 720px;
      margin: 0 auto;
    }

    .edit-header {
      display: grid;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .edit-back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      width: fit-content;
      font-size: 0.84rem;
      font-weight: var(--font-medium);
      color: var(--text-tertiary);
      transition: color var(--duration-fast) var(--ease-default);
    }

    .edit-back-link:hover {
      color: var(--text-primary);
    }

    .edit-back-link svg {
      transition: transform var(--duration-fast) var(--ease-default);
    }

    .edit-back-link:hover svg {
      transform: translateX(-2px);
    }

    .edit-header h1 {
      font-size: clamp(1.75rem, 3.5vw, 2.25rem);
      line-height: 1.1;
      font-family: var(--font-editorial);
      font-weight: var(--font-medium);
      color: var(--text-primary);
    }

    /* Form */
    .edit-form {
      display: grid;
      gap: 1.5rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }

    @media (max-width: 640px) {
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    .form-group {
      display: grid;
      gap: 0.4rem;
    }

    .form-group--wide {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-size: 0.85rem;
      font-weight: var(--font-semibold);
      color: var(--text-secondary);
      letter-spacing: 0.01em;
    }

    .form-group label .required {
      color: var(--color-danger);
      margin-left: 0.15rem;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--input-border);
      border-radius: var(--radius-lg);
      background: var(--input-bg);
      color: var(--text-primary);
      font-size: 0.95rem;
      font-family: var(--font-body);
      transition: all var(--duration-fast) var(--ease-default);
      outline: none;
      width: 100%;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--input-focus-ring);
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: var(--text-quaternary);
    }

    .field-hint {
      font-size: 0.78rem;
      color: var(--text-quaternary);
      font-weight: var(--font-regular);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
      line-height: 1.55;
    }

    /* Actions */
    .form-actions {
      display: flex;
      gap: 0.75rem;
      padding-top: 0.5rem;
    }

    .edit-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      min-height: 2.65rem;
      padding: 0.65rem 1.25rem;
      border-radius: var(--radius-full);
      font-size: 0.875rem;
      font-weight: var(--font-medium);
      font-family: var(--font-body);
      cursor: pointer;
      transition: all var(--duration-fast) var(--ease-default);
      border: none;
      text-decoration: none;
      white-space: nowrap;
    }

    .edit-btn--primary {
      background: var(--btn-primary-bg);
      color: var(--btn-primary-text);
      box-shadow: var(--btn-primary-shadow);
    }

    .edit-btn--primary:hover {
      background: var(--btn-primary-hover);
      transform: translateY(-1px);
    }

    .edit-btn--secondary {
      background: var(--btn-secondary-bg);
      color: var(--btn-secondary-text);
      border: 1px solid var(--btn-secondary-border);
    }

    .edit-btn--secondary:hover {
      background: var(--btn-secondary-hover-bg);
      border-color: var(--border-hover);
    }
  </style>
</Layout>
