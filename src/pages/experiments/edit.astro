---
import Layout from '@layouts/Layout.astro';

const pageTitle = '编辑实验';
const pageDesc = '创建或编辑一条实验记录。';
---

<Layout title={`${pageTitle} - MoonSun.ai`} description={pageDesc} showHeader={false} showAuthModal={false} showFooter={false}>
  <section class="experiment-edit-page">
    <div class="container edit-shell">
      <!-- Header -->
      <header class="edit-header">
        <div class="edit-header__top">
          <a href="/experiments/" class="edit-back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"></path>
            </svg>
            <span>返回记录列表</span>
          </a>

        </div>
        <h1 id="page-title">新建实验记录</h1>
      </header>

      <!-- Form -->
      <div class="claude-surface edit-card">
        <form class="edit-form" id="experiment-form">
          <input type="hidden" id="record-id" />

          <div class="form-grid">
            <!-- Date & Time -->
            <div class="form-group form-group--wide">
              <label for="dateTime">
                日期时间
                <span class="required">*</span>
              </label>
              <input
                type="datetime-local"
                id="dateTime"
                name="dateTime"
                required
              />
            </div>

            <!-- User -->
            <div class="form-group">
              <label for="user">
                记录人
                <span class="required">*</span>
              </label>
              <input
                type="text"
                id="user"
                name="user"
                placeholder="例如：YangHao"
                required
              />
            </div>

            <!-- Operation -->
            <div class="form-group">
              <label for="operation">
                实验操作
                <span class="required">*</span>
              </label>
              <select id="operation" name="operation" required>
                <option value="" disabled selected>请选择操作类型</option>
                <option value="长膜">长膜</option>
                <option value="退火">退火</option>
                <option value="开腔">开腔</option>
              </select>
            </div>

            <!-- Target Selector -->
            <div class="form-group">
              <label for="targetSelect">
                靶材选择
                <span class="required">*</span>
              </label>
              <select id="targetSelect" name="targetSelect" required>
                <option value="" disabled selected>请选择靶材</option>
              </select>
              <span class="field-hint">从已保存的靶材中选择，<a href="/experiments/target/edit/" target="_blank" style="color: var(--color-primary); text-decoration: underline;">去新增靶材 →</a></span>
            </div>

            <!-- Hidden fields for target ref, batch & ratio -->
            <input type="hidden" id="targetId" name="targetId" />
            <input type="hidden" id="targetBatch" name="targetBatch" />
            <input type="hidden" id="targetRatio" name="targetRatio" />

            <!-- Pressure -->
            <div class="form-group">
              <label for="pressure">
                气压 (Pa)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="pressure"
                name="pressure"
                step="any"
                placeholder="例如：0.0025"
                required
              />
              <span class="field-hint">沉积过程中的工作气压</span>
            </div>

            <!-- Gate Valve -->
            <div class="form-group">
              <label for="gateValve">
                闸板阀
                <span class="required">*</span>
              </label>
              <input
                type="text"
                id="gateValve"
                name="gateValve"
                placeholder="例如：50%"
                required
              />
            </div>

            <!-- Growth Temperature -->
            <div class="form-group">
              <label for="growthTemp">
                生长温度 (°C)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="growthTemp"
                name="growthTemp"
                step="1"
                placeholder="例如：850"
                required
              />
            </div>

            <!-- Annealing Temperature -->
            <div class="form-group">
              <label for="annealingTemp">
                退火温度 (°C)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="annealingTemp"
                name="annealingTemp"
                step="1"
                placeholder="例如：400"
                required
              />
            </div>

            <!-- Sample Height -->
            <div class="form-group">
              <label for="sampleHeight">
                样品高度 (mm)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="sampleHeight"
                name="sampleHeight"
                step="0.1"
                placeholder="例如：12.5"
                required
              />
            </div>

            <!-- Sample Thickness -->
            <div class="form-group">
              <label for="sampleThickness">
                样品厚度 (μm)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="sampleThickness"
                name="sampleThickness"
                step="0.01"
                placeholder="例如：0.18"
                required
              />
            </div>

            <!-- Remanence -->
            <div class="form-group">
              <label for="remanence">
                剩磁 (T)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="remanence"
                name="remanence"
                step="any"
                placeholder="例如：0.85"
                required
              />
            </div>

            <!-- Coercivity -->
            <div class="form-group">
              <label for="coercivity">
                矫顽力 (T)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="coercivity"
                name="coercivity"
                step="any"
                placeholder="例如：0.12"
                required
              />
            </div>

            <!-- Saturation Magnetization -->
            <div class="form-group">
              <label for="saturationMagnetization">
                饱和磁化强度 (T)
                <span class="required">*</span>
              </label>
              <input
                type="number"
                id="saturationMagnetization"
                name="saturationMagnetization"
                step="any"
                placeholder="例如：1.25"
                required
              />
            </div>
          </div>

          <!-- Notes -->
          <div class="form-group form-group--wide">
            <label for="notes">备注</label>
            <textarea
              id="notes"
              name="notes"
              rows="5"
              placeholder="观察记录、衬底类型、薄膜厚度、XRD 结果等"
            ></textarea>
          </div>

          <!-- Actions -->
          <div class="form-actions">
            <button type="button" class="claude-button" id="save-ok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              符合
            </button>
            <button type="button" class="claude-button-secondary" id="save-fail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
              不符合
            </button>
            <a href="/experiments/" class="claude-button-secondary">取消</a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script>
    import { experimentStorage } from '@/lib/experiments/storage';
    import { targetStorage } from '@/lib/targets/storage';
    import type { TargetRecord } from '@/lib/targets/types';

    experimentStorage.init();
    targetStorage.init();

    const targetSelect = document.getElementById('targetSelect') as HTMLSelectElement;
    const targetIdInput = document.getElementById('targetId') as HTMLInputElement;
    const targetBatchInput = document.getElementById('targetBatch') as HTMLInputElement;
    const targetRatioInput = document.getElementById('targetRatio') as HTMLInputElement;

    // Load targets into dropdown
    function loadTargetOptions(selectedTargetId?: string) {
      const targets = targetStorage.list();
      const currentValue = targetSelect.value;
      targetSelect.innerHTML = '<option value="" disabled selected>请选择靶材</option>';
      targets.forEach((t: TargetRecord) => {
        const opt = document.createElement('option');
        opt.value = t.id;
        opt.textContent = `${t.name} (${t.batch})`;
        opt.dataset.batch = t.batch;
        opt.dataset.ratio = t.ratio;
        targetSelect.appendChild(opt);
      });
      if (selectedTargetId) {
        const match = targets.find((t: TargetRecord) => t.id === selectedTargetId);
        if (match) {
          targetSelect.value = match.id;
          targetIdInput.value = match.id;
          targetBatchInput.value = match.batch;
          targetRatioInput.value = match.ratio;
        }
      } else if (currentValue) {
        const stillExists = targets.find((t: TargetRecord) => t.id === currentValue);
        if (stillExists) {
          targetSelect.value = currentValue;
        }
      }
    }

    targetSelect?.addEventListener('change', () => {
      const opt = targetSelect.selectedOptions[0];
      if (opt && opt.dataset.batch) {
        targetIdInput.value = targetSelect.value;
        targetBatchInput.value = opt.dataset.batch;
        targetRatioInput.value = opt.dataset.ratio || '';
      }
    });

    loadTargetOptions();

    // Refresh target list when page regains focus
    window.addEventListener('focus', () => {
      loadTargetOptions(targetIdInput.value || undefined);
    });

    // Also listen for storage changes from other tabs
    window.addEventListener('storage', (e) => {
      if (e.key === 'meownote_targets') {
        loadTargetOptions(targetIdInput.value || undefined);
      }
    });

    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('id');

    const form = document.getElementById('experiment-form') as HTMLFormElement;
    const pageTitle = document.getElementById('page-title');
    const recordIdInput = document.getElementById('record-id') as HTMLInputElement;

    function formatDateTimeLocal(iso: string): string {
      const d = new Date(iso);
      const year = d.getFullYear();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${year}-${month}-${day}T${hours}:${minutes}`;
    }

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      if (window.__meownoteToast) {
        window.__meownoteToast.show(message, type);
      } else {
        alert(message);
      }
    }

    if (editId) {
      const record = experimentStorage.get(editId);
      if (record) {
        if (pageTitle) pageTitle.textContent = '编辑实验记录';
        recordIdInput.value = record.id;

        (document.getElementById('dateTime') as HTMLInputElement).value = formatDateTimeLocal(record.dateTime);
        (document.getElementById('user') as HTMLInputElement).value = record.user;
        (document.getElementById('operation') as HTMLSelectElement).value = record.operation;
        loadTargetOptions(record.targetId);
        (document.getElementById('pressure') as HTMLInputElement).value = String(record.pressure);
        (document.getElementById('gateValve') as HTMLInputElement).value = record.gateValve;
        (document.getElementById('growthTemp') as HTMLInputElement).value = String(record.growthTemp);
        (document.getElementById('annealingTemp') as HTMLInputElement).value = String(record.annealingTemp);
        (document.getElementById('sampleHeight') as HTMLInputElement).value = String(record.sampleHeight);
        (document.getElementById('sampleThickness') as HTMLInputElement).value = String(record.sampleThickness);
        (document.getElementById('remanence') as HTMLInputElement).value = String(record.remanence);
        (document.getElementById('coercivity') as HTMLInputElement).value = String(record.coercivity);
        (document.getElementById('saturationMagnetization') as HTMLInputElement).value = String(record.saturationMagnetization);
        (document.getElementById('notes') as HTMLTextAreaElement).value = record.notes;
      } else {
        showToast('记录未找到', 'error');
        window.location.href = '/experiments/';
      }
    } else {
      const now = new Date();
      now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
      (document.getElementById('dateTime') as HTMLInputElement).value = now.toISOString().slice(0, 16);
    }

    function collectData(): any {
      const formData = new FormData(form);
      return {
        dateTime: (formData.get('dateTime') as string) || new Date().toISOString(),
        user: (formData.get('user') as string).trim(),
        operation: (formData.get('operation') as string).trim(),
        targetId: targetIdInput.value.trim() || undefined,
        targetBatch: targetBatchInput.value.trim(),
        targetRatio: targetRatioInput.value.trim(),
        pressure: parseFloat(formData.get('pressure') as string),
        gateValve: (formData.get('gateValve') as string).trim(),
        growthTemp: parseInt(formData.get('growthTemp') as string, 10),
        annealingTemp: parseInt(formData.get('annealingTemp') as string, 10),
        sampleHeight: parseFloat(formData.get('sampleHeight') as string),
        sampleThickness: parseFloat(formData.get('sampleThickness') as string),
        remanence: parseFloat(formData.get('remanence') as string),
        coercivity: parseFloat(formData.get('coercivity') as string),
        saturationMagnetization: parseFloat(formData.get('saturationMagnetization') as string),
        notes: (formData.get('notes') as string).trim(),
      };
    }

    function submitData(performanceOk: boolean) {
      if (!form?.checkValidity()) {
        form?.reportValidity();
        return;
      }
      if (!targetBatchInput.value || !targetRatioInput.value) {
        showToast('请先选择靶材', 'error');
        targetSelect.focus();
        return;
      }
      const data = { ...collectData(), performanceOk };
      const id = recordIdInput.value;
      if (id) {
        experimentStorage.update(id, data);
        showToast('记录已更新');
      } else {
        experimentStorage.create(data);
        showToast('记录已创建');
      }
      window.location.href = '/experiments/';
    }

    document.getElementById('save-ok')?.addEventListener('click', () => submitData(true));
    document.getElementById('save-fail')?.addEventListener('click', () => submitData(false));
  </script>

  <style>
    .experiment-edit-page {
      min-height: 100vh;
      padding: calc(var(--header-height) + 2rem) 0 4rem;
      background: var(--bg-primary);
    }

    .edit-shell {
      max-width: 760px;
      margin: 0 auto;
    }

    .edit-header {
      display: grid;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .edit-header__top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .edit-back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      width: fit-content;
      font-size: 0.84rem;
      font-weight: var(--font-medium);
      color: var(--text-tertiary);
      transition: color var(--duration-fast) var(--ease-default);
    }

    .edit-back-link:hover {
      color: var(--text-primary);
    }

    .edit-back-link svg {
      transition: transform var(--duration-fast) var(--ease-default);
    }

    .edit-back-link:hover svg {
      transform: translateX(-2px);
    }

    .edit-header h1 {
      font-size: clamp(1.75rem, 3.5vw, 2.25rem);
      line-height: 1.1;
      font-family: var(--font-editorial);
      font-weight: var(--font-medium);
      color: var(--text-primary);
    }

    .edit-card {
      padding: clamp(1.5rem, 3vw, 2.5rem);
    }

    .edit-form {
      display: grid;
      gap: 1.5rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }

    @media (max-width: 640px) {
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    .form-group {
      display: grid;
      gap: 0.4rem;
    }

    .form-group--wide {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-size: 0.85rem;
      font-weight: var(--font-semibold);
      color: var(--text-secondary);
      letter-spacing: 0.01em;
    }

    .form-group label .required {
      color: var(--color-danger);
      margin-left: 0.15rem;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--input-border);
      border-radius: var(--radius-lg);
      background: var(--input-bg);
      color: var(--text-primary);
      font-size: 0.95rem;
      font-family: var(--font-body);
      transition: all var(--duration-fast) var(--ease-default);
      outline: none;
      width: 100%;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--input-focus-ring);
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: var(--text-quaternary);
    }

    .field-hint {
      font-size: 0.78rem;
      color: var(--text-quaternary);
      font-weight: var(--font-regular);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
      line-height: 1.55;
    }

    .form-actions {
      display: flex;
      gap: 0.75rem;
      padding-top: 0.5rem;
    }
  </style>
</Layout>
