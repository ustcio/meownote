---
import Layout from '@layouts/Layout.astro';
import ModalShell from '@components/ui/ModalShell.astro';

const pageTitle = '靶材管理';
const pageDesc = '管理实验靶材信息。';
---

<Layout title={`${pageTitle} - MoonSun.ai`} description={pageDesc} showHeader={false} showAuthModal={false} showFooter={false}>
  <section class="targets-page">
    <div class="container">
      <!-- Header -->
      <div class="targets-header">
        <div class="targets-header__copy">
          <h1>靶材管理</h1>
          <p class="targets-header__desc">统一管理实验靶材，供实验记录中快速引用。</p>
        </div>
        <div class="targets-header__actions">
          <a href="/experiments/" class="claude-button-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"></path>
            </svg>
            <span>返回实验记录</span>
          </a>
          <a href="/experiments/target/edit/" class="claude-button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>新增靶材</span>
          </a>
        </div>
      </div>

      <!-- Toolbar -->
      <div class="targets-toolbar">
        <div class="toolbar-search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-input" placeholder="搜索靶材名称、批次..." />
        </div>
      </div>

      <!-- Table -->
      <div class="targets-table-wrapper">
          <table class="targets-table" id="targets-table">
            <thead>
              <tr>
                <th scope="col" class="col-name">靶材名称</th>
                <th scope="col" class="col-batch">靶材批次</th>
                <th scope="col" class="col-ratio">化学计量比</th>
                <th scope="col" class="col-user">记录人</th>
                <th scope="col" class="col-datetime">入库时间</th>
                <th scope="col" class="col-actions">操作</th>
              </tr>
            </thead>
            <tbody id="targets-tbody">
              <!-- Populated by JS -->
            </tbody>
          </table>
          <div class="empty-state" id="empty-state" style="display: none;">
            <div class="empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="16"></line>
                <line x1="8" y1="12" x2="16" y2="12"></line>
              </svg>
            </div>
            <h3>暂无靶材</h3>
            <p>开始添加你的第一个靶材。</p>
            <a href="/experiments/target/edit/" class="claude-button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              添加第一个靶材
            </a>
          </div>
          <div class="empty-state" id="search-empty-state" style="display: none;">
            <div class="empty-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </div>
            <h3>未找到匹配靶材</h3>
            <p>尝试更换搜索关键词。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Delete Modal -->
  <ModalShell id="delete-modal" title="删除靶材" closeId="delete-close" backdropId="delete-backdrop" closeClass="modal-close" contentClass="modal-sm">
    <p>此操作将永久删除该靶材记录，无法撤销。</p>
    <div class="modal-actions">
      <button class="claude-button-secondary" id="delete-cancel">取消</button>
      <button class="btn-danger" id="delete-confirm">删除</button>
    </div>
  </ModalShell>

  <script>
    import { targetStorage } from '@/lib/targets/storage';
    import type { TargetRecord } from '@/lib/targets/types';

    targetStorage.init();

    let allTargets: TargetRecord[] = [];
    let pendingDeleteId: string | null = null;

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      if (window.__meownoteToast) {
        window.__meownoteToast.show(message, type);
      } else {
        alert(message);
      }
    }

    function formatDateTime(iso: string): string {
      const d = new Date(iso);
      const year = d.getFullYear();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${year}/${month}/${day} ${hours}:${minutes}`;
    }

    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function renderTable(targets: TargetRecord[]) {
      const table = document.getElementById('targets-table') as HTMLTableElement;
      const tbody = document.getElementById('targets-tbody') as HTMLTableSectionElement;
      const emptyState = document.getElementById('empty-state') as HTMLElement;
      const searchEmptyState = document.getElementById('search-empty-state') as HTMLElement;

      searchEmptyState.style.display = 'none';

      if (allTargets.length === 0) {
        table.style.display = 'none';
        emptyState.style.display = 'flex';
        updateStats([]);
        return;
      }

      emptyState.style.display = 'none';

      if (targets.length === 0) {
        table.style.display = 'none';
        searchEmptyState.style.display = 'flex';
        return;
      }

      table.style.display = 'table';

      tbody.innerHTML = targets.map((r, i) => {
        // Generate a stable color based on name hash
        const hue = r.name.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % 360;
        const badgeStyle = `background: hsl(${hue}, 60%, 92%); color: hsl(${hue}, 70%, 30%); border: 1px solid hsl(${hue}, 50%, 85%);`;

        return `
        <tr data-id="${r.id}">
          <td class="cell-name">
            <span class="target-badge" style="${badgeStyle}">${escapeHtml(r.name)}</span>
          </td>
          <td class="cell-batch">${escapeHtml(r.batch)}</td>
          <td class="cell-ratio">${escapeHtml(r.ratio)}</td>
          <td class="cell-user">${escapeHtml(r.user)}</td>
          <td class="cell-datetime">${formatDateTime(r.dateTime)}</td>
          <td class="cell-actions">
            <a href="/experiments/target/edit/?id=${r.id}" class="action-btn action-btn--edit" title="编辑">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
            </a>
            <button class="action-btn action-btn--delete" data-id="${r.id}" title="删除">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </td>
        </tr>
      `;
      }).join('');

      tbody.querySelectorAll('.action-btn--delete').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const id = (e.currentTarget as HTMLElement).dataset.id;
          if (id) {
            pendingDeleteId = id;
            document.getElementById('delete-modal')?.classList.add('open');
          }
        });
      });
    }

    function refresh(searchTerm?: string) {
      allTargets = targetStorage.list();
      let filtered = allTargets;
      if (searchTerm) {
        const term = searchTerm.toLowerCase();
        filtered = allTargets.filter((t) =>
          t.name.toLowerCase().includes(term) ||
          t.batch.toLowerCase().includes(term) ||
          t.ratio.toLowerCase().includes(term) ||
          t.user.toLowerCase().includes(term)
        );
      }
      renderTable(filtered);
    }

    refresh();

    // Search
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    let searchDebounce: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(searchDebounce);
      searchDebounce = setTimeout(() => {
        const term = (e.target as HTMLInputElement).value.trim();
        refresh(term || undefined);
      }, 200);
    });

    // Delete modal
    document.getElementById('delete-cancel')?.addEventListener('click', () => {
      pendingDeleteId = null;
      document.getElementById('delete-modal')?.classList.remove('open');
    });

    document.getElementById('delete-close')?.addEventListener('click', () => {
      pendingDeleteId = null;
      document.getElementById('delete-modal')?.classList.remove('open');
    });

    document.getElementById('delete-backdrop')?.addEventListener('click', () => {
      pendingDeleteId = null;
      document.getElementById('delete-modal')?.classList.remove('open');
    });

    document.getElementById('delete-confirm')?.addEventListener('click', () => {
      if (pendingDeleteId) {
        targetStorage.remove(pendingDeleteId);
        showToast('靶材已删除');
        const term = searchInput?.value.trim();
        refresh(term || undefined);
      }
      pendingDeleteId = null;
      document.getElementById('delete-modal')?.classList.remove('open');
    });
  </script>

  <style>
    .targets-page {
      min-height: 100vh;
      padding: calc(var(--header-height) + 2rem) 0 4rem;
      background: var(--bg-primary);
    }

    .targets-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }

    .targets-header__copy h1 {
      font-size: clamp(1.75rem, 3.5vw, 2.25rem);
      line-height: 1.1;
      font-family: var(--font-editorial);
      font-weight: var(--font-medium);
    }

    .targets-header__desc {
      font-size: 0.9rem;
      color: var(--text-tertiary);
      margin-top: 0.4rem;
    }

    .targets-header__actions {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      flex-shrink: 0;
    }

    /* Toolbar */
    .targets-toolbar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .toolbar-search {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      min-height: 2rem;
      padding: 0 0.6rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border-primary);
      border-radius: var(--radius-full);
      transition: all var(--duration-fast) var(--ease-default);
      width: 220px;
      flex-shrink: 0;
    }

    .toolbar-search:focus-within {
      width: 260px;
      border-color: var(--color-primary);
    }

    .toolbar-search svg {
      color: var(--text-tertiary);
      flex-shrink: 0;
    }

    .toolbar-search input {
      flex: 1;
      border: none;
      background: transparent;
      font-size: 0.78rem;
      color: var(--text-primary);
      outline: none;
      padding: 0.35rem 0;
      width: 100%;
    }

    .toolbar-search input::placeholder {
      color: var(--text-tertiary);
    }

    /* Table — 与实验记录列表保持一致 */
    .targets-table-wrapper {
      border: 1px solid var(--border-secondary);
      border-radius: var(--radius-xl);
      background: var(--card-bg);
      box-shadow: var(--card-shadow);
    }

    .targets-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8rem;
      table-layout: fixed;
    }

    .targets-table thead {
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border-secondary);
    }

    .targets-table th {
      padding: 0.6rem 0.5rem;
      text-align: left;
      font-size: 0.7rem;
      font-weight: var(--font-semibold);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      word-wrap: break-word;
      line-height: 1.2;
    }

    .targets-table th:nth-child(1) { width: 18%; }
    .targets-table th:nth-child(2) { width: 22%; }
    .targets-table th:nth-child(3) { width: 22%; }
    .targets-table th:nth-child(4) { width: 10%; }
    .targets-table th:nth-child(5) { width: 13%; }
    .targets-table th:nth-child(6) { width: 5%; text-align: center; }

    .targets-table td {
      padding: 0.6rem 0.5rem;
      border-bottom: 1px solid var(--border-secondary);
      color: var(--text-primary);
      vertical-align: middle;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .targets-table tbody tr {
      transition: background var(--duration-fast) var(--ease-default);
      animation: rowIn 0.35s var(--ease-out) both;
    }

    @keyframes rowIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .targets-table tbody tr:hover {
      background: var(--card-bg-hover);
    }

    .targets-table tbody tr:last-child td {
      border-bottom: none;
    }

    .cell-name {
      font-weight: var(--font-semibold);
    }

    .target-badge {
      display: inline-block;
      padding: 0.2rem 0.5rem;
      border-radius: var(--radius-sm);
      font-size: 0.78rem;
      font-weight: var(--font-semibold);
      white-space: nowrap;
    }

    .cell-batch {
      font-variant-numeric: tabular-nums;
      color: var(--text-secondary);
    }

    .cell-ratio {
      font-variant-numeric: tabular-nums;
      color: var(--color-primary);
    }

    .cell-user {
      color: var(--text-secondary);
    }

    .cell-datetime {
      font-variant-numeric: tabular-nums;
      color: var(--text-secondary);
      font-size: 0.85rem;
      white-space: nowrap;
    }

    .col-actions {
      width: 1%;
      white-space: nowrap;
      text-align: center;
    }

    .cell-actions {
      text-align: center;
      vertical-align: middle;
    }

    .action-btn {
      display: block;
      margin: 0 auto;
      width: 2rem;
      height: 2rem;
      border: none;
      border-radius: var(--radius-md);
      background: transparent;
      color: var(--text-tertiary);
      cursor: pointer;
      transition: all var(--duration-fast) var(--ease-default);
    }

    .action-btn + .action-btn {
      margin-top: 0.35rem;
    }

    .action-btn:hover {
      background: var(--bg-secondary);
      color: var(--text-primary);
    }

    .action-btn--edit:hover {
      color: var(--color-primary);
    }

    .action-btn--delete:hover {
      background: var(--color-danger-light);
      color: var(--color-danger);
    }

    /* Empty states */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 4rem 2rem;
      text-align: center;
      color: var(--text-tertiary);
    }

    .empty-icon {
      color: var(--text-tertiary);
      opacity: 0.5;
    }

    .empty-state h3 {
      font-size: 1.1rem;
      font-weight: var(--font-medium);
      color: var(--text-secondary);
    }

    .empty-state p {
      font-size: 0.9rem;
    }

    @media (max-width: 640px) {
      .targets-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .targets-table th,
      .targets-table td {
        padding: 0.6rem 0.4rem;
      }
    }
  </style>
</Layout>
