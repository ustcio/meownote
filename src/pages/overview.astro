---
// src/pages/overview.astro
import Layout from '@layouts/Layout.astro';
import StackedCards from '@components/ui/StackedCards.astro';
import TabsShowcase from '@components/ui/TabsShowcase.astro';
import TypewriterDemo from '@components/ui/TypewriterDemo.astro';
import InfiniteMarquee from '@components/ui/InfiniteMarquee.astro';
import TextReveal from '@components/ui/TextReveal.astro';

// Demonstration content for Stacked Cards
const capabilities = [
  {
    title: 'Break down problems together',
    description: 'MoonSun builds on your ideas, expands on your logic, and simplifies complexity one step at a time.',
    tag: 'Problem Solving',
    background: 'var(--bg-secondary)'
  },
  {
    title: 'Tackle your toughest work',
    description: 'MoonSun provides expert-level collaboration on the things you need to get done—from coding a product to critical data analysis.',
    tag: 'Collaboration',
    background: 'var(--bg-tertiary)'
  },
  {
    title: 'Explore what’s next',
    description: 'Like an expert in your pocket, collaborating with MoonSun expands what you can build on your own or with teams.',
    tag: 'Innovation',
    background: 'var(--card-bg-cream)'
  }
];

// Demonstration content for Tabs
const tabsData = [
  {
    id: 'tab-code',
    label: 'Code',
    contentTitle: 'Write, debug, and ship faster.',
    contentText: 'From small scripts to scalable infrastructure, bring an expert programming partner directly into your workflow.',
    visualHtml: `<div class="tab-demo"><div class="type-demo-shell"><pre class="type-demo-code">function optimizeSearch(array, target) {
  let left = 0;
  let right = array.length - 1;
  while (left <= right) {
    const mid = Math.floor((left + right) / 2);
    if (array[mid] === target) return mid;
    if (array[mid] < target) left = mid + 1;
    else right = mid - 1;
  }
  return -1;
}</pre></div></div>`
  },
  {
    id: 'tab-write',
    label: 'Write',
    contentTitle: 'Draft with a thoughtful colleague.',
    contentText: 'Need a tone check, a creative spark, or someone to restructure a long document? MoonSun helps you write clearly.',
    visualHtml: `<div class="tab-demo"><div class="type-demo-shell"><p class="type-demo-text">Here is a revised draft of your project proposal, incorporating a more authoritative tone and highlighting the long-term ROI:<br><br>The adoption of this architecture fundamentally derisks our Q3 timeline while offering an estimated 40% reduction in cloud compute over the next fiscal year...</p></div></div>`
  },
  {
    id: 'tab-analyze',
    label: 'Analyze',
    contentTitle: 'Extract insights instantly.',
    contentText: 'Upload PDFs, spreadsheets, or long-form research. MoonSun parses complex information so you can reach conclusions faster.',
    visualHtml: `<div class="tab-demo"><div class="type-demo-shell"><p class="type-demo-text">Based on the uploaded Q2 Financial Report, here are the key takeaways:<br><br>1. Revenue increased by 14.2% YoY, heavily driven by digital channels.<br>2. Operating margins compressed slightly due to one-time R&D expenditures.<br>3. The debt-to-equity ratio remains highly favorable for upcoming acquisitions.</p></div></div>`
  }
];
---

<Layout title="Product Overview - Dynamic Components Showcase">
  <div class="overview-page">
    
    <!-- Hero Section -->
    <header class="overview-header container">
      <TextReveal tag="h1" text="The AI for Problem Solvers" class="heading-large" delay={100} />
      <TextReveal tag="p" text="Tackle complex challenges, analyze data, write code, and think through your hardest work." class="subheading" delay={200} />
    </header>

    <!-- Marquee Section -->
    <section class="marquee-section">
      <InfiniteMarquee speed="30s">
        {["🚀 Fast API", "🛡️ Enterprise Security", "⚡ Real-time processing", "📊 Advanced Analytics", "🧠 High Intelligence", "🌐 Global Infrastructure"].map(item => (
          <span class="marquee-item">{item}</span>
        ))}
      </InfiniteMarquee>
    </section>

    <!-- Tabs Showcase Section -->
    <section class="tabs-section container claude-section">
      <h2>Capabilities</h2>
      <TabsShowcase tabs={tabsData} />
    </section>

    <!-- Stacked Cards Section -->
    <section class="stacked-section container claude-section">
      <h2>Built for scale</h2>
      <StackedCards cards={capabilities} />
    </section>

  </div>
</Layout>

<style>
  .overview-page {
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-20);
  }

  .overview-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 800px;
    margin: 0 auto var(--space-16);
  }

  .heading-large {
    font-family: var(--font-editorial);
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1.05;
    margin-bottom: var(--space-6);
  }

  .subheading {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    max-width: 600px;
  }

  .marquee-section {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--border-secondary);
    border-bottom: 1px solid var(--border-secondary);
    background: var(--bg-secondary);
  }

  .marquee-item {
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    padding: 0 var(--space-4);
  }

  .tabs-section h2, .stacked-section h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-10);
    text-align: center;
  }

  .tab-demo {
    width: 100%;
    height: 100%;
    min-height: 250px;
  }

  .type-demo-shell {
    width: 100%;
    min-height: 250px;
    padding: 1.25rem;
    border-radius: var(--radius-xl);
    background: var(--bg-primary);
    border: 1px solid var(--border-secondary);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.45);
  }

  .type-demo-code,
  .type-demo-text {
    margin: 0;
    white-space: pre-wrap;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }
</style>
