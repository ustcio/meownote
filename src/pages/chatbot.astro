---
import Layout from '@layouts/Layout.astro';
import Icon from '@components/ui/Icon.astro';
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    icon: 'message-circle',
    title: '更稳的对话节奏',
    desc: '从提问、追问到改写，都保持清晰的上下文与输出结构。'
  },
  {
    icon: 'zap',
    title: '少一点摩擦',
    desc: '把常用入口、建议问题和输入区做得更安静、更直接。'
  },
  {
    icon: 'shield',
    title: '信息边界更清楚',
    desc: '重要内容会提醒你核验，避免把 AI 结果误当最终答案。'
  },
  {
    icon: 'globe',
    title: '更适合日常工作',
    desc: '写作、总结、解释概念和整理思路都可以从同一个界面开始。'
  }
];

const suggestions = [
  { icon: 'mail', text: '写一封得体的邮件', prompt: 'Help me write a concise, professional email that asks for a meeting next week.' },
  { icon: 'book', text: '解释一个复杂概念', prompt: 'Explain the concept of machine learning in clear language for a beginner.' },
  { icon: 'code', text: '一起排查代码问题', prompt: 'Help me debug this Python function and explain the root cause step by step.' },
  { icon: 'edit', text: '整理一段长文', prompt: 'Summarize this document, extract the decisions, and suggest the next steps.' },
];
---

<Layout 
  title={`${t('chatbot.title', lang)} - MaxMin.dev`}
  description={t('chatbot.welcome.subtitle', lang)}
>
  <section class="chatbot">
    <div class="chatbot-container">
      <!-- Hero -->
      <div class="chatbot-hero">
        <div class="hero-badge">
          <Icon name="message-circle" size={16} />
          <span>Conversation workspace</span>
        </div>
        <h1 class="hero-title">A calmer way to work with AI</h1>
        <p class="hero-tagline">写作、总结、整理思路，都可以从一个对话开始。</p>
        <p class="hero-description">
          不追求夸张的功能堆叠，而是把输入、建议和回答都整理得更清楚，
          让你更容易从问题走到下一步。
        </p>
      </div>

      <!-- Chat Interface -->
      <div class="chat-interface">
        <!-- Chat Window -->
        <div class="chat-window" id="chat-window">
          <!-- Welcome Message -->
          <div class="chat-welcome" id="chat-welcome">
            <div class="welcome-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <rect width="48" height="48" rx="12" fill="var(--color-primary)"/>
                <path d="M24 8L38 36H10L24 8Z" fill="white"/>
              </svg>
            </div>
            <h3 class="welcome-title">今天想推进什么？</h3>
            <p class="welcome-subtitle">选一个方向开始，或者直接输入你的问题。</p>
            
            <div class="suggestion-grid">
              {suggestions.map((s) => (
                <button class="suggestion-btn" data-prompt={s.prompt}>
                  <Icon name={s.icon} size={18} />
                  <span>{s.text}</span>
                </button>
              ))}
            </div>
          </div>
          
          <!-- Messages Container -->
          <div class="chat-messages" id="chat-messages"></div>
        </div>

        <!-- Input Area -->
        <div class="chat-input-area">
          <div class="input-wrapper">
            <textarea 
              class="chat-input" 
              id="chat-input" 
              placeholder="输入消息..."
              rows="1"
            ></textarea>
            <button class="send-btn" id="send-btn" disabled>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </div>
          <p class="input-hint">AI 可以帮你起草与整理，但重要信息仍然建议你自行核验。</p>
        </div>
      </div>

      <!-- Features -->
      <div class="features-section">
        <h2 class="section-title">为什么这个界面更像 Claude</h2>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card">
              <div class="feature-icon">
                <Icon name={feature.icon} size={24} />
              </div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-desc">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-section">
        <h2 class="cta-title">从一个问题开始</h2>
        <p class="cta-subtitle">把模糊的想法交给 AI，一起把它理顺。</p>
        <div class="cta-actions">
          <button class="btn-primary" id="start-chat-btn">
            <Icon name="message-circle" size={18} />
            <span>开始聊天</span>
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .chatbot {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-8)) var(--space-4) var(--space-12);
    background: var(--bg-primary);
  }

  .chatbot-container {
    max-width: var(--container-2xl);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  /* Hero */
  .chatbot-hero {
    text-align: left;
    padding: var(--space-6) 0 0;
    max-width: 44rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.45rem 0.85rem;
    background: rgba(255, 253, 249, 0.75);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 0.98;
    letter-spacing: var(--tracking-tight);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .hero-description {
    font-size: 1.02rem;
    color: var(--text-secondary);
    max-width: 36rem;
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  /* Chat Interface */
  .chat-interface {
    background: var(--bg-elevated);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    max-width: 960px;
    margin: 0;
    width: 100%;
    box-shadow: var(--card-shadow);
  }

  .chat-window {
    min-height: 400px;
    max-height: 500px;
    overflow-y: auto;
    padding: var(--space-6);
  }

  /* Welcome */
  .chat-welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 350px;
    text-align: center;
  }

  .chat-welcome.hidden {
    display: none;
  }

  .welcome-icon {
    margin-bottom: var(--space-4);
  }

  .welcome-title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .welcome-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .suggestion-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    width: 100%;
    max-width: 450px;
  }

  @media (max-width: 500px) {
    .suggestion-grid {
      grid-template-columns: 1fr;
    }
  }

  .suggestion-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-align: left;
    cursor: pointer;
    min-height: 48px;
    transition: all var(--duration-fast) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  .suggestion-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* Messages */
  .chat-messages {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .message {
    display: flex;
    gap: var(--space-3);
    max-width: 85%;
  }

  .message.user {
    margin-left: auto;
    flex-direction: row-reverse;
  }

  .message-avatar {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
  }

  .message.assistant .message-avatar {
    background: var(--color-primary);
    color: white;
  }

  .message.user .message-avatar {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .message-content {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .message.assistant .message-content {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .message.user .message-content {
    background: var(--color-primary);
    color: white;
  }

  /* Typing Indicator */
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: var(--space-3);
  }

  .typing-dot {
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
    animation: typing 1.4s infinite;
    opacity: 0.4;
  }

  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 60%, 100% { opacity: 0.4; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-4px); }
  }

  /* Input Area */
  .chat-input-area {
    border-top: 1px solid var(--card-border);
    padding: var(--space-4);
    background: var(--bg-elevated);
  }

  .input-wrapper {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    padding: var(--space-3);
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .input-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .chat-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-primary);
    resize: none;
    outline: none;
    min-height: 24px;
    max-height: 120px;
    line-height: 1.5;
  }

  .chat-input::placeholder {
    color: var(--text-muted);
  }

  .send-btn {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-full);
    color: white;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  .send-btn:hover:not(:disabled) {
    background: var(--color-primary-hover);
  }

  .send-btn:disabled {
    background: var(--text-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }

  .input-hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-align: center;
    margin-top: var(--space-2);
  }

  /* Features */
  .features-section {
    padding: var(--space-8) 0;
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }

  .feature-card {
    padding: var(--space-6);
    background: var(--bg-elevated);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    text-align: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .feature-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
    border-radius: var(--radius-lg);
    color: white;
    margin-bottom: var(--space-4);
  }

  .feature-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .feature-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding: var(--space-12);
    background: linear-gradient(135deg, var(--color-primary-light), transparent);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(192, 107, 62, 0.2);
  }

  .cta-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .cta-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--color-primary);
    color: white;
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    min-height: 48px;
    transition: all var(--duration-fast) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  /* Mobile optimizations */
  @media (max-width: 480px) {
    .chatbot {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }

    .chat-window {
      min-height: 300px;
      max-height: 400px;
      padding: var(--space-4);
    }

    .chat-welcome {
      min-height: 280px;
    }

    .welcome-icon svg {
      width: 40px;
      height: 40px;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .cta-section {
      padding: var(--space-8);
    }
  }

</style>

<script>
  const API_BASE = 'https://api.ustc.dev';
  
  let messages: { role: 'user' | 'assistant'; content: string }[] = [];

  const chatWindow = document.getElementById('chat-window');
  const chatWelcome = document.getElementById('chat-welcome');
  const chatMessages = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;

  // Suggestion buttons
  document.querySelectorAll('.suggestion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const prompt = btn.getAttribute('data-prompt');
      if (prompt && chatInput) {
        chatInput.value = prompt;
        chatInput.focus();
        sendBtn.disabled = false;
      }
    });
  });

  // Start chat button
  document.getElementById('start-chat-btn')?.addEventListener('click', () => {
    chatInput?.focus();
    chatInput?.scrollIntoView({ behavior: 'smooth' });
  });

  // Input handling
  chatInput?.addEventListener('input', () => {
    sendBtn.disabled = !chatInput.value.trim();
    chatInput.style.height = 'auto';
    chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + 'px';
  });

  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) {
        sendMessage();
      }
    }
  });

  sendBtn?.addEventListener('click', sendMessage);

  async function sendMessage() {
    const content = chatInput?.value.trim();
    if (!content) return;

    // Hide welcome
    chatWelcome?.classList.add('hidden');

    // Add user message
    addMessage('user', content);
    messages.push({ role: 'user', content });

    // Clear input
    chatInput.value = '';
    chatInput.style.height = 'auto';
    sendBtn.disabled = true;

    // Add typing indicator
    const typingEl = addTypingIndicator();

    try {
      const response = await fetch(`${API_BASE}/api/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: content })
      });

      const data = await response.json();
      
      if (typingEl) typingEl.remove();
      
      if (data.success && data.reply) {
        addMessage('assistant', data.reply);
        messages.push({ role: 'assistant', content: data.reply });
      } else if (data.message) {
        addMessage('assistant', `错误: ${data.message}`);
      } else {
        addMessage('assistant', '抱歉，未能获取回复');
      }
    } catch (error) {
      if (typingEl) typingEl.remove();
      addMessage('assistant', '网络错误，请稍后重试');
    }
  }

  function addMessage(role: 'user' | 'assistant', content: string) {
    const messageEl = document.createElement('div');
    messageEl.className = `message ${role}`;
    
    messageEl.innerHTML = `
      <div class="message-avatar">
        ${role === 'assistant' 
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L20.5 18H3.5L12 3Z"/></svg>'
          : 'U'}
      </div>
      <div class="message-content">${escapeHtml(content)}</div>
    `;
    
    chatMessages?.appendChild(messageEl);
    chatWindow?.scrollTo({ top: chatWindow.scrollHeight, behavior: 'smooth' });
  }

  function addTypingIndicator(): HTMLElement | null {
    const typingEl = document.createElement('div');
    typingEl.className = 'message assistant';
    typingEl.innerHTML = `
      <div class="message-avatar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L20.5 18H3.5L12 3Z"/></svg>
      </div>
      <div class="message-content">
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>
    `;
    chatMessages?.appendChild(typingEl);
    chatWindow?.scrollTo({ top: chatWindow.scrollHeight, behavior: 'smooth' });
    return typingEl;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>
