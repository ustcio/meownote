---
import Layout from '@layouts/Layout.astro';
import Icon from '@components/ui/Icon.astro';
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    icon: 'message-circle',
    title: '智能对话',
    desc: '基于 MiniMax 2.7 模型，支持多轮对话、上下文理解'
  },
  {
    icon: 'zap',
    title: '快速响应',
    desc: '毫秒级响应速度，流畅的对话体验'
  },
  {
    icon: 'shield',
    title: '隐私安全',
    desc: '对话数据本地存储，保护您的隐私'
  },
  {
    icon: 'globe',
    title: '多语言支持',
    desc: '支持中英文及多种语言对话'
  }
];

const suggestions = [
  { icon: 'mail', text: '帮我写一封专业邮件', prompt: 'Help me write a professional email to request a meeting' },
  { icon: 'book', text: '解释复杂概念', prompt: 'Explain the concept of machine learning in simple terms' },
  { icon: 'code', text: '调试代码问题', prompt: 'Help me debug this Python code and explain what went wrong' },
  { icon: 'edit', text: '总结文档内容', prompt: 'Summarize the key points from this article or document' },
];
---

<Layout 
  title={`${t('chatbot.title', lang)} - MaxMin.dev`}
  description={t('chatbot.welcome.subtitle', lang)}
>
  <section class="chatbot">
    <div class="chatbot-container">
      <!-- Hero -->
      <div class="chatbot-hero">
        <div class="hero-badge">
          <Icon name="message-circle" size={16} />
          <span>AI Chat</span>
        </div>
        <h1 class="hero-title">MaxMin Chat</h1>
        <p class="hero-tagline">基于 MiniMax 2.7 的智能对话助手</p>
        <p class="hero-description">
          随时随地与 AI 对话，获取写作、编程、学习等方面的帮助
        </p>
      </div>

      <!-- Chat Interface -->
      <div class="chat-interface">
        <!-- Chat Window -->
        <div class="chat-window" id="chat-window">
          <!-- Welcome Message -->
          <div class="chat-welcome" id="chat-welcome">
            <div class="welcome-icon">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <rect width="48" height="48" rx="12" fill="#C06B3E"/>
                <path d="M24 8L38 36H10L24 8Z" fill="white"/>
              </svg>
            </div>
            <h3 class="welcome-title">有什么我可以帮你的？</h3>
            <p class="welcome-subtitle">选择一个话题开始对话，或直接输入你的问题</p>
            
            <div class="suggestion-grid">
              {suggestions.map((s) => (
                <button class="suggestion-btn" data-prompt={s.prompt}>
                  <Icon name={s.icon} size={18} />
                  <span>{s.text}</span>
                </button>
              ))}
            </div>
          </div>
          
          <!-- Messages Container -->
          <div class="chat-messages" id="chat-messages"></div>
        </div>

        <!-- Input Area -->
        <div class="chat-input-area">
          <div class="input-wrapper">
            <textarea 
              class="chat-input" 
              id="chat-input" 
              placeholder="输入消息..."
              rows="1"
            ></textarea>
            <button class="send-btn" id="send-btn" disabled>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </div>
          <p class="input-hint">AI 回复由 MiniMax 生成，请验证重要信息</p>
        </div>
      </div>

      <!-- Features -->
      <div class="features-section">
        <h2 class="section-title">功能特点</h2>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card">
              <div class="feature-icon">
                <Icon name={feature.icon} size={24} />
              </div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-desc">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-section">
        <h2 class="cta-title">开始对话</h2>
        <p class="cta-subtitle">AI 助手随时准备为您提供帮助</p>
        <div class="cta-actions">
          <button class="btn-primary" id="start-chat-btn">
            <Icon name="message-circle" size={18} />
            <span>开始聊天</span>
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .chatbot {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-8)) var(--space-4) var(--space-12);
    background: var(--bg-primary);
  }

  .chatbot-container {
    max-width: var(--container-xl);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  /* Hero */
  .chatbot-hero {
    text-align: center;
    padding: var(--space-8) 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary-light);
    border: 1px solid rgba(192, 107, 62, 0.2);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text-primary), var(--color-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .hero-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Chat Interface */
  .chat-interface {
    background: var(--bg-elevated);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .chat-window {
    min-height: 400px;
    max-height: 500px;
    overflow-y: auto;
    padding: var(--space-6);
  }

  /* Welcome */
  .chat-welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 350px;
    text-align: center;
  }

  .chat-welcome.hidden {
    display: none;
  }

  .welcome-icon {
    margin-bottom: var(--space-4);
  }

  .welcome-title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .welcome-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .suggestion-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    width: 100%;
    max-width: 450px;
  }

  @media (max-width: 500px) {
    .suggestion-grid {
      grid-template-columns: 1fr;
    }
  }

  .suggestion-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-align: left;
    cursor: pointer;
    min-height: 48px;
    transition: all var(--duration-fast) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  .suggestion-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  /* Messages */
  .chat-messages {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .message {
    display: flex;
    gap: var(--space-3);
    max-width: 85%;
  }

  .message.user {
    margin-left: auto;
    flex-direction: row-reverse;
  }

  .message-avatar {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
  }

  .message.assistant .message-avatar {
    background: var(--color-primary);
    color: white;
  }

  .message.user .message-avatar {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .message-content {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .message.assistant .message-content {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .message.user .message-content {
    background: var(--color-primary);
    color: white;
  }

  /* Typing Indicator */
  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: var(--space-3);
  }

  .typing-dot {
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
    animation: typing 1.4s infinite;
    opacity: 0.4;
  }

  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 60%, 100% { opacity: 0.4; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-4px); }
  }

  /* Input Area */
  .chat-input-area {
    border-top: 1px solid var(--card-border);
    padding: var(--space-4);
    background: var(--bg-elevated);
  }

  .input-wrapper {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    padding: var(--space-3);
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .input-wrapper:focus-within {
    border-color: var(--color-primary);
  }

  .chat-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-primary);
    resize: none;
    outline: none;
    min-height: 24px;
    max-height: 120px;
    line-height: 1.5;
  }

  .chat-input::placeholder {
    color: var(--text-muted);
  }

  .send-btn {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-full);
    color: white;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  .send-btn:hover:not(:disabled) {
    background: var(--color-primary-hover);
  }

  .send-btn:disabled {
    background: var(--text-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }

  .input-hint {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-align: center;
    margin-top: var(--space-2);
  }

  /* Features */
  .features-section {
    padding: var(--space-8) 0;
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }

  .feature-card {
    padding: var(--space-6);
    background: var(--bg-elevated);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    text-align: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .feature-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
    border-radius: var(--radius-lg);
    color: white;
    margin-bottom: var(--space-4);
  }

  .feature-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .feature-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding: var(--space-12);
    background: linear-gradient(135deg, var(--color-primary-light), transparent);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(192, 107, 62, 0.2);
  }

  .cta-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .cta-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background: var(--color-primary);
    color: white;
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    min-height: 48px;
    transition: all var(--duration-fast) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  /* Mobile optimizations */
  @media (max-width: 480px) {
    .chatbot {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }

    .chat-window {
      min-height: 300px;
      max-height: 400px;
      padding: var(--space-4);
    }

    .chat-welcome {
      min-height: 280px;
    }

    .welcome-icon svg {
      width: 40px;
      height: 40px;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .cta-section {
      padding: var(--space-8);
    }
  }

  /* Dark theme */
  [data-theme="dark"] .chatbot {
    background: #1A1207;
  }

  [data-theme="dark"] .hero-title {
    background: linear-gradient(135deg, #F0E9DC, #C06B3E);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  [data-theme="dark"] .hero-tagline {
    color: #C06B3E;
  }

  [data-theme="dark"] .hero-description {
    color: #A89880;
  }

  [data-theme="dark"] .chat-interface {
    background: #2C2210;
    border-color: rgba(240, 233, 220, 0.12);
  }

  [data-theme="dark"] .welcome-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .welcome-subtitle {
    color: #A89880;
  }

  [data-theme="dark"] .suggestion-btn {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(240, 233, 220, 0.12);
    color: #A89880;
  }

  [data-theme="dark"] .suggestion-btn:hover {
    background: rgba(192, 107, 62, 0.1);
    border-color: #C06B3E;
    color: #C06B3E;
  }

  [data-theme="dark"] .message.assistant .message-content {
    background: #1A1207;
    color: #F0E9DC;
  }

  [data-theme="dark"] .input-wrapper {
    background: #1A1207;
    border-color: rgba(240, 233, 220, 0.12);
  }

  [data-theme="dark"] .chat-input {
    color: #F0E9DC;
  }

  [data-theme="dark"] .chat-input::placeholder {
    color: #6A5A42;
  }

  [data-theme="dark"] .input-hint {
    color: #6A5A42;
  }

  [data-theme="dark"] .feature-card {
    background: #2C2210;
    border-color: rgba(240, 233, 220, 0.12);
  }

  [data-theme="dark"] .feature-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .feature-desc {
    color: #A89880;
  }

  [data-theme="dark"] .cta-section {
    background: linear-gradient(135deg, rgba(192, 107, 62, 0.15), transparent);
    border-color: rgba(192, 107, 62, 0.2);
  }

  [data-theme="dark"] .cta-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .cta-subtitle {
    color: #A89880;
  }
</style>

<script>
  const API_BASE = 'https://api.ustc.dev';
  
  let messages: { role: 'user' | 'assistant'; content: string }[] = [];

  const chatWindow = document.getElementById('chat-window');
  const chatWelcome = document.getElementById('chat-welcome');
  const chatMessages = document.getElementById('chat-messages');
  const chatInput = document.getElementById('chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;

  // Suggestion buttons
  document.querySelectorAll('.suggestion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const prompt = btn.getAttribute('data-prompt');
      if (prompt && chatInput) {
        chatInput.value = prompt;
        chatInput.focus();
        sendBtn.disabled = false;
      }
    });
  });

  // Start chat button
  document.getElementById('start-chat-btn')?.addEventListener('click', () => {
    chatInput?.focus();
    chatInput?.scrollIntoView({ behavior: 'smooth' });
  });

  // Input handling
  chatInput?.addEventListener('input', () => {
    sendBtn.disabled = !chatInput.value.trim();
    chatInput.style.height = 'auto';
    chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + 'px';
  });

  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) {
        sendMessage();
      }
    }
  });

  sendBtn?.addEventListener('click', sendMessage);

  async function sendMessage() {
    const content = chatInput?.value.trim();
    if (!content) return;

    // Hide welcome
    chatWelcome?.classList.add('hidden');

    // Add user message
    addMessage('user', content);
    messages.push({ role: 'user', content });

    // Clear input
    chatInput.value = '';
    chatInput.style.height = 'auto';
    sendBtn.disabled = true;

    // Add typing indicator
    const typingEl = addTypingIndicator();

    try {
      const response = await fetch(`${API_BASE}/api/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: content })
      });

      const data = await response.json();
      
      if (typingEl) typingEl.remove();
      
      if (data.success && data.reply) {
        addMessage('assistant', data.reply);
        messages.push({ role: 'assistant', content: data.reply });
      } else if (data.message) {
        addMessage('assistant', `错误: ${data.message}`);
      } else {
        addMessage('assistant', '抱歉，未能获取回复');
      }
    } catch (error) {
      if (typingEl) typingEl.remove();
      addMessage('assistant', '网络错误，请稍后重试');
    }
  }

  function addMessage(role: 'user' | 'assistant', content: string) {
    const messageEl = document.createElement('div');
    messageEl.className = `message ${role}`;
    
    messageEl.innerHTML = `
      <div class="message-avatar">
        ${role === 'assistant' 
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L20.5 18H3.5L12 3Z"/></svg>'
          : 'U'}
      </div>
      <div class="message-content">${escapeHtml(content)}</div>
    `;
    
    chatMessages?.appendChild(messageEl);
    chatWindow?.scrollTo({ top: chatWindow.scrollHeight, behavior: 'smooth' });
  }

  function addTypingIndicator(): HTMLElement | null {
    const typingEl = document.createElement('div');
    typingEl.className = 'message assistant';
    typingEl.innerHTML = `
      <div class="message-avatar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L20.5 18H3.5L12 3Z"/></svg>
      </div>
      <div class="message-content">
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>
    `;
    chatMessages?.appendChild(typingEl);
    chatWindow?.scrollTo({ top: chatWindow.scrollHeight, behavior: 'smooth' });
    return typingEl;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>
