---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';

const features = [
  {
    icon: 'zap',
    title: t('about.features.performance.title'),
    description: t('about.features.performance.desc')
  },
  {
    icon: 'shield',
    title: t('about.features.security.title'),
    description: t('about.features.security.desc')
  },
  {
    icon: 'cpu',
    title: t('about.features.intelligence.title'),
    description: t('about.features.intelligence.desc')
  },
  {
    icon: 'globe',
    title: t('about.features.global.title'),
    description: t('about.features.global.desc')
  },
];

const milestones = [
  { year: '2024', title: t('about.milestones.m1.title'), desc: t('about.milestones.m1.desc') },
  { year: '2023', title: t('about.milestones.m2.title'), desc: t('about.milestones.m2.desc') },
  { year: '2022', title: t('about.milestones.m3.title'), desc: t('about.milestones.m3.desc') },
];

const techStack = [
  { name: 'Astro', icon: '🚀' },
  { name: 'TypeScript', icon: '📘' },
  { name: 'Cloudflare', icon: '☁️' },
  { name: 'TailwindCSS', icon: '🎨' },
];

const stats = [
  { value: '10K+', label: t('about.stats.users') },
  { value: '1M+', label: t('about.stats.messages') },
  { value: '99.9%', label: t('about.stats.uptime') },
  { value: '<100ms', label: t('about.stats.latency') },
];
---

<Layout 
  title={`${t('about.title')} - LiveClaw`}
  description={t('about.subtitle')}
>
  <section class="about">
    <div class="about-container">
      <!-- Hero -->
      <div class="about-hero">
        <span class="about-badge">{t('about.badge')}</span>
        <h1 class="about-title">{t('about.title')}</h1>
        <p class="about-subtitle">{t('about.subtitle')}</p>
      </div>
      
      <!-- Story -->
      <div class="about-story">
        <div class="story-content">
          <h2 class="section-title">{t('about.story.title')}</h2>
          <p class="story-text">{t('about.story.p1')}</p>
          <p class="story-text">{t('about.story.p2')}</p>
        </div>
      </div>
      
      <!-- Stats -->
      <div class="stats-grid">
        {stats.map(stat => (
          <div class="stat-card">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
      
      <!-- Features -->
      <div class="features-section">
        <h2 class="section-title">{t('about.features.title')}</h2>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card hover-lift">
              <div class="feature-icon">
                {feature.icon === 'zap' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                  </svg>
                )}
                {feature.icon === 'shield' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                )}
                {feature.icon === 'cpu' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="4" y="4" width="16" height="16" rx="2" ry="2"/>
                    <rect x="9" y="9" width="6" height="6"/>
                    <line x1="9" y1="1" x2="9" y2="4"/>
                    <line x1="15" y1="1" x2="15" y2="4"/>
                    <line x1="9" y1="20" x2="9" y2="23"/>
                    <line x1="15" y1="20" x2="15" y2="23"/>
                    <line x1="20" y1="9" x2="23" y2="9"/>
                    <line x1="20" y1="14" x2="23" y2="14"/>
                    <line x1="1" y1="9" x2="4" y2="9"/>
                    <line x1="1" y1="14" x2="4" y2="14"/>
                  </svg>
                )}
                {feature.icon === 'globe' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                )}
              </div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-description">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Milestones -->
      <div class="milestones-section">
        <h2 class="section-title">{t('about.milestones.title')}</h2>
        <div class="milestones-timeline">
          {milestones.map((milestone, index) => (
            <div class="milestone-item">
              <div class="milestone-marker">
                <span class="milestone-year">{milestone.year}</span>
                <div class="milestone-dot"></div>
                {index < milestones.length - 1 && <div class="milestone-line"></div>}
              </div>
              <div class="milestone-content">
                <h3 class="milestone-title">{milestone.title}</h3>
                <p class="milestone-desc">{milestone.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Tech Stack -->
      <div class="tech-section">
        <h2 class="section-title">{t('about.tech.title')}</h2>
        <div class="tech-grid">
          {techStack.map(tech => (
            <div class="tech-card">
              <span class="tech-icon">{tech.icon}</span>
              <span class="tech-name">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- CTA -->
      <div class="cta-section">
        <h2 class="cta-title">{t('about.cta.title')}</h2>
        <p class="cta-desc">{t('about.cta.desc')}</p>
        <div class="cta-actions">
          <a href="/chatbot" class="cta-primary">{t('about.cta.primary')}</a>
          <a href="https://github.com/maxwell-xyz" target="_blank" rel="noopener" class="cta-secondary">{t('about.cta.secondary')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-4)) var(--space-4) var(--space-12);
  }
  
  .about-container {
    max-width: var(--container-lg);
    margin: 0 auto;
  }
  
  /* Hero */
  .about-hero {
    text-align: center;
    margin-bottom: var(--space-16);
  }
  
  .about-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: linear-gradient(135deg, var(--color-primary-alpha-20), var(--color-accent-alpha-20));
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }
  
  .about-title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }
  
  @media (min-width: 768px) {
    .about-title {
      font-size: var(--text-5xl);
    }
  }
  
  .about-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Story */
  .about-story {
    max-width: 700px;
    margin: 0 auto var(--space-16);
    text-align: center;
  }
  
  .story-text {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }
  
  .story-text:last-child {
    margin-bottom: 0;
  }
  
  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-16);
  }
  
  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .stat-card {
    text-align: center;
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
  }
  
  .stat-value {
    display: block;
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    background: linear-gradient(135deg, var(--color-accent-blue), var(--color-accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-1);
  }
  
  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Section Title */
  .section-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-8);
    text-align: center;
  }
  
  /* Features */
  .features-section {
    margin-bottom: var(--space-16);
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .feature-card {
    text-align: center;
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--card-shadow);
    transition: all var(--duration-normal) var(--ease-default);
  }
  
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-hover-shadow);
    border-color: var(--border-hover);
  }
  
  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin: 0 auto var(--space-4);
    background: linear-gradient(135deg, var(--color-accent-blue), var(--color-accent-purple));
    border-radius: var(--radius-lg);
    color: white;
  }
  
  .feature-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }
  
  .feature-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  
  /* Milestones */
  .milestones-section {
    margin-bottom: var(--space-16);
  }
  
  .milestones-timeline {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .milestone-item {
    display: flex;
    gap: var(--space-4);
  }
  
  .milestone-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  
  .milestone-year {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }
  
  .milestone-dot {
    width: 12px;
    height: 12px;
    background: var(--color-primary);
    border-radius: 50%;
  }
  
  .milestone-line {
    width: 2px;
    flex: 1;
    background: var(--border-primary);
    margin-top: var(--space-2);
  }
  
  .milestone-content {
    flex: 1;
    padding-bottom: var(--space-6);
  }
  
  .milestone-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }
  
  .milestone-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  
  /* Tech Stack */
  .tech-section {
    margin-bottom: var(--space-16);
  }
  
  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }
  
  .tech-card {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .tech-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }
  
  .tech-icon {
    font-size: var(--text-lg);
  }
  
  .tech-name {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }
  
  /* CTA */
  .cta-section {
    text-align: center;
    padding: var(--space-12);
    background: linear-gradient(135deg, var(--color-primary-alpha-10), var(--color-accent-alpha-10));
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-2xl);
  }
  
  .cta-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }
  
  .cta-desc {
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin-bottom: var(--space-6);
  }
  
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  
  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    background: linear-gradient(135deg, var(--color-accent-blue), var(--color-accent-purple));
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: white;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 212, 255, 0.3);
  }
  
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .cta-secondary:hover {
    background: var(--bg-elevated);
    border-color: var(--border-hover);
  }
</style>
