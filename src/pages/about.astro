---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';

const features = [
  {
    icon: 'zap',
    title: t('about.features.performance.title'),
    description: t('about.features.performance.desc'),
    color: '#D97757'
  },
  {
    icon: 'shield',
    title: t('about.features.security.title'),
    description: t('about.features.security.desc'),
    color: '#5B7E6A'
  },
  {
    icon: 'cpu',
    title: t('about.features.intelligence.title'),
    description: t('about.features.intelligence.desc'),
    color: '#4A5E8A'
  },
  {
    icon: 'globe',
    title: t('about.features.global.title'),
    description: t('about.features.global.desc'),
    color: '#7B5EAA'
  },
];

const milestones = [
  { year: '2024', title: t('about.milestones.m1.title'), desc: t('about.milestones.m1.desc') },
  { year: '2023', title: t('about.milestones.m2.title'), desc: t('about.milestones.m2.desc') },
  { year: '2022', title: t('about.milestones.m3.title'), desc: t('about.milestones.m3.desc') },
];

const techStack = [
  { name: 'Astro', icon: 'rocket' },
  { name: 'TypeScript', icon: 'code' },
  { name: 'Cloudflare', icon: 'cloud' },
  { name: 'TailwindCSS', icon: 'palette' },
];

const stats = [
  { value: '10K+', label: t('about.stats.users') },
  { value: '1M+', label: t('about.stats.messages') },
  { value: '99.9%', label: t('about.stats.uptime') },
  { value: '<100ms', label: t('about.stats.latency') },
];

const iconPaths: Record<string, string> = {
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  cpu: `<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
  globe: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  rocket: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  code: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  cloud: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
  palette: `<circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c0.926 0 1.648-0.746 1.648-1.688 0-0.437-0.18-0.835-0.437-1.125-0.29-0.289-0.438-0.652-0.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"/>`
};
---

<Layout 
  title={`${t('about.title')} - Maxwell.Science`}
  description={t('about.subtitle')}
>
  <section class="about">
    <div class="about-container">
      <!-- Hero -->
      <div class="about-hero">
        <div class="hero-label">
          <span class="label-dot"></span>
          <span class="label-text">{t('about.badge')}</span>
        </div>
        <h1 class="about-title">{t('about.title')}</h1>
        <p class="about-subtitle">{t('about.subtitle')}</p>
      </div>
      
      <!-- Story -->
      <div class="about-story">
        <div class="story-content">
          <h2 class="section-title">{t('about.story.title')}</h2>
          <p class="story-text">{t('about.story.p1')}</p>
          <p class="story-text">{t('about.story.p2')}</p>
        </div>
      </div>
      
      <!-- Stats -->
      <div class="stats-grid">
        {stats.map(stat => (
          <div class="stat-card">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
      
      <!-- Features -->
      <div class="features-section">
        <h2 class="section-title">{t('about.features.title')}</h2>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card">
              <div class="feature-icon" style={`background: ${feature.color}18; color: ${feature.color};`}>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={iconPaths[feature.icon]} />
                </svg>
              </div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-description">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Milestones -->
      <div class="milestones-section">
        <h2 class="section-title">{t('about.milestones.title')}</h2>
        <div class="milestones-timeline">
          {milestones.map((milestone, index) => (
            <div class="milestone-item">
              <div class="milestone-marker">
                <span class="milestone-year">{milestone.year}</span>
                <div class="milestone-dot"></div>
                {index < milestones.length - 1 && <div class="milestone-line"></div>}
              </div>
              <div class="milestone-content">
                <h3 class="milestone-title">{milestone.title}</h3>
                <p class="milestone-desc">{milestone.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Tech Stack -->
      <div class="tech-section">
        <h2 class="section-title">{t('about.tech.title')}</h2>
        <div class="tech-grid">
          {techStack.map(tech => (
            <div class="tech-card">
              <div class="tech-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={iconPaths[tech.icon]} />
                </svg>
              </div>
              <span class="tech-name">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
      
      <!-- CTA -->
      <div class="cta-section">
        <h2 class="cta-title">{t('about.cta.title')}</h2>
        <p class="cta-desc">{t('about.cta.desc')}</p>
        <div class="cta-actions">
          <a href="/chatbot" class="cta-primary">{t('about.cta.primary')}</a>
          <a href="https://github.com/maxwell-xyz" target="_blank" rel="noopener" class="cta-secondary">{t('about.cta.secondary')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-4)) var(--space-4) var(--space-12);
    background: var(--bg-primary);
  }
  
  .about-container {
    max-width: var(--container-lg);
    margin: 0 auto;
  }
  
  .about-hero {
    text-align: left;
    margin-bottom: var(--space-16);
    padding-top: var(--space-8);
    max-width: 42rem;
  }
  
  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  
  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  
  .label-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  
  .about-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: var(--font-medium);
    line-height: 0.98;
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }
  
  .about-subtitle {
    font-family: var(--font-sans);
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0;
    line-height: 1.7;
  }
  
  .about-story {
    max-width: 700px;
    margin: 0 0 var(--space-16);
    text-align: left;
  }
  
  .story-text {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }
  
  .story-text:last-child {
    margin-bottom: 0;
  }
  
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-16);
  }
  
  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .stat-card {
    text-align: center;
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--card-shadow);
  }
  
  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-normal);
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }
  
  .stat-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    margin-bottom: var(--space-8);
    text-align: center;
    letter-spacing: -0.01em;
  }
  
  .features-section {
    margin-bottom: var(--space-16);
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  
  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .feature-card {
    text-align: center;
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-2xl);
    transition: all var(--duration-normal) var(--ease-default);
    cursor: pointer;
  }
  
  .feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--card-border-hover);
    box-shadow: var(--card-shadow-hover);
  }
  
  .feature-card:hover .feature-title {
    color: var(--color-primary);
  }
  
  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin: 0 auto var(--space-4);
    border-radius: var(--radius-lg);
    transition: transform var(--duration-normal) var(--ease-default);
  }
  
  .feature-card:hover .feature-icon {
    transform: scale(1.05);
  }
  
  .feature-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    transition: color var(--duration-normal) var(--ease-default);
  }
  
  .feature-description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.65;
  }
  
  .milestones-section {
    margin-bottom: var(--space-16);
  }
  
  .milestones-timeline {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .milestone-item {
    display: flex;
    gap: var(--space-4);
  }
  
  .milestone-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  
  .milestone-year {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }
  
  .milestone-dot {
    width: 12px;
    height: 12px;
    background: var(--color-primary);
    border-radius: 50%;
  }
  
  .milestone-line {
    width: 2px;
    flex: 1;
    background: var(--border-primary);
    margin-top: var(--space-2);
  }
  
  .milestone-content {
    flex: 1;
    padding-bottom: var(--space-6);
  }
  
  .milestone-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }
  
  .milestone-desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  
  .tech-section {
    margin-bottom: var(--space-16);
  }
  
  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }
  
  .tech-card {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    transition: all var(--duration-fast) var(--ease-default);
    cursor: pointer;
  }
  
  .tech-card:hover {
    border-color: var(--card-border-hover);
    transform: translateY(-2px);
  }
  
  .tech-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--text-primary);
    border-radius: 6px;
    color: var(--text-inverse);
  }
  
  .tech-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: var(--text-primary);
  }
  
  .cta-section {
    text-align: center;
    padding: var(--space-12);
    background: var(--bg-elevated);
    border-radius: var(--radius-2xl);
    box-shadow: var(--card-shadow);
  }
  
  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }
  
  .cta-desc {
    font-family: var(--font-sans);
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin-bottom: var(--space-6);
    line-height: 1.65;
  }
  
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  
  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    background: var(--btn-primary-bg);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: var(--btn-primary-text);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .cta-primary:hover {
    background: var(--btn-primary-hover);
    transform: translateY(-2px);
  }
  
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    background: var(--btn-secondary-bg);
    border: 1px solid var(--btn-secondary-border);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: var(--btn-secondary-text);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .cta-secondary:hover {
    background: var(--btn-secondary-hover-bg);
    border-color: var(--border-hover);
  }

  .cta-primary,
  .cta-secondary {
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }
</style>
