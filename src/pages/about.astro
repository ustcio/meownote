---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';
import LottieAnimation from '@components/ui/LottieAnimation.astro';

const values = [
  {
    icon: 'zap',
    title: t('about.values.performance.title'),
    description: t('about.values.performance.desc'),
    color: '#D97757'
  },
  {
    icon: 'shield',
    title: t('about.values.security.title'),
    description: t('about.values.security.desc'),
    color: '#5B7E6A'
  },
  {
    icon: 'brain',
    title: t('about.values.intelligence.title'),
    description: t('about.values.intelligence.desc'),
    color: '#4A5E8A'
  },
  {
    icon: 'globe',
    title: t('about.values.global.title'),
    description: t('about.values.global.desc'),
    color: '#7B5EAA'
  },
];

const milestones = [
  { year: '2024', title: t('about.milestones.m1.title'), desc: t('about.milestones.m1.desc') },
  { year: '2023', title: t('about.milestones.m2.title'), desc: t('about.milestones.m2.desc') },
  { year: '2022', title: t('about.milestones.m3.title'), desc: t('about.milestones.m3.desc') },
];

const techStack = [
  { name: 'Astro', icon: 'rocket' },
  { name: 'TypeScript', icon: 'code' },
  { name: 'Cloudflare', icon: 'cloud' },
  { name: 'TailwindCSS', icon: 'palette' },
];

const stats = [
  { value: '10K+', label: t('about.stats.users') },
  { value: '1M+', label: t('about.stats.messages') },
  { value: '99.9%', label: t('about.stats.uptime') },
  { value: '<100ms', label: t('about.stats.latency') },
];

const iconPaths: Record<string, string> = {
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  brain: `<path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/><path d="M10 17v4"/><path d="M14 17v4"/>`,
  globe: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  rocket: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  code: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  cloud: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
  palette: `<circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c0.926 0 1.648-0.746 1.648-1.688 0-0.437-0.18-0.835-0.437-1.125-0.29-0.289-0.438-0.652-0.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"/>`
};
---

<Layout 
  title={`${t('about.title')} - Maxwell.Science`}
  description={t('about.subtitle')}
>
  <section class="about-page">
    <div class="about-container">
      
      <!-- Hero Section with Lottie Animation -->
      <div class="about-hero">
        <div class="hero-layout">
          <div class="hero-content">
            <div class="hero-kicker">
              <span class="kicker-dot"></span>
              <span class="kicker-text">{t('about.badge')}</span>
            </div>
            <h1 class="hero-title">{t('about.title')}</h1>
            <p class="hero-subtitle">{t('about.subtitle')}</p>
            <div class="hero-actions">
              <a href="/chatbot/" class="hero-btn-primary">
                <span>{t('about.cta.primary')}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="/kit/" class="hero-btn-secondary">{t('about.cta.secondary')}</a>
            </div>
          </div>
          
          <div class="hero-visual">
            <div class="hero-animation-frame">
              <div class="hero-animation-glow"></div>
              <LottieAnimation 
                src="/animations/lottie/Solutions-Agents-animation.json"
                loop={true}
                autoplay={true}
                speed={0.8}
                framesIn="0,108"
                framesLoop="109,168"
                scrollDriven={true}
                className="hero-lottie"
              />
              <div class="hero-animation-border"></div>
            </div>
            <div class="hero-float-card hero-float-card--stats">
              <span class="float-card-label">Active Users</span>
              <span class="float-card-value">10K+</span>
            </div>
            <div class="hero-float-card hero-float-card--uptime">
              <span class="float-card-dot"></span>
              <span class="float-card-text">99.9% uptime</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats Bar -->
      <div class="stats-bar">
        {stats.map((stat, i) => (
          <div class="stat-item" data-index={i}>
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>

      <!-- Mission Section -->
      <div class="mission-section">
        <div class="mission-grid">
          <div class="mission-heading">
            <h2 class="section-heading">{t('about.story.title')}</h2>
          </div>
          <div class="mission-content">
            <p class="mission-text">{t('about.story.p1')}</p>
            <p class="mission-text">{t('about.story.p2')}</p>
            <p class="mission-text mission-highlight">{t('about.story.p3')}</p>
          </div>
        </div>
      </div>

      <!-- Values Section -->
      <div class="values-section">
        <h2 class="section-heading centered">{t('about.values.title')}</h2>
        <div class="values-grid">
          {values.map((value) => (
            <div class="value-card">
              <div class="value-icon" style={`background: ${value.color}15; color: ${value.color};`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={iconPaths[value.icon]} />
                </svg>
              </div>
              <h3 class="value-title">{value.title}</h3>
              <p class="value-desc">{value.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Milestones Section -->
      <div class="milestones-section">
        <div class="milestones-layout">
          <div class="milestones-heading">
            <h2 class="section-heading">{t('about.milestones.title')}</h2>
          </div>
          <div class="milestones-timeline">
            {milestones.map((milestone, index) => (
              <div class="milestone-item">
                <div class="milestone-track">
                  <span class="milestone-year">{milestone.year}</span>
                  <div class="milestone-dot"></div>
                  {index < milestones.length - 1 && <div class="milestone-line"></div>}
                </div>
                <div class="milestone-body">
                  <h3 class="milestone-title">{milestone.title}</h3>
                  <p class="milestone-desc">{milestone.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Tech Stack Section -->
      <div class="tech-section">
        <div class="tech-layout">
          <div class="tech-heading">
            <h2 class="section-heading">{t('about.tech.title')}</h2>
            <p class="tech-subtitle">{t('about.tech.desc')}</p>
          </div>
          <div class="tech-grid">
            {techStack.map(tech => (
              <div class="tech-chip">
                <div class="tech-chip-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <Fragment set:html={iconPaths[tech.icon]} />
                  </svg>
                </div>
                <span class="tech-chip-name">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- CTA Section -->
      <div class="cta-section">
        <div class="cta-content">
          <h2 class="cta-heading">{t('about.cta.title')}</h2>
          <p class="cta-desc">{t('about.cta.desc')}</p>
          <div class="cta-buttons">
            <a href="/chatbot/" class="cta-btn-primary">
              <span>{t('about.cta.primary')}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a href="/kit/" class="cta-btn-secondary">{t('about.cta.secondary')}</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* ===== Page Layout ===== */
  .about-page {
    min-height: 100vh;
    padding: calc(var(--header-total-height, 72px) + var(--space-8)) var(--space-4) var(--space-16);
    background: var(--bg-primary);
  }

  .about-container {
    max-width: var(--container-lg);
    margin: 0 auto;
  }

  /* ===== Hero Section ===== */
  .about-hero {
    margin-bottom: var(--space-12);
    padding-top: var(--space-4);
  }

  .hero-layout {
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero-layout {
      grid-template-columns: 1fr 1.1fr;
      gap: var(--space-12);
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .kicker-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }

  .kicker-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: var(--font-semibold);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: var(--font-medium);
    line-height: 1.0;
    letter-spacing: 0;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.1s both;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--text-secondary);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 560px;
    margin: 0 0 var(--space-6);
    line-height: 1.65;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.2s both;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.3s both;
  }

  .hero-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--btn-primary-bg);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--btn-primary-text);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
    cursor: pointer;
  }

  .hero-btn-primary:hover {
    background: var(--btn-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--btn-primary-shadow);
  }

  .hero-btn-primary svg {
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .hero-btn-primary:hover svg {
    transform: translateX(3px);
  }

  .hero-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
    cursor: pointer;
  }

  .hero-btn-secondary:hover {
    color: var(--text-primary);
  }

  /* ===== Hero Visual / Animation ===== */
  .hero-visual {
    position: relative;
    display: none;
  }

  @media (min-width: 900px) {
    .hero-visual {
      display: block;
      opacity: 0;
      animation: heroVisualIn 0.8s var(--ease-out) 0.3s both;
    }
  }

  @keyframes heroVisualIn {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hero-animation-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
  }

  .hero-animation-glow {
    position: absolute;
    inset: -40%;
    background: radial-gradient(ellipse at center, var(--color-primary-alpha-10) 0%, transparent 70%);
    animation: glowPulse 4s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.05); }
  }

  .hero-lottie {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  .hero-lottie :global(svg) {
    width: 100%;
    height: 100%;
  }

  .hero-animation-border {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-2xl);
    box-shadow: 
      0 0 0 1px var(--card-border),
      0 20px 60px -15px rgba(0, 0, 0, 0.15);
    pointer-events: none;
    z-index: 2;
  }

  [data-theme="dark"] .hero-animation-border {
    box-shadow: 
      0 0 0 1px var(--card-border),
      0 20px 60px -15px rgba(0, 0, 0, 0.5);
  }

  .hero-float-card {
    position: absolute;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(12px);
    z-index: 3;
  }

  [data-theme="dark"] .hero-float-card {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .hero-float-card--stats {
    top: -16px;
    right: -12px;
    animation: floatCard1 6s ease-in-out infinite;
  }

  .hero-float-card--uptime {
    bottom: 24px;
    left: -20px;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    animation: floatCard2 7s ease-in-out infinite;
    animation-delay: 1s;
  }

  @keyframes floatCard1 {
    0%, 100% { transform: translateY(0) rotate(2deg); }
    50% { transform: translateY(-8px) rotate(-1deg); }
  }

  @keyframes floatCard2 {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-6px) rotate(1deg); }
  }

  .float-card-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: var(--font-semibold);
    margin-bottom: 2px;
  }

  .float-card-value {
    font-family: var(--font-number);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums lining-nums;
  }

  .float-card-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #28c840;
    box-shadow: 0 0 0 3px rgba(40, 200, 64, 0.2);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .float-card-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }

  /* ===== Stats Bar ===== */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-12);
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
  }

  @media (min-width: 768px) {
    .stats-bar {
      grid-template-columns: repeat(4, 1fr);
      padding: var(--space-8);
    }
  }

  .stat-item {
    text-align: center;
    padding: var(--space-3);
    opacity: 0;
    animation: fade-in-up 0.5s ease forwards;
  }

  .stat-item:nth-child(1) { animation-delay: 0.1s; }
  .stat-item:nth-child(2) { animation-delay: 0.2s; }
  .stat-item:nth-child(3) { animation-delay: 0.3s; }
  .stat-item:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .stat-value {
    display: block;
    font-family: var(--font-number);
    font-size: clamp(2rem, 3.6vw, 2.8rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.35rem;
    letter-spacing: -0.04em;
    line-height: 0.92;
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    line-height: 1.5;
  }

  /* ===== Section Headings ===== */
  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
  }

  .section-heading.centered {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  /* ===== Mission Section ===== */
  .mission-section {
    margin-bottom: var(--space-12);
    padding: var(--space-8) 0;
    border-top: 1px solid var(--border-secondary);
    border-bottom: 1px solid var(--border-secondary);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .mission-grid {
      grid-template-columns: 280px 1fr;
      gap: var(--space-10);
    }
  }

  .mission-heading {
    position: sticky;
    top: calc(var(--header-total-height, 72px) + var(--space-4));
    align-self: start;
  }

  .mission-text {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .mission-text:last-child {
    margin-bottom: 0;
  }

  .mission-highlight {
    color: var(--text-primary);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    line-height: 1.6;
    padding-left: var(--space-4);
    border-left: 3px solid var(--color-primary);
  }

  /* ===== Values Section ===== */
  .values-section {
    margin-bottom: var(--space-12);
    padding: var(--space-8) 0;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    transition: all var(--duration-normal) var(--ease-default);
    cursor: default;
  }

  .value-card:hover {
    border-color: var(--card-border-hover);
    transform: translateY(-3px);
    box-shadow: var(--card-shadow-hover);
  }

  .value-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .value-card:hover .value-icon {
    transform: scale(1.08);
  }

  .value-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .value-desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ===== Milestones Section ===== */
