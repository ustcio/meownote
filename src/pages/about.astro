---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';
import LottieAnimation from '@components/ui/LottieAnimation.astro';

const values = [
  {
    icon: 'zap',
    title: t('about.values.performance.title'),
    description: t('about.values.performance.desc'),
    color: '#D97757'
  },
  {
    icon: 'shield',
    title: t('about.values.security.title'),
    description: t('about.values.security.desc'),
    color: '#5B7E6A'
  },
  {
    icon: 'brain',
    title: t('about.values.intelligence.title'),
    description: t('about.values.intelligence.desc'),
    color: '#4A5E8A'
  },
  {
    icon: 'globe',
    title: t('about.values.global.title'),
    description: t('about.values.global.desc'),
    color: '#7B5EAA'
  },
];

const milestones = [
  { year: '2024', title: t('about.milestones.m1.title'), desc: t('about.milestones.m1.desc') },
  { year: '2023', title: t('about.milestones.m2.title'), desc: t('about.milestones.m2.desc') },
  { year: '2022', title: t('about.milestones.m3.title'), desc: t('about.milestones.m3.desc') },
];

const techStack = [
  { name: 'Astro', icon: 'rocket' },
  { name: 'TypeScript', icon: 'code' },
  { name: 'Cloudflare', icon: 'cloud' },
  { name: 'TailwindCSS', icon: 'palette' },
];

const stats = [
  { value: '10K+', label: t('about.stats.users') },
  { value: '1M+', label: t('about.stats.messages') },
  { value: '99.9%', label: t('about.stats.uptime') },
  { value: '<100ms', label: t('about.stats.latency') },
];

const iconPaths: Record<string, string> = {
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  brain: `<path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z"/><path d="M9 21h6"/><path d="M10 17v4"/><path d="M14 17v4"/>`,
  globe: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  rocket: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  code: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  cloud: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
  palette: `<circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c0.926 0 1.648-0.746 1.648-1.688 0-0.437-0.18-0.835-0.437-1.125-0.29-0.289-0.438-0.652-0.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"/>`
};
---

<Layout 
  title={`${t('about.title')} - MoonSun.ai`}
  description={t('about.subtitle')}
>
  <main class="about-page" role="main">
    
    <!-- ===== Hero Section ===== -->
    <section class="hero-section" aria-labelledby="hero-heading">
      <div class="hero-bg-texture" aria-hidden="true"></div>
      <div class="hero-gradient-orb hero-gradient-orb--1" aria-hidden="true"></div>
      <div class="hero-gradient-orb hero-gradient-orb--2" aria-hidden="true"></div>
      
      <div class="hero-container">
        <div class="hero-layout">
          <div class="hero-content">
            <div class="hero-kicker" data-animate="fade-up" data-delay="0">
              <span class="kicker-line" aria-hidden="true"></span>
              <span class="kicker-text">{t('about.badge')}</span>
            </div>
            
            <h1 id="hero-heading" class="hero-title" data-animate="fade-up" data-delay="100">
              {t('about.title')}
            </h1>
            
            <p class="hero-subtitle" data-animate="fade-up" data-delay="200">
              {t('about.subtitle')}
            </p>
            
            <div class="hero-actions" data-animate="fade-up" data-delay="300">
              <a href="/chatbot/" class="btn btn--primary" aria-label={t('about.cta.primary')}>
                <span>{t('about.cta.primary')}</span>
                <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
              <a href="/kit/" class="btn btn--ghost">{t('about.cta.secondary')}</a>
            </div>
          </div>
          
          <div class="hero-visual" data-animate="scale-in" data-delay="400">
            <div class="hero-lottie-wrapper">
              <LottieAnimation 
                src="/animations/lottie/Solutions-Agents-animation.json"
                loop={true}
                autoplay={true}
                speed={0.8}
                framesIn="0,108"
                framesLoop="109,168"
                scrollDriven={true}
                className="hero-lottie"
              />
            </div>
            
            <div class="floating-card floating-card--users" data-animate="float" data-delay="600">
              <div class="floating-card-inner">
                <span class="floating-card-label">Active Users</span>
                <span class="floating-card-value">10K+</span>
              </div>
            </div>
            
            <div class="floating-card floating-card--status" data-animate="float" data-delay="800">
              <div class="floating-card-inner">
                <span class="status-dot" aria-hidden="true"></span>
                <span class="floating-card-text">99.9% uptime</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Stats Bar ===== -->
    <section class="stats-section" aria-label="Key metrics">
      <div class="stats-container">
        <div class="stats-grid">
          {stats.map((stat, i) => (
            <article class="stat-card" data-animate="fade-up" data-delay={i * 100} data-index={i}>
              <span class="stat-value" aria-label={stat.label}>{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
              <div class="stat-accent" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== Mission / Story Section ===== -->
    <section class="mission-section" aria-labelledby="mission-heading">
      <div class="mission-container">
        <div class="mission-layout">
          <div class="mission-sticky" data-animate="fade-right">
            <span class="section-number" aria-hidden="true">01</span>
            <h2 id="mission-heading" class="section-heading">{t('about.story.title')}</h2>
          </div>
          
          <div class="mission-content" data-animate="fade-left" data-delay="200">
            <p class="mission-text">{t('about.story.p1')}</p>
            <p class="mission-text">{t('about.story.p2')}</p>
            <blockquote class="mission-highlight">
              <span class="highlight-quote" aria-hidden="true">"</span>
              <p>{t('about.story.p3')}</p>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Values Section ===== -->
    <section class="values-section" aria-labelledby="values-heading">
      <div class="values-container">
        <header class="values-header" data-animate="fade-up">
          <span class="section-number" aria-hidden="true">02</span>
          <h2 id="values-heading" class="section-heading section-heading--centered">{t('about.values.title')}</h2>
        </header>
        
        <div class="values-grid">
          {values.map((value, i) => (
            <article class="value-card" data-animate="fade-up" data-delay={i * 120} style={`--card-accent: ${value.color}`}>
              <div class="value-card-glow" aria-hidden="true"></div>
              <div class="value-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <Fragment set:html={iconPaths[value.icon]} />
                </svg>
              </div>
              <h3 class="value-title">{value.title}</h3>
              <p class="value-desc">{value.description}</p>
              <div class="value-card-line" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== Milestones Section ===== -->
    <section class="milestones-section" aria-labelledby="milestones-heading">
      <div class="milestones-container">
        <header class="milestones-header" data-animate="fade-up">
          <span class="section-number" aria-hidden="true">03</span>
          <h2 id="milestones-heading" class="section-heading">{t('about.milestones.title')}</h2>
        </header>
        
        <div class="timeline" role="list" aria-label="Project timeline">
          {milestones.map((milestone, index) => (
            <article class="timeline-item" data-animate="fade-up" data-delay={index * 150} role="listitem">
              <div class="timeline-marker">
                <span class="timeline-year">{milestone.year}</span>
                <div class="timeline-dot" aria-hidden="true"></div>
                {index < milestones.length - 1 && <div class="timeline-connector" aria-hidden="true"></div>}
              </div>
              <div class="timeline-content">
                <h3 class="timeline-title">{milestone.title}</h3>
                <p class="timeline-desc">{milestone.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== Tech Stack Section ===== -->
    <section class="tech-section" aria-labelledby="tech-heading">
      <div class="tech-container">
        <header class="tech-header" data-animate="fade-up">
          <span class="section-number" aria-hidden="true">04</span>
          <h2 id="tech-heading" class="section-heading section-heading--centered">{t('about.tech.title')}</h2>
          <p class="tech-subtitle">{t('about.tech.desc')}</p>
        </header>
        
        <div class="tech-orbit" data-animate="scale-in" data-delay="200" aria-label="Technology stack">
          {techStack.map((tech, i) => (
            <div class="tech-node" data-animate="fade-up" data-delay={300 + i * 100}>
              <div class="tech-node-ring" aria-hidden="true"></div>
              <div class="tech-node-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <Fragment set:html={iconPaths[tech.icon]} />
                </svg>
              </div>
              <span class="tech-node-name">{tech.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CTA Section ===== -->
    <section class="cta-section" aria-labelledby="cta-heading">
      <div class="cta-bg-pattern" aria-hidden="true"></div>
      <div class="cta-container">
        <div class="cta-content" data-animate="fade-up">
          <span class="section-number section-number--light" aria-hidden="true">05</span>
          <h2 id="cta-heading" class="cta-heading">{t('about.cta.title')}</h2>
          <p class="cta-desc">{t('about.cta.desc')}</p>
          <div class="cta-actions">
            <a href="/chatbot/" class="btn btn--primary btn--large" aria-label={t('about.cta.primary')}>
              <span>{t('about.cta.primary')}</span>
              <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a href="/kit/" class="btn btn--outline btn--large">{t('about.cta.secondary')}</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ========================================
     BASE & RESET
     ======================================== */
  .about-page {
    min-height: 100vh;
    padding-top: calc(var(--header-total-height, 72px) + var(--space-8));
    padding-bottom: var(--space-16);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    background: var(--bg-primary);
    overflow-x: hidden;
  }

  /* ========================================
     ANIMATIONS
     ======================================== */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeRight {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes floatGentle {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(1deg); }
  }

  @keyframes floatGentle2 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-8px) rotate(-1deg); }
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 15px) scale(0.95); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-25px, 25px) scale(1.03); }
    66% { transform: translate(15px, -10px) scale(0.97); }
  }

  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.08); }
  }

  @keyframes lineExpand {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .about-page [data-animate] {
    opacity: 0;
  }

  .about-page [data-animate].is-visible {
    animation-fill-mode: forwards;
  }

  .about-page [data-animate="fade-up"].is-visible {
    animation: fadeUp 0.7s var(--ease-out) both;
    animation-delay: var(--anim-delay, 0s);
  }

  .about-page [data-animate="fade-right"].is-visible {
    animation: fadeRight 0.7s var(--ease-out) both;
    animation-delay: var(--anim-delay, 0s);
  }

  .about-page [data-animate="fade-left"].is-visible {
    animation: fadeRight 0.7s var(--ease-out) both;
    animation-delay: var(--anim-delay, 0s);
    animation-direction: reverse;
  }

  .about-page [data-animate="scale-in"].is-visible {
    animation: scaleIn 0.8s var(--ease-out) both;
    animation-delay: var(--anim-delay, 0s);
  }

  .about-page [data-animate="float"].is-visible {
    animation: floatGentle 6s ease-in-out infinite;
    animation-delay: var(--anim-delay, 0s);
  }

  /* ========================================
     SHARED COMPONENTS
     ======================================== */
  .section-number {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
    opacity: 0.8;
  }

  .section-number--light {
    color: rgba(255, 255, 255, 0.6);
  }

  .section-heading {
    font-family: var(--font-editorial);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.025em;
    line-height: 1.15;
  }

  .section-heading--centered {
    text-align: center;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-default);
    min-height: 48px;
    padding: var(--space-3) var(--space-6);
    -webkit-tap-highlight-color: transparent;
    position: relative;
    overflow: hidden;
  }

  .btn--primary {
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    box-shadow: 0 2px 8px rgba(23, 20, 18, 0.12);
  }

  .btn--primary:hover {
    background: var(--btn-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--btn-primary-shadow);
  }

  .btn--primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn--ghost {
    background: transparent;
    color: var(--text-secondary);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }

  .btn--ghost:hover {
    color: var(--text-primary);
  }

  .btn--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    border: 1.5px solid rgba(255, 255, 255, 0.25);
  }

  .btn--outline:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .btn--large {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
  }

  .btn-arrow {
    transition: transform var(--duration-fast) var(--ease-default);
  }

  /* ========================================
     HERO SECTION
     ======================================== */
  .hero-section {
    position: relative;
    margin-bottom: var(--space-16);
    padding-top: var(--space-4);
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .hero-bg-texture {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 1px 1px, var(--border-secondary) 1px, transparent 0);
    background-size: 32px 32px;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
    pointer-events: none;
  }

  .hero-gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    opacity: 0.5;
  }

  .hero-gradient-orb--1 {
    width: 500px;
    height: 500px;
    top: -10%;
    right: -5%;
    background: radial-gradient(circle, var(--color-primary-alpha-20) 0%, transparent 70%);
    animation: orbFloat1 12s ease-in-out infinite;
  }

  .hero-gradient-orb--2 {
    width: 400px;
    height: 400px;
    bottom: -15%;
    left: -10%;
    background: radial-gradient(circle, rgba(176, 196, 183, 0.15) 0%, transparent 70%);
    animation: orbFloat2 15s ease-in-out infinite;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    max-width: var(--container-lg);
    margin: 0 auto;
    width: 100%;
  }

  .hero-layout {
    display: grid;
    gap: var(--space-10);
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero-layout {
      grid-template-columns: 1fr 1.15fr;
      gap: var(--space-16);
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .kicker-line {
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
  }

  .kicker-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hero-title {
    font-family: var(--font-editorial);
    font-size: clamp(2.75rem, 7vw, 4.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    color: var(--text-secondary);
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    max-width: 520px;
    margin: 0 0 var(--space-8);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    display: none;
  }

  @media (min-width: 960px) {
    .hero-visual {
      display: block;
    }
  }

  .hero-lottie-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-2xl);
    overflow: visible;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--shadow-xl);
  }

  .hero-lottie {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-lottie :global(svg) {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .floating-card {
    position: absolute;
    z-index: 3;
  }

  .floating-card-inner {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  [data-theme="dark"] .floating-card-inner {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }

  .floating-card--users {
    top: -12px;
    right: -16px;
  }

  .floating-card--status {
    bottom: 20px;
    left: -24px;
  }

  .floating-card-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
