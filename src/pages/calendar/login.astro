---
import AppLayout from '@layouts/AppLayout.astro';
import SiteLogo from '@components/ui/SiteLogo.astro';

const title = 'Calendar 登录 - MoonSun.ai';
const description = 'Calendar 页面受密码保护。';
---

<AppLayout title={title} description={description}>
  <section class="calendar-login-page">
    <nav class="calendar-login-nav">
      <div class="calendar-login-nav__inner">
        <SiteLogo label="Back to MoonSun home" />
        <a href="/" class="calendar-login-nav__home">Back home</a>
      </div>
    </nav>

    <div class="calendar-login-shell">
      <div class="calendar-login-card">
        <div class="calendar-login-header">
          <h1>Calendar</h1>
          <p>此页面受密码保护，请输入访问密码。</p>
        </div>

        <form id="calendar-login-form" class="calendar-login-form">
          <label class="calendar-field">
            <span class="field-label">访问密码</span>
            <input
              type="password"
              id="calendar-password"
              name="password"
              placeholder="请输入密码"
              required
              autocomplete="off"
            />
          </label>

          <button type="submit" class="calendar-submit-btn" id="calendar-login-submit">
            <span class="btn-label">进入 Calendar</span>
            <span class="btn-spinner" aria-hidden="true"></span>
          </button>

          <p class="calendar-login-error" id="calendar-login-error" hidden></p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      const CORRECT_PASSWORD = 'USTC';
      const CALENDAR_AUTH_KEY = 'calendar_auth';

      const form = document.getElementById('calendar-login-form');
      const passwordInput = document.getElementById('calendar-password');
      const errorEl = document.getElementById('calendar-login-error');
      const submitBtn = document.getElementById('calendar-login-submit');

      function setError(message) {
        if (!errorEl) return;
        errorEl.hidden = !message;
        errorEl.textContent = message || '';
      }

      function setLoading(loading) {
        submitBtn?.classList.toggle('is-loading', loading);
        if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = loading;
      }

      function isSafeReturnPath(path) {
        return Boolean(path)
          && path.startsWith('/calendar')
          && !path.startsWith('/calendar/login');
      }

      function getReturnPath() {
        const params = new URLSearchParams(window.location.search);
        const next = params.get('next') || '';
        return isSafeReturnPath(next) ? next : '/calendar/';
      }

      function persistAuth() {
        localStorage.setItem(CALENDAR_AUTH_KEY, JSON.stringify(true));
      }

      function redirectToCalendar(path) {
        window.location.replace(isSafeReturnPath(path) ? path : '/calendar/');
      }

      // If already authenticated, redirect
      try {
        const auth = localStorage.getItem(CALENDAR_AUTH_KEY);
        if (auth && JSON.parse(auth) === true) {
          redirectToCalendar(getReturnPath());
          return;
        }
      } catch {
        // ignore
      }

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        setError('');

        const password = passwordInput instanceof HTMLInputElement ? passwordInput.value.trim() : '';

        if (!password) {
          setError('请输入密码。');
          return;
        }

        setLoading(true);

        // Simple client-side password check
        if (password === CORRECT_PASSWORD) {
          persistAuth();
          window.__meownoteToast?.show('验证成功', 'success');
          redirectToCalendar(getReturnPath());
        } else {
          setError('密码错误，请重试。');
          window.__meownoteToast?.show('密码错误', 'error');
        }

        setLoading(false);
      });
    })();
  </script>

  <style>
    .calendar-login-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background: var(--bg-primary);
      color: var(--text-primary);
    }

    .calendar-login-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: var(--z-fixed);
      background: var(--bg-primary);
      border-bottom: 1px solid var(--border-primary);
    }

    .calendar-login-nav__inner {
      max-width: var(--container-xl);
      width: calc(100% - (2 * clamp(1.5rem, 1.07rem + 2.14vw, 3rem)));
      min-height: var(--header-height);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .calendar-login-nav__home {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      padding: 0.72rem 1rem;
      border-radius: var(--radius-full);
      border: 1px solid var(--border-primary);
      background: transparent;
      color: var(--nav-link);
      font-size: 0.95rem;
      font-weight: var(--font-medium);
      text-decoration: none;
      transition: all var(--duration-fast) var(--ease-default);
    }

    .calendar-login-nav__home:hover {
      color: var(--nav-link-hover);
      background: var(--bg-secondary);
    }

    .calendar-login-shell {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: calc(var(--header-height) + 2rem) 1.5rem 2rem;
    }

    .calendar-login-card {
      width: 100%;
      max-width: 28rem;
      padding: 2.5rem;
      border-radius: var(--radius-2xl);
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      box-shadow: var(--card-shadow);
    }

    .calendar-login-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .calendar-login-header h1 {
      font-family: var(--font-editorial);
      font-size: clamp(1.75rem, 3.5vw, 2.25rem);
      font-weight: var(--font-medium);
      line-height: 1.2;
      letter-spacing: var(--tracking-tight);
      color: var(--text-primary);
      margin: 0 0 0.5rem;
    }

    .calendar-login-header p {
      font-size: var(--text-sm);
      color: var(--text-secondary);
      margin: 0;
    }

    .calendar-login-form {
      display: grid;
      gap: 1rem;
    }

    .calendar-field {
      display: grid;
      gap: 0.4rem;
    }

    .field-label {
      font-size: 0.85rem;
      font-weight: var(--font-semibold);
      color: var(--text-secondary);
    }

    .calendar-field input {
      min-height: 2.75rem;
      border-radius: var(--radius-lg);
      border: 1px solid var(--input-border);
      background: var(--input-bg);
      padding: 0 0.85rem;
      font-size: 0.95rem;
      color: var(--text-primary);
      outline: none;
      transition: all var(--duration-fast) var(--ease-default);
      width: 100%;
    }

    .calendar-field input::placeholder {
      color: var(--text-quaternary);
    }

    .calendar-field input:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--input-focus-ring);
    }

    .calendar-submit-btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      width: 100%;
      border: none;
      border-radius: var(--radius-lg);
      background: var(--color-primary);
      color: #fff;
      font-size: 0.95rem;
      font-weight: var(--font-medium);
      cursor: pointer;
      transition: background var(--duration-fast) var(--ease-default);
      margin-top: 0.5rem;
    }

    .calendar-submit-btn:hover {
      background: var(--color-primary-hover);
    }

    .calendar-submit-btn .btn-spinner {
      position: absolute;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-top-color: #fff;
      border-radius: 50%;
      opacity: 0;
      animation: calendar-spin 0.8s linear infinite;
    }

    .calendar-submit-btn.is-loading .btn-label {
      opacity: 0;
    }

    .calendar-submit-btn.is-loading .btn-spinner {
      opacity: 1;
    }

    .calendar-login-error {
      margin: 0;
      min-height: 1rem;
      font-size: 0.85rem;
      color: var(--color-danger);
      text-align: center;
    }

    @keyframes calendar-spin {
      to { transform: rotate(360deg); }
    }

    @media (max-width: 480px) {
      .calendar-login-card {
        padding: 1.75rem 1.25rem;
      }
    }
  </style>
</AppLayout>
