---
import Layout from '@layouts/Layout.astro';
import Icon from '@components/ui/Icon.astro';
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    icon: 'cpu',
    title: t('claw.feature.agent.title', lang),
    description: t('claw.feature.agent.desc', lang)
  },
  {
    icon: 'message-circle',
    title: t('claw.feature.platforms.title', lang),
    description: t('claw.feature.platforms.desc', lang)
  },
  {
    icon: 'brain',
    title: t('claw.feature.memory.title', lang),
    description: t('claw.feature.memory.desc', lang)
  },
  {
    icon: 'shield',
    title: t('claw.feature.privacy.title', lang),
    description: t('claw.feature.privacy.desc', lang)
  },
  {
    icon: 'sparkles',
    title: t('claw.feature.evolve.title', lang),
    description: t('claw.feature.evolve.desc', lang)
  },
  {
    icon: 'plug',
    title: t('claw.feature.integrations.title', lang),
    description: t('claw.feature.integrations.desc', lang)
  },
];

const installMethods = {
  mac: [
    {
      title: 'Homebrew (推荐)',
      command: 'brew install openclaw',
      desc: '最简单的安装方式，自动处理依赖'
    },
    {
      title: 'npm',
      command: 'npm install -g openclaw',
      desc: '需要 Node.js 18+ 环境'
    },
    {
      title: '一键脚本',
      command: 'curl -fsSL https://openclaw.ai/install.sh | bash',
      desc: '自动检测系统并安装'
    },
    {
      title: '从源码构建',
      command: `git clone https://github.com/ustcio/openclaw.git
cd openclaw
npm install
npm run build
npm link`,
      desc: '适合开发者'
    }
  ],
  windows: [
    {
      title: 'PowerShell (推荐)',
      command: 'winget install openclaw',
      desc: 'Windows 11 内置包管理器'
    },
    {
      title: 'Scoop',
      command: `scoop bucket add extras
scoop install openclaw`,
      desc: '流行的 Windows 包管理器'
    },
    {
      title: 'npm',
      command: 'npm install -g openclaw',
      desc: '需要 Node.js 18+ 环境'
    },
    {
      title: 'Chocolatey',
      command: 'choco install openclaw',
      desc: '企业级包管理器'
    }
  ]
};

const skills = [
  {
    name: 'Academic Paper Reviewer',
    icon: 'book',
    desc: '多视角学术论文评审，模拟5位独立审稿人',
    href: '/kit/academic',
    badge: 'Hot'
  },
  {
    name: 'Literature Search',
    icon: 'search',
    desc: 'PubMed、arXiv、bioRxiv 文献搜索',
    href: '#',
    badge: 'New'
  },
  {
    name: 'Deep Research',
    icon: 'brain',
    desc: '深度研究与报告生成',
    href: '/research/',
    badge: null
  },
  {
    name: 'Web Scraper',
    icon: 'globe',
    desc: '网页内容提取，支持 JS 渲染页面',
    href: '#',
    badge: null
  },
  {
    name: 'Playwright Automation',
    icon: 'cpu',
    desc: '浏览器自动化测试与数据采集',
    href: '#',
    badge: null
  },
  {
    name: 'Paper Writing',
    icon: 'edit',
    desc: '学术论文写作指导与润色',
    href: '#',
    badge: null
  }
];

const platforms = [
  { name: 'WhatsApp', icon: 'message-circle' },
  { name: 'Telegram', icon: 'send' },
  { name: 'Discord', icon: 'users' },
  { name: 'Slack', icon: 'slack' },
  { name: 'Signal', icon: 'shield' },
  { name: 'iMessage', icon: 'message-square' },
];

const integrations = [
  'Gmail', 'GitHub', 'Google Calendar', 'Notion', 'Obsidian', 
  'Spotify', 'Hue Lights', 'Google Drive', 'Slack', 'Twitter'
];

const stats = [
  { value: '10K+', label: t('claw.stats.users', lang) },
  { value: '200+', label: t('claw.stats.skills', lang) },
  { value: '50+', label: t('claw.stats.integrations', lang) },
];
---

<Layout 
  title="OpenClaw - AI Assistant That Takes Action"
  description={t('claw.subtitle', lang)}
>
  <section class="claw">
    <div class="claw-container">
      <!-- Hero -->
      <div class="claw-hero">
        <div class="hero-badge">
          <Icon name="box" size={16} />
          <span>Open source companion</span>
        </div>
        <h1 class="hero-title">OpenClaw</h1>
        <p class="hero-tagline">{t('claw.tagline', lang)}</p>
        <p class="hero-subtitle">{t('claw.subtitle', lang)}</p>
        <p class="hero-description">{t('claw.description', lang)}</p>
        <div class="hero-actions">
          <a href="#install" class="btn-primary">
            <Icon name="download" size={18} />
            <span>立即安装</span>
          </a>
          <a href="https://github.com/ustcio/openclaw" class="btn-secondary" target="_blank" rel="noopener">
            <Icon name="github" size={18} />
            <span>GitHub</span>
          </a>
          <a href="https://clawhub.ai" class="btn-secondary" target="_blank" rel="noopener">
            <Icon name="box" size={18} />
            <span>ClawHub</span>
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-section">
        <div class="stats-grid">
          {stats.map((stat) => (
            <div class="stat-item">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Installation -->
      <div class="install-section" id="install">
        <h2 class="section-title">安装指南</h2>
        <p class="section-subtitle">选择适合你系统的安装方式</p>
        
        <div class="install-tabs">
          <button class="tab-btn active" data-tab="mac">
            <Icon name="laptop" size={18} />
            <span>macOS</span>
          </button>
          <button class="tab-btn" data-tab="windows">
            <Icon name="monitor" size={18} />
            <span>Windows</span>
          </button>
          <button class="tab-btn" data-tab="linux">
            <Icon name="terminal" size={18} />
            <span>Linux</span>
          </button>
        </div>

        <div class="install-content">
          <!-- macOS -->
          <div class="tab-panel active" id="mac-panel">
            <div class="install-grid">
              {installMethods.mac.map((method) => (
                <div class="install-card">
                  <div class="install-header">
                    <h3 class="install-title">{method.title}</h3>
                    <span class="install-desc">{method.desc}</span>
                  </div>
                  <pre class="install-code"><code>{method.command}</code></pre>
                </div>
              ))}
            </div>
          </div>

          <!-- Windows -->
          <div class="tab-panel" id="windows-panel">
            <div class="install-grid">
              {installMethods.windows.map((method) => (
                <div class="install-card">
                  <div class="install-header">
                    <h3 class="install-title">{method.title}</h3>
                    <span class="install-desc">{method.desc}</span>
                  </div>
                  <pre class="install-code"><code>{method.command}</code></pre>
                </div>
              ))}
            </div>
          </div>

          <!-- Linux -->
          <div class="tab-panel" id="linux-panel">
            <div class="install-grid">
              <div class="install-card">
                <div class="install-header">
                  <h3 class="install-title">npm</h3>
                  <span class="install-desc">通用安装方式</span>
                </div>
                <pre class="install-code"><code>npm install -g openclaw</code></pre>
              </div>
              <div class="install-card">
                <div class="install-header">
                  <h3 class="install-title">一键脚本</h3>
                  <span class="install-desc">自动检测发行版</span>
                </div>
                <pre class="install-code"><code>curl -fsSL https://openclaw.ai/install.sh | bash</code></pre>
              </div>
              <div class="install-card">
                <div class="install-header">
                  <h3 class="install-title">Arch Linux (AUR)</h3>
                  <span class="install-desc">使用 yay 或 paru</span>
                </div>
                <pre class="install-code"><code>yay -S openclaw</code></pre>
              </div>
              <div class="install-card">
                <div class="install-header">
                  <h3 class="install-title">Debian/Ubuntu</h3>
                  <span class="install-desc">APT 仓库</span>
                </div>
                <pre class="install-code"><code>sudo apt install openclaw</code></pre>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Skills -->
      <div class="skills-section">
        <div class="skills-header">
          <div>
            <h2 class="section-title">内置 Skills</h2>
            <p class="section-subtitle">强大的技能扩展，开箱即用</p>
          </div>
          <a href="https://clawhub.ai" class="btn-secondary" target="_blank" rel="noopener">
            <Icon name="external-link" size={16} />
            <span>探索更多 Skills</span>
          </a>
        </div>
        
        <div class="skills-grid">
          {skills.map((skill) => (
            <a href={skill.href} class="skill-card">
              <div class="skill-icon">
                <Icon name={skill.icon} size={24} />
              </div>
              <div class="skill-content">
                <div class="skill-header">
                  <h3 class="skill-name">{skill.name}</h3>
                  {skill.badge && <span class="skill-badge">{skill.badge}</span>}
                </div>
                <p class="skill-desc">{skill.desc}</p>
              </div>
              <Icon name="chevron-right" size={18} class="skill-arrow" />
            </a>
          ))}
        </div>
      </div>

      <!-- ClawHub Banner -->
      <div class="clawhub-banner">
        <div class="clawhub-content">
          <div class="clawhub-icon">
            <Icon name="box" size={32} />
          </div>
          <div class="clawhub-text">
            <h3>ClawHub - Skills 市场</h3>
            <p>发现、分享、发布自定义 Skills。社区驱动的 AI 能力扩展平台。</p>
          </div>
          <a href="https://clawhub.ai" class="btn-primary" target="_blank" rel="noopener">
            访问 ClawHub
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>

      <!-- Platforms -->
      <div class="platforms-section">
        <h2 class="section-label">多平台支持</h2>
        <div class="platforms-grid">
          {platforms.map((platform) => (
            <div class="platform-item">
              <Icon name={platform.icon} size={20} />
              <span>{platform.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Features -->
      <div class="features-section">
        <h2 class="section-title">{t('claw.features.title', lang)}</h2>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card hover-lift">
              <div class="feature-icon">
                <Icon name={feature.icon} size={24} />
              </div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-description">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Integrations -->
      <div class="integrations-section">
        <h2 class="section-title">集成生态</h2>
        <p class="section-subtitle">连接你已使用的服务</p>
        <div class="integrations-grid">
          {integrations.map((name) => (
            <div class="integration-item">
              <span class="integration-name">{name}</span>
            </div>
          ))}
          <div class="integration-item integration-more">
            <span>+40 more</span>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-section">
        <h2 class="cta-title">开始使用 OpenClaw</h2>
        <p class="cta-subtitle">几分钟安装，立即提升效率</p>
        <div class="cta-actions">
          <a href="#install" class="btn-primary large">
            <Icon name="download" size={20} />
            <span>立即安装</span>
          </a>
          <a href="https://clawhub.ai" class="btn-secondary large" target="_blank" rel="noopener">
            <Icon name="box" size={20} />
            <span>浏览 Skills</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      tabPanels.forEach(panel => {
        panel.classList.remove('active');
        if (panel.id === `${tab}-panel`) {
          panel.classList.add('active');
        }
      });
    });
  });
</script>

<style>
  .claw {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-5)) var(--space-4) var(--space-8);
  }

  .claw-container {
    max-width: var(--container-xl);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  /* Hero */
  .claw-hero {
    text-align: left;
    padding: var(--space-8) 0;
    max-width: 52rem;
    margin: 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.45rem 0.85rem;
    background: rgba(255, 253, 249, 0.75);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 5.2rem);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 0.98;
    letter-spacing: var(--tracking-tight);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--text-primary);
    font-weight: var(--font-medium);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .hero-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: flex;
    justify-content: flex-start;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    color: white;
    background: var(--color-primary);
    box-shadow: var(--btn-primary-shadow);
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(217, 119, 87, 0.3);
  }

  .btn-primary.large {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-lg);
  }

  .btn-secondary {
    color: var(--text-primary);
    background: transparent;
    border: 1px solid var(--border-primary);
  }

  .btn-secondary:hover {
    background: rgba(0, 0, 0, 0.05);
    border-color: var(--border-hover);
  }

  .btn-secondary.large {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-lg);
  }

  /* Stats */
  .stats-section {
    padding: var(--space-8) 0;
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }

  /* Section Title */
  .section-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    text-align: center;
    margin-bottom: var(--space-4);
  }

  .section-subtitle {
    font-size: var(--text-base);
    color: var(--text-tertiary);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: var(--text-3xl);
    }
  }

  /* Installation */
  .install-section {
    background: var(--bg-elevated);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    border: 1px solid var(--card-border);
  }

  .install-tabs {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .tab-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-8);
    background: transparent;
    border: 1.5px solid var(--card-border);
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .tab-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .tab-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .install-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .install-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .install-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  .install-header {
    padding: var(--space-6);
    border-bottom: 1px solid var(--card-border);
  }

  .install-title {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .install-desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }

  .install-code {
    padding: var(--space-6);
    margin: 0;
    background: rgba(0, 0, 0, 0.02);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--text-primary);
    overflow-x: auto;
    white-space: pre-wrap;
  }

  .install-header {
    padding: var(--space-4);
    border-bottom: 1px solid var(--card-border);
  }

  .install-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .install-desc {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .install-code {
    padding: var(--space-4);
    margin: 0;
    background: rgba(0, 0, 0, 0.02);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
    overflow-x: auto;
    white-space: pre-wrap;
  }

  .install-code code {
    color: inherit;
  }

  /* Skills */
  .skills-section {
    padding: var(--space-8) 0;
  }

  .skills-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .skills-header .section-title,
  .skills-header .section-subtitle {
    text-align: left;
    margin-bottom: 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-5);
  }

  .skill-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .skill-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .skill-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
    border-radius: var(--radius-lg);
    color: white;
  }

  .skill-content {
    flex: 1;
  }

  .skill-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .skill-name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin: 0;
  }

  .skill-badge {
    padding: 2px 8px;
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
