---
import Layout from '@layouts/Layout.astro';
import { t } from '@i18n/translate';
---

<Layout 
  title={`${t('error.404.title')} - MaxMini`}
  description={t('error.404.message')}
>
  <section class="not-found">
    <div class="not-found-container">
      <div class="not-found-content">
        <!-- Animated Cat -->
        <div class="cat-container">
          <div class="cat">
            <div class="cat-face">
              <div class="cat-ears">
                <div class="ear left"></div>
                <div class="ear right"></div>
              </div>
              <div class="cat-eyes">
                <div class="eye left">
                  <div class="pupil"></div>
                </div>
                <div class="eye right">
                  <div class="pupil"></div>
                </div>
              </div>
              <div class="cat-nose"></div>
              <div class="cat-mouth"></div>
              <div class="whiskers left">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="whiskers right">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Error Message -->
        <div class="error-content">
          <h1 class="error-code">404</h1>
          <h2 class="error-title">{t('error.404.title')}</h2>
          <p class="error-message">{t('error.404.message')}</p>
          
          <div class="error-actions">
            <a href="/" class="btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
              {t('error.404.home')}
            </a>
            <button class="btn-secondary" onclick="history.back()">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              {t('error.404.back')}
            </button>
          </div>
        </div>
      </div>
      
      <!-- Fun Facts -->
      <div class="fun-fact">
        <p class="fact-text">🐱 {t('error.404.fact')}</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--header-total-height) + var(--space-4)) var(--space-4) var(--space-12);
  }
  
  .not-found-container {
    max-width: var(--container-md);
    margin: 0 auto;
    text-align: center;
  }
  
  .not-found-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }
  
  /* Cat Animation */
  .cat-container {
    perspective: 1000px;
  }
  
  .cat {
    animation: float 3s ease-in-out infinite;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  .cat-face {
    position: relative;
    width: 120px;
    height: 100px;
    background: linear-gradient(135deg, #ffd6a5 0%, #ffb366 100%);
    border-radius: 50% 50% 45% 45%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }
  
  .cat-ears {
    position: absolute;
    top: -20px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 5px;
  }
  
  .ear {
    width: 0;
    height: 0;
    border-left: 18px solid transparent;
    border-right: 18px solid transparent;
    border-bottom: 30px solid #ffd6a5;
  }
  
  .ear::after {
    content: '';
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-bottom: 18px solid #ffb3b3;
  }
  
  .cat-eyes {
    position: absolute;
    top: 35px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 30px;
  }
  
  .eye {
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%;
    position: relative;
    overflow: hidden;
  }
  
  .pupil {
    position: absolute;
    width: 8px;
    height: 8px;
    background: #333;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: look 4s ease-in-out infinite;
  }
  
  @keyframes look {
    0%, 100% { transform: translate(-50%, -50%); }
    25% { transform: translate(-80%, -50%); }
    75% { transform: translate(-20%, -50%); }
  }
  
  .cat-nose {
    position: absolute;
    top: 55px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 10px;
    background: #ff9999;
    border-radius: 50% 50% 50% 50% / 30% 30% 70% 70%;
  }
  
  .cat-mouth {
    position: absolute;
    top: 62px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 10px;
    border: 2px solid #ff9999;
    border-top: none;
    border-radius: 0 0 50% 50%;
  }
  
  .whiskers {
    position: absolute;
    top: 55px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  
  .whiskers.left {
    left: -20px;
  }
  
  .whiskers.right {
    right: -20px;
  }
  
  .whiskers span {
    display: block;
    width: 25px;
    height: 2px;
    background: #ccc;
    border-radius: 1px;
  }
  
  .whiskers.left span {
    transform-origin: right center;
  }
  
  .whiskers.right span {
    transform-origin: left center;
  }
  
  .whiskers.left span:nth-child(1) { transform: rotate(-10deg); }
  .whiskers.left span:nth-child(2) { transform: rotate(0deg); }
  .whiskers.left span:nth-child(3) { transform: rotate(10deg); }
  
  .whiskers.right span:nth-child(1) { transform: rotate(10deg); }
  .whiskers.right span:nth-child(2) { transform: rotate(0deg); }
  .whiskers.right span:nth-child(3) { transform: rotate(-10deg); }
  
  /* Error Content */
  .error-content {
    text-align: center;
  }
  
  .error-code {
    font-size: 8rem;
    font-weight: var(--font-bold);
    background: linear-gradient(135deg, var(--color-accent-blue), var(--color-accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: var(--space-4);
  }
  
  @media (max-width: 640px) {
    .error-code {
      font-size: 5rem;
    }
  }
  
  .error-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }
  
  .error-message {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .error-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: linear-gradient(135deg, var(--color-accent-blue), var(--color-accent-purple));
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: white;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 212, 255, 0.3);
  }
  
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .btn-secondary:hover {
    background: var(--bg-elevated);
    border-color: var(--border-hover);
  }
  
  /* Fun Fact */
  .fun-fact {
    margin-top: var(--space-12);
    padding: var(--space-4);
    background: var(--bg-tertiary);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-secondary);
  }
  
  .fact-text {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
</style>
