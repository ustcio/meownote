---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title={`Workspace - MaxMin.dev`}
  description="Personal workspace for notes and files"
>
  <section class="workspace-page">
    <div class="workspace-container">
      <!-- Header -->
      <header class="workspace-header">
        <div class="header-top">
          <h1 class="page-title">Workspace</h1>
          <div class="header-stats" id="header-stats">
            <span id="files-count">0 files</span>
          </div>
        </div>
        <p class="page-subtitle">Your notes and files, organized in one place.</p>
      </header>

      <!-- Toolbar -->
      <div class="toolbar">
        <div class="toolbar-left">
          <div class="search-box">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="search-input" placeholder="Search..." />
          </div>
          <div class="sort-dropdown" id="sort-dropdown">
            <button class="sort-btn" id="sort-btn">
              <span id="sort-label">Recent</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="sort-menu" id="sort-menu">
              <button class="sort-option active" data-sort="updated_at">Recent</button>
              <button class="sort-option" data-sort="created_at">Created</button>
              <button class="sort-option" data-sort="title">Name</button>
            </div>
          </div>
        </div>
        <div class="toolbar-right">
          <button class="btn-icon" id="clipboard-btn" title="Quick Clipboard">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
              <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
            </svg>
          </button>
          <button class="btn-icon" id="upload-btn" title="Upload File">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
          </button>
          <button class="btn-primary" id="new-note-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>New</span>
          </button>
        </div>
      </div>

      <!-- Skeleton Loading -->
      <div class="skeleton-grid" id="skeleton-grid">
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
      </div>

      <!-- Empty State -->
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
        </div>
        <h3>No files yet</h3>
        <p>Create your first note or upload a file to get started.</p>
        <button class="btn-primary btn-lg" id="empty-new-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Create Note
        </button>
      </div>

      <!-- Files Grid -->
      <div class="files-grid" id="files-grid"></div>
    </div>

    <input type="file" id="file-upload" hidden multiple accept=".txt,.md,.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.zip,.rar" />
  </section>

  <!-- Clipboard Modal -->
  <div class="modal" id="clipboard-modal">
    <div class="modal-backdrop" id="clipboard-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3>Quick Clipboard</h3>
        <button class="btn-icon-sm" id="clipboard-close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <input type="text" id="clipboard-title" placeholder="Title (optional)" class="input-field" />
        <textarea id="clipboard-content" placeholder="Paste your text here..." rows="6" class="input-field textarea"></textarea>
        <div class="modal-actions">
          <button class="btn-secondary" id="paste-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            Paste
          </button>
          <button class="btn-primary" id="save-clipboard-btn">Save</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Modal -->
  <div class="modal" id="delete-modal">
    <div class="modal-backdrop" id="delete-backdrop"></div>
    <div class="modal-content modal-sm">
      <div class="modal-header">
        <h3>Delete File</h3>
        <button class="btn-icon-sm" id="delete-close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <p id="delete-message">Are you sure you want to delete this file?</p>
        <div class="modal-actions">
          <button class="btn-secondary" id="delete-cancel">Cancel</button>
          <button class="btn-danger" id="delete-confirm">Delete</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>
</Layout>

<style>
  :root {
    --bg: #faf8f5;
    --bg-secondary: #ffffff;
    --fg: #1a1a1a;
    --fg-muted: #6b6b6b;
    --border: #e5e5e5;
    --border-hover: #d0d0d0;
    --accent: #0066ff;
    --accent-hover: #0052cc;
    --danger: #ff3b30;
    --danger-hover: #e6352b;
    --radius: 10px;
    --radius-lg: 14px;
    --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.06);
    --shadow-hover: 0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
    --shadow-lg: 0 12px 32px rgba(0,0,0,0.12);
  }

  [data-theme="dark"] {
    --bg: #0a0a0a;
    --bg-secondary: #141414;
    --fg: #fafafa;
    --fg-muted: #8a8a8a;
    --border: #262626;
    --border-hover: #404040;
  }

  .workspace-page {
    min-height: 100vh;
    background: var(--bg);
    padding: calc(var(--header-height) + 32px) 24px 80px;
  }

  .workspace-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Header */
  .workspace-header {
    margin-bottom: 32px;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .page-title {
    font-size: 28px;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.02em;
  }

  .header-stats {
    font-size: 14px;
    color: var(--fg-muted);
  }

  .page-subtitle {
    font-size: 15px;
    color: var(--fg-muted);
  }

  /* Toolbar */
  .toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .toolbar-left, .toolbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    min-width: 240px;
    transition: all 0.15s ease;
  }

  .search-box:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
  }

  .search-box svg {
    color: var(--fg-muted);
    flex-shrink: 0;
  }

  .search-box input {
    border: none;
    background: transparent;
    font-size: 14px;
    color: var(--fg);
    width: 100%;
    outline: none;
  }

  .search-box input::placeholder {
    color: var(--fg-muted);
  }

  /* Sort Dropdown */
  .sort-dropdown {
    position: relative;
  }

  .sort-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 14px;
    color: var(--fg);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .sort-btn:hover {
    border-color: var(--border-hover);
  }

  .sort-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    min-width: 120px;
    padding: 4px;
    display: none;
    z-index: 100;
  }

  .sort-dropdown.open .sort-menu {
    display: block;
  }

  .sort-option {
    display: block;
    width: 100%;
    padding: 8px 12px;
    background: transparent;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    color: var(--fg);
    text-align: left;
    cursor: pointer;
    transition: background 0.1s ease;
  }

  .sort-option:hover {
    background: var(--border);
  }

  .sort-option.active {
    background: var(--accent);
    color: white;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }

  .btn-primary.btn-lg {
    padding: 12px 24px;
    font-size: 15px;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    background: var(--bg-secondary);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-secondary:hover {
    border-color: var(--border-hover);
    background: var(--bg);
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--fg-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-icon:hover {
    border-color: var(--border-hover);
    color: var(--fg);
  }

  .btn-icon-sm {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    border-radius: 8px;
    color: var(--fg-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-icon-sm:hover {
    background: var(--border);
    color: var(--fg);
  }

  .btn-danger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    background: var(--danger);
    color: white;
    border: none;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-danger:hover {
    background: var(--danger-hover);
  }

  /* Skeleton */
  .skeleton-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .skeleton-card {
    height: 120px;
    background: linear-gradient(90deg, var(--border) 0%, var(--bg-secondary) 50%, var(--border) 100%);
    background-size: 200% 100%;
    border-radius: var(--radius-lg);
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Empty State */
  .empty-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    text-align: center;
  }

  .empty-state.visible {
    display: flex;
  }

  .empty-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--border);
    border-radius: 20px;
    margin-bottom: 24px;
    color: var(--fg-muted);
  }

  .empty-state h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 8px;
  }

  .empty-state p {
    font-size: 14px;
    color: var(--fg-muted);
    margin-bottom: 24px;
    max-width: 280px;
  }

  /* Files Grid */
  .files-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  /* File Card */
  .file-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }

  .file-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .file-card-header {
    display: flex;
    gap: 14px;
    margin-bottom: 12px;
  }

  .file-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: rgba(0, 102, 255, 0.08);
    color: var(--accent);
  }

  .file-icon.text { background: rgba(0, 102, 255, 0.08); color: var(--accent); }
  .file-icon.document { background: rgba(128, 0, 255, 0.08); color: #8000ff; }
  .file-icon.image { background: rgba(0, 200, 83, 0.08); color: #00c853; }
  .file-icon.archive { background: rgba(255, 145, 0, 0.08); color: #ff9100; }
  .file-icon.clipboard { background: rgba(255, 59, 48, 0.08); color: var(--danger); }

  .file-info {
    flex: 1;
    min-width: 0;
  }

  .file-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 4px;
  }

  .file-card:hover .file-title {
    color: var(--accent);
  }

  .file-meta {
    font-size: 13px;
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .file-preview {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  /* Delete Button */
  .file-delete {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg-muted);
    cursor: pointer;
    opacity: 0;
    transition: all 0.15s ease;
  }

  .file-card:hover .file-delete {
    opacity: 1;
  }

  .file-delete:hover {
    background: var(--danger);
    border-color: var(--danger);
    color: white;
  }

  /* Modal */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .modal.open {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    position: relative;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 420px;
    box-shadow: var(--shadow-lg);
    animation: modalIn 0.2s ease;
  }

  .modal-content.modal-sm {
    max-width: 360px;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }

  .modal-header h3 {
    font-size: 16px;
    font-weight: 600;
    color: var(--fg);
  }

  .modal-body {
    padding: 20px;
  }

  .modal-body p {
    font-size: 14px;
    color: var(--fg-muted);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  .input-field {
    width: 100%;
    padding: 12px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 14px;
    color: var(--fg);
    transition: all 0.15s ease;
    margin-bottom: 12px;
  }

  .input-field:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
  }

  .input-field.textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.5;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--fg);
    color: var(--bg);
    padding: 12px 20px;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    z-index: 1001;
    opacity: 0;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-lg);
    pointer-events: none;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .toast.success {
    background: #00c853;
    color: white;
  }

  .toast.error {
    background: var(--danger);
    color: white;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .workspace-page {
      padding: calc(var(--header-height) + 24px) 16px 60px;
    }

    .toolbar {
      flex-direction: column;
      align-items: stretch;
    }

    .toolbar-left, .toolbar-right {
      flex-wrap: wrap;
    }

    .search-box {
      min-width: auto;
      flex: 1;
    }

    .files-grid {
      grid-template-columns: 1fr;
    }

    .btn-primary span {
      display: inline;
    }
  }
</style>

<script>
  const API_BASE = 'https://api.ustc.dev';

  let files: any[] = [];
  let sortBy = 'updated_at';
  let searchQuery = '';
  let deleteTargetId: string | null = null;

  const filesGrid = document.getElementById('files-grid');
  const skeletonGrid = document.getElementById('skeleton-grid');
  const emptyState = document.getElementById('empty-state');
  const filesCount = document.getElementById('files-count');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
  const newNoteBtn = document.getElementById('new-note-btn');
  const uploadBtn = document.getElementById('upload-btn');
  const clipboardBtn = document.getElementById('clipboard-btn');
  const toast = document.getElementById('toast');
  const sortDropdown = document.getElementById('sort-dropdown');
  const sortBtn = document.getElementById('sort-btn');
  const sortLabel = document.getElementById('sort-label');
  const sortMenu = document.getElementById('sort-menu');

  const clipboardModal = document.getElementById('clipboard-modal');
  const clipboardBackdrop = document.getElementById('clipboard-backdrop');
  const clipboardClose = document.getElementById('clipboard-close');
  const clipboardTitle = document.getElementById('clipboard-title') as HTMLInputElement;
  const clipboardContent = document.getElementById('clipboard-content') as HTMLTextAreaElement;
  const pasteBtn = document.getElementById('paste-btn');
  const saveClipboardBtn = document.getElementById('save-clipboard-btn');

  const deleteModal = document.getElementById('delete-modal');
  const deleteBackdrop = document.getElementById('delete-backdrop');
  const deleteClose = document.getElementById('delete-close');
  const deleteCancel = document.getElementById('delete-cancel');
  const deleteConfirm = document.getElementById('delete-confirm');

  const fileTypeConfig: Record<string, { icon: string; type: string }> = {
    'txt': { icon: 'text', type: 'text' },
    'md': { icon: 'text', type: 'text' },
    'pdf': { icon: 'document', type: 'document' },
    'doc': { icon: 'document', type: 'document' },
    'docx': { icon: 'document', type: 'document' },
    'xls': { icon: 'document', type: 'document' },
    'xlsx': { icon: 'document', type: 'document' },
    'png': { icon: 'image', type: 'image' },
    'jpg': { icon: 'image', type: 'image' },
    'jpeg': { icon: 'image', type: 'image' },
    'gif': { icon: 'image', type: 'image' },
    'zip': { icon: 'archive', type: 'archive' },
    'rar': { icon: 'archive', type: 'archive' },
    'clipboard': { icon: 'clipboard', type: 'clipboard' },
  };

  async function init() {
    await loadFiles();
    initSortDropdown();
    initModals();
  }

  function initSortDropdown() {
    sortBtn?.addEventListener('click', () => {
      sortDropdown?.classList.toggle('open');
    });

    document.querySelectorAll('.sort-option').forEach(opt => {
      opt.addEventListener('click', () => {
        document.querySelectorAll('.sort-option').forEach(o => o.classList.remove('active'));
        opt.classList.add('active');
        sortBy = opt.getAttribute('data-sort') || 'updated_at';
        if (sortLabel) sortLabel.textContent = opt.textContent;
        sortDropdown?.classList.remove('open');
        loadFiles();
      });
    });

    document.addEventListener('click', (e) => {
      if (!sortDropdown?.contains(e.target as Node)) {
        sortDropdown?.classList.remove('open');
      }
    });
  }

  function initModals() {
    clipboardBtn?.addEventListener('click', () => openClipboardModal());
    clipboardBackdrop?.addEventListener('click', () => closeClipboardModal());
    clipboardClose?.addEventListener('click', () => closeClipboardModal());
    pasteBtn?.addEventListener('click', pasteFromClipboard);
    saveClipboardBtn?.addEventListener('click', saveClipboard);

    deleteBackdrop?.addEventListener('click', () => closeDeleteModal());
    deleteClose?.addEventListener('click', () => closeDeleteModal());
    deleteCancel?.addEventListener('click', () => closeDeleteModal());
    deleteConfirm?.addEventListener('click', confirmDelete);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeClipboardModal();
        closeDeleteModal();
      }
    });
  }

  async function loadFiles() {
    showLoading();
    try {
      const response = await fetch(`${API_BASE}/api/workspace?sortBy=${sortBy}&order=desc`);
      const result = await response.json();
      files = result.data || [];
      renderFiles();
    } catch (error) {
      console.error('Load failed:', error);
      showToast('Failed to load files', 'error');
    } finally {
      hideLoading();
    }
  }

  function getTimeAgo(date: Date): string {
    const now = new Date();
    const diff = now.getTime() - date.getTime();
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);
    if (minutes < 1) return 'Just now';
    if (minutes < 60) return `${minutes}m`;
    if (hours < 24) return `${hours}h`;
    if (days < 7) return `${days}d`;
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function renderFiles() {
    const filtered = files.filter(f => f.title.toLowerCase().includes(searchQuery.toLowerCase()));
    filesCount!.textContent = `${filtered.length} file${filtered.length !== 1 ? 's' : ''}`;

    if (filtered.length === 0) {
      filesGrid!.innerHTML = '';
      emptyState!.classList.add('visible');
      return;
    }

    emptyState!.classList.remove('visible');

    filesGrid!.innerHTML = filtered.map(file => {
      const ext = file.type || 'txt';
      const config = fileTypeConfig[ext] || { icon: 'document', type: 'document' };
      const date = new Date(file.updatedAt || file.createdAt);
      const timeAgo = getTimeAgo(date);
      const preview = file.content ? file.content.substring(0, 100).trim() : '';

      return `
        <div class="file-card" data-id="${file.id}">
          <button class="file-delete" data-id="${file.id}" title="Delete">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
          </button>
          <div class="file-card-header">
            <div class="file-icon ${config.type}">
              ${getFileIcon(config.icon)}
            </div>
            <div class="file-info">
              <div class="file-title">${escapeHtml(file.title)}</div>
              <div class="file-meta">
                <span>${ext.toUpperCase()}</span>
                <span>·</span>
                <span>${timeAgo}</span>
              </div>
            </div>
          </div>
          ${preview ? `<div class="file-preview">${escapeHtml(preview)}</div>` : ''}
        </div>
      `;
    }).join('');

    document.querySelectorAll('.file-card').forEach(card => {
      card.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.file-delete')) return;
        const id = card.getAttribute('data-id');
        if (id) window.location.href = `/workspace/edit?id=${id}`;
      });
    });

    document.querySelectorAll('.file-delete').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        const id = (e.currentTarget as HTMLElement).getAttribute('data-id');
        if (id) openDeleteModal(id);
      });
    });
  }

  function getFileIcon(type: string): string {
    const icons: Record<string, string> = {
      text: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>`,
      document: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>`,
      image: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>`,
      archive: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8v13H3V8"></path><path d="M1 3h22v5H1z"></path><path d="M10 12h4"></path></svg>`,
      clipboard: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>`
    };
    return icons[type] || icons.document;
  }

  function openDeleteModal(id: string) {
    deleteTargetId = id;
    deleteModal?.classList.add('open');
  }

  function closeDeleteModal() {
    deleteTargetId = null;
    deleteModal?.classList.remove('open');
  }

  async function confirmDelete() {
    if (!deleteTargetId) return;
    closeDeleteModal();
    try {
      const response = await fetch(`${API_BASE}/api/workspace/${deleteTargetId}`, { method: 'DELETE' });
      const result = await response.json();
      if (result.success) {
        showToast('Deleted', 'success');
        await loadFiles();
      } else {
        showToast(result.message || 'Delete failed', 'error');
      }
    } catch (error) {
      showToast('Delete failed', 'error');
    }
  }

  function openClipboardModal() {
    clipboardModal?.classList.add('open');
    clipboardContent?.focus();
  }

  function closeClipboardModal() {
    clipboardModal?.classList.remove('open');
    clipboardTitle!.value = '';
    clipboardContent!.value = '';
  }

  async function pasteFromClipboard() {
    try {
      const text = await navigator.clipboard.readText();
      clipboardContent!.value = text;
      showToast('Pasted', 'success');
    } catch {
      showToast('Cannot access clipboard', 'error');
    }
  }

  async function saveClipboard() {
    const title = clipboardTitle?.value.trim() || 'Quick Clip';
    const content = clipboardContent?.value.trim();
    if (!content) {
      showToast('Please enter content', 'error');
      return;
    }
    try {
      const response = await fetch(`${API_BASE}/api/workspace`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, content, type: 'clipboard', fileSize: content.length })
      });
      const result = await response.json();
      if (result.success) {
        showToast('Saved', 'success');
        closeClipboardModal();
        await loadFiles();
      } else {
        showToast(result.message || 'Save failed', 'error');
      }
    } catch {
      showToast('Save failed', 'error');
    }
  }

  async function createNote() {
    try {
      const response = await fetch(`${API_BASE}/api/workspace`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: 'Untitled', content: '', type: 'txt' })
      });
      const result = await response.json();
      if (result.success && result.data?.id) {
        window.location.href = `/workspace/edit?id=${result.data.id}`;
      } else {
        showToast('Failed to create note', 'error');
      }
    } catch {
      showToast('Failed to create note', 'error');
    }
  }

  async function handleUpload(e: Event) {
    const input = e.target as HTMLInputElement;
    const fileList = input.files;
    if (!fileList || fileList.length === 0) return;

    let successCount = 0;
    for (const file of Array.from(fileList)) {
      try {
        const ext = file.name.split('.').pop()?.toLowerCase() || 'bin';
        const isText = ['txt', 'md', 'json', 'js', 'ts', 'css', 'html'].includes(ext);
        let content = '';
        if (isText) content = await file.text();
        const response = await fetch(`${API_BASE}/api/workspace`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: file.name.replace(/\.[^/.]+$/, ''),
            content,
            type: ext,
            fileSize: file.size
          })
        });
        if ((await response.json()).success) successCount++;
      } catch {}
    }
    input.value = '';
    if (successCount > 0) {
      showToast(`${successCount} file${successCount > 1 ? 's' : ''} uploaded`, 'success');
      await loadFiles();
    }
  }

  function showLoading() {
    if (skeletonGrid) skeletonGrid.style.display = 'grid';
    emptyState?.classList.remove('visible');
    if (filesGrid) filesGrid.innerHTML = '';
  }

  function hideLoading() {
    if (skeletonGrid) skeletonGrid.style.display = 'none';
  }

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    if (toast) {
      toast.textContent = message;
      toast.className = 'toast show ' + type;
      setTimeout(() => toast.classList.remove('show'), 2500);
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  newNoteBtn?.addEventListener('click', createNote);
  uploadBtn?.addEventListener('click', () => fileUpload?.click());
  fileUpload?.addEventListener('change', handleUpload);
  document.getElementById('empty-new-btn')?.addEventListener('click', createNote);
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    renderFiles();
  });

  init();
</script>
