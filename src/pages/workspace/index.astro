<script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev', TOKEN_KEY: 'meownote_auth_token' }}>
  let files = [];
  let sortBy = 'updated_at';
  let searchQuery = '';
  let deleteTargetId = null;
  let searchDebounce = null;
  let categoryFilter = 'all';

  const categoryTags = [
    { key: 'all', label: 'All', color: '' },
    { key: 'claude', label: 'Claude Code', color: 'var(--color-primary)' },
    { key: 'literature', label: '文献', color: '#4A5E8A' },
    { key: 'temp', label: '临时', color: '#6f8e7f' },
    { key: 'notes', label: '笔记', color: '#a07850' },
    { key: 'reference', label: '参考', color: '#8a7f74' },
  ];

  function getAuthToken() {
    const token = localStorage.getItem(TOKEN_KEY);
    if (!token) return null;
    try {
      return decodeURIComponent(atob(token));
    } catch {
      return token;
    }
  }

  function getAuthHeaders() {
    const headers = {};
    const token = getAuthToken();
    if (token) {
      headers['Authorization'] = `Bearer ${token}`;
    }
    return headers;
  }

  const filesGrid = document.getElementById('files-grid');
  const skeletonGrid = document.getElementById('skeleton-grid');
  const emptyState = document.getElementById('empty-state');
  const filesCount = document.getElementById('files-count');
  const sortHint = document.getElementById('sort-hint');
  const searchInput = document.getElementById('search-input');
  const fileUpload = document.getElementById('file-upload');
  const newNoteBtn = document.getElementById('new-note-btn');
  const uploadBtn = document.getElementById('upload-btn');
  const clipboardBtn = document.getElementById('clipboard-btn');
  const toast = document.getElementById('toast');
  const sortDropdown = document.getElementById('sort-dropdown');
  const sortBtn = document.getElementById('sort-btn');
  const sortLabel = document.getElementById('sort-label');

  const clipboardModal = document.getElementById('clipboard-modal');
  const clipboardBackdrop = document.getElementById('clipboard-backdrop');
  const clipboardClose = document.getElementById('clipboard-close');
  const clipboardTitle = document.getElementById('clipboard-title');
  const clipboardContent = document.getElementById('clipboard-content');
  const pasteBtn = document.getElementById('paste-btn');
  const saveClipboardBtn = document.getElementById('save-clipboard-btn');

  const deleteModal = document.getElementById('delete-modal');
  const deleteBackdrop = document.getElementById('delete-backdrop');
  const deleteClose = document.getElementById('delete-close');
  const deleteCancel = document.getElementById('delete-cancel');
  const deleteConfirm = document.getElementById('delete-confirm');

  const fileTypeConfig = {
    txt: { icon: 'text', type: 'text' },
    md: { icon: 'text', type: 'text' },
    markdown: { icon: 'text', type: 'text' },
    json: { icon: 'text', type: 'text' },
    js: { icon: 'text', type: 'text' },
    ts: { icon: 'text', type: 'text' },
    css: { icon: 'text', type: 'text' },
    html: { icon: 'text', type: 'text' },
    pdf: { icon: 'document', type: 'document' },
    doc: { icon: 'document', type: 'document' },
    docx: { icon: 'document', type: 'document' },
    xls: { icon: 'document', type: 'document' },
    xlsx: { icon: 'document', type: 'document' },
    png: { icon: 'image', type: 'image' },
    jpg: { icon: 'image', type: 'image' },
    jpeg: { icon: 'image', type: 'image' },
    gif: { icon: 'image', type: 'image' },
    zip: { icon: 'archive', type: 'archive' },
    rar: { icon: 'archive', type: 'archive' },
    clipboard: { icon: 'clipboard', type: 'clipboard' },
  };

  async function apiRequest(path, options = {}) {
    const isFormData = options.body && typeof FormData !== 'undefined' && options.body.constructor.name === 'FormData';
    const timeoutMs = isFormData ? 60000 : 10000;
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), timeoutMs);

    try {
      const headers = isFormData
        ? { ...getAuthHeaders(), ...(options.headers || {}) }
        : { 'Content-Type': 'application/json', ...getAuthHeaders(), ...(options.headers || {}) };

      const fetchOptions = {
        ...options,
        headers,
        signal: controller.signal,
      };

      console.log(`[API] ${options.method || 'GET'} ${API_BASE}${path}`, { isFormData, hasBody: !!options.body, bodyType: options.body?.constructor?.name });

      const response = await fetch(`${API_BASE}${path}`, fetchOptions);

      clearTimeout(timeoutId);

      console.log(`[API] Response: ${response.status} ${response.statusText}`);

      if (!response.ok) {
        if (response.status === 401) {
          throw new Error('请先登录');
        }
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || `HTTP ${response.status}: ${response.statusText}`);
      }

      return response.json();
    } catch (error) {
      clearTimeout(timeoutId);
      console.error(`[API] Error:`, error);
      throw error;
    }
  }

  async function init() {
    await loadFiles();
    initSortDropdown();
    initCategoryFilters();
    initModals();
    initGridActions();
  }

  function initCategoryFilters() {
    const filterContainer = document.getElementById('category-filters');
    if (!filterContainer) return;

    categoryTags.forEach((cat, idx) => {
      if (!cat.key || cat.key === 'all') return;
      const chip = document.createElement('button');
      chip.className = 'filter-chip';
      chip.setAttribute('data-category', cat.key);
      if (cat.color) {
        chip.style.setProperty('--chip-color', cat.color);
      }
      chip.textContent = cat.label;
      filterContainer.appendChild(chip);
    });

    filterContainer.querySelectorAll('.filter-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        filterContainer.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        categoryFilter = chip.getAttribute('data-category') || 'all';
        renderFiles();
      });
    });
  }

  function initSortDropdown() {
    sortBtn?.addEventListener('click', () => sortDropdown?.classList.toggle('open'));
    document.querySelectorAll('.sort-option').forEach((option) => {
      option.addEventListener('click', () => {
        document.querySelectorAll('.sort-option').forEach((item) => item.classList.remove('active'));
        option.classList.add('active');
        sortBy = option.getAttribute('data-sort') || 'updated_at';
        if (sortLabel) sortLabel.textContent = option.textContent;
        sortDropdown?.classList.remove('open');
        loadFiles();
      });
    });

    document.addEventListener('click', (event) => {
      if (!sortDropdown?.contains(event.target)) {
        sortDropdown?.classList.remove('open');
      }
    });
  }

  function initModals() {
    clipboardBtn?.addEventListener('click', () => clipboardModal?.classList.add('open'));
    clipboardBackdrop?.addEventListener('click', () => clipboardModal?.classList.remove('open'));
    clipboardClose?.addEventListener('click', () => clipboardModal?.classList.remove('open'));
    pasteBtn?.addEventListener('click', pasteFromClipboard);
    saveClipboardBtn?.addEventListener('click', saveClipboard);

    deleteBackdrop?.addEventListener('click', () => deleteModal?.classList.remove('open'));
    deleteClose?.addEventListener('click', () => deleteModal?.classList.remove('open'));
    deleteCancel?.addEventListener('click', () => deleteModal?.classList.remove('open'));
    deleteConfirm?.addEventListener('click', confirmDelete);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        clipboardModal?.classList.remove('open');
        deleteModal?.classList.remove('open');
      }
    });
  }

  function initGridActions() {
    filesGrid?.addEventListener('click', async (event) => {
      const actionBtn = event.target.closest('.file-card-btn');
      if (actionBtn) {
        event.preventDefault();
        event.stopPropagation();
        const id = actionBtn.getAttribute('data-id');
        const action = actionBtn.getAttribute('data-action');
        const file = files.find((item) => item.id === id);

        if (!id) return;

        if (action === 'open') {
          window.location.href = `/workspace/edit?id=${id}`;
        } else if (action === 'tag') {
          openTagPicker(id);
        } else if (action === 'download') {
          if (file) {
            await downloadWorkspaceFile(id, file.title || 'download', file.type || 'txt');
          }
        } else if (action === 'delete') {
          deleteTargetId = id;
          deleteModal?.classList.add('open');
        }
        return;
      }

      const card = event.target.closest('.file-card');
      if (!card || event.target.closest('button')) return;
      const id = card.getAttribute('data-id');
      if (id) {
        window.location.href = `/workspace/edit?id=${id}`;
      }
    });
  }

  async function loadFiles() {
    showLoading();

    try {
      const params = [`sortBy=${sortBy}`, 'order=desc'];
      if (searchQuery) params.push(`search=${encodeURIComponent(searchQuery)}`);

      const result = await apiRequest(`/api/workspace?${params.join('&')}`);
      files = result.data || [];
      renderFiles();
    } catch (error) {
      console.error('Load failed:', error);
      showToast('Failed to load files', 'error');
    } finally {
      hideLoading();
    }
  }

  function formatDateTime(dateStr) {
    if (!dateStr) return '';
    const date = new Date(dateStr.replace(' ', 'T') + 'Z');
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    const h = String(date.getHours()).padStart(2, '0');
    const min = String(date.getMinutes()).padStart(2, '0');
    return `${y}-${m}-${d} ${h}:${min}`;
  }

  function formatSize(bytes) {
    if (!bytes) return '';
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function isEditableType(type) {
    return ['txt', 'md', 'markdown', 'json', 'js', 'ts', 'css', 'html', 'clipboard'].includes((type || '').toLowerCase());
  }

  function updateResultsCopy() {
    if (filesCount) {
      filesCount.textContent = `${files.length} item${files.length === 1 ? '' : 's'}`;
    }

    if (!sortHint) return;

    if (searchQuery) {
      sortHint.textContent = files.length === 0
        ? `No matches for "${searchQuery}".`
        : `${files.length} result${files.length === 1 ? '' : 's'} for "${searchQuery}".`;
      return;
    }

    const messages = {
      updated_at: 'Everything in your workspace, sorted by latest change.',
      created_at: 'Everything in your workspace, sorted by creation date.',
      title: 'Everything in your workspace, sorted alphabetically.',
    };

    sortHint.textContent = messages[sortBy] || messages.updated_at;
  }

  const categoryDefs = [
    { key: 'claude', label: 'Claude Code', color: '#d97757' },
    { key: 'literature', label: '文献', color: '#4A5E8A' },
    { key: 'temp', label: '临时', color: '#6f8e7f' },
    { key: 'notes', label: '笔记', color: '#a07850' },
    { key: 'reference', label: '参考', color: '#8a7f74' },
  ];

  function getCurrentTag(file) {
    const currentTags = (file.tag || '').split(',').map(t => t.trim()).filter(Boolean);
    return currentTags.find(t => categoryDefs.some(c => c.key === t)) || '';
  }

  function renderCategoryButton(file) {
    const currentTag = getCurrentTag(file);
    const cat = categoryDefs.find(c => c.key === currentTag);
    if (!cat) {
      return '<button class="file-card-btn secondary category-tag-btn" data-action="tag" data-id="${}" style="display: inline-flex; align-items: center; gap: 4px; padding: 8px 12px; background: var(--bg-secondary, #f5f0e8); color: var(--text-tertiary, #999); border: 1px dashed var(--border-primary, #ddd); border-radius: 20px; cursor: pointer; min-height: 2rem; font-size: 0.85rem;">Tag</button>';
    }
    return `<button class="file-card-btn secondary category-tag-btn" data-action="tag" data-id="${file.id}" style="display: inline-flex; align-items: center; gap: 4px; padding: 8px 12px; background: ${cat.color}15; color: ${cat.color}; border: 1px solid ${cat.color}40; border-radius: 20px; cursor: pointer; min-height: 2rem; font-size: 0.85rem;">${cat.label}</button>`;
  }

  let tagTargetId = null;

  function openTagPicker(fileId) {
    tagTargetId = fileId;
    const file = files.find(f => f.id === fileId);
    if (!file) return;

    const currentTag = getCurrentTag(file);
    const optionsEl = document.getElementById('tag-options');
    if (!optionsEl) return;

    optionsEl.innerHTML = categoryDefs.map(cat => {
      const isActive = cat.key === currentTag;
      return `<button class="tag-option${isActive ? ' active' : ''}" data-cat="${cat.key}" style="--cat-color: ${cat.color};">${cat.label}</button>`;
    }).join('');

    document.getElementById('tag-modal')?.classList.add('open');
  }

  async function saveCategory(category) {
    if (!tagTargetId) return;
    try {
      const result = await apiRequest(`/api/workspace/${tagTargetId}`, {
        method: 'PUT',
        body: JSON.stringify({ tag: category }),
      });
      if (result.success) {
        const file = files.find(f => f.id === tagTargetId);
        if (file) {
          file.tag = category;
        }
        renderFiles();
        showToast('Category updated', 'success');
      }
    } catch (error) {
      showToast('Failed to update category', 'error');
    }
    tagTargetId = null;
  }

  function renderFiles() {
    updateResultsCopy();

    const filteredFiles = files.filter(f => {
      if (categoryFilter === 'all') return true;
      const currentTag = getCurrentTag(f);
      return currentTag === categoryFilter;
    });

    if (filteredFiles.length === 0) {
      filesGrid.innerHTML = '';
      emptyState.classList.add('visible');
      return;
    }

    emptyState.classList.remove('visible');
    filesGrid.innerHTML = filteredFiles
      .map((file) => {
        const ext = (file.type || 'txt').toLowerCase();
        const config = fileTypeConfig[ext] || { icon: 'document', type: 'document' };
        const timeStr = formatDateTime(file.createdAt);
        const editable = isEditableType(ext);
        const size = formatSize(file.fileSize || 0);

        return `
          <article class="file-card" data-id="${file.id}" style="display: flex; flex-direction: column; padding: 1.25rem; background: #ffffff; border: 1px solid rgba(71,57,44,0.15); border-radius: 1.25rem; box-shadow: 0 4px 16px rgba(47,35,22,0.08); cursor: pointer; transition: all 0.2s ease;">
            <div class="file-card-top" style="display: flex; align-items: center; gap: 0.9rem;">
              <div class="file-icon ${config.type}" style="width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: white; background: ${config.type === 'text' ? '#d97757' : config.type === 'document' ? '#4A5E8A' : config.type === 'image' ? '#6f8e7f' : config.type === 'archive' ? '#a07850' : '#bf5c46'};">${getFileIcon(config.icon)}</div>
              <div class="file-content" style="flex: 1; min-width: 0;">
                <div class="file-title" style="font-size: 1rem; font-weight: 600; color: #171412; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${escapeHtml(file.title)}</div>
                <div class="file-meta" style="display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: #8a7f74;">
                  <span class="file-badge" style="background: rgba(217,119,87,0.12); color: #d97757; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">${escapeHtml(ext.toUpperCase())}</span>
                  <span>${timeStr}</span>
                  ${size ? `<span>·</span><span>${size}</span>` : ''}
                </div>
              </div>
            </div>
            <div class="file-card-actions" style="display: flex; align-items: center; gap: 8px; margin-top: 12px; padding-top: 12px; border-top: 1px solid #eee;">
              <button class="file-card-btn" data-action="open" data-id="${file.id}" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: #171412; color: white; border: none; border-radius: 20px; font-size: 0.9rem; font-weight: 500; cursor: pointer;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
                Open
              </button>
              <button class="file-card-btn secondary" data-action="download" data-id="${file.id}" style="display: inline-flex; align-items: center; justify-content: center; padding: 8px 12px; background: #f5f0e8; color: #333; border: 1px solid #ddd; border-radius: 20px; cursor: pointer;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
              </button>
              ${renderCategoryButton(file)}
              <button class="file-card-btn danger" data-action="delete" data-id="${file.id}" title="Delete" style="display: inline-flex; align-items: center; justify-content: center; padding: 8px; background: transparent; color: #999; border: none; cursor: pointer; margin-left: auto;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
              </button>
            </div>
          </article>
        `;
      })
      .join('');
  }

  function getFileIcon(type) {
    const icons = {
      text: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>',
      document: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>',
      image: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>',
      archive: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8v13H3V8"></path><path d="M1 3h22v5H1z"></path><path d="M10 12h4"></path></svg>',
      clipboard: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>',
    };

    return icons[type] || icons.document;
  }

  async function downloadWorkspaceFile(id, fallbackName = 'download', type = '') {
    try {
      console.log(`[Download] Downloading file: ${id} (${type})`);
      const response = await fetch(`${API_BASE}/api/workspace/${id}/download`, {
        headers: getAuthHeaders(),
      });

      console.log(`[Download] Response: ${response.status} ${response.statusText}`);

      if (!response.ok) {
        if (response.status === 401) {
          throw new Error('请先登录');
        }
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || `HTTP ${response.status}: ${response.statusText}`);
      }

      const blob = await response.blob();
      console.log(`[Download] Blob size: ${blob.size} bytes, type: ${blob.type}`);

      const blobUrl = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = blobUrl;

      const contentDisposition = response.headers.get('Content-Disposition') || '';
      const utf8Match = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
      const basicMatch = contentDisposition.match(/filename="([^"]+)"/i);
      const plainMatch = contentDisposition.match(/filename=([^;]+)/i);
      let filename = fallbackName;
      if (utf8Match?.[1]) {
        filename = decodeURIComponent(utf8Match[1]);
      } else if (basicMatch?.[1]) {
        filename = basicMatch[1];
      } else if (plainMatch?.[1]) {
        filename = plainMatch[1].replace(/^["']|["']$/g, '');
      }
      anchor.download = filename;
      console.log(`[Download] Filename: ${filename}`);

      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      setTimeout(() => URL.revokeObjectURL(blobUrl), 100);
      showToast('Downloaded', 'success');
    } catch (error) {
      console.error('[Download] Error:', error);
      showToast(error.message || 'Download failed', 'error');
    }
  }

  async function confirmDelete() {
    if (!deleteTargetId) return;
    deleteModal?.classList.remove('open');

    try {
      const result = await apiRequest(`/api/workspace/${deleteTargetId}`, { method: 'DELETE' });
      if (result.success) {
        showToast('Deleted', 'success');
        await loadFiles();
      } else {
        showToast(result.message || 'Delete failed', 'error');
      }
    } catch {
      showToast('Delete failed', 'error');
    }

    deleteTargetId = null;
  }

  async function pasteFromClipboard() {
    try {
      const text = await navigator.clipboard.readText();
      if (clipboardContent) clipboardContent.value = text;
      showToast('Pasted', 'success');
    } catch {
      showToast('Cannot access clipboard', 'error');
    }
  }

  async function saveClipboard() {
    const title = clipboardTitle?.value.trim() || 'Quick Clip';
    const content = clipboardContent?.value.trim();

    if (!content) {
      showToast('Please enter content', 'error');
      return;
    }

    try {
      const result = await apiRequest('/api/workspace', {
        method: 'POST',
        body: JSON.stringify({ title, content, type: 'clipboard', fileSize: content.length }),
      });

      if (result.success) {
        showToast('Saved', 'success');
        clipboardModal?.classList.remove('open');
        if (clipboardTitle) clipboardTitle.value = '';
        if (clipboardContent) clipboardContent.value = '';
        await loadFiles();
      } else {
        showToast(result.message || 'Save failed', 'error');
      }
    } catch {
      showToast('Save failed', 'error');
    }
  }

  async function createNote() {
    try {
      const result = await apiRequest('/api/workspace', {
        method: 'POST',
        body: JSON.stringify({ title: 'Untitled', content: '', type: 'txt' }),
      });

      if (result.success && result.data?.id) {
        window.location.href = `/workspace/edit?id=${result.data.id}`;
      } else {
        showToast('Failed to create note', 'error');
      }
    } catch {
      showToast('Failed to create note', 'error');
    }
  }

  async function handleUpload(event) {
    const input = event.target;
    const fileList = Array.from(input.files || []);

    if (fileList.length === 0) return;

    let successCount = 0;
    let errorCount = 0;
    const total = fileList.length;
    const errors = [];

    showToast(`Uploading ${total} file${total > 1 ? 's' : ''}...`, 'info');

    for (let i = 0; i < fileList.length; i++) {
      const file = fileList[i];
      try {
        console.log(`[Upload] Uploading: ${file.name} (${file.size} bytes, ${file.type})`);
        const formData = new FormData();
        formData.append('file', file);
        const result = await apiRequest('/api/workspace', {
          method: 'POST',
          body: formData,
        });

        console.log(`[Upload] Result for ${file.name}:`, result);

        if (result.success) {
          successCount++;
        } else {
          errorCount++;
          const errMsg = result.message || result.error || 'Unknown error';
          errors.push(`${file.name}: ${errMsg}`);
          console.error(`[Upload] Failed for ${file.name}:`, errMsg);
        }
      } catch (error) {
        errorCount++;
        const errMsg = error.message || 'Network error';
        errors.push(`${file.name}: ${errMsg}`);
        console.error(`[Upload] Error for ${file.name}:`, error);
      }
    }

    input.value = '';

    if (successCount > 0) {
      await loadFiles();
    }

    if (errorCount === 0) {
      showToast(`${successCount} file${successCount > 1 ? 's' : ''} uploaded`, 'success');
    } else if (successCount > 0) {
      showToast(`${successCount}/${total} uploaded, ${errorCount} failed`, 'warning');
    } else {
      const firstError = errors[0] || 'Upload failed';
      showToast(`Upload failed: ${firstError}`, 'error');
    }
  }

  function showLoading() {
    if (skeletonGrid) skeletonGrid.style.display = 'grid';
    emptyState?.classList.remove('visible');
    if (filesGrid) filesGrid.innerHTML = '';
  }

  function hideLoading() {
    if (skeletonGrid) skeletonGrid.style.display = 'none';
  }

  function showToast(message, type = 'success') {
    if (!toast) return;
    toast.textContent = message;
    toast.className = `toast show ${type}`;
    setTimeout(() => toast.classList.remove('show'), 2500);
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  newNoteBtn?.addEventListener('click', createNote);
  document.getElementById('empty-new-btn')?.addEventListener('click', createNote);
  uploadBtn?.addEventListener('click', () => fileUpload?.click());
  fileUpload?.addEventListener('change', handleUpload);
  searchInput?.addEventListener('input', (event) => {
    searchQuery = event.target.value;
    if (searchDebounce) clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => loadFiles(), 300);
  });

  init();
</script>
