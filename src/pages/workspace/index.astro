---
import Layout from '@layouts/Layout.astro';
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);
---

<Layout 
  title={`Workspace - LiveMind`}
  description="Collaborative workspace for notes and files"
>
  <section class="workspace-page">
    <div class="workspace-bg">
      <div class="bg-circle bg-circle-1"></div>
      <div class="bg-circle bg-circle-2"></div>
    </div>

    <div class="workspace-container">
      <!-- Header Section -->
      <div class="workspace-header">
        <div class="header-eyebrow">
          <span class="eyebrow-dot"></span>
          <span class="eyebrow-text">Personal Workspace</span>
        </div>
        
        <h1 class="workspace-title">
          Your Digital Workspace
        </h1>
        
        <p class="workspace-description">
          Organize your thoughts, collaborate on ideas, and keep your files in one place. 
          Sync across devices seamlessly.
        </p>
      </div>

      <!-- Toolbar -->
      <div class="workspace-toolbar">
        <div class="toolbar-left">
          <div class="search-box">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="search-input" placeholder="Search files..." />
          </div>
          
          <select class="sort-select" id="sort-select">
            <option value="updated_at">Recent Updates</option>
            <option value="created_at">Created Time</option>
            <option value="title">Name</option>
          </select>
        </div>
        
        <div class="toolbar-right">
          <button class="btn-secondary" id="upload-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            <span>Upload</span>
          </button>
          <button class="btn-primary" id="new-note-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>New Note</span>
          </button>
        </div>
      </div>

      <!-- Stats -->
      <div class="workspace-stats">
        <span id="files-count">0 files</span>
      </div>

      <!-- Loading State -->
      <div class="loading-state visible" id="loading-state">
        <div class="loading-spinner">
          <div class="spinner-ring"></div>
        </div>
        <p>Loading workspace...</p>
      </div>

      <!-- Empty State -->
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="12" y1="18" x2="12" y2="12"></line>
            <line x1="9" y1="15" x2="15" y2="15"></line>
          </svg>
        </div>
        <h3>No files yet</h3>
        <p>Create your first note or upload a file to get started</p>
        <div class="empty-actions">
          <button class="btn-empty-primary" id="empty-new-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Create First Note
          </button>
        </div>
      </div>

      <!-- Files Grid -->
      <div class="files-grid" id="files-grid"></div>
    </div>

    <!-- Hidden file input -->
    <input type="file" id="file-upload" hidden multiple accept=".txt,.md,.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.zip,.rar" />
  </section>

  <!-- Toast -->
  <div class="toast" id="toast"></div>
</Layout>

<style>
  /* Main Container */
  .workspace-page {
    min-height: 100vh;
    background: #F0E9DC;
    padding: calc(var(--header-height) + var(--space-8)) var(--space-6) var(--space-16);
    position: relative;
    overflow: hidden;
  }

  /* Background Decoration */
  .workspace-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
  }

  .bg-circle-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #C06B3E 0%, transparent 70%);
    top: -150px;
    right: -150px;
  }

  .bg-circle-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #5B7E6A 0%, transparent 70%);
    bottom: -100px;
    left: -100px;
  }

  .workspace-container {
    max-width: var(--container-xl);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Header Section */
  .workspace-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .eyebrow-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #7A6A52;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .workspace-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: var(--font-normal);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #1A1207;
    margin-bottom: var(--space-4);
  }

  .workspace-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: #6B5C42;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .workspace-description {
      font-size: var(--text-lg);
    }
  }

  /* Toolbar */
  .workspace-toolbar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .workspace-toolbar {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .toolbar-left,
  .toolbar-right {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .toolbar-left {
    flex: 1;
  }

  .search-box {
    flex: 1;
    max-width: 400px;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: #FFFFFF;
    border: 1px solid #D0C4B0;
    border-radius: var(--radius-lg);
    transition: all var(--duration-fast) var(--ease-default);
  }

  .search-box:focus-within {
    border-color: #C06B3E;
    box-shadow: 0 0 0 3px rgba(192, 107, 62, 0.1);
  }

  .search-box svg {
    color: #7A6A52;
    flex-shrink: 0;
  }

  .search-box input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: var(--text-sm);
    color: #1A1207;
    outline: none;
    font-family: var(--font-sans);
  }

  .search-box input::placeholder {
    color: #9A8A72;
  }

  .sort-select {
    padding: var(--space-3) var(--space-4);
    background: #FFFFFF;
    border: 1px solid #D0C4B0;
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: #1A1207;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .sort-select:hover {
    border-color: #C4B9A5;
  }

  /* Buttons */
  .btn-primary,
  .btn-secondary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  .btn-primary {
    background: #1A1207;
    color: #F0E9DC;
    border: none;
  }

  .btn-primary:hover {
    background: #2C2210;
  }

  .btn-secondary {
    background: #FFFFFF;
    color: #1A1207;
    border: 1px solid #D0C4B0;
  }

  .btn-secondary:hover {
    border-color: #C06B3E;
    color: #C06B3E;
  }

  /* Stats */
  .workspace-stats {
    margin-bottom: var(--space-6);
  }

  .workspace-stats span {
    font-size: var(--text-sm);
    color: #7A6A52;
    font-family: var(--font-sans);
  }

  /* Files Grid */
  .files-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .files-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .files-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* File Card */
  .file-card {
    background: #EDE5D4;
    border: 1px solid #D0C4B0;
    border-radius: 16px;
    padding: var(--space-6);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    position: relative;
    overflow: hidden;
  }

  .file-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: transparent;
    transition: background var(--duration-fast) var(--ease-default);
  }

  .file-card:hover {
    border-color: #C4B9A5;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .file-card:hover::before {
    background: #C06B3E;
  }

  .file-header {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .file-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .file-card:hover .file-icon {
    transform: scale(1.05);
  }

  .file-icon.text {
    background: rgba(59, 130, 246, 0.12);
    color: #3B82F6;
  }

  .file-icon.document {
    background: rgba(168, 85, 247, 0.12);
    color: #A855F7;
  }

  .file-icon.image {
    background: rgba(34, 197, 94, 0.12);
    color: #22C55E;
  }

  .file-icon.archive {
    background: rgba(249, 115, 22, 0.12);
    color: #F97316;
  }

  .file-info {
    flex: 1;
    min-width: 0;
  }

  .file-title {
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    color: #1A1207;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: var(--space-1);
    font-family: var(--font-sans);
  }

  .file-card:hover .file-title {
    color: #C06B3E;
  }

  .file-meta {
    font-size: var(--text-xs);
    color: #7A6A52;
    font-family: var(--font-sans);
  }

  .file-preview {
    font-size: var(--text-sm);
    color: #6B5C42;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font-sans);
  }

  /* Delete Button */
  .file-actions {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
  }

  .delete-btn {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid transparent;
    color: #7A6A52;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .file-card:hover .delete-btn {
    opacity: 1;
  }

  .delete-btn:hover {
    background: rgba(220, 38, 38, 0.1);
    border-color: rgba(220, 38, 38, 0.2);
    color: #DC2626;
  }

  /* Loading State */
  .loading-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-4);
  }

  .loading-state.visible {
    display: flex;
  }

  .loading-spinner {
    position: relative;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
  }

  .spinner-ring {
    position: absolute;
    inset: 0;
    border: 3px solid #D0C4B0;
    border-top-color: #C06B3E;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-state p {
    font-size: var(--text-sm);
    color: #7A6A52;
    font-family: var(--font-sans);
  }

  /* Empty State */
  .empty-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-4);
  }

  .empty-state.visible {
    display: flex;
  }

  .empty-icon {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: rgba(192, 107, 62, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
  }

  .empty-icon svg {
    color: #C06B3E;
  }

  .empty-state h3 {
    font-size: var(--text-xl);
    color: #1A1207;
    margin: 0 0 var(--space-2);
    font-family: var(--font-display);
    font-weight: var(--font-normal);
  }

  .empty-state p {
    font-size: var(--text-sm);
    color: #7A6A52;
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  .empty-actions {
    display: flex;
    gap: var(--space-3);
  }

  .btn-empty-primary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: #C06B3E;
    color: #F0E9DC;
    border: none;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .btn-empty-primary:hover {
    background: #A85A32;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #1A1207;
    color: #F0E9DC;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    z-index: 1000;
    opacity: 0;
    transition: all var(--duration-normal) var(--ease-default);
    font-family: var(--font-sans);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  /* Dark Theme Support */
  [data-theme="dark"] .workspace-page {
    background: #1A1207;
  }

  [data-theme="dark"] .bg-circle {
    opacity: 0.05;
  }

  [data-theme="dark"] .workspace-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .workspace-description {
    color: #A89880;
  }

  [data-theme="dark"] .eyebrow-text {
    color: #A89880;
  }

  [data-theme="dark"] .search-box {
    background: #2C2210;
    border-color: rgba(240, 233, 220, 0.15);
  }

  [data-theme="dark"] .sort-select {
    background: #2C2210;
    border-color: rgba(240, 233, 220, 0.15);
    color: #F0E9DC;
  }

  [data-theme="dark"] .btn-secondary {
    background: #2C2210;
    color: #F0E9DC;
    border-color: rgba(240, 233, 220, 0.15);
  }

  [data-theme="dark"] .file-card {
    background: #2C2210;
    border-color: rgba(240, 233, 220, 0.15);
  }

  [data-theme="dark"] .file-card:hover {
    border-color: rgba(240, 233, 220, 0.25);
  }

  [data-theme="dark"] .file-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .file-preview,
  [data-theme="dark"] .file-meta {
    color: #A89880;
  }

  [data-theme="dark"] .delete-btn {
    background: rgba(240, 233, 220, 0.05);
    color: #A89880;
  }

  [data-theme="dark"] .empty-icon {
    background: rgba(192, 107, 62, 0.15);
  }

  [data-theme="dark"] .empty-state h3 {
    color: #F0E9DC;
  }

  [data-theme="dark"] .empty-state p {
    color: #A89880;
  }

  [data-theme="dark"] .toast {
    background: #F0E9DC;
    color: #1A1207;
  }

  [data-theme="dark"] .spinner-ring {
    border-color: rgba(240, 233, 220, 0.15);
    border-top-color: #C06B3E;
  }

  [data-theme="dark"] .loading-state p,
  [data-theme="dark"] .workspace-stats span {
    color: #A89880;
  }
</style>

<script>
  let files: any[] = [];
  let sortBy = 'updated_at';
  let searchQuery = '';

  // DOM Elements
  const filesGrid = document.getElementById('files-grid');
  const emptyState = document.getElementById('empty-state');
  const loadingState = document.getElementById('loading-state');
  const filesCount = document.getElementById('files-count');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const fileUpload = document.getElementById('file-upload') as HTMLInputElement;
  const newNoteBtn = document.getElementById('new-note-btn');
  const uploadBtn = document.getElementById('upload-btn');
  const toast = document.getElementById('toast');

  // File type config
  const fileTypeConfig: Record<string, { icon: string; type: string }> = {
    'txt': { icon: 'text', type: 'text' },
    'md': { icon: 'text', type: 'text' },
    'pdf': { icon: 'document', type: 'document' },
    'doc': { icon: 'document', type: 'document' },
    'docx': { icon: 'document', type: 'document' },
    'xls': { icon: 'document', type: 'document' },
    'xlsx': { icon: 'document', type: 'document' },
    'png': { icon: 'image', type: 'image' },
    'jpg': { icon: 'image', type: 'image' },
    'jpeg': { icon: 'image', type: 'image' },
    'gif': { icon: 'image', type: 'image' },
    'zip': { icon: 'archive', type: 'archive' },
    'rar': { icon: 'archive', type: 'archive' },
  };

  // Initialize
  async function init() {
    await loadFiles();
  }

  // Load files
  async function loadFiles() {
    showLoading();
    
    try {
      const response = await fetch(`/api/workspace?sortBy=${sortBy}&order=desc${searchQuery ? '&search=' + encodeURIComponent(searchQuery) : ''}`);
      const result = await response.json();
      
      files = result.data || [];
      renderFiles();
    } catch (error) {
      console.error('Load failed:', error);
      showToast('加载失败');
    } finally {
      hideLoading();
    }
  }

  // Render files
  function renderFiles() {
    const filtered = files.filter(f => 
      f.title.toLowerCase().includes(searchQuery.toLowerCase())
    );

    filesCount!.textContent = `${filtered.length} 个文件`;
    
    if (filtered.length === 0) {
      filesGrid!.innerHTML = '';
      emptyState!.classList.add('visible');
      return;
    }

    emptyState!.classList.remove('visible');
    
    filesGrid!.innerHTML = filtered.map(file => {
      const ext = file.type || 'txt';
      const config = fileTypeConfig[ext] || { icon: 'document', type: 'document' };
      const date = new Date(file.updatedAt || file.createdAt).toLocaleDateString();
      const preview = file.content ? file.content.substring(0, 50) + '...' : '';
      
      return `
        <div class="file-card" data-id="${file.id}">
          <div class="file-header">
            <div class="file-icon ${config.type}">
              ${getFileIcon(config.icon)}
            </div>
            <div class="file-info">
              <div class="file-title">${escapeHtml(file.title)}</div>
              <div class="file-meta">${ext.toUpperCase()} · ${date}</div>
            </div>
          </div>
          ${preview ? `<div class="file-preview">${escapeHtml(preview)}</div>` : ''}
          <div class="file-actions">
            <button class="delete-btn" data-id="${file.id}" title="删除">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </div>
        </div>
      `;
    }).join('');

    // Bind events
    document.querySelectorAll('.file-card').forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.delete-btn')) return;
        const id = card.getAttribute('data-id');
        if (id) window.location.href = `/workspace/edit?id=${id}`;
      });
    });

    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.getAttribute('data-id');
        if (id && confirm('确定删除此文件？')) {
          await deleteFile(id);
        }
      });
    });
  }

  // Get file icon SVG
  function getFileIcon(type: string): string {
    const icons: Record<string, string> = {
      text: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
      </svg>`,
      document: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
      </svg>`,
      image: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <polyline points="21 15 16 10 5 21"></polyline>
      </svg>`,
      archive: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 8v13H3V8"></path>
        <path d="M1 3h22v5H1z"></path>
        <path d="M10 12h4"></path>
      </svg>`
    };
    return icons[type] || icons.document;
  }

  // Delete file
  async function deleteFile(id: string) {
    try {
      const response = await fetch(`/api/workspace/${id}`, {
        method: 'DELETE'
      });
      
      const result = await response.json();
      
      if (result.success) {
        showToast('删除成功');
        await loadFiles();
      } else {
        showToast('删除失败');
      }
    } catch (error) {
      console.error('Delete failed:', error);
      showToast('删除失败');
    }
  }

  // Create new note
  async function createNote() {
    try {
      const response = await fetch('/api/workspace', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: 'Untitled Note',
          content: '',
          type: 'txt'
        })
      });
      
      const result = await response.json();
      
      if (result.success && result.data?.id) {
        showToast('Note created successfully');
        setTimeout(() => {
          window.location.href = `/workspace/edit?id=${result.data.id}`;
        }, 500);
      } else {
        showToast('Failed to create note');
      }
    } catch (error) {
      console.error('Create failed:', error);
      showToast('Failed to create note');
    }
  }

  // Upload file
  async function handleUpload(e: Event) {
    const input = e.target as HTMLInputElement;
    const fileList = input.files;
    if (!fileList || fileList.length === 0) return;

    let successCount = 0;
    let failCount = 0;

    for (const file of Array.from(fileList)) {
      try {
        const ext = file.name.split('.').pop()?.toLowerCase() || 'bin';
        const isText = ['txt', 'md'].includes(ext);
        
        let content = '';
        
        if (isText) {
          content = await file.text();
        }

        const response = await fetch('/api/workspace', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: file.name.replace(/\.[^/.]+$/, ''),
            content: content,
            type: ext,
            fileSize: file.size
          })
        });
        
        const result = await response.json();
        
        if (result.success) {
          successCount++;
        } else {
          failCount++;
        }
      } catch (error) {
        console.error('Upload failed:', error);
        failCount++;
      }
    }

    input.value = '';
    
    if (successCount > 0) {
      showToast(`${successCount} file(s) uploaded successfully`);
    }
    if (failCount > 0) {
      showToast(`Failed to upload ${failCount} file(s)`);
    }
    
    await loadFiles();
  }

  // Helper functions
  function showLoading() {
    loadingState?.classList.add('visible');
    emptyState?.classList.remove('visible');
    if (filesGrid) filesGrid.innerHTML = '';
  }

  function hideLoading() {
    loadingState?.classList.remove('visible');
  }

  function showToast(message: string) {
    if (toast) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Event listeners
  newNoteBtn?.addEventListener('click', createNote);
  uploadBtn?.addEventListener('click', () => fileUpload?.click());
  fileUpload?.addEventListener('change', handleUpload);
  
  // Empty state button
  const emptyNewBtn = document.getElementById('empty-new-btn');
  emptyNewBtn?.addEventListener('click', createNote);
  
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    renderFiles();
  });
  
  sortSelect?.addEventListener('change', (e) => {
    sortBy = (e.target as HTMLSelectElement).value;
    loadFiles();
  });

  // Initialize
  init();
</script>
