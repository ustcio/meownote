---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title={`Workspace - MaxMin.dev`}
  description="Personal workspace for notes and files"
>
  <section class="workspace-page">
    <div class="workspace-container">
      <header class="workspace-header">
        <div class="workspace-header__copy">
          <span class="workspace-kicker">Personal workspace</span>
          <h1 class="page-title">Workspace</h1>
          <p class="page-subtitle">
            Keep notes, uploads, and quick captures in one calm place. Draft text inline, store files safely,
            and download anything when you need it.
          </p>
        </div>
        <div class="workspace-summary">
          <div class="summary-card">
            <span class="summary-label">Library</span>
            <strong id="files-count">0 items</strong>
          </div>
          <div class="summary-card">
            <span class="summary-label">Flow</span>
            <strong>Create, capture, upload</strong>
          </div>
        </div>
      </header>

      <div class="toolbar">
        <div class="toolbar-left">
          <div class="search-box">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text" id="search-input" placeholder="Search notes, titles, or pasted text" />
          </div>
          <div class="sort-dropdown" id="sort-dropdown">
            <button class="sort-btn" id="sort-btn">
              <span id="sort-label">Recent</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="sort-menu" id="sort-menu">
              <button class="sort-option active" data-sort="updated_at">Recent</button>
              <button class="sort-option" data-sort="created_at">Created</button>
              <button class="sort-option" data-sort="title">Name</button>
            </div>
          </div>
        </div>
        <div class="toolbar-right">
          <button class="btn-secondary" id="clipboard-btn" title="Quick capture">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
              <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
            </svg>
            <span>Quick clip</span>
          </button>
          <button class="btn-secondary" id="upload-btn" title="Upload files">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            <span>Upload</span>
          </button>
          <button class="btn-primary" id="new-note-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>New note</span>
          </button>
        </div>
        <p class="toolbar-hint" id="toolbar-hint">
          Upload documents, images, and archives. Text files stay editable in place.
        </p>
      </div>

      <div class="results-bar">
        <div>
          <p class="results-label">Recent items</p>
          <p class="results-caption" id="results-caption">Everything in your workspace, sorted by the latest change.</p>
        </div>
      </div>

      <div class="skeleton-grid" id="skeleton-grid">
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
      </div>

      <div class="empty-state" id="empty-state">
        <div class="empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
        </div>
        <h3>Nothing here yet</h3>
        <p>Start with a note, save a quick clip, or upload files you want close at hand.</p>
        <button class="btn-primary btn-lg" id="empty-new-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Create note
        </button>
      </div>

      <div class="files-grid" id="files-grid"></div>
    </div>

    <input type="file" id="file-upload" hidden multiple accept=".txt,.md,.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif,.zip,.rar" />
  </section>

  <div class="modal" id="clipboard-modal">
    <div class="modal-backdrop" id="clipboard-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3>Quick capture</h3>
        <button class="btn-icon-sm" id="clipboard-close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <input type="text" id="clipboard-title" placeholder="Title (optional)" class="input-field" />
        <textarea id="clipboard-content" placeholder="Paste or write a note you want to save for later..." rows="6" class="input-field textarea"></textarea>
        <div class="modal-actions">
          <button class="btn-secondary" id="paste-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            Paste
          </button>
          <button class="btn-primary" id="save-clipboard-btn">Save</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal" id="delete-modal">
    <div class="modal-backdrop" id="delete-backdrop"></div>
    <div class="modal-content modal-sm">
      <div class="modal-header">
        <h3>Delete item</h3>
        <button class="btn-icon-sm" id="delete-close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <p id="delete-message">This will permanently remove the item from your workspace.</p>
        <div class="modal-actions">
          <button class="btn-secondary" id="delete-cancel">Cancel</button>
          <button class="btn-danger" id="delete-confirm">Delete</button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>
</Layout>

<style>
  .workspace-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top right, rgba(217, 119, 87, 0.08), transparent 24rem),
      linear-gradient(180deg, rgba(255, 252, 247, 0.92) 0%, rgba(250, 246, 238, 0.72) 18%, transparent 100%);
    padding: calc(var(--header-height, 64px) + 36px) 24px 88px;
  }

  .workspace-container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .workspace-header {
    display: grid;
    gap: 1.5rem;
    padding: 1.75rem;
    margin-bottom: 1.35rem;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.75rem;
    background: rgba(255, 252, 247, 0.9);
    box-shadow: 0 22px 56px rgba(50, 34, 20, 0.08);
  }

  @media (min-width: 900px) {
    .workspace-header {
      grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
      align-items: start;
    }
  }

  .workspace-header__copy {
    display: grid;
    gap: 0.85rem;
  }

  .workspace-kicker {
    display: inline-flex;
    width: fit-content;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(23, 20, 18, 0.06);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .page-title {
    font-size: clamp(2.25rem, 4vw, 3.15rem);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .page-subtitle {
    max-width: 42rem;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .workspace-summary {
    display: grid;
    gap: 0.9rem;
  }

  .summary-card {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(71, 57, 44, 0.08);
  }

  .summary-label {
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .summary-card strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }

  .toolbar {
    display: grid;
    gap: 1rem;
    padding: 1.1rem 1.15rem;
    margin-bottom: 1rem;
    border: 1px solid rgba(71, 57, 44, 0.08);
    border-radius: 1.45rem;
    background: rgba(255, 253, 249, 0.88);
  }

  @media (min-width: 860px) {
    .toolbar {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    .toolbar-hint {
      grid-column: 1 / -1;
    }
  }

  .toolbar-left,
  .toolbar-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .toolbar-right {
    justify-content: flex-start;
  }

  .toolbar-hint {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .toolbar-hint.is-busy {
    color: var(--color-primary);
  }

  .toolbar-hint.is-error {
    color: var(--color-danger);
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 3rem;
    padding: 0.75rem 0.95rem;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 999px;
    min-width: min(100%, 22rem);
    flex: 1 1 20rem;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .search-box:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(217, 119, 87, 0.12);
  }

  .search-box svg {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .search-box input {
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    width: 100%;
    outline: none;
  }

  .search-box input::placeholder {
    color: var(--text-tertiary);
  }

  .sort-dropdown {
    position: relative;
  }

  .sort-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .sort-btn:hover {
    border-color: rgba(71, 57, 44, 0.2);
  }

  .sort-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: rgba(255, 253, 249, 0.98);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1rem;
    box-shadow: 0 20px 40px rgba(38, 29, 21, 0.12);
    min-width: 9rem;
    padding: 0.35rem;
    display: none;
    z-index: 100;
  }

  .sort-dropdown.open .sort-menu {
    display: block;
  }

  .sort-option {
    display: block;
    width: 100%;
    padding: 0.6rem 0.8rem;
    background: transparent;
    border: none;
    border-radius: 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    text-align: left;
    cursor: pointer;
    transition: background 0.1s ease;
  }

  .sort-option:hover {
    background: rgba(23, 20, 18, 0.05);
  }

  .sort-option.active {
    background: rgba(217, 119, 87, 0.14);
    color: var(--text-primary);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 3rem;
    padding: 0.75rem 1.1rem;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    border: none;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    box-shadow: var(--btn-primary-shadow);
  }

  .btn-primary:hover {
    background: var(--btn-primary-hover);
  }

  .btn-primary:disabled,
  .btn-secondary:disabled,
  .file-action:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    box-shadow: none;
  }

  .btn-primary.btn-lg {
    min-height: 3.25rem;
    padding-inline: 1.35rem;
    font-size: 0.96rem;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.84);
    color: var(--btn-secondary-text);
    border: 1px solid rgba(71, 57, 44, 0.12);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-secondary:hover {
    border-color: rgba(71, 57, 44, 0.2);
    background: rgba(255, 255, 255, 0.94);
  }

  .results-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-inline: 0.15rem;
  }

  .results-label {
    margin: 0 0 0.25rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  .results-caption {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .btn-icon-sm {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    border-radius: 8px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-icon-sm:hover {
    background: var(--bg-elevated);
    color: var(--text-primary);
  }

  .btn-danger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    background: var(--color-danger);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-danger:hover {
    background: var(--color-danger-hover);
  }

  .skeleton-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .skeleton-card {
    height: 220px;
    background: linear-gradient(90deg, rgba(222, 213, 200, 0.7) 0%, rgba(255, 253, 249, 0.92) 50%, rgba(222, 213, 200, 0.7) 100%);
    background-size: 200% 100%;
    border-radius: 1.5rem;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .empty-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 5rem 1.5rem;
    text-align: center;
    border: 1px dashed rgba(71, 57, 44, 0.15);
    border-radius: 1.75rem;
    background: rgba(255, 253, 249, 0.76);
  }

  .empty-state.visible {
    display: flex;
  }

  .empty-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(23, 20, 18, 0.06);
    border-radius: 20px;
    margin-bottom: 24px;
    color: var(--text-tertiary);
  }

  .empty-state h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .empty-state p {
    font-size: 0.96rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
    max-width: 30rem;
  }

  .files-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  .file-card {
    display: grid;
    gap: 1rem;
    min-height: 15rem;
    padding: 1.25rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(252, 247, 240, 0.94) 100%);
    border: 1px solid rgba(71, 57, 44, 0.14);
    border-radius: 1.5rem;
    transition: all var(--duration-normal) var(--ease-default);
    position: relative;
    box-shadow: 0 18px 40px rgba(47, 35, 22, 0.12);
  }

  .file-card:hover {
    border-color: rgba(71, 57, 44, 0.22);
    box-shadow: 0 24px 48px rgba(47, 35, 22, 0.16);
    transform: translateY(-2px);
  }

  .file-card-top {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .file-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .file-icon.text { background: var(--color-primary-light); color: var(--color-primary); }
  .file-icon.document { background: rgba(74, 94, 138, 0.1); color: #4A5E8A; }
  .file-icon.image { background: var(--color-success-light); color: var(--color-success); }
  .file-icon.archive { background: rgba(217, 119, 87, 0.1); color: var(--color-primary); }
  .file-icon.clipboard { background: var(--color-danger-light); color: var(--color-danger); }

  .file-info {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 0.55rem;
  }

  .file-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .file-badge,
  .file-size {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: var(--font-medium);
  }

  .file-badge {
    background: rgba(23, 20, 18, 0.06);
    color: var(--text-secondary);
  }

  .file-size {
    background: rgba(217, 119, 87, 0.08);
    color: var(--color-primary);
  }

  .file-title {
    font-size: 1.2rem;
    font-weight: var(--font-medium);
    color: var(--text-primary);
    line-height: 1.3;
  }

  .file-card:hover .file-title {
    color: var(--color-primary);
  }

  .file-meta {
    font-size: 0.86rem;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .file-preview {
    min-height: 3.8rem;
    font-size: 0.94rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .file-actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-top: auto;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(71, 57, 44, 0.08);
  }

  .file-action {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(71, 57, 44, 0.12);
    background: rgba(255, 255, 255, 0.9);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .file-action:hover {
    border-color: rgba(71, 57, 44, 0.22);
    background: rgba(255, 255, 255, 1);
  }

  .file-action.primary {
    background: var(--text-primary);
    color: white;
    border-color: transparent;
  }

  .file-action.primary:hover {
    background: #26211c;
  }

  .file-delete {
    width: 2.35rem;
    height: 2.35rem;
    margin-left: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 999px;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .file-delete:hover {
    background: rgba(186, 74, 47, 0.08);
    border-color: rgba(186, 74, 47, 0.16);
    color: var(--color-danger);
  }

  .modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .modal.open {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    position: relative;
    background: rgba(255, 253, 249, 0.98);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.5rem;
    width: 100%;
    max-width: 27rem;
    box-shadow: 0 24px 60px rgba(36, 28, 21, 0.18);
    animation: modalIn 0.2s ease;
  }

  .modal-content.modal-sm {
    max-width: 360px;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(71, 57, 44, 0.08);
  }

  .modal-header h3 {
    font-size: 1.05rem;
    font-weight: var(--font-semibold);
    color: var(--text-primary);
  }

  .modal-body {
    padding: 1.25rem;
  }

  .modal-body p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
  }

  .input-field {
    width: 100%;
    padding: 0.85rem 0.95rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    transition: all var(--duration-fast) var(--ease-default);
    margin-bottom: 0.85rem;
  }

  .input-field:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(217, 119, 87, 0.12);
  }

  .input-field::placeholder {
    color: var(--text-tertiary);
  }

  .input-field.textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.5;
  }

  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--text-primary);
    color: var(--text-inverse);
    padding: 0.8rem 1rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    z-index: 1001;
    opacity: 0;
    transition: all var(--duration-normal) var(--ease-default);
    box-shadow: var(--shadow-lg);
    pointer-events: none;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .toast.success {
    background: var(--color-success);
    color: white;
  }

  .toast.error {
    background: var(--color-danger);
    color: white;
  }

  @media (max-width: 640px) {
    .workspace-page {
      padding: calc(var(--header-height, 64px) + 24px) 16px 60px;
    }

    .workspace-header,
    .toolbar {
      padding: 1rem;
    }

    .toolbar-left,
    .toolbar-right {
      width: 100%;
    }

    .search-box {
      min-width: auto;
    }

    .files-grid {
      grid-template-columns: 1fr;
    }

    .file-card {
      padding: 1rem;
    }

    .file-actions {
      flex-wrap: wrap;
    }

    .file-action {
      flex: 1 1 calc(50% - 0.325rem);
    }
  }
</style>

<script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev' }}>
  let files = [];
  let sortBy = 'updated_at';
  let searchQuery = '';
  let deleteTargetId = null;
  let searchDebounce = null;
  const defaultToolbarHint = 'Upload documents, images, and archives. Text files stay editable in place.';

  const filesGrid = document.getElementById('files-grid');
  const skeletonGrid = document.getElementById('skeleton-grid');
  const emptyState = document.getElementById('empty-state');
  const filesCount = document.getElementById('files-count');
  const resultsCaption = document.getElementById('results-caption');
  const searchInput = document.getElementById('search-input');
  const fileUpload = document.getElementById('file-upload');
  const newNoteBtn = document.getElementById('new-note-btn');
  const uploadBtn = document.getElementById('upload-btn');
  const clipboardBtn = document.getElementById('clipboard-btn');
  const toolbarHint = document.getElementById('toolbar-hint');
  const toast = document.getElementById('toast');
  const sortDropdown = document.getElementById('sort-dropdown');
  const sortBtn = document.getElementById('sort-btn');
  const sortLabel = document.getElementById('sort-label');

  const clipboardModal = document.getElementById('clipboard-modal');
  const clipboardBackdrop = document.getElementById('clipboard-backdrop');
  const clipboardClose = document.getElementById('clipboard-close');
  const clipboardTitle = document.getElementById('clipboard-title');
  const clipboardContent = document.getElementById('clipboard-content');
  const pasteBtn = document.getElementById('paste-btn');
  const saveClipboardBtn = document.getElementById('save-clipboard-btn');

  const deleteModal = document.getElementById('delete-modal');
  const deleteBackdrop = document.getElementById('delete-backdrop');
  const deleteClose = document.getElementById('delete-close');
  const deleteCancel = document.getElementById('delete-cancel');
  const deleteConfirm = document.getElementById('delete-confirm');

  const fileTypeConfig = {
    txt: { icon: 'text', type: 'text' },
    md: { icon: 'text', type: 'text' },
    markdown: { icon: 'text', type: 'text' },
    json: { icon: 'text', type: 'text' },
    js: { icon: 'text', type: 'text' },
    ts: { icon: 'text', type: 'text' },
    css: { icon: 'text', type: 'text' },
    html: { icon: 'text', type: 'text' },
    pdf: { icon: 'document', type: 'document' },
    doc: { icon: 'document', type: 'document' },
    docx: { icon: 'document', type: 'document' },
    xls: { icon: 'document', type: 'document' },
    xlsx: { icon: 'document', type: 'document' },
    png: { icon: 'image', type: 'image' },
    jpg: { icon: 'image', type: 'image' },
    jpeg: { icon: 'image', type: 'image' },
    gif: { icon: 'image', type: 'image' },
    zip: { icon: 'archive', type: 'archive' },
    rar: { icon: 'archive', type: 'archive' },
    clipboard: { icon: 'clipboard', type: 'clipboard' },
  };

  async function apiRequest(path, options = {}) {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 10000);

    try {
      const isFormData = options.body instanceof FormData;
      const headers = isFormData
        ? { ...(options.headers || {}) }
        : { 'Content-Type': 'application/json', ...(options.headers || {}) };

      const response = await fetch(`${API_BASE}${path}`, {
        ...options,
        headers,
        signal: controller.signal,
      });

      clearTimeout(timeoutId);

      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || `HTTP ${response.status}`);
      }

      return response.json();
    } catch (error) {
      clearTimeout(timeoutId);
      throw error;
    }
  }

  async function init() {
    await loadFiles();
    initSortDropdown();
    initModals();
    initGridActions();
  }

  function initSortDropdown() {
    sortBtn?.addEventListener('click', () => sortDropdown?.classList.toggle('open'));
    document.querySelectorAll('.sort-option').forEach((option) => {
      option.addEventListener('click', () => {
        document.querySelectorAll('.sort-option').forEach((item) => item.classList.remove('active'));
        option.classList.add('active');
        sortBy = option.getAttribute('data-sort') || 'updated_at';
        if (sortLabel) sortLabel.textContent = option.textContent;
        sortDropdown?.classList.remove('open');
        loadFiles();
      });
    });

    document.addEventListener('click', (event) => {
      if (!sortDropdown?.contains(event.target)) {
        sortDropdown?.classList.remove('open');
      }
    });
  }

  function initModals() {
    clipboardBtn?.addEventListener('click', () => clipboardModal?.classList.add('open'));
    clipboardBackdrop?.addEventListener('click', () => clipboardModal?.classList.remove('open'));
    clipboardClose?.addEventListener('click', () => clipboardModal?.classList.remove('open'));
    pasteBtn?.addEventListener('click', pasteFromClipboard);
    saveClipboardBtn?.addEventListener('click', saveClipboard);

    deleteBackdrop?.addEventListener('click', () => deleteModal?.classList.remove('open'));
    deleteClose?.addEventListener('click', () => deleteModal?.classList.remove('open'));
    deleteCancel?.addEventListener('click', () => deleteModal?.classList.remove('open'));
    deleteConfirm?.addEventListener('click', confirmDelete);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        clipboardModal?.classList.remove('open');
        deleteModal?.classList.remove('open');
      }
    });
  }

  function initGridActions() {
    filesGrid?.addEventListener('click', async (event) => {
      const deleteButton = event.target.closest('.file-delete');
      if (deleteButton) {
        event.preventDefault();
        event.stopPropagation();
        const id = deleteButton.getAttribute('data-id');
        if (id) {
          deleteTargetId = id;
          deleteModal?.classList.add('open');
        }
        return;
      }

      const actionButton = event.target.closest('.file-action');
      if (actionButton) {
        event.preventDefault();
        event.stopPropagation();
        const id = actionButton.getAttribute('data-id');
        const action = actionButton.getAttribute('data-action');
        const file = files.find((item) => item.id === id);

        if (!id || !file) return;

        if (action === 'open') {
          window.location.href = `/workspace/edit?id=${id}`;
        }

        if (action === 'download') {
          await downloadWorkspaceFile(id, file.title || 'download', file.type || 'txt');
        }
        return;
      }

      const card = event.target.closest('.file-card');
      if (!card || event.target.closest('button')) return;
      const id = card.getAttribute('data-id');
      if (id) {
        window.location.href = `/workspace/edit?id=${id}`;
      }
    });
  }

  async function loadFiles() {
    showLoading();

    try {
      const params = [`sortBy=${sortBy}`, 'order=desc'];
      if (searchQuery) params.push(`search=${encodeURIComponent(searchQuery)}`);

      const result = await apiRequest(`/api/workspace?${params.join('&')}`);
      files = result.data || [];
      renderFiles();
    } catch (error) {
      console.error('Load failed:', error);
      showToast('Failed to load files', 'error');
    } finally {
      hideLoading();
    }
  }

  function getTimeAgo(date) {
    const diff = Date.now() - date.getTime();
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (minutes < 1) return 'Just now';
    if (minutes < 60) return `${minutes}m`;
    if (hours < 24) return `${hours}h`;
    if (days < 7) return `${days}d`;
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function formatSize(bytes) {
    if (!bytes) return '0 B';
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function isEditableType(type) {
    return ['txt', 'md', 'markdown', 'json', 'js', 'ts', 'css', 'html', 'clipboard'].includes((type || '').toLowerCase());
  }

  function getPreviewText(file) {
    if (file.content && file.content.trim()) {
      return file.content.replace(/\s+/g, ' ').trim();
    }

    if (!isEditableType(file.type) && !file.fileUrl) {
      return 'This older upload is missing stored binary data. Re-upload it to restore downloads.';
    }

    const fallback = {
      pdf: 'Stored PDF ready for download from your workspace.',
      doc: 'Stored document ready for download from your workspace.',
      docx: 'Stored document ready for download from your workspace.',
      xls: 'Spreadsheet stored safely in your workspace.',
      xlsx: 'Spreadsheet stored safely in your workspace.',
      png: 'Image stored safely in your workspace.',
      jpg: 'Image stored safely in your workspace.',
      jpeg: 'Image stored safely in your workspace.',
      gif: 'Image stored safely in your workspace.',
      zip: 'Archive stored safely in your workspace.',
      rar: 'Archive stored safely in your workspace.',
      clipboard: 'Quick capture saved for later reuse.',
    };

    return fallback[(file.type || '').toLowerCase()] || 'Saved in your workspace and ready when you need it.';
  }

  function updateResultsCopy() {
    if (filesCount) {
      filesCount.textContent = `${files.length} item${files.length === 1 ? '' : 's'}`;
    }

    if (!resultsCaption) return;

    if (searchQuery) {
      resultsCaption.textContent = files.length === 0
        ? `No matches for "${searchQuery}". Try a broader keyword.`
        : `${files.length} result${files.length === 1 ? '' : 's'} for "${searchQuery}".`;
      return;
    }

    const messages = {
      updated_at: 'Everything in your workspace, sorted by the latest change.',
      created_at: 'Everything in your workspace, sorted by when it was created.',
      title: 'Everything in your workspace, sorted alphabetically.',
    };

    resultsCaption.textContent = messages[sortBy] || messages.updated_at;
  }

  function renderFiles() {
    updateResultsCopy();

    if (files.length === 0) {
      filesGrid.innerHTML = '';
      emptyState.classList.add('visible');
      return;
    }

    emptyState.classList.remove('visible');
    filesGrid.innerHTML = files
      .map((file) => {
        const ext = (file.type || 'txt').toLowerCase();
        const config = fileTypeConfig[ext] || { icon: 'document', type: 'document' };
        const date = new Date(file.updatedAt || file.createdAt);
        const timeAgo = getTimeAgo(date);
        const preview = getPreviewText(file);
        const editable = isEditableType(ext);
        const storedFileReady = editable || Boolean(file.fileUrl);
        const statusLabel = editable
          ? 'Editable in workspace'
          : storedFileReady
            ? 'Stored file'
            : 'Missing file data';

        return `
          <article class="file-card" data-id="${file.id}">
            <div class="file-card-top">
              <div class="file-icon ${config.type}">${getFileIcon(config.icon)}</div>
              <div class="file-info">
                <div class="file-badges">
                  <span class="file-badge">${escapeHtml(ext.toUpperCase())}</span>
                  <span class="file-size">${escapeHtml(formatSize(file.fileSize || 0))}</span>
                </div>
                <div class="file-title">${escapeHtml(file.title)}</div>
                <div class="file-meta">
                  <span>Updated ${escapeHtml(timeAgo)}</span>
                  <span>·</span>
                  <span>${escapeHtml(statusLabel)}</span>
                </div>
              </div>
              <button class="file-delete" data-id="${file.id}" title="Delete">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v4a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
              </button>
            </div>
            <p class="file-preview">${escapeHtml(preview)}</p>
            <div class="file-actions">
              <button class="file-action primary" data-action="open" data-id="${file.id}">Open</button>
              <button class="file-action" data-action="download" data-id="${file.id}" ${storedFileReady ? '' : 'disabled'}>
                ${editable ? 'Export' : storedFileReady ? 'Download' : 'Unavailable'}
              </button>
            </div>
          </article>
        `;
      })
      .join('');
  }

  function getFileIcon(type) {
    const icons = {
      text: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>',
      document: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>',
      image: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>',
      archive: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8v13H3V8"></path><path d="M1 3h22v5H1z"></path><path d="M10 12h4"></path></svg>',
      clipboard: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>',
    };

    return icons[type] || icons.document;
  }

  function getDownloadFilename(response, fallbackName, type) {
    const contentDisposition = response.headers.get('Content-Disposition') || '';
    const utf8Match = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
    if (utf8Match?.[1]) {
      return decodeURIComponent(utf8Match[1]);
    }

    const basicMatch = contentDisposition.match(/filename="([^"]+)"/i);
    if (basicMatch?.[1]) {
      return basicMatch[1];
    }

    const normalizedType = (type || '').toLowerCase();
    const extension = normalizedType === 'clipboard' ? 'txt' : normalizedType;
    if (extension && !fallbackName.toLowerCase().endsWith(`.${extension}`)) {
      return `${fallbackName}.${extension}`;
    }

    return fallbackName || 'download';
  }

  async function downloadWorkspaceFile(id, fallbackName = 'download', type = '') {
    try {
      setToolbarHint('Preparing your download...', 'busy');
      const response = await fetch(`${API_BASE}/api/workspace/${id}/download`);

      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || 'Download failed');
      }

      const blob = await response.blob();
      const blobUrl = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = blobUrl;
      anchor.download = getDownloadFilename(response, fallbackName, type);
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(blobUrl);
      showToast('Download ready', 'success');
      resetToolbarHint();
    } catch (error) {
      console.error('Download failed:', error);
      showToast(error.message || 'Download failed', 'error');
      setToolbarHint('Download failed. Try re-uploading the file if it was added before this fix.', 'error');
    }
  }

  function setToolbarHint(message, state = 'default') {
    if (!toolbarHint) return;
    toolbarHint.textContent = message;
    toolbarHint.classList.remove('is-busy', 'is-error');
    if (state === 'busy') toolbarHint.classList.add('is-busy');
    if (state === 'error') toolbarHint.classList.add('is-error');
  }

  function resetToolbarHint() {
    setToolbarHint(defaultToolbarHint);
  }

  function setControlsDisabled(disabled) {
    [uploadBtn, newNoteBtn, clipboardBtn].forEach((button) => {
      if (button) button.disabled = disabled;
    });
  }

  async function confirmDelete() {
    if (!deleteTargetId) return;
    deleteModal?.classList.remove('open');

    try {
      const result = await apiRequest(`/api/workspace/${deleteTargetId}`, { method: 'DELETE' });
      if (result.success) {
        showToast('Deleted', 'success');
        await loadFiles();
      } else {
        showToast(result.message || 'Delete failed', 'error');
      }
    } catch {
      showToast('Delete failed', 'error');
    }

    deleteTargetId = null;
  }

  async function pasteFromClipboard() {
    try {
      const text = await navigator.clipboard.readText();
      if (clipboardContent) clipboardContent.value = text;
      showToast('Pasted', 'success');
    } catch {
      showToast('Cannot access clipboard', 'error');
    }
  }

  async function saveClipboard() {
    const title = clipboardTitle?.value.trim() || 'Quick Clip';
    const content = clipboardContent?.value.trim();

    if (!content) {
      showToast('Please enter content', 'error');
      return;
    }

    try {
      const result = await apiRequest('/api/workspace', {
        method: 'POST',
        body: JSON.stringify({ title, content, type: 'clipboard', fileSize: content.length }),
      });

      if (result.success) {
        showToast('Saved', 'success');
        clipboardModal?.classList.remove('open');
        if (clipboardTitle) clipboardTitle.value = '';
        if (clipboardContent) clipboardContent.value = '';
        await loadFiles();
      } else {
        showToast(result.message || 'Save failed', 'error');
      }
    } catch {
      showToast('Save failed', 'error');
    }
  }

  async function createNote() {
    try {
      const result = await apiRequest('/api/workspace', {
        method: 'POST',
        body: JSON.stringify({ title: 'Untitled', content: '', type: 'txt' }),
      });

      if (result.success && result.data?.id) {
        window.location.href = `/workspace/edit?id=${result.data.id}`;
      } else {
        showToast('Failed to create note', 'error');
      }
    } catch {
      showToast('Failed to create note', 'error');
    }
  }

  async function handleUpload(event) {
    const input = event.target;
    const fileList = Array.from(input.files || []);

    if (fileList.length === 0) return;

    let successCount = 0;
    setControlsDisabled(true);

    for (let index = 0; index < fileList.length; index++) {
      const file = fileList[index];
      setToolbarHint(`Uploading ${index + 1} of ${fileList.length}: ${file.name}`, 'busy');

      try {
        const formData = new FormData();
        formData.append('file', file);
        const result = await apiRequest('/api/workspace', {
          method: 'POST',
          body: formData,
        });

        if (result.success) {
          successCount++;
        }
      } catch (error) {
        console.error('Upload failed:', error);
      }
    }

    input.value = '';
    setControlsDisabled(false);

    if (successCount > 0) {
      showToast(`${successCount} file${successCount > 1 ? 's' : ''} uploaded`, 'success');
      await loadFiles();
    }

    if (successCount < fileList.length) {
      showToast('Some files failed to upload', 'error');
      setToolbarHint('Some files could not be uploaded. Try again with smaller files or a single retry.', 'error');
      return;
    }

    resetToolbarHint();
  }

  function showLoading() {
    if (skeletonGrid) skeletonGrid.style.display = 'grid';
    emptyState?.classList.remove('visible');
    if (filesGrid) filesGrid.innerHTML = '';
  }

  function hideLoading() {
    if (skeletonGrid) skeletonGrid.style.display = 'none';
  }

  function showToast(message, type = 'success') {
    if (!toast) return;
    toast.textContent = message;
    toast.className = `toast show ${type}`;
    setTimeout(() => toast.classList.remove('show'), 2500);
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  newNoteBtn?.addEventListener('click', createNote);
  document.getElementById('empty-new-btn')?.addEventListener('click', createNote);
  uploadBtn?.addEventListener('click', () => fileUpload?.click());
  fileUpload?.addEventListener('change', handleUpload);
  searchInput?.addEventListener('input', (event) => {
    searchQuery = event.target.value;
    if (searchDebounce) clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => loadFiles(), 300);
  });

  init();
</script>
