---
import Layout from '@layouts/Layout.astro';
---

<Layout 
  title="Edit Note - Workspace"
  description="Edit your note"
>
  <section class="editor-page">
    <div class="editor-container">
      <!-- Header -->
      <div class="editor-header">
        <a href="/workspace" class="back-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>Back to Workspace</span>
        </a>
        <div class="header-actions">
          <span class="save-status" id="save-status">
            <span class="status-dot"></span>
            Saved
          </span>
          <button class="btn-icon" id="copy-btn" title="Copy content">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
          <button class="btn-icon" id="download-btn" title="Download">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </button>
          <button class="btn-icon danger" id="delete-btn" title="Delete">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Loading State -->
      <div class="loading-state visible" id="loading-state">
        <div class="loading-spinner">
          <div class="spinner-ring"></div>
        </div>
        <p>Loading note...</p>
      </div>

      <!-- Editor -->
      <div class="editor-content" id="editor-content" style="display: none;">
        <input type="text" class="title-input" id="title-input" placeholder="Untitled Note" />
        <div class="editor-divider"></div>
        <textarea class="content-textarea" id="content-textarea" placeholder="Start writing your note...&#10;&#10;Markdown supported"></textarea>
      </div>

      <!-- File Preview (for non-text files) -->
      <div class="file-preview-container" id="file-preview-container" style="display: none;">
        <div class="file-info-card">
          <div class="file-icon-large" id="file-icon-large">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <h2 class="file-title-large" id="file-title-large"></h2>
          <div class="file-meta-large" id="file-meta-large"></div>
          <button class="btn-download" id="download-file-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download File</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Toast -->
  <div class="toast" id="toast"></div>
</Layout>

<style>
  /* Main Container */
  .editor-page {
    min-height: 100vh;
    background: #F0E9DC;
    padding-top: var(--header-height);
  }

  .editor-container {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  /* Header */
  .editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid #D0C4B0;
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: #7A6A52;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
    font-family: var(--font-sans);
  }

  .back-btn:hover {
    color: #C06B3E;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Save Status */
  .save-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: #7A6A52;
    padding: var(--space-2) var(--space-3);
    background: rgba(192, 107, 62, 0.08);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    transition: all var(--duration-fast) var(--ease-default);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5B7E6A;
    transition: background var(--duration-fast) var(--ease-default);
  }

  .save-status.saving {
    color: #C06B3E;
    background: rgba(192, 107, 62, 0.15);
  }

  .save-status.saving .status-dot {
    background: #C06B3E;
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Icon Buttons */
  .btn-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid #D0C4B0;
    color: #7A6A52;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-icon:hover {
    border-color: #C06B3E;
    color: #C06B3E;
    background: rgba(192, 107, 62, 0.08);
  }

  .btn-icon.danger:hover {
    border-color: #DC2626;
    color: #DC2626;
    background: rgba(220, 38, 38, 0.08);
  }

  /* Editor Content */
  .editor-content {
    display: flex;
    flex-direction: column;
  }

  .title-input {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-normal);
    color: #1A1207;
    border: none;
    background: transparent;
    outline: none;
    padding: 0;
    width: 100%;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .title-input::placeholder {
    color: #9A8A72;
  }

  .editor-divider {
    height: 1px;
    background: #E0D4C0;
    margin: var(--space-6) 0;
  }

  .content-textarea {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.8;
    color: #1A1207;
    border: none;
    background: transparent;
    outline: none;
    resize: none;
    min-height: calc(100vh - 300px);
    width: 100%;
  }

  .content-textarea::placeholder {
    color: #9A8A72;
  }

  /* Loading State */
  .loading-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-4);
  }

  .loading-state.visible {
    display: flex;
  }

  .loading-spinner {
    position: relative;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
  }

  .spinner-ring {
    position: absolute;
    inset: 0;
    border: 3px solid #D0C4B0;
    border-top-color: #C06B3E;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-state p {
    font-size: var(--text-sm);
    color: #7A6A52;
    font-family: var(--font-sans);
  }

  /* File Preview */
  .file-preview-container {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) var(--space-4);
  }

  .file-info-card {
    text-align: center;
    background: #EDE5D4;
    border: 1px solid #D0C4B0;
    border-radius: 20px;
    padding: var(--space-12);
    max-width: 400px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .file-icon-large {
    width: 96px;
    height: 96px;
    margin: 0 auto var(--space-6);
    background: rgba(192, 107, 62, 0.1);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #C06B3E;
  }

  .file-title-large {
    font-size: var(--text-2xl);
    color: #1A1207;
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-weight: var(--font-normal);
  }

  .file-meta-large {
    font-size: var(--text-sm);
    color: #7A6A52;
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: #1A1207;
    color: #F0E9DC;
    border: none;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .btn-download:hover {
    background: #2C2210;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: #1A1207;
    color: #F0E9DC;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    z-index: 1000;
    opacity: 0;
    transition: all var(--duration-normal) var(--ease-default);
    font-family: var(--font-sans);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  /* Dark Theme */
  [data-theme="dark"] .editor-page {
    background: #1A1207;
  }

  [data-theme="dark"] .editor-header {
    border-bottom-color: rgba(240, 233, 220, 0.15);
  }

  [data-theme="dark"] .back-btn {
    color: #A89880;
  }

  [data-theme="dark"] .back-btn:hover {
    color: #C06B3E;
  }

  [data-theme="dark"] .save-status {
    color: #A89880;
    background: rgba(192, 107, 62, 0.15);
  }

  [data-theme="dark"] .btn-icon {
    background: transparent;
    border-color: rgba(240, 233, 220, 0.15);
    color: #A89880;
  }

  [data-theme="dark"] .btn-icon:hover {
    border-color: #C06B3E;
    color: #C06B3E;
    background: rgba(192, 107, 62, 0.15);
  }

  [data-theme="dark"] .btn-icon.danger:hover {
    border-color: #DC2626;
    color: #DC2626;
    background: rgba(220, 38, 38, 0.15);
  }

  [data-theme="dark"] .title-input {
    color: #F0E9DC;
  }

  [data-theme="dark"] .title-input::placeholder {
    color: #6A5A42;
  }

  [data-theme="dark"] .editor-divider {
    background: rgba(240, 233, 220, 0.1);
  }

  [data-theme="dark"] .content-textarea {
    color: #F0E9DC;
  }

  [data-theme="dark"] .content-textarea::placeholder {
    color: #6A5A42;
  }

  [data-theme="dark"] .file-info-card {
    background: #2C2210;
    border-color: rgba(240, 233, 220, 0.15);
  }

  [data-theme="dark"] .file-title-large {
    color: #F0E9DC;
  }

  [data-theme="dark"] .file-meta-large {
    color: #A89880;
  }

  [data-theme="dark"] .btn-download {
    background: #F0E9DC;
    color: #1A1207;
  }

  [data-theme="dark"] .btn-download:hover {
    background: #EDE5D4;
  }

  [data-theme="dark"] .spinner-ring {
    border-color: rgba(240, 233, 220, 0.15);
    border-top-color: #C06B3E;
  }

  [data-theme="dark"] .loading-state p {
    color: #A89880;
  }

  [data-theme="dark"] .toast {
    background: #F0E9DC;
    color: #1A1207;
  }
</style>

<script>
  let fileId: string | null = null;
  let currentFile: any = null;
  let saveTimeout: number | null = null;

  // DOM Elements
  const loadingState = document.getElementById('loading-state');
  const editorContent = document.getElementById('editor-content');
  const filePreviewContainer = document.getElementById('file-preview-container');
  const titleInput = document.getElementById('title-input') as HTMLInputElement;
  const contentTextarea = document.getElementById('content-textarea') as HTMLTextAreaElement;
  const saveStatus = document.getElementById('save-status');
  const toast = document.getElementById('toast');

  // Initialize
  async function init() {
    const params = new URLSearchParams(window.location.search);
    fileId = params.get('id');
    
    if (!fileId) {
      window.location.href = '/workspace';
      return;
    }

    await loadFile();
  }

  // Load file
  async function loadFile() {
    try {
      const response = await fetch(`/api/workspace/${fileId}`);
      const result = await response.json();

      if (!result.success || !result.data) {
        showToast('File not found');
        setTimeout(() => window.location.href = '/workspace', 1500);
        return;
      }

      currentFile = result.data;
      const isText = ['txt', 'md'].includes(currentFile.type);

      if (isText) {
        showEditor();
        titleInput.value = currentFile.title || '';
        contentTextarea.value = currentFile.content || '';
        titleInput.addEventListener('input', scheduleSave);
        contentTextarea.addEventListener('input', scheduleSave);
      } else {
        showFilePreview();
      }
    } catch (error) {
      console.error('Load failed:', error);
      showToast('Failed to load file');
    } finally {
      loadingState?.classList.remove('visible');
    }
  }

  // Show editor
  function showEditor() {
    editorContent!.style.display = 'flex';
    filePreviewContainer!.style.display = 'none';
  }

  // Show file preview
  function showFilePreview() {
    editorContent!.style.display = 'none';
    filePreviewContainer!.style.display = 'flex';
    
    const ext = currentFile.type?.toUpperCase() || 'FILE';
    const size = currentFile.fileSize ? formatSize(currentFile.fileSize) : 'Unknown size';
    
    document.getElementById('file-title-large')!.textContent = currentFile.title || 'Untitled';
    document.getElementById('file-meta-large')!.textContent = `${ext} · ${size}`;
    
    document.getElementById('download-file-btn')?.addEventListener('click', downloadFile);
  }

  // Schedule auto-save
  function scheduleSave() {
    if (saveStatus) {
      saveStatus.innerHTML = '<span class="status-dot"></span>Saving...';
      saveStatus.classList.add('saving');
    }
    
    if (saveTimeout) clearTimeout(saveTimeout);
    
    saveTimeout = window.setTimeout(async () => {
      await saveFile();
    }, 500);
  }

  // Save file
  async function saveFile() {
    try {
      const response = await fetch(`/api/workspace/${fileId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: titleInput.value,
          content: contentTextarea.value
        })
      });
      
      const result = await response.json();
      
      if (result.success) {
        if (saveStatus) {
          saveStatus.innerHTML = '<span class="status-dot"></span>Saved';
          saveStatus.classList.remove('saving');
        }
      } else {
        showToast('Failed to save');
      }
    } catch (error) {
      console.error('Save failed:', error);
      showToast('Failed to save');
    }
  }

  // Copy content
  async function copyContent() {
    const content = contentTextarea.value;
    
    try {
      await navigator.clipboard.writeText(content);
      showToast('Copied to clipboard');
    } catch (error) {
      contentTextarea.select();
      document.execCommand('copy');
      showToast('Copied to clipboard');
    }
  }

  // Download as txt
  function downloadAsTxt() {
    const content = contentTextarea.value;
    const title = titleInput.value || 'Untitled';
    
    const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${title}.txt`;
    a.click();
    URL.revokeObjectURL(url);
    showToast('Downloaded successfully');
  }

  // Download non-text file
  async function downloadFile() {
    if (!currentFile?.fileUrl) {
      showToast('File unavailable');
      return;
    }

    showToast('Download feature coming soon');
  }

  // Delete file
  async function deleteFile() {
    if (!confirm('Are you sure you want to delete this file?')) return;

    try {
      const response = await fetch(`/api/workspace/${fileId}`, {
        method: 'DELETE'
      });
      
      const result = await response.json();
      
      if (result.success) {
        showToast('Deleted successfully');
        setTimeout(() => window.location.href = '/workspace', 1000);
      } else {
        showToast('Failed to delete');
      }
    } catch (error) {
      console.error('Delete failed:', error);
      showToast('Failed to delete');
    }
  }

  // Helper functions
  function formatSize(bytes: number): string {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function showToast(message: string) {
    if (toast) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
  }

  // Event listeners
  document.getElementById('copy-btn')?.addEventListener('click', copyContent);
  document.getElementById('download-btn')?.addEventListener('click', downloadAsTxt);
  document.getElementById('delete-btn')?.addEventListener('click', deleteFile);

  // Initialize
  init();
</script>
