---
import Layout from '@layouts/Layout.astro';
---

<Layout 
  title="Edit Note - Workspace"
  description="Edit your note"
>
  <section class="editor-page">
    <div class="editor-container">
      <div class="editor-header">
        <a href="/workspace" class="back-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>Back to Workspace</span>
        </a>
        <div class="header-actions">
          <span class="save-status" id="save-status">
            <span class="status-dot"></span>
            Saved
          </span>
          <button class="btn-icon" id="copy-btn" title="Copy content">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
          <button class="btn-icon" id="download-btn" title="Download">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </button>
          <button class="btn-icon danger" id="delete-btn" title="Delete">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
          </button>
        </div>
      </div>

      <div class="loading-state visible" id="loading-state">
        <div class="loading-spinner">
          <div class="spinner-ring"></div>
        </div>
        <p>Loading note...</p>
      </div>

      <div class="editor-content" id="editor-content" style="display: none;">
        <input type="text" class="title-input" id="title-input" placeholder="Untitled Note" />
        <div class="editor-divider"></div>
        
        <div class="markdown-toolbar">
          <button class="md-btn" data-action="bold" title="Bold (Ctrl+B)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"></path><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"></path></svg>
          </button>
          <button class="md-btn" data-action="italic" title="Italic (Ctrl+I)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="4" x2="10" y2="4"></line><line x1="14" y1="20" x2="5" y2="20"></line><line x1="15" y1="4" x2="9" y2="20"></line></svg>
          </button>
          <button class="md-btn" data-action="heading" title="Heading">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16"></path><path d="M4 6v12"></path><path d="M20 6v12"></path></svg>
          </button>
          <div class="toolbar-divider"></div>
          <button class="md-btn" data-action="list" title="Bullet List">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><circle cx="4" cy="6" r="1" fill="currentColor"></circle><circle cx="4" cy="12" r="1" fill="currentColor"></circle><circle cx="4" cy="18" r="1" fill="currentColor"></circle></svg>
          </button>
          <button class="md-btn" data-action="link" title="Link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          </button>
          <button class="md-btn" data-action="code" title="Code">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
          </button>
        </div>
        
        <textarea class="content-textarea" id="content-textarea" placeholder="Start writing your note...&#10;&#10;Markdown supported"></textarea>
        
        <div class="editor-status-bar">
          <span id="word-count">0 words</span>
          <span class="status-sep">·</span>
          <span id="char-count">0 characters</span>
          <div class="status-right">
            <span class="save-indicator" id="save-indicator">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
              Auto-saved
            </span>
          </div>
        </div>
      </div>

      <div class="file-preview-container" id="file-preview-container" style="display: none;">
        <div class="file-info-card">
          <div class="file-icon-large" id="file-icon-large">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <h2 class="file-title-large" id="file-title-large"></h2>
          <div class="file-meta-large" id="file-meta-large"></div>
          <button class="btn-download" id="download-file-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download File</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <div class="toast" id="toast"></div>
</Layout>

<style>
  .editor-page {
    min-height: 100vh;
    background: var(--bg-primary);
    padding-top: var(--header-height);
  }

  .editor-container {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-primary);
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
    font-family: var(--font-sans);
  }

  .back-btn:hover {
    color: var(--color-primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .save-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    padding: var(--space-2) var(--space-3);
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    transition: all var(--duration-fast) var(--ease-default);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    transition: background var(--duration-fast) var(--ease-default);
  }

  .save-status.saving {
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .save-status.saving .status-dot {
    background: var(--color-primary);
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .btn-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-icon:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .btn-icon.danger:hover {
    border-color: var(--color-danger);
    color: var(--color-danger);
    background: var(--color-danger-light);
  }

  .editor-content {
    display: flex;
    flex-direction: column;
  }

  .title-input {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    border: none;
    background: transparent;
    outline: none;
    padding: 0;
    width: 100%;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .title-input::placeholder {
    color: var(--text-tertiary);
  }

  .editor-divider {
    height: 1px;
    background: var(--border-secondary);
    margin: var(--space-6) 0;
  }

  .content-textarea {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--text-primary);
    border: none;
    background: transparent;
    outline: none;
    resize: none;
    min-height: calc(100vh - 300px);
    width: 100%;
  }

  .content-textarea::placeholder {
    color: var(--text-tertiary);
  }

  .markdown-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) 0;
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-secondary);
  }

  .md-btn {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .md-btn:hover {
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  .toolbar-divider {
    width: 1px;
    height: 20px;
    background: var(--border-primary);
    margin: 0 var(--space-2);
  }

  .editor-status-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) 0;
    margin-top: var(--space-8);
    border-top: 1px solid var(--border-secondary);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    font-family: var(--font-sans);
  }

  .status-sep {
    opacity: 0.5;
  }

  .status-right {
    margin-left: auto;
  }

  .save-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .save-indicator svg {
    color: var(--color-success);
  }

  .save-indicator.saving svg {
    color: var(--color-primary);
    animation: pulse 1s infinite;
  }

  .loading-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-4);
  }

  .loading-state.visible {
    display: flex;
  }

  .loading-spinner {
    position: relative;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
  }

  .spinner-ring {
    position: absolute;
    inset: 0;
    border: 3px solid var(--border-primary);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-state p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-family: var(--font-sans);
  }

  .file-preview-container {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) var(--space-4);
  }

  .file-info-card {
    text-align: center;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    padding: var(--space-12);
    max-width: 400px;
    box-shadow: var(--card-shadow);
  }

  .file-icon-large {
    width: 96px;
    height: 96px;
    margin: 0 auto var(--space-6);
    background: var(--color-primary-light);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }

  .file-title-large {
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-weight: var(--font-normal);
  }

  .file-meta-large {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--text-primary);
    color: var(--text-inverse);
    border: none;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .btn-download:hover {
    opacity: 0.85;
  }

  .toast {
    position: fixed;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--text-primary);
    color: var(--text-inverse);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    z-index: 1000;
    opacity: 0;
    transition: all var(--duration-normal) var(--ease-default);
    font-family: var(--font-sans);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .toast.success {
    background: var(--color-success);
  }

  .toast.error {
    background: var(--color-danger);
  }
</style>

<script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev' }}>
  let fileId = null;
  let currentFile = null;
  let saveTimeout = null;
  let isDirty = false;
  let isSaving = false;

  const loadingState = document.getElementById('loading-state');
  const editorContent = document.getElementById('editor-content');
  const filePreviewContainer = document.getElementById('file-preview-container');
  const titleInput = document.getElementById('title-input');
  const contentTextarea = document.getElementById('content-textarea');
  const toast = document.getElementById('toast');
  const wordCountEl = document.getElementById('word-count');
  const charCountEl = document.getElementById('char-count');
  const saveIndicator = document.getElementById('save-indicator');

  async function apiRequest(path, options = {}) {
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 10000);
    try {
      const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
      const response = await fetch(`${API_BASE}${path}`, { ...options, headers, signal: controller.signal });
      clearTimeout(timeoutId);
      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || `HTTP ${response.status}`);
      }
      return response.json();
    } catch (e) {
      clearTimeout(timeoutId);
      throw e;
    }
  }

  async function init() {
    const params = new URLSearchParams(window.location.search);
    fileId = params.get('id');

    if (!fileId) {
      window.location.href = '/workspace';
      return;
    }

    await loadFile();
    window.addEventListener('beforeunload', (e) => {
      if (isDirty) {
        e.preventDefault();
      }
    });
  }

  async function loadFile() {
    try {
      const result = await apiRequest(`/api/workspace/${fileId}`);

      if (!result.success || !result.data) {
        showToast('File not found', 'error');
        setTimeout(() => window.location.href = '/workspace', 1500);
        return;
      }

      currentFile = result.data;
      const isText = ['txt', 'md', 'clipboard'].includes(currentFile.type);

      if (isText) {
        showEditor();
        titleInput.value = currentFile.title || '';
        contentTextarea.value = currentFile.content || '';
        titleInput.addEventListener('input', () => { isDirty = true; scheduleSave(); });
        contentTextarea.addEventListener('input', () => { updateStats(); isDirty = true; scheduleSave(); });
      } else {
        showFilePreview();
      }
    } catch (error) {
      console.error('Load failed:', error);
      showToast('Failed to load file', 'error');
    } finally {
      loadingState?.classList.remove('visible');
    }
  }

  function showEditor() {
    editorContent.style.display = 'flex';
    filePreviewContainer.style.display = 'none';
    updateStats();
    initMarkdownToolbar();
    titleInput.focus();
  }

  function updateStats() {
    const text = contentTextarea.value;
    const words = text.trim() ? text.trim().split(/\s+/).length : 0;
    const chars = text.length;

    if (wordCountEl) wordCountEl.textContent = `${words} ${words === 1 ? 'word' : 'words'}`;
    if (charCountEl) charCountEl.textContent = `${chars} ${chars === 1 ? 'character' : 'characters'}`;
  }

  function initMarkdownToolbar() {
    const mdBtns = document.querySelectorAll('.md-btn');
    mdBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.getAttribute('data-action');
        if (action) applyMarkdown(action);
      });
    });
  }

  function applyMarkdown(action) {
    const start = contentTextarea.selectionStart;
    const end = contentTextarea.selectionEnd;
    const text = contentTextarea.value;
    const selected = text.substring(start, end);

    let replacement = '';

    switch (action) {
      case 'bold':
        replacement = `**${selected || 'bold text'}**`;
        break;
      case 'italic':
        replacement = `*${selected || 'italic text'}*`;
        break;
      case 'heading':
        replacement = `## ${selected || 'Heading'}`;
        break;
      case 'list':
        replacement = `\n- ${selected || 'List item'}`;
        break;
      case 'link':
        replacement = `[${selected || 'link text'}](url)`;
        break;
      case 'code':
        replacement = selected.includes('\n') ? `\`\`\`\n${selected || 'code'}\n\`\`\`` : `\`${selected || 'code'}\``;
        break;
    }

    contentTextarea.setRangeText(replacement, start, end, 'end');
    contentTextarea.focus();
    updateStats();
    scheduleSave();
  }

  function showFilePreview() {
    editorContent.style.display = 'none';
    filePreviewContainer.style.display = 'flex';

    const ext = currentFile.type?.toUpperCase() || 'FILE';
    const size = currentFile.fileSize ? formatSize(currentFile.fileSize) : 'Unknown size';

    document.getElementById('file-title-large').textContent = currentFile.title || 'Untitled';
    document.getElementById('file-meta-large').textContent = `${ext} · ${size}`;

    document.getElementById('download-file-btn')?.addEventListener('click', downloadFile);
  }

  function scheduleSave() {
    setSaveStatus('saving');
    if (saveTimeout) clearTimeout(saveTimeout);
    saveTimeout = window.setTimeout(async () => {
      await saveFile();
    }, 800);
  }

  async function saveFile() {
    if (isSaving) return;
    isSaving = true;

    try {
      const result = await apiRequest(`/api/workspace/${fileId}`, {
        method: 'PUT',
        body: JSON.stringify({
          title: titleInput.value,
          content: contentTextarea.value
        })
      });

      if (result.success) {
        isDirty = false;
        setSaveStatus('saved');
      } else {
        setSaveStatus('error');
        showToast('Failed to save', 'error');
      }
    } catch (error) {
      console.error('Save failed:', error);
      setSaveStatus('error');
      showToast('Failed to save', 'error');
    } finally {
      isSaving = false;
    }
  }

  function setSaveStatus(status) {
    const dotSvg = '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>';
    if (!saveIndicator) return;

    if (status === 'saving') {
      saveIndicator.classList.add('saving');
      saveIndicator.innerHTML = dotSvg + 'Saving...';
    } else if (status === 'saved') {
      saveIndicator.classList.remove('saving');
      saveIndicator.innerHTML = dotSvg + 'Auto-saved';
    } else {
      saveIndicator.classList.remove('saving');
      saveIndicator.innerHTML = dotSvg + 'Save failed';
    }
  }

  async function copyContent() {
    const content = contentTextarea.value;
    if (!content.trim()) {
      showToast('Nothing to copy', 'error');
      return;
    }

    try {
      await navigator.clipboard.writeText(content);
      showToast('Copied to clipboard', 'success');
    } catch {
      showToast('Clipboard access unavailable', 'error');
    }
  }

  function downloadAsTxt() {
    const content = contentTextarea.value;
    if (!content.trim()) {
      showToast('Nothing to download', 'error');
      return;
    }

    const title = titleInput.value || 'Untitled';
    const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${title}.txt`;
    a.click();
    URL.revokeObjectURL(url);
    showToast('Downloaded', 'success');
  }

  async function downloadFile() {
    if (!currentFile?.fileUrl) {
      showToast('File unavailable', 'error');
      return;
    }

    try {
      const response = await fetch(currentFile.fileUrl);
      if (!response.ok) throw new Error('Download failed');
      const blob = await response.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = currentFile.title || 'download';
      a.click();
      URL.revokeObjectURL(url);
      showToast('Downloaded', 'success');
    } catch {
      showToast('Download failed', 'error');
    }
  }

  async function deleteFile() {
    if (!confirm('Are you sure you want to delete this file?')) return;

    try {
      const result = await apiRequest(`/api/workspace/${fileId}`, { method: 'DELETE' });

      if (result.success) {
        isDirty = false;
        showToast('Deleted', 'success');
        setTimeout(() => window.location.href = '/workspace', 800);
      } else {
        showToast(result.message || 'Failed to delete', 'error');
      }
    } catch (error) {
      console.error('Delete failed:', error);
      showToast('Failed to delete', 'error');
    }
  }

  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function showToast(message, type = 'success') {
    if (toast) {
      toast.textContent = message;
      toast.className = 'toast show ' + type;
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => { toast.className = 'toast'; }, 300);
      }, 2500);
    }
  }

  document.getElementById('copy-btn')?.addEventListener('click', copyContent);
  document.getElementById('download-btn')?.addEventListener('click', downloadAsTxt);
  document.getElementById('delete-btn')?.addEventListener('click', deleteFile);

  init();
</script>
