---
import Layout from '@layouts/Layout.astro';
---

<Layout 
  title="Edit Note - Workspace"
  description="Edit your note"
>
  <section class="editor-page">
    <div class="editor-container">
      <div class="editor-header">
        <a href="/workspace/" class="editor-back-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>Back to workspace</span>
        </a>
        <div class="header-actions">
          <span class="save-status" id="save-status">
            <span class="status-dot"></span>
            Saved
          </span>
          <div class="editor-action-group" role="group" aria-label="File actions">
            <button class="editor-action-btn" id="copy-btn" title="Copy content">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <span>Copy</span>
            </button>
            <button class="editor-action-btn" id="download-btn" title="Download">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              <span>Export</span>
            </button>
            <button class="editor-action-btn editor-action-btn--danger" id="delete-btn" title="Delete">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
              <span>Delete</span>
            </button>
          </div>
        </div>
      </div>

      <div class="loading-state visible" id="loading-state">
        <div class="loading-spinner">
          <div class="spinner-ring"></div>
        </div>
        <p>Loading note...</p>
      </div>

      <div class="editor-content" id="editor-content" style="display: none;">
        <div class="editor-meta-row">
          <span class="editor-meta-pill" id="file-type-pill">TXT</span>
          <span class="editor-meta-copy" id="file-updated-copy">Last updated just now</span>
        </div>
        <input type="text" class="title-input" id="title-input" placeholder="Untitled note" />
        <div class="editor-divider"></div>
        
        <div class="markdown-toolbar">
          <button class="md-btn" data-action="bold" title="Bold (Ctrl+B)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"></path><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"></path></svg>
          </button>
          <button class="md-btn" data-action="italic" title="Italic (Ctrl+I)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="4" x2="10" y2="4"></line><line x1="14" y1="20" x2="5" y2="20"></line><line x1="15" y1="4" x2="9" y2="20"></line></svg>
          </button>
          <button class="md-btn" data-action="heading" title="Heading">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16"></path><path d="M4 6v12"></path><path d="M20 6v12"></path></svg>
          </button>
          <div class="toolbar-divider"></div>
          <button class="md-btn" data-action="list" title="Bullet List">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><circle cx="4" cy="6" r="1" fill="currentColor"></circle><circle cx="4" cy="12" r="1" fill="currentColor"></circle><circle cx="4" cy="18" r="1" fill="currentColor"></circle></svg>
          </button>
          <button class="md-btn" data-action="link" title="Link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          </button>
          <button class="md-btn" data-action="code" title="Code">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
          </button>
        </div>
        
        <textarea class="content-textarea" id="content-textarea" placeholder="Start writing your note...&#10;&#10;Markdown supported"></textarea>
        
        <div class="editor-status-bar">
          <span id="word-count">0 words</span>
          <span class="status-sep">·</span>
          <span id="char-count">0 characters</span>
          <div class="status-right">
            <span class="save-indicator" id="save-indicator">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
              Auto-saved
            </span>
          </div>
        </div>
      </div>

      <div class="file-preview-container" id="file-preview-container" style="display: none;">
        <div class="file-info-card">
          <div class="file-icon-large" id="file-icon-large">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <h2 class="file-title-large" id="file-title-large"></h2>
          <div class="file-meta-large" id="file-meta-large"></div>
          <p class="file-preview-copy" id="file-preview-copy">
            This file is stored in your workspace and ready for a direct download.
          </p>
          <button class="btn-download" id="download-file-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Download file</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <div class="toast" id="toast"></div>
</Layout>

<style>
  .editor-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top right, rgba(217, 119, 87, 0.08), transparent 22rem),
      linear-gradient(180deg, rgba(255, 252, 247, 0.92) 0%, rgba(250, 246, 238, 0.74) 18%, transparent 100%);
    padding-top: var(--header-height);
  }

  .editor-container {
    max-width: 980px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .editor-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    margin-bottom: var(--space-6);
    padding: 1rem 1.15rem;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.4rem;
    background: rgba(255, 252, 247, 0.88);
    box-shadow: 0 10px 30px rgba(47, 35, 22, 0.05);
  }

  .editor-back-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.75rem;
    width: fit-content;
    padding: 0 0.15rem;
    font-size: 0.96rem;
    font-weight: var(--font-medium);
    line-height: 1;
    white-space: nowrap;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
    font-family: var(--font-sans);
  }

  .editor-back-link svg {
    flex-shrink: 0;
  }

  .editor-back-link:hover {
    color: var(--color-primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .editor-action-group {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(71, 57, 44, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.04);
  }

  .save-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.75rem;
    padding: 0.72rem 1rem;
    font-size: 0.92rem;
    font-weight: var(--font-medium);
    line-height: 1;
    white-space: nowrap;
    color: var(--text-secondary);
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    transition: all var(--duration-fast) var(--ease-default);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-success);
    transition: background var(--duration-fast) var(--ease-default);
  }

  .save-status.saving {
    color: var(--color-primary);
    background: var(--color-primary-subtle);
  }

  .save-status.saving .status-dot {
    background: var(--color-primary);
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .editor-action-btn {
    min-height: 2.75rem;
    min-width: max-content;
    padding: 0.72rem 1rem;
    border-radius: 0;
    background: transparent;
    border: none;
    border-left: 1px solid rgba(71, 57, 44, 0.1);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.48rem;
    transition: all var(--duration-fast) var(--ease-default);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: var(--font-medium);
    line-height: 1;
    white-space: nowrap;
  }

  .editor-action-btn svg {
    flex-shrink: 0;
  }

  .editor-action-btn:first-child {
    border-left: none;
  }

  .editor-action-btn:hover {
    border-left-color: rgba(71, 57, 44, 0.1);
    color: var(--text-primary);
    background: rgba(71, 57, 44, 0.05);
  }

  .editor-action-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .editor-action-btn--danger:hover {
    color: var(--color-danger);
    background: rgba(186, 74, 47, 0.08);
  }

  .editor-action-btn.hidden {
    display: none;
  }

  .editor-content,
  .file-preview-container {
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.75rem;
    background: rgba(255, 253, 249, 0.92);
    box-shadow: 0 20px 48px rgba(47, 35, 22, 0.08);
  }

  .editor-content {
    display: flex;
    flex-direction: column;
  }

  .editor-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: var(--space-5);
  }

  .editor-meta-pill,
  .editor-meta-copy {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: var(--font-medium);
  }

  .editor-meta-pill {
    background: rgba(23, 20, 18, 0.06);
    color: var(--text-secondary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .editor-meta-copy {
    background: rgba(217, 119, 87, 0.08);
    color: var(--color-primary);
  }

  .title-input {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    border: none;
    background: transparent;
    outline: none;
    padding: 0;
    width: 100%;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .title-input::placeholder {
    color: var(--text-tertiary);
  }

  .editor-divider {
    height: 1px;
    background: var(--border-secondary);
    margin: var(--space-6) 0;
  }

  .content-textarea {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--text-primary);
    border: none;
    background: transparent;
    outline: none;
    resize: none;
    min-height: calc(100vh - 360px);
    width: 100%;
  }

  .content-textarea::placeholder {
    color: var(--text-tertiary);
  }

  .markdown-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) 0;
    margin-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-secondary);
  }

  .md-btn {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .md-btn:hover {
    background: var(--color-primary-light);
    color: var(--color-primary);
  }

  .toolbar-divider {
    width: 1px;
    height: 20px;
    background: var(--border-primary);
    margin: 0 var(--space-2);
  }

  .editor-status-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) 0;
    margin-top: var(--space-8);
    border-top: 1px solid var(--border-secondary);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    font-family: var(--font-sans);
  }

  .status-sep {
    opacity: 0.5;
  }

  .status-right {
    margin-left: auto;
  }

  .save-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .save-indicator svg {
    color: var(--color-success);
  }

  .save-indicator.saving svg {
    color: var(--color-primary);
    animation: pulse 1s infinite;
  }

  .loading-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-10) var(--space-4);
  }

  .loading-state.visible {
    display: flex;
  }

  .loading-spinner {
    position: relative;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
  }

  .spinner-ring {
    position: absolute;
    inset: 0;
    border: 3px solid var(--border-primary);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-state p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-family: var(--font-sans);
  }

  .file-preview-container {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .file-info-card {
    text-align: center;
    background: transparent;
    border: none;
    padding: var(--space-8) var(--space-4);
    max-width: 34rem;
  }

  .file-icon-large {
    width: 96px;
    height: 96px;
    margin: 0 auto var(--space-6);
    background: var(--color-primary-light);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }

  .file-title-large {
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    font-family: var(--font-display);
    font-weight: var(--font-normal);
  }

  .file-meta-large {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  .file-preview-copy {
    margin: 0 0 var(--space-6);
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--text-secondary);
    font-family: var(--font-sans);
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--text-primary);
    color: var(--text-inverse);
    border: none;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .btn-download:hover {
    opacity: 0.85;
  }

  .btn-download:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  @media (max-width: 760px) {
    .editor-container {
      padding: var(--space-6) var(--space-4);
    }

    .editor-header {
      grid-template-columns: 1fr;
      align-items: stretch;
      gap: 0.75rem;
    }

    .header-actions {
      width: 100%;
      justify-content: flex-start;
    }
  }

  @media (max-width: 480px) {
    .editor-container {
      padding: var(--space-4) var(--space-3);
    }

    .editor-header {
      padding: 0.75rem 0.9rem;
      border-radius: 1.1rem;
    }

    .editor-content,
    .file-preview-container {
      padding: 1rem;
      border-radius: 1.1rem;
    }

    .title-input {
      font-size: clamp(1.5rem, 5vw, 2rem);
    }

    .header-actions {
      gap: 0.4rem;
    }

    .editor-action-group {
      max-width: 100%;
    }

    .save-status {
      min-height: 2.4rem;
      padding: 0.58rem 0.85rem;
      font-size: 0.84rem;
    }

    .editor-action-btn {
      min-height: 2.4rem;
      min-width: max-content;
      padding: 0.56rem 0.78rem;
      font-size: 0.84rem;
    }

    .editor-action-btn span,
    .editor-back-link span {
      display: none;
    }

    .file-icon-large {
      width: 72px;
      height: 72px;
      border-radius: 16px;
    }

    .file-info-card {
      padding: var(--space-6) var(--space-2);
    }

    .content-textarea {
      min-height: 50vh;
    }

    .save-status {
      font-size: var(--text-xs);
      padding: var(--space-2) var(--space-2);
    }
  }

  .toast {
    position: fixed;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--text-primary);
    color: var(--text-inverse);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    z-index: 1000;
    opacity: 0;
    transition: all var(--duration-normal) var(--ease-default);
    font-family: var(--font-sans);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  .toast.success {
    background: var(--color-success);
  }

  .toast.error {
    background: var(--color-danger);
  }
</style>

<script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev', TOKEN_KEY: 'meownote_auth_token' }}>
  let fileId = null;
  let currentFile = null;
  let saveTimeout = null;
  let isDirty = false;
  let isSaving = false;
  let markdownToolbarReady = false;

  function getAuthToken() {
    const token = localStorage.getItem(TOKEN_KEY);
    if (!token) return null;
    try {
      return decodeURIComponent(atob(token));
    } catch {
      return token;
    }
  }

  function getAuthHeaders() {
    const headers = {};
    const token = getAuthToken();
    if (token) {
      headers['Authorization'] = `Bearer ${token}`;
    }
    return headers;
  }

  const loadingState = document.getElementById('loading-state');
  const editorContent = document.getElementById('editor-content');
  const filePreviewContainer = document.getElementById('file-preview-container');
  const titleInput = document.getElementById('title-input');
  const contentTextarea = document.getElementById('content-textarea');
  const toast = document.getElementById('toast');
  const wordCountEl = document.getElementById('word-count');
  const charCountEl = document.getElementById('char-count');
  const saveIndicator = document.getElementById('save-indicator');
  const saveStatus = document.getElementById('save-status');
  const copyBtn = document.getElementById('copy-btn');
  const downloadBtn = document.getElementById('download-btn');
  const fileTypePill = document.getElementById('file-type-pill');
  const fileUpdatedCopy = document.getElementById('file-updated-copy');
  const filePreviewCopy = document.getElementById('file-preview-copy');

  async function apiRequest(path, options = {}) {
    const isFormData = options.body instanceof FormData;
    const timeoutMs = isFormData ? 60000 : 10000;
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
    try {
      const headers = isFormData
        ? { ...getAuthHeaders(), ...(options.headers || {}) }
        : { 'Content-Type': 'application/json', ...getAuthHeaders(), ...(options.headers || {}) };
      const response = await fetch(`${API_BASE}${path}`, { ...options, headers, signal: controller.signal });
      clearTimeout(timeoutId);
      if (!response.ok) {
        if (response.status === 401) {
          throw new Error('请先登录');
        }
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || `HTTP ${response.status}`);
      }
      return response.json();
    } catch (e) {
      clearTimeout(timeoutId);
      throw e;
    }
  }

  function isTextType(type) {
    return ['txt', 'md', 'markdown', 'clipboard', 'json', 'js', 'ts', 'css', 'html'].includes((type || '').toLowerCase());
  }

  function getTypeLabel(type) {
    const normalized = (type || 'txt').toUpperCase();
    return normalized === 'MARKDOWN' ? 'MD' : normalized;
  }

  function getTextExtension(type) {
    const normalized = (type || 'txt').toLowerCase();
    if (normalized === 'clipboard') return 'txt';
    if (normalized === 'markdown') return 'md';
    return normalized || 'txt';
  }

  function formatDateTime(value) {
    if (!value) return 'just now';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return 'just now';
    return date.toLocaleString('en-US', {
      month: 'short',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    });
  }

  function getDownloadFilename(response, fallbackName, type) {
    const contentDisposition = response.headers.get('Content-Disposition') || '';
    const utf8Match = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
    if (utf8Match?.[1]) {
      return decodeURIComponent(utf8Match[1]);
    }

    const basicMatch = contentDisposition.match(/filename="([^"]+)"/i);
    if (basicMatch?.[1]) {
      return basicMatch[1];
    }

    const plainMatch = contentDisposition.match(/filename=([^;]+)/i);
    if (plainMatch?.[1]) {
      return plainMatch[1].replace(/^["']|["']$/g, '');
    }

    const extension = getTextExtension(type);
    if (extension && !fallbackName.toLowerCase().endsWith(`.${extension}`)) {
      return `${fallbackName}.${extension}`;
    }

    return fallbackName || 'download';
  }

  async function init() {
    const params = new URLSearchParams(window.location.search);
    fileId = params.get('id');

    if (!fileId) {
      window.location.href = '/workspace';
      return;
    }

    await loadFile();
    window.addEventListener('beforeunload', (e) => {
      if (isDirty) {
        e.preventDefault();
      }
    });
  }

  async function loadFile() {
    try {
      const result = await apiRequest(`/api/workspace/${fileId}`);

      if (!result.success || !result.data) {
        showToast('File not found', 'error');
        setTimeout(() => window.location.href = '/workspace', 1500);
        return;
      }

      currentFile = result.data;
      applyFileMetadata();
      const textFile = isTextType(currentFile.type);

      if (textFile) {
        showEditor();
        titleInput.value = currentFile.title || '';
        contentTextarea.value = currentFile.content || '';
        titleInput.addEventListener('input', () => { isDirty = true; scheduleSave(); });
        contentTextarea.addEventListener('input', () => { updateStats(); isDirty = true; scheduleSave(); });
      } else {
        showFilePreview();
      }
    } catch (error) {
      console.error('Load failed:', error);
      showToast('Failed to load file', 'error');
    } finally {
      loadingState?.classList.remove('visible');
    }
  }

  function applyFileMetadata() {
    if (!currentFile) return;

    if (fileTypePill) {
      fileTypePill.textContent = getTypeLabel(currentFile.type);
    }

    if (fileUpdatedCopy) {
      fileUpdatedCopy.textContent = `Last updated ${formatDateTime(currentFile.updatedAt || currentFile.createdAt)}`;
    }
  }

  function showEditor() {
    editorContent.style.display = 'flex';
    filePreviewContainer.style.display = 'none';
    updateStats();
    initMarkdownToolbar();
    copyBtn?.classList.remove('hidden');
    if (downloadBtn) downloadBtn.disabled = false;
    updateHeaderActions('Export');
    titleInput.focus();
  }

  function updateStats() {
    const text = contentTextarea.value;
    const words = text.trim() ? text.trim().split(/\s+/).length : 0;
    const chars = text.length;

    if (wordCountEl) wordCountEl.textContent = `${words} ${words === 1 ? 'word' : 'words'}`;
    if (charCountEl) charCountEl.textContent = `${chars} ${chars === 1 ? 'character' : 'characters'}`;
  }

  function initMarkdownToolbar() {
    if (markdownToolbarReady) return;
    const mdBtns = document.querySelectorAll('.md-btn');
    mdBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.getAttribute('data-action');
        if (action) applyMarkdown(action);
      });
    });
    markdownToolbarReady = true;
  }

  function applyMarkdown(action) {
    const start = contentTextarea.selectionStart;
    const end = contentTextarea.selectionEnd;
    const text = contentTextarea.value;
    const selected = text.substring(start, end);

    let replacement = '';

    switch (action) {
      case 'bold':
        replacement = `**${selected || 'bold text'}**`;
        break;
      case 'italic':
        replacement = `*${selected || 'italic text'}*`;
        break;
      case 'heading':
        replacement = `## ${selected || 'Heading'}`;
        break;
      case 'list':
        replacement = `\n- ${selected || 'List item'}`;
        break;
      case 'link':
        replacement = `[${selected || 'link text'}](url)`;
        break;
      case 'code':
        replacement = selected.includes('\n') ? `\`\`\`\n${selected || 'code'}\n\`\`\`` : `\`${selected || 'code'}\``;
        break;
    }

    contentTextarea.setRangeText(replacement, start, end, 'end');
    contentTextarea.focus();
    updateStats();
    scheduleSave();
  }

  function showFilePreview() {
    editorContent.style.display = 'none';
    filePreviewContainer.style.display = 'flex';
    copyBtn?.classList.add('hidden');

    const ext = currentFile.type?.toUpperCase() || 'FILE';
    const size = currentFile.fileSize ? formatSize(currentFile.fileSize) : 'Unknown size';
    const updated = formatDateTime(currentFile.updatedAt || currentFile.createdAt);
    const hasBinary = Boolean(currentFile.fileUrl);

    document.getElementById('file-title-large').textContent = currentFile.title || 'Untitled';
    document.getElementById('file-meta-large').textContent = `${ext} · ${size} · Updated ${updated}`;
    if (filePreviewCopy) {
      filePreviewCopy.textContent = hasBinary
        ? 'This file is stored in your workspace and now downloads through the server for better reliability.'
        : 'This older upload is missing its stored binary data. Re-upload it once to restore reliable downloads.';
    }

    const previewDownloadBtn = document.getElementById('download-file-btn');
    if (previewDownloadBtn) {
      previewDownloadBtn.disabled = !hasBinary;
    }

    if (downloadBtn) {
      downloadBtn.disabled = !hasBinary;
    }

    updateHeaderActions(hasBinary ? 'Download' : 'Unavailable');
    previewDownloadBtn?.addEventListener('click', downloadFile);
  }

  function scheduleSave() {
    setSaveStatus('saving');
    if (saveTimeout) clearTimeout(saveTimeout);
    saveTimeout = window.setTimeout(async () => {
      await saveFile();
    }, 800);
  }

  async function saveFile() {
    if (isSaving) return;
    isSaving = true;

    try {
      const result = await apiRequest(`/api/workspace/${fileId}`, {
        method: 'PUT',
        body: JSON.stringify({
          title: titleInput.value,
          content: contentTextarea.value
        })
      });

      if (result.success) {
        isDirty = false;
        currentFile = {
          ...currentFile,
          title: titleInput.value,
          content: contentTextarea.value,
          updatedAt: result.data?.updatedAt || new Date().toISOString(),
        };
        applyFileMetadata();
        setSaveStatus('saved');
      } else {
        setSaveStatus('error');
        showToast('Failed to save', 'error');
      }
    } catch (error) {
      console.error('Save failed:', error);
      setSaveStatus('error');
      showToast('Failed to save', 'error');
    } finally {
      isSaving = false;
    }
  }

  function setSaveStatus(status) {
    const dotSvg = '<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>';
    if (!saveIndicator) return;

    if (status === 'saving') {
      saveIndicator.classList.add('saving');
      saveIndicator.innerHTML = dotSvg + 'Saving...';
      if (saveStatus) saveStatus.innerHTML = '<span class="status-dot"></span>Saving';
      saveStatus?.classList.add('saving');
    } else if (status === 'saved') {
      saveIndicator.classList.remove('saving');
      saveIndicator.innerHTML = dotSvg + 'Auto-saved';
      if (saveStatus) saveStatus.innerHTML = '<span class="status-dot"></span>Saved';
      saveStatus?.classList.remove('saving');
    } else {
      saveIndicator.classList.remove('saving');
      saveIndicator.innerHTML = dotSvg + 'Save failed';
      if (saveStatus) saveStatus.innerHTML = '<span class="status-dot"></span>Save failed';
      saveStatus?.classList.remove('saving');
    }
  }

  function updateHeaderActions(downloadLabel) {
    const downloadText = downloadBtn?.querySelector('span');
    if (downloadText) {
      downloadText.textContent = downloadLabel;
    }
  }

  async function copyContent() {
    const content = contentTextarea.value;
    if (!content.trim()) {
      showToast('Nothing to copy', 'error');
      return;
    }

    try {
      await navigator.clipboard.writeText(content);
      showToast('Copied to clipboard', 'success');
    } catch {
      showToast('Clipboard access unavailable', 'error');
    }
  }

  function downloadAsText() {
    const content = contentTextarea.value ?? '';
    const title = (titleInput.value || currentFile?.title || 'Untitled').trim() || 'Untitled';
    const extension = getTextExtension(currentFile?.type);
    const mime = extension === 'md' ? 'text/markdown;charset=utf-8' : 'text/plain;charset=utf-8';
    const blob = new Blob([content], { type: mime });
    const url = URL.createObjectURL(blob);
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = title.toLowerCase().endsWith(`.${extension}`) ? title : `${title}.${extension}`;
    anchor.click();
    URL.revokeObjectURL(url);
    showToast('Downloaded', 'success');
  }

  async function downloadFile() {
    if (!currentFile?.fileUrl) {
      showToast('This file needs to be re-uploaded before it can be downloaded again', 'error');
      return;
    }

    try {
      const downloadPath = currentFile?.downloadUrl || `/api/workspace/${fileId}/download`;
      const response = await fetch(`${API_BASE}${downloadPath}`, {
        headers: getAuthHeaders(),
      });

      if (!response.ok) {
        if (response.status === 401) {
          throw new Error('请先登录');
        }
        const err = await response.json().catch(() => ({}));
        throw new Error(err.message || 'Download failed');
      }

      const blob = await response.blob();
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = getDownloadFilename(response, currentFile?.title || 'download', currentFile?.type || 'txt');
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      setTimeout(() => URL.revokeObjectURL(url), 100);
      showToast('Downloaded', 'success');
    } catch (error) {
      console.error('Download failed:', error);
      showToast(error.message || 'Download failed', 'error');
    }
  }

  function downloadCurrentFile() {
    if (isTextType(currentFile?.type)) {
      downloadAsText();
      return;
    }

    downloadFile();
  }

  async function deleteFile() {
    if (!confirm('Delete this item from your workspace?')) return;

    try {
      const result = await apiRequest(`/api/workspace/${fileId}`, { method: 'DELETE' });

      if (result.success) {
        isDirty = false;
        showToast('Deleted', 'success');
        setTimeout(() => window.location.href = '/workspace', 800);
      } else {
        showToast(result.message || 'Failed to delete', 'error');
      }
    } catch (error) {
      console.error('Delete failed:', error);
      showToast('Failed to delete', 'error');
    }
  }

  function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function showToast(message, type = 'success') {
    if (toast) {
      toast.textContent = message;
      toast.className = 'toast show ' + type;
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => { toast.className = 'toast'; }, 300);
      }, 2500);
    }
  }

  document.getElementById('copy-btn')?.addEventListener('click', copyContent);
  document.getElementById('download-btn')?.addEventListener('click', downloadCurrentFile);
  document.getElementById('delete-btn')?.addEventListener('click', deleteFile);

  init();
</script>
