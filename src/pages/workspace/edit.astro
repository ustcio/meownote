---
import Layout from '@layouts/Layout.astro';
---

<Layout 
  title="编辑笔记 - Workspace"
  description="Edit your note"
>
  <div class="editor-page">
    <div class="editor-container">
      <!-- Header -->
      <div class="editor-header">
        <a href="/workspace" class="back-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>返回</span>
        </a>
        <div class="header-actions">
          <span class="save-status" id="save-status">已保存</span>
          <button class="btn-icon" id="copy-btn" title="复制全部">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
          <button class="btn-icon" id="download-btn" title="下载">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </button>
          <button class="btn-icon danger" id="delete-btn" title="删除">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Loading State -->
      <div class="loading-state visible" id="loading-state">
        <div class="spinner"></div>
        <p>加载中...</p>
      </div>

      <!-- Editor -->
      <div class="editor-content" id="editor-content" style="display: none;">
        <input type="text" class="title-input" id="title-input" placeholder="输入标题..." />
        <textarea class="content-textarea" id="content-textarea" placeholder="开始输入内容...&#10;&#10;支持 Markdown 格式"></textarea>
      </div>

      <!-- File Preview (for non-text files) -->
      <div class="file-preview-container" id="file-preview-container" style="display: none;">
        <div class="file-info-card">
          <div class="file-icon-large" id="file-icon-large">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <h2 class="file-title-large" id="file-title-large"></h2>
          <div class="file-meta-large" id="file-meta-large"></div>
          <button class="btn-primary large" id="download-file-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>下载文件</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>
</Layout>

<style>
  .editor-page {
    min-height: 100vh;
    background: var(--bg-primary);
    padding-top: var(--header-height);
  }

  .editor-container {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-6);
  }

  .editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .back-btn:hover {
    color: var(--color-primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .save-status {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    padding: var(--space-1) var(--space-3);
    background: var(--bg-secondary);
    border-radius: var(--radius-full);
  }

  .save-status.saving {
    color: var(--color-primary);
  }

  .btn-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-icon:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .btn-icon.danger:hover {
    border-color: #DC2626;
    color: #DC2626;
  }

  .editor-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .title-input {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-normal);
    color: var(--text-primary);
    border: none;
    background: transparent;
    outline: none;
    padding: 0;
    width: 100%;
  }

  .title-input::placeholder {
    color: var(--text-muted);
  }

  .content-textarea {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--text-primary);
    border: none;
    background: transparent;
    outline: none;
    resize: none;
    min-height: calc(100vh - 250px);
    width: 100%;
  }

  .content-textarea::placeholder {
    color: var(--text-muted);
  }

  .loading-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-4);
  }

  .loading-state.visible {
    display: flex;
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid var(--border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: var(--space-4);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading-state p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .file-preview-container {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) var(--space-4);
  }

  .file-info-card {
    text-align: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    max-width: 400px;
  }

  .file-icon-large {
    width: 80px;
    height: 80px;
    margin: 0 auto var(--space-6);
    background: rgba(59, 130, 246, 0.1);
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3B82F6;
  }

  .file-title-large {
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .file-meta-large {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-6);
  }

  .btn-primary.large {
    padding: var(--space-4) var(--space-8);
  }

  .toast {
    position: fixed;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--text-primary);
    color: var(--bg-primary);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    z-index: 1000;
    opacity: 0;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
</style>

<script>
  let fileId: string | null = null;
  let currentFile: any = null;
  let saveTimeout: number | null = null;

  // DOM Elements
  const loadingState = document.getElementById('loading-state');
  const editorContent = document.getElementById('editor-content');
  const filePreviewContainer = document.getElementById('file-preview-container');
  const titleInput = document.getElementById('title-input') as HTMLInputElement;
  const contentTextarea = document.getElementById('content-textarea') as HTMLTextAreaElement;
  const saveStatus = document.getElementById('save-status');
  const toast = document.getElementById('toast');

  // Initialize
  async function init() {
    // Get file ID from URL query parameter
    const params = new URLSearchParams(window.location.search);
    fileId = params.get('id');
    
    if (!fileId) {
      window.location.href = '/workspace';
      return;
    }

    await loadFile();
  }

  // Load file
  async function loadFile() {
    try {
      const response = await fetch(`/api/workspace/${fileId}`);
      const result = await response.json();

      if (!result.success || !result.data) {
        showToast('文件不存在');
        setTimeout(() => window.location.href = '/workspace', 1500);
        return;
      }

      currentFile = result.data;

      // Check if text file
      const isText = ['txt', 'md'].includes(currentFile.type);

      if (isText) {
        showEditor();
        titleInput.value = currentFile.title || '';
        contentTextarea.value = currentFile.content || '';

        // Auto-save listeners
        titleInput.addEventListener('input', scheduleSave);
        contentTextarea.addEventListener('input', scheduleSave);
      } else {
        showFilePreview();
      }
    } catch (error) {
      console.error('Load failed:', error);
      showToast('加载失败');
    } finally {
      loadingState?.classList.remove('visible');
    }
  }

  // Show editor
  function showEditor() {
    editorContent!.style.display = 'flex';
    filePreviewContainer!.style.display = 'none';
  }

  // Show file preview
  function showFilePreview() {
    editorContent!.style.display = 'none';
    filePreviewContainer!.style.display = 'flex';
    
    const ext = currentFile.type?.toUpperCase() || 'FILE';
    const size = currentFile.fileSize ? formatSize(currentFile.fileSize) : '未知大小';
    
    document.getElementById('file-title-large')!.textContent = currentFile.title || '未命名文件';
    document.getElementById('file-meta-large')!.textContent = `${ext} · ${size}`;
    
    document.getElementById('download-file-btn')?.addEventListener('click', downloadFile);
  }

  // Schedule auto-save
  function scheduleSave() {
    if (saveStatus) {
      saveStatus.textContent = '保存中...';
      saveStatus.classList.add('saving');
    }
    
    if (saveTimeout) clearTimeout(saveTimeout);
    
    saveTimeout = window.setTimeout(async () => {
      await saveFile();
    }, 500);
  }

  // Save file
  async function saveFile() {
    try {
      const response = await fetch(`/api/workspace/${fileId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: titleInput.value,
          content: contentTextarea.value
        })
      });
      
      const result = await response.json();
      
      if (result.success) {
        if (saveStatus) {
          saveStatus.textContent = '已保存';
          saveStatus.classList.remove('saving');
        }
      } else {
        showToast('保存失败');
      }
    } catch (error) {
      console.error('Save failed:', error);
      showToast('保存失败');
    }
  }

  // Copy content
  async function copyContent() {
    const content = contentTextarea.value;
    
    try {
      await navigator.clipboard.writeText(content);
      showToast('已复制到剪贴板');
    } catch (error) {
      // Fallback
      contentTextarea.select();
      document.execCommand('copy');
      showToast('已复制到剪贴板');
    }
  }

  // Download as txt
  function downloadAsTxt() {
    const content = contentTextarea.value;
    const title = titleInput.value || '未命名';
    
    const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${title}.txt`;
    a.click();
    URL.revokeObjectURL(url);
  }

  // Download non-text file
  async function downloadFile() {
    if (!currentFile?.fileUrl) {
      showToast('文件不可用');
      return;
    }

    showToast('文件下载功能开发中');
  }

  // Delete file
  async function deleteFile() {
    if (!confirm('确定删除此文件？')) return;

    try {
      const response = await fetch(`/api/workspace/${fileId}`, {
        method: 'DELETE'
      });
      
      const result = await response.json();
      
      if (result.success) {
        showToast('删除成功');
        setTimeout(() => window.location.href = '/workspace', 1000);
      } else {
        showToast('删除失败');
      }
    } catch (error) {
      console.error('Delete failed:', error);
      showToast('删除失败');
    }
  }

  // Helper functions
  function formatSize(bytes: number): string {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function showToast(message: string) {
    if (toast) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
  }

  // Event listeners
  document.getElementById('copy-btn')?.addEventListener('click', copyContent);
  document.getElementById('download-btn')?.addEventListener('click', downloadAsTxt);
  document.getElementById('delete-btn')?.addEventListener('click', deleteFile);

  // Initialize
  init();
</script>
