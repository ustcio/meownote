---
import AppLayout from '@layouts/AppLayout.astro';

const title = 'Workspace Admin Login - Maxwell.Science';
const description = 'Secure access for the Maxwell workspace.';
const previewNotes = [
  'Private notes vault',
  'Fast capture & structured tags',
  'Workspace actions protected by admin access',
];
---

<AppLayout title={title} description={description}>
  <section class="workspace-login-page">
    <header class="workspace-login-nav">
      <a href="/" class="workspace-login-brand" aria-label="Maxwell.Science home">
        <span class="brand-mark">✳</span>
        <span class="brand-wordmark">
          <span class="brand-maxwell">Maxwell</span>
          <span class="brand-dot">.</span>
          <span class="brand-science">Science</span>
        </span>
      </a>

      <nav class="workspace-login-links" aria-label="Workspace navigation">
        <a href="/chatbot/">AI 助手</a>
        <a href="/kit/">Kit</a>
        <a href="/about/">About</a>
      </nav>

      <a href="/workspace/" class="workspace-login-console">
        Workspace
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <line x1="7" y1="17" x2="17" y2="7"></line>
          <polyline points="9 7 17 7 17 15"></polyline>
        </svg>
      </a>
    </header>

    <div class="workspace-login-shell">
      <div class="workspace-login-copy">
        <div class="workspace-login-kicker">Workspace authentication</div>
        <h1>Think fast,<br />build in private</h1>
        <p class="workspace-login-subtitle">Only the super administrator can enter this workspace.</p>

        <div class="workspace-login-card">
          <div class="workspace-login-card__head">
            <span class="admin-badge">Super Admin</span>
            <strong class="admin-name">YangHao</strong>
            <p>Use the administrator password to unlock notes, uploads, and editing tools.</p>
          </div>

          <form id="workspace-login-form" class="workspace-login-form">
            <button type="button" class="workspace-google-btn">
              <span class="google-g">G</span>
              Continue as YangHao
            </button>

            <div class="workspace-login-divider">
              <span>or</span>
            </div>

            <label class="workspace-field">
              <span>Administrator account</span>
              <input type="text" value="YangHao" readonly />
            </label>

            <label class="workspace-field">
              <span>Password</span>
              <input type="password" id="workspace-admin-password" name="password" placeholder="Enter administrator password" required />
            </label>

            <input type="hidden" id="workspace-next" value="/workspace/" />

            <button type="submit" class="workspace-submit-btn" id="workspace-login-submit">
              <span class="btn-label">Enter workspace</span>
              <span class="btn-spinner" aria-hidden="true"></span>
            </button>

            <p class="workspace-legal">
              By continuing, you confirm this area is reserved for the Maxwell workspace administrator.
            </p>
            <p class="workspace-login-error" id="workspace-login-error" hidden></p>
          </form>
        </div>

        <a href="/" class="workspace-download-link">
          <span class="download-icon">⌘</span>
          Back to Maxwell home
        </a>
      </div>

      <aside class="workspace-login-preview">
        <div class="preview-frame">
          <div class="preview-frame__noise"></div>
          <div class="preview-brand">
            <span class="preview-mark">✳</span>
            <div>
              <strong>Workspace</strong>
              <span>Maxwell admin console</span>
            </div>
          </div>

          <div class="preview-canvas">
            <div class="preview-card preview-card--hero">
              <span class="preview-card__eyebrow">Protected area</span>
              <h2>Claude-inspired calm,<br />built for operator focus.</h2>
              <p>Warm editorial typography, soft structure, and a single secure path into the workspace.</p>
            </div>

            <div class="preview-grid">
              {previewNotes.map((item) => (
                <article class="preview-card preview-card--mini">
                  <span class="preview-card__dot"></span>
                  <p>{item}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev' }}>
    (function() {
      const ADMIN_USERNAME = 'YangHao';
      const authStore = window.__meownoteAuth;

      const form = document.getElementById('workspace-login-form');
      const passwordInput = document.getElementById('workspace-admin-password');
      const errorEl = document.getElementById('workspace-login-error');
      const submitBtn = document.getElementById('workspace-login-submit');
      const nextInput = document.getElementById('workspace-next');

      function setError(message) {
        if (!errorEl) return;
        errorEl.hidden = !message;
        errorEl.textContent = message || '';
      }

      function setLoading(loading) {
        submitBtn?.classList.toggle('is-loading', loading);
        if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = loading;
      }

      function resolveNextPath() {
        const params = new URLSearchParams(window.location.search);
        const next = params.get('next');
        if (next && next.startsWith('/workspace')) {
          nextInput.value = next;
          return next;
        }
        return nextInput.value || '/workspace/';
      }

      function hydrateIfLoggedIn() {
        const token = authStore?.getToken?.();
        const user = authStore?.getUser?.();
        const username = user?.username || user?.name || '';
        const next = resolveNextPath();

        if (token && username === ADMIN_USERNAME) {
          window.location.replace(next);
        }
      }

      document.querySelector('.workspace-google-btn')?.addEventListener('click', () => {
        passwordInput?.focus();
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        setError('');

        const password = passwordInput instanceof HTMLInputElement ? passwordInput.value.trim() : '';
        const next = resolveNextPath();

        if (!password) {
          setError('请输入管理员密码。');
          return;
        }

        setLoading(true);

        try {
          const response = await fetch(`${API_BASE}/api/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: ADMIN_USERNAME, password }),
          });

          const result = await response.json().catch(() => ({}));

          if (!response.ok || !result.success) {
            throw new Error(result.message || '登录失败，请检查管理员密码。');
          }

          const user = result.user || {};
          const username = user.username || user.name || '';
          if (username !== ADMIN_USERNAME) {
            throw new Error('当前账号没有 Workspace 超级管理员权限。');
          }

          authStore?.setSession?.(result.token, user);
          window.__meownoteToast?.show('Workspace access granted', 'success');
          window.location.replace(next);
        } catch (error) {
          setError(error instanceof Error ? error.message : '登录失败，请稍后重试。');
          window.__meownoteToast?.show('Workspace login failed', 'error');
        } finally {
          setLoading(false);
        }
      });

      resolveNextPath();
      hydrateIfLoggedIn();
    })();
  </script>
</AppLayout>

<style>
  .workspace-login-page {
    min-height: 100vh;
    padding: 1rem;
    background:
      radial-gradient(circle at top left, rgba(238, 186, 198, 0.72), transparent 26%),
      radial-gradient(circle at 85% 18%, rgba(243, 208, 198, 0.55), transparent 24%),
      linear-gradient(180deg, #f6e4e7 0%, #f7f1eb 12%, #f9f6f1 100%);
    color: #171412;
  }

  .workspace-login-nav {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    max-width: 1480px;
    margin: 0 auto 1.25rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid rgba(108, 84, 73, 0.1);
    border-radius: 999px;
    background: rgba(255, 250, 246, 0.72);
    backdrop-filter: blur(14px);
    box-shadow: 0 14px 40px rgba(93, 67, 46, 0.07);
  }

  .workspace-login-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: inherit;
  }

  .brand-mark,
  .preview-mark {
    color: var(--color-primary);
    font-size: 2rem;
    line-height: 1;
  }

  .brand-wordmark {
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }

  .brand-maxwell {
    font-family: var(--font-editorial);
    font-size: 1.65rem;
    font-weight: 500;
  }

  .brand-dot {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin: 0 0.05em;
  }

  .brand-science {
    font-size: 1rem;
    color: var(--text-secondary);
  }

  .workspace-login-links {
    display: flex;
    justify-content: center;
    gap: 1.8rem;
  }

  .workspace-login-links a {
    font-size: 0.98rem;
    color: #4a423c;
  }

  .workspace-login-console {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 3.1rem;
    padding: 0.8rem 1.4rem;
    border-radius: 1rem;
    border: 1px solid rgba(64, 51, 43, 0.16);
    background: rgba(255, 251, 247, 0.85);
    font-size: 1rem;
    font-weight: 500;
    color: #1e1a17;
  }

  .workspace-login-shell {
    max-width: 1480px;
    margin: 0 auto;
    padding: clamp(1rem, 1.5vw, 1.5rem);
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(1.5rem, 3vw, 3.5rem);
    align-items: stretch;
  }

  .workspace-login-copy {
    padding: clamp(2rem, 4vw, 4.5rem) clamp(1rem, 1vw, 1.5rem) clamp(2rem, 3vw, 3rem);
  }

  .workspace-login-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.42rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.88);
    border: 1px solid rgba(100, 78, 65, 0.12);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6e655d;
    margin-bottom: 1.35rem;
  }

  .workspace-login-copy h1 {
    font-family: var(--font-editorial);
    font-size: clamp(3.6rem, 7vw, 6rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
    margin-bottom: 1.5rem;
  }

  .workspace-login-subtitle {
    margin: 0 0 2.2rem;
    font-family: var(--font-editorial);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    color: #2d2620;
  }

  .workspace-login-card {
    max-width: 39rem;
    padding: 1.3rem;
    border-radius: 2rem;
    background: rgba(255, 251, 246, 0.9);
    border: 1px solid rgba(108, 87, 73, 0.12);
    box-shadow: 0 24px 52px rgba(94, 66, 41, 0.1);
  }

  .workspace-login-card__head {
    margin-bottom: 1.15rem;
  }

  .admin-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(217, 119, 87, 0.1);
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .admin-name {
    display: block;
    margin-top: 0.85rem;
    font-size: 1.85rem;
    font-weight: 600;
    color: #1f1b18;
  }

  .workspace-login-card__head p {
    margin-top: 0.55rem;
    max-width: 30rem;
    color: #6a625b;
    font-size: 1rem;
  }

  .workspace-login-form {
    display: grid;
    gap: 1rem;
  }

  .workspace-google-btn,
  .workspace-submit-btn,
  .workspace-download-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    min-height: 4.1rem;
    width: 100%;
    border-radius: 1.1rem;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .workspace-google-btn {
    border: 1px solid rgba(94, 72, 60, 0.14);
    background: #fffdfa;
    color: #171412;
  }

  .google-g {
    display: inline-grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #4285f4, #34a853 55%, #fbbc05 75%, #ea4335);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .workspace-login-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7f756c;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
  }

  .workspace-field {
    display: grid;
    gap: 0.45rem;
  }

  .workspace-field span {
    font-size: 0.9rem;
    color: #5f564e;
  }

  .workspace-field input {
    min-height: 4rem;
    border-radius: 1rem;
    border: 1px solid rgba(80, 63, 52, 0.14);
    background: #fffdfa;
    padding: 0 1.1rem;
    font-size: 1rem;
    color: #171412;
  }

  .workspace-field input[readonly] {
    color: #5f564e;
    background: #f7f1ea;
  }

  .workspace-submit-btn {
    position: relative;
    border: none;
    background: #171412;
    color: #fff;
    margin-top: 0.2rem;
  }

  .workspace-submit-btn:hover {
    background: #28211d;
    color: #fff;
  }

  .workspace-submit-btn .btn-spinner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    opacity: 0;
    animation: workspace-spin 0.8s linear infinite;
  }

  .workspace-submit-btn.is-loading .btn-label {
    opacity: 0;
  }

  .workspace-submit-btn.is-loading .btn-spinner {
    opacity: 1;
  }

  .workspace-legal {
    margin: 0;
    font-size: 0.92rem;
    color: #7f756c;
  }

  .workspace-login-error {
    margin: 0;
    min-height: 1.25rem;
    font-size: 0.95rem;
    color: var(--color-danger);
  }

  .workspace-download-link {
    width: fit-content;
    margin-top: 1.8rem;
    padding: 0 1.8rem;
    border: 1px solid rgba(94, 72, 60, 0.14);
    background: rgba(255, 251, 247, 0.78);
    color: #1d1915;
  }

  .download-icon {
    font-size: 1.3rem;
  }

  .workspace-login-preview {
    min-height: 100%;
  }

  .preview-frame {
    position: relative;
    min-height: 100%;
    padding: clamp(1.5rem, 2vw, 2rem);
    border-radius: 2rem;
    border: 1px solid rgba(104, 80, 68, 0.12);
    background: rgba(255, 251, 247, 0.72);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.45), 0 24px 60px rgba(94, 66, 41, 0.08);
    overflow: hidden;
  }

  .preview-frame__noise {
    position: absolute;
    inset: 0;
    background-image: var(--bg-grain);
    opacity: 0.55;
    pointer-events: none;
  }

  .preview-brand,
  .preview-canvas {
    position: relative;
    z-index: 1;
  }

  .preview-brand {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .preview-brand strong {
    display: block;
    font-family: var(--font-editorial);
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 0.95;
  }

  .preview-brand span:last-child {
    color: #6d645c;
    font-size: 0.98rem;
  }

  .preview-canvas {
    display: grid;
    gap: 1rem;
  }

  .preview-card {
    border-radius: 1.5rem;
    border: 1px solid rgba(100, 79, 66, 0.12);
    background: rgba(255, 255, 255, 0.66);
    backdrop-filter: blur(8px);
  }

  .preview-card--hero {
    padding: clamp(2rem, 4vw, 4rem);
    min-height: 25rem;
    display: grid;
    align-content: center;
  }

  .preview-card__eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .preview-card--hero h2 {
    font-family: var(--font-editorial);
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    line-height: 0.96;
    margin-bottom: 1rem;
  }

  .preview-card--hero p {
    max-width: 34rem;
    font-size: 1.08rem;
    color: #5f564e;
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .preview-card--mini {
    min-height: 10rem;
    padding: 1.2rem;
    display: grid;
    align-content: start;
    gap: 0.9rem;
  }

  .preview-card__dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 6px rgba(217, 119, 87, 0.1);
  }

  .preview-card--mini p {
    margin: 0;
    font-size: 1rem;
    color: #3c342f;
  }

  @keyframes workspace-spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 1100px) {
    .workspace-login-shell {
      grid-template-columns: 1fr;
    }

    .workspace-login-copy {
      padding-bottom: 0;
    }

    .preview-card--hero {
      min-height: 18rem;
    }
  }

  @media (max-width: 820px) {
    .workspace-login-page {
      padding: 0.8rem;
    }

    .workspace-login-nav {
      grid-template-columns: 1fr auto;
      padding: 0.8rem 0.9rem;
    }

    .workspace-login-links {
      display: none;
    }

    .workspace-login-copy h1 {
      font-size: clamp(2.7rem, 12vw, 4rem);
    }

    .workspace-login-subtitle {
      font-size: 1.3rem;
    }

    .preview-grid {
      grid-template-columns: 1fr;
    }

    .workspace-google-btn,
    .workspace-submit-btn,
    .workspace-download-link,
    .workspace-field input {
      min-height: 3.6rem;
    }
  }
</style>
