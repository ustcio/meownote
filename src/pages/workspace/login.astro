---
import AppLayout from '@layouts/AppLayout.astro';
import AbstractThread from '@components/ui/AbstractThread.astro';

const title = 'Workspace Admin Login - Maxwell.Science';
const description = 'Secure access for the Maxwell workspace.';
---

<AppLayout title={title} description={description}>
  <section class="workspace-login-page">
    <div class="workspace-login-shell">
      <div class="workspace-login-card">
        <div class="workspace-login-card__head">
          <span class="admin-badge">Super Admin</span>
          <strong class="admin-name">YangHao</strong>
          <p>Use the administrator password to unlock notes, uploads, and editing tools.</p>
        </div>

        <form id="workspace-login-form" class="workspace-login-form">
          <button type="button" class="workspace-google-btn">
            <span class="google-g">G</span>
            Continue as YangHao
          </button>

          <div class="workspace-login-divider">
            <span>or</span>
          </div>

          <label class="workspace-field">
            <span>Administrator account</span>
            <input type="text" value="YangHao@Trading.com" readonly />
          </label>

          <label class="workspace-field">
            <span>Password</span>
            <input
              type="password"
              id="workspace-admin-password"
              name="password"
              placeholder="Enter administrator password"
              required
            />
          </label>

          <input type="hidden" id="workspace-next" value="/workspace/" />

          <button type="submit" class="workspace-submit-btn" id="workspace-login-submit">
            <span class="btn-label">Enter workspace</span>
            <span class="btn-spinner" aria-hidden="true"></span>
          </button>

          <p class="workspace-legal">
            By continuing, you confirm this area is reserved for the Maxwell workspace administrator.
          </p>
          <p class="workspace-login-error" id="workspace-login-error" hidden></p>
        </form>
      </div>

      <aside class="workspace-login-visual" aria-hidden="true">
        <div class="visual-ambient">
          <span class="visual-dot" style="--x: 10%; --y: 22%; --s: 4px; --delay: 0s"></span>
          <span class="visual-dot" style="--x: 88%; --y: 18%; --s: 6px; --delay: 0.5s"></span>
          <span class="visual-dot" style="--x: 54%; --y: 76%; --s: 5px; --delay: 1s"></span>
          <span class="visual-dot" style="--x: 78%; --y: 84%; --s: 3px; --delay: 1.4s"></span>
        </div>

        <div class="workspace-login-visual__copy">
          <span class="visual-kicker">Calm operator workspace</span>
          <h2>AI that thinks.<br />You decide.</h2>
          <p>Write clearly. Plan confidently. Research thoroughly in one calm, capable workspace.</p>
        </div>

        <div class="workspace-login-visual__thread">
          <AbstractThread class="workspace-thread-art" />
        </div>
      </aside>
    </div>
  </section>

  <script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev' }}>
    (function() {
      const ADMIN_USERNAME = 'YangHao';
      const ADMIN_EMAIL = 'YangHao@Trading.com';
      const authStore = window.__meownoteAuth;

      const form = document.getElementById('workspace-login-form');
      const passwordInput = document.getElementById('workspace-admin-password');
      const errorEl = document.getElementById('workspace-login-error');
      const submitBtn = document.getElementById('workspace-login-submit');
      const nextInput = document.getElementById('workspace-next');

      function setError(message) {
        if (!errorEl) return;
        errorEl.hidden = !message;
        errorEl.textContent = message || '';
      }

      function setLoading(loading) {
        submitBtn?.classList.toggle('is-loading', loading);
        if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = loading;
      }

      function isAdminUser(user) {
        const username = user?.username || user?.name || '';
        const email = user?.email || '';
        return username === ADMIN_USERNAME || email === ADMIN_EMAIL;
      }

      function resolveNextPath() {
        const params = new URLSearchParams(window.location.search);
        const next = params.get('next');
        if (next && next.startsWith('/workspace')) {
          nextInput.value = next;
          return next;
        }
        return nextInput.value || '/workspace/';
      }

      function hydrateIfLoggedIn() {
        const token = authStore?.getToken?.();
        const user = authStore?.getUser?.();
        const next = resolveNextPath();

        if (token && isAdminUser(user)) {
          window.location.replace(next);
        }
      }

      async function attemptLogin(account, password) {
        const response = await fetch(`${API_BASE}/api/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: account, password }),
        });
        const result = await response.json().catch(() => ({}));
        return { response, result };
      }

      document.querySelector('.workspace-google-btn')?.addEventListener('click', () => {
        passwordInput?.focus();
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        setError('');

        const password = passwordInput instanceof HTMLInputElement ? passwordInput.value.trim() : '';
        const next = resolveNextPath();

        if (!password) {
          setError('请输入管理员密码。');
          return;
        }

        setLoading(true);

        try {
          let { response, result } = await attemptLogin(ADMIN_EMAIL, password);

          if (!response.ok || !result.success) {
            ({ response, result } = await attemptLogin(ADMIN_USERNAME, password));
          }

          if (!response.ok || !result.success) {
            throw new Error(result.message || '用户名/邮箱或密码错误');
          }

          const user = result.user || {};
          if (!isAdminUser(user)) {
            throw new Error('当前账号没有 Workspace 超级管理员权限。');
          }

          authStore?.setSession?.(result.token, user);
          window.__meownoteToast?.show('Workspace access granted', 'success');
          window.location.replace(next);
        } catch (error) {
          setError(error instanceof Error ? error.message : '登录失败，请稍后重试。');
          window.__meownoteToast?.show('Workspace login failed', 'error');
        } finally {
          setLoading(false);
        }
      });

      resolveNextPath();
      hydrateIfLoggedIn();
    })();
  </script>
</AppLayout>

<style>
  .workspace-login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 1.5rem;
    background: var(--bg-primary);
    color: #171412;
    overflow: hidden;
  }

  .workspace-login-shell {
    width: min(1480px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(24rem, 44rem) minmax(0, 1fr);
    gap: clamp(1.5rem, 3vw, 4rem);
    align-items: center;
  }

  .workspace-login-card {
    padding: 1.45rem;
    border-radius: 2.2rem;
    background: rgba(255, 251, 246, 0.92);
    border: 1px solid rgba(108, 87, 73, 0.12);
    box-shadow: 0 24px 52px rgba(94, 66, 41, 0.1);
    opacity: 0;
    animation: visualUp 0.7s var(--ease-out) 0.06s both;
  }

  .workspace-login-card__head {
    margin-bottom: 1.15rem;
  }

  .admin-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(217, 119, 87, 0.1);
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .admin-name {
    display: block;
    margin-top: 0.85rem;
    font-size: 1.85rem;
    font-weight: 600;
    color: #1f1b18;
  }

  .workspace-login-card__head p {
    margin-top: 0.55rem;
    max-width: 30rem;
    color: #6a625b;
    font-size: 1rem;
  }

  .workspace-login-form {
    display: grid;
    gap: 1rem;
  }

  .workspace-google-btn,
  .workspace-submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    min-height: 4.1rem;
    width: 100%;
    border-radius: 1.1rem;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .workspace-google-btn {
    border: 1px solid rgba(94, 72, 60, 0.14);
    background: #fffdfa;
    color: #171412;
  }

  .google-g {
    display: inline-grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #4285f4, #34a853 55%, #fbbc05 75%, #ea4335);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .workspace-login-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7f756c;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
  }

  .workspace-field {
    display: grid;
    gap: 0.45rem;
  }

  .workspace-field span {
    font-size: 0.9rem;
    color: #5f564e;
  }

  .workspace-field input {
    min-height: 4rem;
    border-radius: 1rem;
    border: 1px solid rgba(80, 63, 52, 0.14);
    background: #fffdfa;
    padding: 0 1.1rem;
    font-size: 1rem;
    color: #171412;
  }

  .workspace-field input[readonly] {
    color: #5f564e;
    background: #f7f1ea;
  }

  .workspace-submit-btn {
    position: relative;
    border: none;
    background: #171412;
    color: #fff;
    margin-top: 0.2rem;
  }

  .workspace-submit-btn:hover {
    background: #28211d;
    color: #fff;
  }

  .workspace-submit-btn .btn-spinner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    opacity: 0;
    animation: workspace-spin 0.8s linear infinite;
  }

  .workspace-submit-btn.is-loading .btn-label {
    opacity: 0;
  }

  .workspace-submit-btn.is-loading .btn-spinner {
    opacity: 1;
  }

  .workspace-legal {
    margin: 0;
    font-size: 0.92rem;
    color: #7f756c;
  }

  .workspace-login-error {
    margin: 0;
    min-height: 1.25rem;
    font-size: 0.95rem;
    color: var(--color-danger);
  }

  .workspace-login-visual {
    position: relative;
    min-height: min(78vh, 54rem);
    display: grid;
    align-items: center;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .visual-ambient {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .visual-dot {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.08;
    animation: heroDotFloat 10s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .workspace-login-visual__copy,
  .workspace-login-visual__thread {
    position: relative;
    z-index: 1;
  }

  .workspace-login-visual__copy {
    max-width: 36rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: visualUp 0.7s var(--ease-out) 0.18s both;
  }

  .visual-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.32rem 0.78rem;
    border-radius: 999px;
    background: rgba(217, 119, 87, 0.08);
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .workspace-login-visual__copy h2 {
    margin: 1rem 0 0;
    font-family: var(--font-editorial);
    font-size: clamp(3.1rem, 6vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .workspace-login-visual__copy p {
    max-width: 34rem;
    margin: 1rem 0 0;
    font-size: clamp(1rem, 1.8vw, 1.14rem);
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .workspace-login-visual__thread {
    min-height: 30rem;
    opacity: 0;
    animation: visualUp 0.8s var(--ease-out) 0.3s both;
  }

  .workspace-thread-art {
    min-height: 100%;
  }

  .workspace-thread-art :global(.cognitive-sphere) {
    box-shadow:
      inset -15px -15px 30px rgba(0, 0, 0, 0.08),
      0 18px 48px rgba(217, 119, 87, 0.28);
  }

  @keyframes workspace-spin {
    to { transform: rotate(360deg); }
  }

  @keyframes heroDotFloat {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.08; }
    50% { transform: translateY(-30px) scale(1.5); opacity: 0.15; }
  }

  @keyframes visualUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1100px) {
    .workspace-login-shell {
      grid-template-columns: 1fr;
    }

    .workspace-login-visual {
      min-height: 34rem;
      padding-top: 0;
    }
  }

  @media (max-width: 820px) {
    .workspace-login-page {
      display: block;
      padding: 1rem;
    }

    .workspace-login-card {
      padding: 1.2rem;
      border-radius: 1.75rem;
    }

    .workspace-google-btn,
    .workspace-submit-btn,
    .workspace-field input {
      min-height: 3.6rem;
    }

    .workspace-login-visual {
      min-height: 24rem;
      margin-top: 1rem;
      padding: 0;
    }

    .workspace-login-visual__copy h2 {
      font-size: clamp(2.6rem, 12vw, 4rem);
    }
  }
</style>
