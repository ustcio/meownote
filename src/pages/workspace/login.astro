---
import AppLayout from '@layouts/AppLayout.astro';

const title = 'Workspace Admin Login - Maxwell.Science';
const description = 'Secure access for the Maxwell workspace.';

const slides = [
  {
    kicker: 'Cowork',
    title: 'Cowork handles your',
    highlight: 'weekly reports',
    description: 'Automatically generate performance summaries and insights.',
    image: '/images/carousel/cowork-how-01.webp',
  },
  {
    kicker: 'Cowork',
    title: 'Cowork handles your',
    highlight: 'data analysis',
    description: 'Transform raw data into actionable intelligence.',
    image: '/images/carousel/cowork-how-02.webp',
  },
  {
    kicker: 'Cowork',
    title: 'Cowork handles your',
    highlight: 'team collaboration',
    description: 'Seamless workflows across your entire organization.',
    image: '/images/carousel/cowork-how-03.webp',
  },
  {
    kicker: 'Cowork',
    title: 'Cowork handles your',
    highlight: 'research tasks',
    description: 'Deep research capabilities at your fingertips.',
    image: '/images/carousel/blog-plugins.jpg',
  }
];
---

<AppLayout title={title} description={description}>
  <section class="workspace-login-page">
    <header class="workspace-login-nav">
      <a href="/" class="workspace-login-brand" aria-label="Back to Maxwell home">
        <svg width="20" height="20" viewBox="0 0 28 28" fill="none">
          <path d="M14 0C6.268 0 0 6.268 0 14s6.268 14 14 14 14-6.268 14-14S21.732 0 14 0z" fill="#D97757"/>
          <path d="M14 4c-5.523 0-10 4.477-10 10s4.477 10 10 10 10-4.477 10-10S19.523 4 14 4z" fill="#fff" opacity="0.3"/>
        </svg>
        <span class="workspace-login-brand__wordmark">Maxwell</span>
      </a>

      <nav class="workspace-login-nav__links" aria-label="Workspace navigation">
        <a href="/chatbot/">Chat</a>
        <a href="/workspace/">Workspace</a>
        <a href="/kit/">Kit</a>
        <a href="/about/">About</a>
      </nav>

      <a href="/" class="workspace-login-nav__home">Back home</a>
    </header>

    <div class="workspace-login-shell">
      <!-- Left: Login Card -->
      <div class="workspace-login-left">
        <div class="workspace-login-card">
          <div class="workspace-login-card__head">
            <span class="admin-badge">Super Admin</span>
            <h1 class="admin-name">YangHao</h1>
            <p>Use the administrator password to unlock notes, uploads, and editing tools.</p>
          </div>

          <form id="workspace-login-form" class="workspace-login-form">
            <button type="button" class="workspace-google-btn">
              <svg width="18" height="18" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              Continue as YangHao
            </button>

            <div class="workspace-login-divider">
              <span>or</span>
            </div>

            <label class="workspace-field">
              <span>Administrator account</span>
              <input type="text" value="YangHao" readonly />
            </label>

            <label class="workspace-field">
              <span>Password</span>
              <input
                type="password"
                id="workspace-admin-password"
                name="password"
                placeholder="Enter administrator password"
                required
              />
            </label>

            <input type="hidden" id="workspace-next" value="/workspace/" />

            <button type="submit" class="workspace-submit-btn" id="workspace-login-submit">
              <span class="btn-label">Enter workspace</span>
              <span class="btn-spinner" aria-hidden="true"></span>
            </button>

            <p class="workspace-legal">
              By continuing, you confirm this area is reserved for the Maxwell workspace administrator.
            </p>
            <p class="workspace-login-error" id="workspace-login-error" hidden></p>
          </form>
        </div>
      </div>

      <!-- Right: Carousel Card (fixed size) -->
      <div class="workspace-login-right">
        <div class="carousel-card">
          <div class="carousel-card__header">
            <div class="carousel-card__logo">
              <svg width="18" height="18" viewBox="0 0 28 28" fill="none">
                <path d="M14 0C6.268 0 0 6.268 0 14s6.268 14 14 14 14-6.268 14-14S21.732 0 14 0z" fill="#D97757"/>
                <path d="M14 4c-5.523 0-10 4.477-10 10s4.477 10 10 10 10-4.477 10-10S19.523 4 14 4z" fill="#fff" opacity="0.3"/>
              </svg>
              <span>Maxwell</span>
            </div>
            <span class="carousel-card__kicker">Cowork</span>
          </div>

          <div class="carousel-viewport">
            {slides.map((slide, index) => (
              <div class="carousel-slide" data-index={index}>
                <div class="slide-text">
                  <h2 class="slide-title">
                    {slide.title}
                    <span class="slide-highlight">{slide.highlight}</span>
                  </h2>
                  <p class="slide-description">{slide.description}</p>
                </div>
                <div class="slide-image-wrapper">
                  <img src={slide.image} alt={slide.highlight} loading="lazy" />
                </div>
              </div>
            ))}
          </div>

          <div class="carousel-footer">
            <div class="carousel-dots">
              {slides.map((_, index) => (
                <button class="carousel-dot" data-slide={index} aria-label={`Slide ${index + 1}`}>
                  <span class="dot-inner"></span>
                </button>
              ))}
            </div>
          </div>

          <div class="carousel-progress">
            <div class="progress-bar"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ API_BASE: 'https://api.ustc.dev' }}>
    (function() {
      const ADMIN_USERNAME = 'YangHao';
      const TOKEN_KEYS = ['meownote_auth_token', 'auth_token'];
      const USER_KEYS = ['meownote_user_data', 'user'];
      let isRedirecting = false;

      const form = document.getElementById('workspace-login-form');
      const passwordInput = document.getElementById('workspace-admin-password');
      const errorEl = document.getElementById('workspace-login-error');
      const submitBtn = document.getElementById('workspace-login-submit');
      const nextInput = document.getElementById('workspace-next');

      function setError(message) {
        if (!errorEl) return;
        errorEl.hidden = !message;
        errorEl.textContent = message || '';
      }

      function setLoading(loading) {
        submitBtn?.classList.toggle('is-loading', loading);
        if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = loading;
      }

      function readJSON(key) {
        try {
          const raw = localStorage.getItem(key);
          return raw ? JSON.parse(raw) : null;
        } catch {
          return null;
        }
      }

      function writeJSON(key, value) {
        localStorage.setItem(key, JSON.stringify(value));
      }

      function getStoredToken() {
        return TOKEN_KEYS.map((key) => localStorage.getItem(key)).find(Boolean) || null;
      }

      function getStoredUser() {
        return USER_KEYS.map((key) => readJSON(key)).find(Boolean) || null;
      }

      function isSafeWorkspacePath(path) {
        return Boolean(path) && path.startsWith('/workspace') && !path.startsWith('/workspace/login');
      }

      function persistSession(token, user) {
        if (window.__meownoteAuth?.setSession) {
          window.__meownoteAuth.setSession(token, user);
          return;
        }

        const nextToken = token || getStoredToken();
        if (nextToken) {
          localStorage.setItem('meownote_auth_token', nextToken);
          localStorage.setItem('auth_token', nextToken);
        }
        writeJSON('meownote_user_data', user);
        writeJSON('user', user);
        window.dispatchEvent(new CustomEvent('auth:login', { detail: user }));
      }

      function isAdminUser(user) {
        const username = user?.username || user?.name || '';
        return username === ADMIN_USERNAME;
      }

      function resolveNextPath() {
        const params = new URLSearchParams(window.location.search);
        const next = params.get('next');
        if (next && isSafeWorkspacePath(next)) {
          nextInput.value = next;
          return next;
        }
        return nextInput.value || '/workspace/';
      }

      function redirectToWorkspace(path) {
        if (isRedirecting) return;
        isRedirecting = true;
        window.location.replace(isSafeWorkspacePath(path) ? path : '/workspace/');
      }

      function hydrateIfLoggedIn() {
        const redirectCount = parseInt(localStorage.getItem('meownote_redirect_count') || '0', 10);
        if (redirectCount > 3) {
          localStorage.removeItem('meownote_redirect_count');
          return;
        }

        const token = window.__meownoteAuth?.getToken?.() || getStoredToken();
        const user = window.__meownoteAuth?.getUser?.() || getStoredUser();
        const next = resolveNextPath();

        if (token && isAdminUser(user)) {
          localStorage.setItem('meownote_redirect_count', String(redirectCount + 1));
          redirectToWorkspace(next);
        } else {
          localStorage.removeItem('meownote_redirect_count');
        }
      }

      async function attemptLogin(path, account, password) {
        const response = await fetch(`${API_BASE}${path}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: account, password }),
        });
        const result = await response.json().catch(() => ({}));
        return { response, result };
      }

      document.querySelector('.workspace-google-btn')?.addEventListener('click', () => {
        passwordInput?.focus();
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        setError('');

        const password = passwordInput instanceof HTMLInputElement ? passwordInput.value.trim() : '';
        const next = resolveNextPath();

        if (!password) {
          setError('请输入管理员密码。');
          return;
        }

        setLoading(true);

        try {
          const loginPaths = ['/api/admin/login', '/api/superadmin/login', '/api/trading/login'];
          let response = null;
          let result = {};

          for (const path of loginPaths) {
            const attempt = await attemptLogin(path, ADMIN_USERNAME, password);
            response = attempt.response;
            result = attempt.result;

            if (response.ok && result.success) {
              break;
            }
          }

          if (!response || !response.ok || !result.success) {
            throw new Error(result.message || result.error || '用户名或密码错误');
          }

          const user = result.user || {};
          if (!isAdminUser(user)) {
            throw new Error('当前账号没有 Workspace 超级管理员权限。');
          }

          persistSession(result.token, user);
          window.__meownoteToast?.show('Workspace access granted', 'success');
          redirectToWorkspace(next);
        } catch (error) {
          setError(error instanceof Error ? error.message : '登录失败，请稍后重试。');
          window.__meownoteToast?.show('Workspace login failed', 'error');
        } finally {
          setLoading(false);
        }
      });

      resolveNextPath();
      hydrateIfLoggedIn();

      // Carousel logic
      const carouselCard = document.querySelector('.carousel-card');
      if (carouselCard) {
        const slides = carouselCard.querySelectorAll('.carousel-slide');
        const dots = carouselCard.querySelectorAll('.carousel-dot');
        const progressBar = carouselCard.querySelector('.progress-bar');
        let currentIndex = 0;
        let autoplayInterval = null;
        const autoplayDelay = 5000;

        function goToSlide(index, direction = 'down') {
          if (index === currentIndex) return;
          const currentSlide = slides[currentIndex];
          const nextSlide = slides[index];
          currentSlide.classList.remove('active');
          currentSlide.classList.add(direction === 'down' ? 'exit-up' : '');
          nextSlide.style.transform = direction === 'down' ? 'translateY(1rem)' : 'translateY(-1rem)';
          void nextSlide.offsetHeight;
          nextSlide.classList.add('active');
          nextSlide.style.transform = '';
          dots[currentIndex].classList.remove('active');
          dots[index].classList.add('active');
          currentIndex = index;
          resetProgress();
        }

        function nextSlide() {
          goToSlide((currentIndex + 1) % slides.length, 'down');
        }

        function resetProgress() {
          if (progressBar) {
            progressBar.style.transition = 'none';
            progressBar.style.width = '0%';
            void progressBar.offsetHeight;
            progressBar.style.transition = `width ${autoplayDelay}ms linear`;
            progressBar.style.width = '100%';
          }
        }

        function startAutoplay() {
          stopAutoplay();
          resetProgress();
          autoplayInterval = setInterval(nextSlide, autoplayDelay);
        }

        function stopAutoplay() {
          if (autoplayInterval) {
            clearInterval(autoplayInterval);
            autoplayInterval = null;
          }
        }

        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            if (index === currentIndex) return;
            goToSlide(index, index > currentIndex ? 'down' : 'up');
            startAutoplay();
          });
        });

        carouselCard.addEventListener('mouseenter', stopAutoplay);
        carouselCard.addEventListener('mouseleave', startAutoplay);

        if (slides.length > 0) {
          slides[0].classList.add('active');
          if (dots.length > 0) dots[0].classList.add('active');
          startAutoplay();
        }
      }
    })();
  </script>
</AppLayout>

<style>
  .workspace-login-page {
    min-height: 100vh;
    display: grid;
    align-content: start;
    padding: 1.5rem;
    background: var(--bg-primary);
    color: #171412;
  }

  /* ── Nav ── */
  .workspace-login-nav {
    width: min(1200px, 100%);
    margin: 0 auto 2.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    min-height: 3.5rem;
  }

  .workspace-login-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: inherit;
    text-decoration: none;
  }

  .workspace-login-brand svg {
    flex-shrink: 0;
  }

  .workspace-login-brand__wordmark {
    font-family: var(--font-editorial);
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .workspace-login-nav__links {
    display: inline-flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .workspace-login-nav__links a,
  .workspace-login-nav__home {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .workspace-login-nav__links a:hover,
  .workspace-login-nav__home:hover {
    color: var(--text-primary);
  }

  .workspace-login-nav__home {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.2rem;
    padding: 0 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(108, 87, 73, 0.1);
    background: var(--bg-primary);
  }

  /* ── Shell ── */
  .workspace-login-shell {
    width: min(1200px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── Left: Login Card ── */
  .workspace-login-left {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 1rem;
  }

  .workspace-login-card {
    width: 100%;
    max-width: 28rem;
    padding: 2rem;
    border-radius: 1.5rem;
    background: #fff;
    border: 1px solid rgba(108, 87, 73, 0.08);
    box-shadow: 0 8px 32px rgba(94, 66, 41, 0.08);
  }

  .workspace-login-card__head {
    margin-bottom: 1.5rem;
  }

  .admin-badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.5rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: rgba(217, 119, 87, 0.08);
    color: var(--color-primary);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .admin-name {
    display: block;
    margin: 0.6rem 0 0.4rem;
    font-family: var(--font-editorial);
    font-size: 1.6rem;
    font-weight: 600;
    color: #1f1b18;
    letter-spacing: -0.02em;
  }

  .workspace-login-card__head p {
    margin: 0;
    color: #6a625b;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .workspace-login-form {
    display: grid;
    gap: 0.85rem;
  }

  .workspace-google-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 3rem;
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgba(94, 72, 60, 0.12);
    background: #fff;
    color: #171412;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-default);
  }

  .workspace-google-btn:hover {
    background: #faf8f5;
  }

  .workspace-login-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9e948c;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .workspace-field {
    display: grid;
    gap: 0.35rem;
  }

  .workspace-field span {
    font-size: 0.8rem;
    font-weight: 500;
    color: #5f564e;
  }

  .workspace-field input {
    min-height: 2.8rem;
    border-radius: 0.65rem;
    border: 1px solid rgba(80, 63, 52, 0.12);
    background: #faf8f5;
    padding: 0 0.85rem;
    font-size: 0.9rem;
    color: #171412;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .workspace-field input:focus {
    border-color: var(--color-primary);
  }

  .workspace-field input[readonly] {
    color: #5f564e;
    background: #f5f0ea;
    cursor: default;
  }

  .workspace-submit-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    width: 100%;
    border: none;
    border-radius: 0.75rem;
    background: #171412;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 0.25rem;
    transition: background var(--duration-fast) var(--ease-default);
  }

  .workspace-submit-btn:hover {
    background: #28211d;
  }

  .workspace-submit-btn .btn-spinner {
    position: absolute;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    opacity: 0;
    animation: workspace-spin 0.8s linear infinite;
  }

  .workspace-submit-btn.is-loading .btn-label {
    opacity: 0;
  }

  .workspace-submit-btn.is-loading .btn-spinner {
    opacity: 1;
  }

  .workspace-legal {
    margin: 0;
    font-size: 0.78rem;
    color: #9e948c;
    line-height: 1.5;
  }

  .workspace-login-error {
    margin: 0;
    min-height: 1rem;
    font-size: 0.85rem;
    color: var(--color-danger);
  }

  /* ── Right: Carousel Card (FIXED SIZE) ── */
  .workspace-login-right {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .carousel-card {
    position: relative;
    width: 100%;
    max-width: 28rem;
    height: 34rem;
    padding: 1.75rem;
    border-radius: 1.5rem;
    background: var(--bg-primary);
    border: 1px solid rgba(108, 87, 73, 0.08);
    box-shadow: 0 8px 32px rgba(94, 66, 41, 0.08);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .carousel-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }

  .carousel-card__logo {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-editorial);
    font-size: 0.95rem;
    font-weight: 500;
    color: #1f1b18;
  }

  .carousel-card__logo svg {
    flex-shrink: 0;
  }

  .carousel-card__kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: rgba(217, 119, 87, 0.08);
    color: var(--color-primary);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Fixed viewport */
  .carousel-viewport {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    opacity: 0;
    transform: translateY(1rem);
    transition:
      opacity 0.5s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
    pointer-events: none;
  }

  .carousel-slide.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }

  .carousel-slide.exit-up {
    opacity: 0;
    transform: translateY(-1rem);
  }

  .slide-text {
    flex-shrink: 0;
  }

  .slide-title {
    font-family: var(--font-editorial);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: #1f1b18;
    margin: 0 0 0.35rem;
  }

  .slide-highlight {
    display: block;
    color: var(--color-primary);
    font-weight: 500;
  }

  .slide-description {
    font-size: 0.82rem;
    line-height: 1.5;
    color: #6a625b;
    margin: 0;
  }

  .slide-image-wrapper {
    flex: 1;
    min-height: 0;
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(217, 119, 87, 0.04);
    border: 1px solid rgba(108, 87, 73, 0.06);
  }

  .slide-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

