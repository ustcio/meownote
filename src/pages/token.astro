---
import Layout from '../layouts/Layout.astro';
---

<Layout title="API Proxy | Maxwell.Science">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>

  <div class="proxy-page">
    <div class="proxy-container">
      <!-- Login Section -->
      <div id="login-section" class="proxy-login">
        <div class="proxy-login__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="proxy-login__title">API Proxy</h1>
        <p class="proxy-login__subtitle">Super Admin Access</p>

        <form id="login-form" class="proxy-login__form">
          <div class="form-group">
            <label for="username" class="form-label">Username</label>
            <input type="text" id="username" name="username" class="form-input" placeholder="Enter username" autocomplete="username" required />
          </div>
          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input type="password" id="password" name="password" class="form-input" placeholder="Enter password" autocomplete="current-password" required />
          </div>
          <div id="login-error" class="form-error" style="display:none;"></div>
          <button type="submit" class="claude-button proxy-login__btn" id="login-btn">
            <span class="btn-text">Sign In</span>
            <span class="btn-loader" style="display:none;">
              <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
              </svg>
            </span>
          </button>
        </form>
      </div>

      <!-- Dashboard Section -->
      <div id="dashboard-section" class="proxy-dashboard" style="display:none;">
        <div class="proxy-dashboard__header">
          <div>
            <h1 class="proxy-dashboard__title">API Proxy</h1>
            <p class="proxy-dashboard__subtitle">Welcome, <span id="admin-name"></span></p>
          </div>
          <div class="proxy-dashboard__actions">
            <button id="add-source-btn" class="claude-button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Source
            </button>
            <button id="logout-btn" class="claude-button claude-button--ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </button>
          </div>
        </div>

        <div id="sources-list" class="sources-list">
          <div class="loading-state">
            <div class="skeleton" style="width:100%;height:100px;border-radius:var(--radius-xl);"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Source Modal -->
    <div id="source-modal" class="modal-overlay">
      <div class="modal">
        <div class="modal__header">
          <h2 id="source-modal-title" class="modal__title">Add Source API</h2>
          <button type="button" class="modal__close" id="source-modal-close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <form id="source-form">
          <div class="modal__body">
            <input type="hidden" id="source-id" />
            <div class="form-group">
              <label class="form-label">Name</label>
              <input type="text" id="source-name" class="form-input" placeholder="e.g. OpenAI" required />
            </div>
            <div class="form-group">
              <label class="form-label">Provider</label>
              <select id="source-provider" class="form-input">
                <option value="openai">OpenAI</option>
                <option value="anthropic">Anthropic</option>
                <option value="azure">Azure OpenAI</option>
                <option value="dashscope">阿里云 DashScope</option>
                <option value="custom">Custom</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Base URL</label>
              <input type="text" id="source-baseurl" class="form-input" placeholder="https://api.openai.com/v1" required />
            </div>
            <div class="form-group">
              <label class="form-label">API Key</label>
              <input type="text" id="source-apikey" class="form-input" placeholder="sk-..." required />
            </div>
            <div class="form-group">
              <label class="form-label">Default Model <span class="form-hint">(optional, fallback when user doesn't specify)</span></label>
              <input type="text" id="source-model" class="form-input" placeholder="e.g. gpt-4o, claude-sonnet-4-20250514" />
            </div>
            <div id="source-error" class="form-error" style="display:none;"></div>
          </div>
          <div class="modal__footer">
            <button type="button" class="claude-button claude-button--ghost" id="source-cancel-btn">Cancel</button>
            <button type="submit" class="claude-button" id="source-save-btn">
              <span class="btn-text">Save</span>
              <span class="btn-loader" style="display:none;">
                <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Channel Modal -->
    <div id="channel-modal" class="modal-overlay">
      <div class="modal">
        <div class="modal__header">
          <h2 id="channel-modal-title" class="modal__title">Add Channel</h2>
          <button type="button" class="modal__close" id="channel-modal-close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <form id="channel-form">
          <div class="modal__body">
            <input type="hidden" id="channel-id" />
            <input type="hidden" id="channel-source-id" />
            <div class="form-group">
              <label class="form-label">Channel Name</label>
              <input type="text" id="channel-name" class="form-input" placeholder="e.g. ChatBot" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Rate Limit <span class="form-hint">(req/min)</span></label>
                <input type="number" id="channel-ratelimit" class="form-input" value="0" min="0" />
              </div>
              <div class="form-group">
                <label class="form-label">Daily Quota <span class="form-hint">(0=unlimited)</span></label>
                <input type="number" id="channel-quota" class="form-input" value="0" min="0" />
              </div>
            </div>
            <div id="channel-error" class="form-error" style="display:none;"></div>
          </div>
          <div class="modal__footer">
            <button type="button" class="claude-button claude-button--ghost" id="channel-cancel-btn">Cancel</button>
            <button type="submit" class="claude-button" id="channel-save-btn">
              <span class="btn-text">Save</span>
              <span class="btn-loader" style="display:none;">
                <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Stats Modal -->
    <div id="stats-modal" class="modal-overlay">
      <div class="modal modal--wide">
        <div class="modal__header">
          <h2 id="stats-title" class="modal__title">Usage Statistics</h2>
          <button type="button" class="modal__close" id="stats-modal-close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div class="modal__body">
          <div class="stats-summary" id="stats-summary"></div>
          <div class="stats-chart-container">
            <canvas id="stats-chart"></canvas>
          </div>
          <div class="stats-channels" id="stats-channels"></div>
        </div>
        <div class="modal__footer">
          <button type="button" class="claude-button claude-button--ghost" id="stats-close-btn">Close</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .proxy-page {
      min-height: 100vh;
      padding: calc(var(--header-height) + var(--space-8)) var(--space-4) var(--space-12);
      background: var(--bg-primary);
    }

    @media (min-width: 768px) {
      .proxy-page { padding-left: var(--space-6); padding-right: var(--space-6); }
    }

    .proxy-container { max-width: var(--container-lg); margin: 0 auto; }

    .proxy-login { max-width: 380px; margin: 4rem auto; text-align: center; }

    .proxy-login__icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 56px; height: 56px; border-radius: var(--radius-xl);
      background: var(--color-primary-light); color: var(--color-primary);
      margin-bottom: var(--space-5);
    }

    .proxy-login__title {
      font-family: var(--font-display); font-size: var(--text-2xl);
      font-weight: 600; letter-spacing: var(--tracking-tight);
      color: var(--text-primary); margin: 0 0 var(--space-1);
    }

    .proxy-login__subtitle { font-size: var(--text-sm); color: var(--text-tertiary); margin: 0 0 var(--space-8); }
    .proxy-login__form { display: flex; flex-direction: column; gap: var(--space-4); text-align: left; }
    .proxy-login__btn { width: 100%; justify-content: center; margin-top: var(--space-2); }

    .proxy-dashboard__header {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: var(--space-8); gap: var(--space-4); flex-wrap: wrap;
    }

    .proxy-dashboard__title {
      font-family: var(--font-display); font-size: var(--text-2xl);
      font-weight: 600; letter-spacing: var(--tracking-tight);
      color: var(--text-primary); margin: 0 0 var(--space-1);
    }

    .proxy-dashboard__subtitle { font-size: var(--text-sm); color: var(--text-tertiary); margin: 0; }
    .proxy-dashboard__actions { display: flex; gap: var(--space-2); }

    .sources-list { display: flex; flex-direction: column; gap: var(--space-3); }

    .source-card {
      background: var(--card-bg); border: 1px solid var(--card-border);
      border-radius: var(--radius-xl); overflow: hidden;
      transition: border-color var(--duration-fast) var(--ease-default), box-shadow var(--duration-fast) var(--ease-default);
    }

    .source-card:hover { border-color: var(--card-border-hover); box-shadow: var(--card-shadow-hover); }

    .source-card__header {
      padding: var(--space-4) var(--space-5); cursor: pointer;
      display: flex; align-items: center; gap: var(--space-4); user-select: none;
      transition: background var(--duration-fast) var(--ease-default);
    }

    .source-card__header:hover { background: var(--card-bg-hover); }

    .source-card__icon {
      display: flex; align-items: center; justify-content: center;
      width: 40px; height: 40px; border-radius: var(--radius-lg);
      background: var(--color-primary-light); color: var(--color-primary); flex-shrink: 0;
    }

    .source-card__info { flex: 1; min-width: 0; }

    .source-card__name {
      font-family: var(--font-display); font-size: var(--text-base);
      font-weight: 600; letter-spacing: var(--tracking-tight);
      color: var(--text-primary); margin: 0 0 2px;
    }

    .source-card__meta {
      font-size: var(--text-xs); color: var(--text-tertiary);
      display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center;
    }

    .source-card__meta-item { display: flex; align-items: center; gap: 4px; }

    .source-card__right { display: flex; align-items: center; gap: var(--space-3); flex-shrink: 0; }

    .source-card__toggle {
      color: var(--text-quaternary);
      transition: transform var(--duration-fast) var(--ease-default);
    }

    .source-card__toggle.open { transform: rotate(180deg); }

    .source-card__body { display: none; border-top: 1px solid var(--card-border); }
    .source-card__body.open { display: block; }

    .source-card__stats {
      padding: var(--space-4) var(--space-5); background: var(--bg-secondary);
      display: flex; gap: var(--space-6); flex-wrap: wrap;
    }

    .source-card__stat { text-align: left; }

    .source-card__stat-value {
      font-family: var(--font-display); font-size: var(--text-lg);
      font-weight: 600; color: var(--text-primary); letter-spacing: var(--tracking-tight);
    }

    .source-card__stat-label { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
    .source-card__channels { padding: var(--space-2) var(--space-5); }

    .source-card__actions {
      padding: var(--space-3) var(--space-5); display: flex;
      gap: var(--space-2); flex-wrap: wrap; border-top: 1px solid var(--card-border);
    }

    .channel-table { width: 100%; border-collapse: collapse; }

    .channel-table th {
      text-align: left; padding: var(--space-2) var(--space-3);
      font-size: var(--text-xs); font-weight: 500; color: var(--text-tertiary);
      text-transform: uppercase; letter-spacing: var(--tracking-wider);
      border-bottom: 1px solid var(--card-border);
    }

    .channel-table td {
      padding: var(--space-3); font-size: var(--text-sm);
      color: var(--text-secondary); border-bottom: 1px solid var(--card-border); vertical-align: middle;
    }

    .channel-table tr:last-child td { border-bottom: none; }
    .channel-table .actions { display: flex; gap: 4px; }

    .channel-name { font-weight: 500; color: var(--text-primary); }
    .channel-model { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-tertiary); }

    .status-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: var(--text-xs); font-weight: 500;
      padding: 3px 10px; border-radius: var(--radius-full);
    }

    .status-badge--active { background: var(--color-success-light); color: var(--color-success); }
    .status-badge--inactive { background: var(--bg-tertiary); color: var(--text-quaternary); }

    .status-dot { width: 6px; height: 6px; border-radius: 50%; }
    .status-badge--active .status-dot { background: var(--color-success); }
    .status-badge--inactive .status-dot { background: var(--text-quaternary); }

    .btn-sm {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 14px; border-radius: var(--radius-full);
      font-size: var(--text-xs); font-weight: 500; cursor: pointer; border: none;
      transition: all var(--duration-fast) var(--ease-default);
    }

    .btn-sm--primary { background: var(--color-primary); color: white; }
    .btn-sm--primary:hover { background: var(--color-primary-hover); transform: translateY(-1px); }
    .btn-sm--ghost { background: transparent; color: var(--text-tertiary); border: 1px solid var(--card-border); }
    .btn-sm--ghost:hover { background: var(--card-bg-hover); color: var(--text-primary); }
    .btn-sm--danger { background: transparent; color: var(--color-danger); border: 1px solid rgba(179, 79, 61, 0.2); }
    .btn-sm--danger:hover { background: var(--color-danger-light); }

    .form-group { display: flex; flex-direction: column; gap: var(--space-2); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }

    .form-label { font-size: var(--text-sm); font-weight: 500; color: var(--text-secondary); }
    .form-hint { font-size: var(--text-xs); color: var(--text-quaternary); font-weight: 400; }

    .form-input {
      padding: 0.625rem var(--space-4); border: 1px solid var(--input-border);
      border-radius: var(--radius-md); background: var(--input-bg);
      color: var(--text-primary); font-family: var(--font-body); font-size: var(--text-sm);
      transition: border-color var(--duration-fast) var(--ease-default), box-shadow var(--duration-fast) var(--ease-default);
    }

    .form-input:focus {
      outline: none; border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--input-focus-ring);
    }

    .form-input::placeholder { color: var(--text-quaternary); }

    .form-error {
      padding: var(--space-3) var(--space-4); background: var(--color-danger-light);
      border: 1px solid rgba(179, 79, 61, 0.2); border-radius: var(--radius-md);
      color: var(--color-danger); font-size: var(--text-sm);
    }

    .modal-overlay {
      position: fixed; inset: 0; background: var(--bg-overlay);
      z-index: var(--z-modal); display: none;
      align-items: center; justify-content: center;
      padding: var(--space-4); backdrop-filter: blur(4px);
    }

    .modal-overlay.active { display: flex; }

    .modal {
      background: var(--card-bg); border: 1px solid var(--card-border);
      border-radius: var(--radius-2xl); width: 100%;
      max-width: 480px; max-height: 90vh; overflow-y: auto; box-shadow: var(--shadow-xl);
    }

    .modal--wide { max-width: 680px; }

    .modal__header {
      display: flex; align-items: center; justify-content: space-between;
      padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--card-border);
    }

    .modal__title {
      font-family: var(--font-display); font-size: var(--text-lg);
      font-weight: 600; letter-spacing: var(--tracking-tight);
      color: var(--text-primary); margin: 0;
    }

    .modal__close {
      display: flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: var(--radius-md);
      border: none; background: transparent; color: var(--text-tertiary);
      cursor: pointer; transition: all var(--duration-fast) var(--ease-default);
    }

    .modal__close:hover { background: var(--card-bg-hover); color: var(--text-primary); }

    .modal__body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }

    .modal__footer {
      padding: var(--space-4) var(--space-6); border-top: 1px solid var(--card-border);
      display: flex; justify-content: flex-end; gap: var(--space-2);
    }

    .stats-summary {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
      gap: var(--space-3); margin-bottom: var(--space-5);
    }

    .stats-summary-item {
      text-align: center; padding: var(--space-3) var(--space-2);
      background: var(--bg-secondary); border-radius: var(--radius-lg);
    }

    .stats-summary-value {
      font-family: var(--font-display); font-size: var(--text-xl);
      font-weight: 600; color: var(--text-primary); letter-spacing: var(--tracking-tight);
    }

    .stats-summary-label { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
    .stats-chart-container { margin-bottom: var(--space-5); height: 220px; }

    .stats-channels table { width: 100%; border-collapse: collapse; }
    .stats-channels th, .stats-channels td {
      padding: var(--space-2) var(--space-3); text-align: left;
      font-size: var(--text-xs); border-bottom: 1px solid var(--card-border);
    }
    .stats-channels th { color: var(--text-tertiary); font-weight: 500; text-transform: uppercase; letter-spacing: var(--tracking-wider); }
    .stats-channels td { color: var(--text-secondary); }

    .loading-state { padding: var(--space-12) 0; }

    .empty-state { text-align: center; padding: var(--space-16) var(--space-4); color: var(--text-tertiary); }
    .empty-state svg { margin-bottom: var(--space-4); opacity: 0.2; }
    .empty-state p { font-size: var(--text-sm); margin: 0; }

    .skeleton {
      background: linear-gradient(90deg, var(--bg-tertiary) 25%, var(--bg-secondary) 50%, var(--bg-tertiary) 75%);
      background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite;
      border-radius: var(--radius-md);
    }

    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    .spinner { animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 640px) {
      .proxy-dashboard__header { flex-direction: column; align-items: flex-start; }
      .form-row { grid-template-columns: 1fr; }
      .source-card__stats { gap: var(--space-4); }
      .source-card__meta { flex-direction: column; gap: 2px; align-items: flex-start; }
      .stats-summary { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <script is:inline>
    (function() {
      var API_BASE = 'https://api.ustc.dev';
      var TOKEN_KEY = 'meownote_super_admin_token';

      var PROVIDER_PRESETS = {
        openai: { baseUrl: 'https://api.openai.com/v1', format: 'openai', defaultModel: 'gpt-4o' },
        anthropic: { baseUrl: 'https://api.anthropic.com/v1', format: 'anthropic', defaultModel: 'claude-sonnet-4-20250514' },
        azure: { baseUrl: 'https://xxx.openai.azure.com/openai', format: 'openai', defaultModel: 'gpt-4o' },
        dashscope: { baseUrl: 'https://dashscope.aliyuncs.com/compatible-mode/v1', format: 'openai', defaultModel: 'qwen-max' },
        custom: { baseUrl: '', format: 'openai', defaultModel: '' }
      };

      var sourcesData = [];

      function getToken() { return localStorage.getItem(TOKEN_KEY); }

      function showLoading(btn) {
        if (!btn) return;
        btn.disabled = true;
        var bt = btn.querySelector('.btn-text');
        var bl = btn.querySelector('.btn-loader');
        if (bt) bt.style.display = 'none';
        if (bl) bl.style.display = 'inline-flex';
      }

      function hideLoading(btn) {
        if (!btn) return;
        btn.disabled = false;
        var bt = btn.querySelector('.btn-text');
        var bl = btn.querySelector('.btn-loader');
        if (bt) bt.style.display = 'inline';
        if (bl) bl.style.display = 'none';
      }

      function showError(el, msg) { if (el) { el.textContent = msg; el.style.display = 'block'; } }
      function hideError(el) { if (el) el.style.display = 'none'; }

      function closeModal(id) {
        var m = document.getElementById(id);
        if (m) m.classList.remove('active');
      }

      function openModal(id) {
        var m = document.getElementById(id);
        if (m) m.classList.add('active');
      }

      function maskKey(key) {
        if (!key || key.length < 8) return '****';
        return key.substring(0, 4) + '****' + key.substring(key.length - 4);
      }

      function formatNumber(n) { if (!n) return '0'; return Number(n).toLocaleString(); }
      function formatLatency(ms) { if (!ms) return '-'; if (ms < 1000) return Math.round(ms) + 'ms'; return (ms / 1000).toFixed(1) + 's'; }

      async function apiCall(path, options) {
        options = options || {};
        var token = getToken();
        var headers = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = 'Bearer ' + token;
        if (options.headers) { for (var k in options.headers) headers[k] = options.headers[k]; }
        var res = await fetch(API_BASE + path, Object.assign({}, options, { headers: headers }));
        return res.json();
      }

      async function verifySession() {
        var token = getToken();
        if (!token) return false;
        try {
          var data = await apiCall('/api/superadmin/verify');
          if (data.success) { showDashboard(data.user); return true; }
        } catch(e) {}
        localStorage.removeItem(TOKEN_KEY);
        return false;
      }

      function showDashboard(user) {
        var ls = document.getElementById('login-section');
        var ds = document.getElementById('dashboard-section');
        if (ls) ls.style.display = 'none';
        if (ds) ds.style.display = 'block';
        var an = document.getElementById('admin-name');
        if (an && user) an.textContent = user.username;
        loadSources();
      }

      function showLogin() {
        var ls = document.getElementById('login-section');
        var ds = document.getElementById('dashboard-section');
        if (ls) ls.style.display = 'block';
        if (ds) ds.style.display = 'none';
      }

      async function loadSources() {
        var container = document.getElementById('sources-list');
        if (!container) return;
        container.innerHTML = '<div class="loading-state"><div class="skeleton" style="width:100%;height:100px;border-radius:var(--radius-xl);"></div></div>';
        try {
          var data = await apiCall('/api/proxy/sources');
          console.log('loadSources response:', JSON.stringify(data));
          if (!data.success) {
            var errMsg = data.error || data.message || 'Failed to load sources (API returned success: false)';
            container.innerHTML = '<div class="empty-state"><p>' + errMsg + '</p><p style="font-size:var(--text-xs);margin-top:var(--space-2);color:var(--text-quaternary);">Response: ' + JSON.stringify(data).substring(0, 200) + '</p></div>';
            return;
          }
          sourcesData = data.sources || [];
          console.log('sourcesData:', sourcesData);
          renderSources();
        } catch(e) {
          console.error('loadSources error:', e);
          container.innerHTML = '<div class="empty-state"><p>Network error: ' + e.message + '</p><p style="font-size:var(--text-xs);margin-top:var(--space-2);color:var(--text-quaternary);">Check console for details</p></div>';
        }
      }

      function renderSources() {
        var container = document.getElementById('sources-list');
        if (!container) return;
        if (sourcesData.length === 0) {
          container.innerHTML = '<div class="empty-state"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><p>No API sources configured yet.</p><p style="font-size:var(--text-xs);margin-top:var(--space-2);color:var(--text-quaternary);">Click "Add Source" to get started.</p></div>';
          return;
        }

        var html = '';
        for (var i = 0; i < sourcesData.length; i++) {
          var s = sourcesData[i];
          html += '<div class="source-card" data-source-id="' + s.id + '">';
          html += '<div class="source-card__header" onclick="window.toggleSource(\'' + s.id + '\')">';
          html += '<div class="source-card__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>';
          html += '<div class="source-card__info"><div class="source-card__name">' + s.name + '</div>';
          html += '<div class="source-card__meta"><span class="source-card__meta-item">' + s.base_url + '</span>';
          html += '<span class="source-card__meta-item">Key: ' + maskKey(s.api_key) + '</span>';
          html += '<span class="source-card__meta-item">' + s.api_format + '</span></div></div>';
          html += '<div class="source-card__right"><span class="status-badge ' + (s.is_active ? 'status-badge--active' : 'status-badge--inactive') + '">';
          html += '<span class="status-dot"></span>' + (s.is_active ? 'Active' : 'Disabled') + '</span>';
          html += '<svg class="source-card__toggle" id="toggle-' + s.id + '" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
          html += '</div></div>';
          html += '<div class="source-card__body" id="body-' + s.id + '">';
          html += '<div class="source-card__stats"><div class="source-card__stat"><div class="source-card__stat-value">' + formatNumber(s.total_usage) + '</div><div class="source-card__stat-label">Total Calls</div></div>';
          html += '<div class="source-card__stat"><div class="source-card__stat-value">' + s.channel_count + '</div><div class="source-card__stat-label">Channels</div></div></div>';
          html += '<div class="source-card__actions">';
          html += '<button class="btn-sm btn-sm--ghost" onclick="window.openAddChannel(\'' + s.id + '\')"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Add Channel</button>';
          html += '<button class="btn-sm btn-sm--ghost" onclick="window.viewSourceStats(\'' + s.id + '\')"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>Stats</button>';
          html += '<button class="btn-sm btn-sm--ghost" onclick="window.editSource(\'' + s.id + '\')">Edit</button>';
          html += '<button class="btn-sm btn-sm--ghost" onclick="window.toggleSourceStatus(\'' + s.id + '\')">' + (s.is_active ? 'Disable' : 'Enable') + '</button>';
          html += '<button class="btn-sm btn-sm--danger" onclick="window.deleteSource(\'' + s.id + '\')">Delete</button>';
          html += '</div></div></div>';
        }
        container.innerHTML = html;
      }

      window.toggleSource = function(id) {
        var body = document.getElementById('body-' + id);
        var toggle = document.getElementById('toggle-' + id);
        if (body) body.classList.toggle('open');
        if (toggle) toggle.classList.toggle('open');
      };

      window.editSource = function(id) {
        var source = null;
        for (var i = 0; i < sourcesData.length; i++) {
          if (sourcesData[i].id === id) { source = sourcesData[i]; break; }
        }
        if (!source) return;
        var t = document.getElementById('source-modal-title');
        if (t) t.textContent = 'Edit Source';
        var sid = document.getElementById('source-id');
        if (sid) sid.value = source.id;
        var sn = document.getElementById('source-name');
        if (sn) sn.value = source.name;
        var sp = document.getElementById('source-provider');
        if (sp) sp.value = source.api_format || 'openai';
        var sb = document.getElementById('source-baseurl');
        if (sb) sb.value = source.base_url;
        var sa = document.getElementById('source-apikey');
        if (sa) sa.value = source.api_key;
        var sm = document.getElementById('source-model');
        if (sm) sm.value = source.default_model || '';
        var se = document.getElementById('source-error');
        if (se) se.style.display = 'none';
        openModal('source-modal');
      };

      window.toggleSourceStatus = async function(id) {
        if (!confirm('Toggle this source?')) return;
        await apiCall('/api/proxy/sources/' + id + '/toggle', { method: 'POST' });
        loadSources();
      };

      window.deleteSource = async function(id) {
        if (!confirm('Delete this source? All channels will be deleted too.')) return;
        var result = await apiCall('/api/proxy/sources/' + id, { method: 'DELETE' });
        if (result.error) { alert(result.error); return; }
        loadSources();
      };

      window.openAddChannel = function(sourceId) {
        var t = document.getElementById('channel-modal-title');
        if (t) t.textContent = 'Add Channel';
        var cid = document.getElementById('channel-id');
        if (cid) cid.value = '';
        var csid = document.getElementById('channel-source-id');
        if (csid) csid.value = sourceId;
        var cn = document.getElementById('channel-name');
        if (cn) cn.value = '';
        var cr = document.getElementById('channel-ratelimit');
        if (cr) cr.value = '0';
        var cq = document.getElementById('channel-quota');
        if (cq) cq.value = '0';
        var ce = document.getElementById('channel-error');
        if (ce) ce.style.display = 'none';
        openModal('channel-modal');
      };

      window.viewSourceStats = async function(sourceId) {
        var source = null;
        for (var i = 0; i < sourcesData.length; i++) {
          if (sourcesData[i].id === sourceId) { source = sourcesData[i]; break; }
        }
        if (!source) return;
        var st = document.getElementById('stats-title');
        if (st) st.textContent = source.name + ' — Statistics';
        openModal('stats-modal');
        var ss = document.getElementById('stats-summary');
        if (ss) ss.innerHTML = '<div class="loading-state"><div class="skeleton" style="width:100%;height:80px;"></div></div>';
        var sc = document.getElementById('stats-channels');
        if (sc) sc.innerHTML = '';

        try {
          var data = await apiCall('/api/proxy/sources/' + sourceId + '/stats');
          if (!data.success) return;

          var s = data.source || {};
          var summaryHtml = '';
          summaryHtml += '<div class="stats-summary-item"><div class="stats-summary-value">' + formatNumber(s.total_calls) + '</div><div class="stats-summary-label">Calls</div></div>';
          summaryHtml += '<div class="stats-summary-item"><div class="stats-summary-value">' + formatNumber(s.success_count) + '</div><div class="stats-summary-label">Success</div></div>';
          summaryHtml += '<div class="stats-summary-item"><div class="stats-summary-value">' + formatNumber(s.error_count) + '</div><div class="stats-summary-label">Errors</div></div>';
          summaryHtml += '<div class="stats-summary-item"><div class="stats-summary-value">' + formatNumber(s.total_prompt_tokens) + '</div><div class="stats-summary-label">Input Tokens</div></div>';
          summaryHtml += '<div class="stats-summary-item"><div class="stats-summary-value">' + formatNumber(s.total_completion_tokens) + '</div><div class="stats-summary-label">Output Tokens</div></div>';
          summaryHtml += '<div class="stats-summary-item"><div class="stats-summary-value">' + formatLatency(s.avg_latency) + '</div><div class="stats-summary-label">Avg Latency</div></div>';
          if (ss) ss.innerHTML = summaryHtml;

          var channels = data.channels || [];
          if (channels.length > 0 && sc) {
            var chHtml = '<h3 style="font-size:var(--text-sm);font-weight:600;color:var(--text-primary);margin:var(--space-4) 0 var(--space-3);">Channel Breakdown</h3>';
            chHtml += '<table><thead><tr><th>Channel</th><th>Status</th><th>Calls</th><th>Tokens</th><th>Latency</th><th>Success</th><th>Errors</th></tr></thead><tbody>';
            for (var c = 0; c < channels.length; c++) {
              var ch = channels[c];
              chHtml += '<tr><td class="channel-name">' + ch.name + '</td>';
              chHtml += '<td><span class="status-badge ' + (ch.is_active ? 'status-badge--active' : 'status-badge--inactive') + '"><span class="status-dot"></span>' + (ch.is_active ? 'Active' : 'Disabled') + '</span></td>';
              chHtml += '<td>' + formatNumber(ch.calls) + '</td>';
              chHtml += '<td>' + formatNumber(ch.tokens) + '</td>';
              chHtml += '<td>' + formatLatency(ch.avg_latency) + '</td>';
              chHtml += '<td>' + formatNumber(ch.success_count) + '</td>';
              chHtml += '<td>' + formatNumber(ch.error_count) + '</td></tr>';
            }
            chHtml += '</tbody></table>';
            sc.innerHTML = chHtml;
          }
        } catch(e) {
          if (ss) ss.innerHTML = '<div class="empty-state"><p>Failed to load stats</p></div>';
        }
      };

      // Close modals on overlay click
      var overlays = document.querySelectorAll('.modal-overlay');
      for (var o = 0; o < overlays.length; o++) {
        overlays[o].addEventListener('click', function(e) {
          if (e.target === this) this.classList.remove('active');
        });
      }

      // Close buttons
      var closeBtns = document.querySelectorAll('.modal__close, #source-cancel-btn, #channel-cancel-btn, #stats-close-btn');
      for (var cb = 0; cb < closeBtns.length; cb++) {
        closeBtns[cb].addEventListener('click', function() {
          var modal = this.closest('.modal-overlay');
          if (modal) modal.classList.remove('active');
        });
      }

      // Login form
      var loginForm = document.getElementById('login-form');
      if (loginForm) {
        loginForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          var btn = document.getElementById('login-btn');
          var errorEl = document.getElementById('login-error');
          hideError(errorEl);
          showLoading(btn);

          try {
            var res = await fetch(API_BASE + '/api/superadmin/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ username: document.getElementById('username').value, password: document.getElementById('password').value })
            });
            var data = await res.json();
            if (data.success) {
              localStorage.setItem(TOKEN_KEY, data.token);
              showDashboard(data.user);
              loginForm.reset();
            } else {
              showError(errorEl, data.error || 'Login failed');
            }
          } catch(err) {
            showError(errorEl, 'Network error');
          } finally {
            hideLoading(btn);
          }
        });
      }

      // Logout
      var logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          localStorage.removeItem(TOKEN_KEY);
          showLogin();
        });
      }

      // Add Source button
      var addSourceBtn = document.getElementById('add-source-btn');
      if (addSourceBtn) {
        addSourceBtn.addEventListener('click', function() {
          var t = document.getElementById('source-modal-title');
          if (t) t.textContent = 'Add Source API';
          var sid = document.getElementById('source-id');
          if (sid) sid.value = '';
          var sn = document.getElementById('source-name');
          if (sn) sn.value = '';
          var sp = document.getElementById('source-provider');
          if (sp) sp.value = 'openai';
          var sb = document.getElementById('source-baseurl');
          if (sb) sb.value = PROVIDER_PRESETS.openai.baseUrl;
          var sa = document.getElementById('source-apikey');
          if (sa) sa.value = '';
          var sm = document.getElementById('source-model');
          if (sm) sm.value = '';
          var se = document.getElementById('source-error');
          if (se) se.style.display = 'none';
          openModal('source-modal');
        });
      }

      // Source form submit
      var sourceForm = document.getElementById('source-form');
      if (sourceForm) {
        sourceForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          var btn = document.getElementById('source-save-btn');
          var errorEl = document.getElementById('source-error');
          hideError(errorEl);
          showLoading(btn);

          var id = document.getElementById('source-id').value;
          var nameVal = document.getElementById('source-name').value.trim();
          var baseUrlVal = document.getElementById('source-baseurl').value.trim();
          var apiKeyVal = document.getElementById('source-apikey').value.trim();
          var providerVal = document.getElementById('source-provider').value;
          var modelVal = document.getElementById('source-model').value.trim();

          if (!nameVal || !baseUrlVal || !apiKeyVal) {
            showError(errorEl, 'Name, Base URL and API Key are required');
            hideLoading(btn);
            return;
          }

          var data = {
            name: nameVal,
            base_url: baseUrlVal,
            api_key: apiKeyVal,
            api_format: providerVal
          };
          if (modelVal) data.default_model = modelVal;

          try {
            var result;
            if (id) {
              result = await apiCall('/api/proxy/sources/' + id, { method: 'PUT', body: JSON.stringify(data) });
            } else {
              result = await apiCall('/api/proxy/sources', { method: 'POST', body: JSON.stringify(data) });
            }
            if (result.success || result.id) {
              closeModal('source-modal');
              loadSources();
            } else {
              showError(errorEl, result.error || result.message || 'Failed to save');
            }
          } catch(err) {
            showError(errorEl, 'Network error: ' + err.message);
          } finally {
            hideLoading(btn);
          }
        });
      }

      // Channel form submit
      var channelForm = document.getElementById('channel-form');
      if (channelForm) {
        channelForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          var btn = document.getElementById('channel-save-btn');
          var errorEl = document.getElementById('channel-error');
          hideError(errorEl);
          showLoading(btn);

          var id = document.getElementById('channel-id').value;
          var sourceId = document.getElementById('channel-source-id').value;
          var nameVal = document.getElementById('channel-name').value.trim();

          if (!nameVal) {
            showError(errorEl, 'Channel name is required');
            hideLoading(btn);
            return;
          }

          var data = {
            name: nameVal,
            rate_limit: parseInt(document.getElementById('channel-ratelimit').value) || 0,
            daily_quota: parseInt(document.getElementById('channel-quota').value) || 0
          };

          try {
            var result;
            if (id) {
              result = await apiCall('/api/proxy/channels/' + id, { method: 'PUT', body: JSON.stringify(data) });
            } else {
              result = await apiCall('/api/proxy/sources/' + sourceId + '/channels', { method: 'POST', body: JSON.stringify(data) });
            }
            if (result.success || result.id) {
              closeModal('channel-modal');
              loadSources();
            } else {
              showError(errorEl, result.error || result.message || 'Failed to save');
            }
          } catch(err) {
            showError(errorEl, 'Network error: ' + err.message);
          } finally {
            hideLoading(btn);
          }
        });
      }

      // Provider preset auto-fill
      var providerSelect = document.getElementById('source-provider');
      if (providerSelect) {
        providerSelect.addEventListener('change', function() {
          var preset = PROVIDER_PRESETS[this.value];
          if (preset) {
            var sb = document.getElementById('source-baseurl');
            if (sb) sb.value = preset.baseUrl;
            var sm = document.getElementById('source-model');
            if (sm) sm.value = preset.defaultModel;
          }
        });
      }

      // Init
      verifySession();
    })();
  </script>
</Layout>
