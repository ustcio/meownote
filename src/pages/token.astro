---
import Layout from '../layouts/Layout.astro';
---

<Layout title="API Proxy | Maxwell.Science">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>

  <div class="proxy-page">
    <div class="proxy-container">
      <!-- Login Section -->
      <div id="login-section" class="proxy-login">
        <div class="proxy-login__card">
          <div class="proxy-login__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h1 class="proxy-login__title">API Proxy</h1>
          <p class="proxy-login__subtitle">Super Admin Access</p>

          <form id="login-form" class="proxy-login__form">
            <div class="form-group">
              <label for="username" class="form-label">Username</label>
              <input type="text" id="username" name="username" class="form-input" placeholder="Enter username" autocomplete="username" required />
            </div>
            <div class="form-group">
              <label for="password" class="form-label">Password</label>
              <input type="password" id="password" name="password" class="form-input" placeholder="Enter password" autocomplete="current-password" required />
            </div>
            <div id="login-error" class="form-error" style="display:none;"></div>
            <button type="submit" class="proxy-login__btn" id="login-btn">
              <span class="btn-text">Sign In</span>
              <span class="btn-loader" style="display:none;">
                <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </form>
        </div>
      </div>

      <!-- Dashboard Section -->
      <div id="dashboard-section" class="proxy-dashboard" style="display:none;">
        <div class="proxy-dashboard__header">
          <div class="proxy-dashboard__brand">
            <div class="proxy-dashboard__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
            </div>
            <div>
              <h1 class="proxy-dashboard__title">API Proxy</h1>
              <p class="proxy-dashboard__subtitle">Welcome, <span id="admin-name"></span></p>
            </div>
          </div>
          <div class="proxy-dashboard__actions">
            <button id="add-source-btn" class="btn btn--primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Source
            </button>
            <button id="logout-btn" class="btn btn--ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </button>
          </div>
        </div>

        <!-- Summary Stats Bar -->
        <div id="summary-stats" class="summary-stats" style="display:none;">
          <div class="summary-stat">
            <div class="summary-stat__value" id="stat-sources">0</div>
            <div class="summary-stat__label">Sources</div>
          </div>
          <div class="summary-stat">
            <div class="summary-stat__value" id="stat-channels">0</div>
            <div class="summary-stat__label">Channels</div>
          </div>
          <div class="summary-stat">
            <div class="summary-stat__value" id="stat-calls">0</div>
            <div class="summary-stat__label">Total Calls</div>
          </div>
          <div class="summary-stat">
            <div class="summary-stat__value" id="stat-active">0</div>
            <div class="summary-stat__label">Active</div>
          </div>
        </div>

        <div id="sources-list" class="sources-list">
          <div class="loading-state">
            <div class="skeleton" style="width:100%;height:120px;border-radius:16px;"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Source Modal -->
    <div id="source-modal" class="modal-overlay">
      <div class="modal">
        <div class="modal__header">
          <div>
            <h2 id="source-modal-title" class="modal__title">Add Source API</h2>
            <p class="modal__subtitle">Configure an API provider connection</p>
          </div>
          <button type="button" class="modal__close" id="source-modal-close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <form id="source-form">
          <div class="modal__body">
            <input type="hidden" id="source-id" />
            <div class="form-group">
              <label class="form-label">Name <span class="form-required">*</span></label>
              <input type="text" id="source-name" class="form-input" placeholder="e.g. OpenAI, Anthropic" required />
            </div>
            <div class="form-group">
              <label class="form-label">Provider <span class="form-required">*</span></label>
              <div class="provider-grid">
                <label class="provider-option" data-value="openai">
                  <input type="radio" name="source-provider" value="openai" checked />
                  <div class="provider-option__icon provider-option__icon--openai">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/></svg>
                  </div>
                  <span class="provider-option__label">OpenAI</span>
                </label>
                <label class="provider-option" data-value="anthropic">
                  <input type="radio" name="source-provider" value="anthropic" />
                  <div class="provider-option__icon provider-option__icon--anthropic">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 14.5c0-1.5-1-2.5-2.5-2.5h-4c-1.5 0-2.5 1-2.5 2.5v5c0 1.5 1 2.5 2.5 2.5h4c1.5 0 2.5-1 2.5-2.5v-5zM12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8z"/></svg>
                  </div>
                  <span class="provider-option__label">Anthropic</span>
                </label>
                <label class="provider-option" data-value="azure">
                  <input type="radio" name="source-provider" value="azure" />
                  <div class="provider-option__icon provider-option__icon--azure">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.05 4.24L7.56 18.16l-3.8-1.52 5.49-13.92 3.8 1.52zM17.24 6.24l-4.48 11.36 3.8 1.52 4.48-11.36-3.8-1.52z"/></svg>
                  </div>
                  <span class="provider-option__label">Azure</span>
                </label>
                <label class="provider-option" data-value="dashscope">
                  <input type="radio" name="source-provider" value="dashscope" />
                  <div class="provider-option__icon provider-option__icon--dashscope">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                  </div>
                  <span class="provider-option__label">DashScope</span>
                </label>
                <label class="provider-option" data-value="custom">
                  <input type="radio" name="source-provider" value="custom" />
                  <div class="provider-option__icon provider-option__icon--custom">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                  </div>
                  <span class="provider-option__label">Custom</span>
                </label>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Base URL <span class="form-required">*</span></label>
              <input type="text" id="source-baseurl" class="form-input" placeholder="https://api.openai.com/v1" required />
            </div>
            <div class="form-group">
              <label class="form-label">API Key <span class="form-required">*</span></label>
              <div class="input-with-toggle">
                <input type="password" id="source-apikey" class="form-input form-input--apikey" placeholder="sk-..." required />
                <button type="button" class="input-toggle" onclick="window.toggleApiKeyVisibility(this)" aria-label="Toggle API key visibility">
                  <svg class="icon-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  <svg class="icon-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </button>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Default Model <span class="form-hint">(optional)</span></label>
              <input type="text" id="source-model" class="form-input" placeholder="e.g. gpt-4o, claude-sonnet-4-20250514" />
            </div>
            <div id="source-error" class="form-error" style="display:none;"></div>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn--ghost" id="source-cancel-btn">Cancel</button>
            <button type="submit" class="btn btn--primary" id="source-save-btn">
              <span class="btn-text">Save</span>
              <span class="btn-loader" style="display:none;">
                <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Channel Modal -->
    <div id="channel-modal" class="modal-overlay">
      <div class="modal">
        <div class="modal__header">
          <div>
            <h2 id="channel-modal-title" class="modal__title">Add Channel</h2>
            <p class="modal__subtitle">Create a sub-channel for this source</p>
          </div>
          <button type="button" class="modal__close" id="channel-modal-close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <form id="channel-form">
          <div class="modal__body">
            <input type="hidden" id="channel-id" />
            <input type="hidden" id="channel-source-id" />
            <div class="form-group">
              <label class="form-label">Channel Name <span class="form-required">*</span></label>
              <input type="text" id="channel-name" class="form-input" placeholder="e.g. ChatBot, Research" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Rate Limit <span class="form-hint">(req/min)</span></label>
                <input type="number" id="channel-ratelimit" class="form-input" value="0" min="0" />
              </div>
              <div class="form-group">
                <label class="form-label">Daily Quota <span class="form-hint">(0=unlimited)</span></label>
                <input type="number" id="channel-quota" class="form-input" value="0" min="0" />
              </div>
            </div>
            <div id="channel-error" class="form-error" style="display:none;"></div>
          </div>
          <div class="modal__footer">
            <button type="button" class="btn btn--ghost" id="channel-cancel-btn">Cancel</button>
            <button type="submit" class="btn btn--primary" id="channel-save-btn">
              <span class="btn-text">Save</span>
              <span class="btn-loader" style="display:none;">
                <svg class="spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Stats Modal -->
    <div id="stats-modal" class="modal-overlay">
      <div class="modal modal--wide">
        <div class="modal__header">
          <div>
            <h2 id="stats-title" class="modal__title">Usage Statistics</h2>
            <p class="modal__subtitle">Performance overview for this source</p>
          </div>
          <button type="button" class="modal__close" id="stats-modal-close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div class="modal__body">
          <div class="stats-summary" id="stats-summary"></div>
          <div class="stats-chart-container">
            <canvas id="stats-chart"></canvas>
          </div>
          <div class="stats-channels" id="stats-channels"></div>
        </div>
        <div class="modal__footer">
          <button type="button" class="btn btn--ghost" id="stats-close-btn">Close</button>
        </div>
      </div>
    </div>
  </div>

  <style is:inline>
    /* ============================================================
       API Proxy Page - Redesigned
       ============================================================ */

    .proxy-page {
      min-height: 100vh;
      padding: calc(var(--header-height) + 2rem) 1rem 4rem;
      background: var(--bg-primary);
    }

    @media (min-width: 768px) {
      .proxy-page { padding-left: 1.5rem; padding-right: 1.5rem; }
    }

    .proxy-container { max-width: 800px; margin: 0 auto; }

    /* ---- Login ---- */
    .proxy-page .proxy-login {
      display: flex; align-items: center; justify-content: center;
      min-height: 60vh;
    }

    .proxy-page .proxy-login__card {
      width: 100%; max-width: 400px;
      background: var(--card-bg); border: 1px solid var(--card-border);
      border-radius: 20px; padding: 2.5rem 2rem;
      text-align: center;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }

    .proxy-page .proxy-login__icon {
      display: inline-flex; align-items: center; justify-content: center;
      width: 52px; height: 52px; border-radius: 16px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
      color: #fff; margin-bottom: 1.25rem;
    }

    .proxy-page .proxy-login__title {
      font-family: var(--font-display); font-size: 1.5rem;
      font-weight: 700; color: var(--text-primary); margin: 0 0 0.25rem;
    }

    .proxy-page .proxy-login__subtitle { font-size: 0.875rem; color: var(--text-tertiary); margin: 0 0 2rem; }
    .proxy-page .proxy-login__form { display: flex; flex-direction: column; gap: 1rem; text-align: left; }

    .proxy-page .proxy-login__btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      width: 100%; padding: 0.75rem 1.5rem; border: none; border-radius: 12px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
      color: #fff; font-size: 0.9375rem; font-weight: 600; cursor: pointer;
      transition: all 0.2s ease; margin-top: 0.5rem;
    }
    .proxy-page .proxy-login__btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
    .proxy-page .proxy-login__btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    /* ---- Dashboard Header ---- */
    .proxy-page .proxy-dashboard__header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1.5rem; gap: 1rem; flex-wrap: wrap;
    }

    .proxy-page .proxy-dashboard__brand { display: flex; align-items: center; gap: 0.75rem; }

    .proxy-page .proxy-dashboard__icon {
      display: flex; align-items: center; justify-content: center;
      width: 40px; height: 40px; border-radius: 12px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
      color: #fff; flex-shrink: 0;
    }

    .proxy-page .proxy-dashboard__title {
      font-family: var(--font-display); font-size: 1.375rem;
      font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.2;
    }

    .proxy-page .proxy-dashboard__subtitle { font-size: 0.8125rem; color: var(--text-tertiary); margin: 0; }
    .proxy-page .proxy-dashboard__actions { display: flex; gap: 0.5rem; }

    /* ---- Summary Stats ---- */
    .proxy-page .summary-stats {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .proxy-page .summary-stat {
      background: var(--card-bg); border: 1px solid var(--card-border);
      border-radius: 14px; padding: 1rem 0.75rem; text-align: center;
    }

    .proxy-page .summary-stat__value {
      font-family: var(--font-display); font-size: 1.25rem;
      font-weight: 700; color: var(--text-primary);
    }

    .proxy-page .summary-stat__label { font-size: 0.6875rem; color: var(--text-tertiary); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.05em; }

    /* ---- Source Cards ---- */
    .proxy-page .sources-list { display: flex; flex-direction: column; gap: 0.75rem; }

    .proxy-page .source-card {
      background: var(--card-bg); border: 1px solid var(--card-border);
      border-radius: 16px; overflow: hidden;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .proxy-page .source-card:hover { border-color: var(--card-border-hover); box-shadow: 0 2px 12px rgba(0,0,0,0.06); }

    .proxy-page .source-card__header {
      padding: 1rem 1.25rem; cursor: pointer;
      display: flex; align-items: center; gap: 0.875rem; user-select: none;
      transition: background 0.15s ease;
    }

    .proxy-page .source-card__header:hover { background: var(--card-bg-hover); }

    .proxy-page .source-card__icon {
      display: flex; align-items: center; justify-content: center;
      width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
    }

    .proxy-page .source-card__icon--openai { background: #10a37f15; color: #10a37f; }
    .proxy-page .source-card__icon--anthropic { background: #d9775715; color: #d97757; }
    .proxy-page .source-card__icon--azure { background: #0078d415; color: #0078d4; }
    .proxy-page .source-card__icon--dashscope { background: #615ef015; color: #615ef0; }
    .proxy-page .source-card__icon--custom { background: var(--bg-tertiary); color: var(--text-tertiary); }

    .proxy-page .source-card__info { flex: 1; min-width: 0; }

    .proxy-page .source-card__name {
      font-family: var(--font-display); font-size: 0.9375rem;
      font-weight: 600; color: var(--text-primary); margin: 0 0 3px;
    }

    .proxy-page .source-card__url {
      font-size: 0.75rem; color: var(--text-quaternary);
      font-family: var(--font-mono); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

