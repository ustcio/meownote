---
import Layout from '@layouts/Layout.astro';
import ModalShell from '@components/ui/ModalShell.astro';

const pageTitle = '实验记录';
const pageDesc = '记录并管理薄膜生长实验参数，保持每一次沉积条件触手可及。';
---

<Layout title={`${pageTitle} - MoonSun.ai`} description={pageDesc} showHeader={false} showAuthModal={false} showFooter={false}>
  <section class="experiments-page">
    <div class="container">
      <!-- Header -->
      <div class="experiments-header">
        <div class="experiments-header__copy">
          <h1>实验记录</h1>

        </div>
        <div class="experiments-header__actions">
          <div class="experiments-stats">
            <div class="stat-card">
              <span class="stat-label">总记录数</span>
              <strong id="records-count">0</strong>
            </div>
            <div class="stat-card">
              <span class="stat-label">最新记录</span>
              <strong id="last-record-date">—</strong>
            </div>
          </div>

        </div>
      </div>

      <!-- Toolbar -->
      <div class="experiments-toolbar">
        <div class="toolbar-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-input" placeholder="搜索靶材材料..." />
        </div>
        <div class="toolbar-actions">
          <div class="toolbar-sort">
            <label for="sort-field">排序</label>
            <select id="sort-field">
              <option value="dateTime">日期</option>
              <option value="targetBatch">靶材批次</option>
              <option value="pressure">气压</option>
              <option value="growthTemp">生长温度</option>
            </select>
            <button class="sort-direction-btn" id="sort-direction" aria-label="切换排序方向">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="18 15 12 9 6 15"></polyline>
              </svg>
            </button>
          </div>
          <button class="btn-ghost" id="import-btn" title="导入 JSON">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            <span>导入</span>
          </button>
          <button class="btn-ghost" id="export-btn" title="导出 TXT">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>导出 TXT</span>
          </button>
          <button class="btn-ghost" id="export-md-btn" title="导出 Markdown">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
            <span>导出 Markdown</span>
          </button>
          <a href="/experiments/equipment/edit/" class="claude-button-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
              <line x1="6" y1="6" x2="6.01" y2="6"></line>
              <line x1="6" y1="18" x2="6.01" y2="18"></line>
            </svg>
            <span>新增设备故障</span>
          </a>
          <a href="/experiments/edit/" class="claude-button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <span>新建记录</span>
          </a>
        </div>
      </div>

      <!-- Records Table -->
      <div class="experiments-table-wrapper">
        <table class="experiments-table" id="records-table">
          <thead>
            <tr>
              <th scope="col">日期时间</th>
              <th scope="col">记录人</th>
              <th scope="col">靶材批次</th>
              <th scope="col">计量比</th>
              <th scope="col">气压 (Pa)</th>
              <th scope="col">闸板阀</th>
              <th scope="col">生长温度 (°C)</th>
              <th scope="col">退火温度 (°C)</th>
              <th scope="col">样品高度 (mm)</th>
              <th scope="col">厚度 (μm)</th>
              <th scope="col">剩磁 (T)</th>
              <th scope="col">矫顽力 (T)</th>
              <th scope="col">饱和磁化 (T)</th>
              <th scope="col" class="col-actions">操作</th>
            </tr>
          </thead>
          <tbody id="records-tbody">
            <!-- Populated by JS -->
          </tbody>
        </table>
        <div class="empty-state" id="empty-state" style="display: none;">
          <div class="empty-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
          </div>
          <h3>暂无记录</h3>
          <p>开始记录你的第一条数据。</p>
          <a href="/experiments/edit/" class="claude-button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            创建第一条记录
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Delete Modal -->
  <ModalShell id="delete-modal" title="删除记录" closeId="delete-close" backdropId="delete-backdrop" closeClass="modal-close" contentClass="modal-sm">
    <p>此操作将永久删除该实验记录，无法撤销。</p>
    <div class="modal-actions">
      <button class="claude-button-secondary" id="delete-cancel">取消</button>
      <button class="btn-danger" id="delete-confirm">删除</button>
    </div>
  </ModalShell>

  <input type="file" id="import-file" accept=".json" style="display: none;" />

  <script>
    import { experimentStorage } from '@/lib/experiments/storage';
    import { equipmentStorage } from '@/lib/equipment/storage';
    import type { ExperimentRecord, SortConfig } from '@/lib/experiments/types';
    import type { EquipmentRecord } from '@/lib/equipment/types';

    type ListItem = ({ kind: 'experiment' } & ExperimentRecord) | ({ kind: 'equipment' } & EquipmentRecord);

    let currentSort: SortConfig = { field: 'dateTime', direction: 'desc' };
    let currentSearch = '';
    let pendingDeleteId: string | null = null;
    let pendingDeleteKind: 'experiment' | 'equipment' | null = null;

    function showToast(message: string, type: 'success' | 'error' = 'success') {
      if (window.__meownoteToast) {
        window.__meownoteToast.show(message, type);
      } else {
        alert(message);
      }
    }

    function formatDateTime(iso: string): string {
      const d = new Date(iso);
      return d.toLocaleString('zh-CN', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      });
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function updateStats(items: ListItem[]) {
      const countEl = document.getElementById('records-count');
      const lastDateEl = document.getElementById('last-record-date');
      if (countEl) countEl.textContent = String(items.length);
      if (lastDateEl) {
        if (items.length === 0) {
          lastDateEl.textContent = '—';
        } else {
          const sorted = [...items].sort((a, b) => new Date(b.dateTime).getTime() - new Date(a.dateTime).getTime());
          lastDateEl.textContent = formatDateTime(sorted[0].dateTime).split(' ')[0];
        }
      }
    }

    function renderTable(items: ListItem[]) {
      const tbody = document.getElementById('records-tbody');
      const emptyState = document.getElementById('empty-state');
      const table = document.getElementById('records-table');

      if (!tbody || !emptyState || !table) return;

      if (items.length === 0) {
        table.style.display = 'none';
        emptyState.style.display = 'flex';
        updateStats(items);
        return;
      }

      table.style.display = 'table';
      emptyState.style.display = 'none';
      updateStats(items);

      tbody.innerHTML = items
        .map(
          (r, index) => {
            if (r.kind === 'equipment') {
              return `
        <tr data-id="${r.id}" data-kind="equipment" style="animation-delay: ${Math.min(index * 0.03, 0.4)}s">
          <td class="cell-datetime">${formatDateTime(r.dateTime)}</td>
          <td class="cell-target">${escapeHtml(r.user)}</td>
          <td class="cell-equipment-type"><span class="equipment-badge">设备故障</span></td>
          <td class="cell-summary" colspan="10">${escapeHtml(r.summary)}</td>
          <td class="cell-actions">
            <a href="/experiments/equipment/detail/?id=${r.id}" class="action-btn action-btn--detail" title="细节">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
            </a>
            <button class="action-btn action-btn--delete" data-id="${r.id}" data-kind="equipment" title="删除">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </td>
        </tr>
      `;
            }
            const perfAttr = r.performanceOk === true ? 'data-performance="ok"' : r.performanceOk === false ? 'data-performance="fail"' : '';
            return `
        <tr data-id="${r.id}" data-kind="experiment" ${perfAttr} style="animation-delay: ${Math.min(index * 0.03, 0.4)}s">
          <td class="cell-datetime">${formatDateTime(r.dateTime)}</td>
          <td class="cell-target">${escapeHtml(r.user)}</td>
          <td class="cell-target">${escapeHtml(r.targetBatch)}</td>
          <td class="cell-target">${escapeHtml(r.targetRatio)}</td>
          <td class="cell-pressure">${r.pressure}</td>
          <td class="cell-gate">${escapeHtml(r.gateValve)}</td>
          <td class="cell-temp">${r.growthTemp}</td>
          <td class="cell-temp">${r.annealingTemp}</td>
          <td class="cell-height">${r.sampleHeight ?? '-'}</td>
          <td class="cell-height">${r.sampleThickness ?? '-'}</td>
          <td class="cell-height">${r.remanence ?? '-'}</td>
          <td class="cell-height">${r.coercivity ?? '-'}</td>
          <td class="cell-height">${r.saturationMagnetization ?? '-'}</td>
          <td class="cell-actions">
            <a href="/experiments/edit/?id=${r.id}" class="action-btn action-btn--edit" title="编辑">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
            </a>
            <button class="action-btn action-btn--delete" data-id="${r.id}" data-kind="experiment" title="删除">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
          </td>
        </tr>
      `;
          }
        )
        .join('');

      tbody.querySelectorAll('.action-btn--delete').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const el = e.currentTarget as HTMLElement;
          const id = el.dataset.id;
          const kind = el.dataset.kind as 'experiment' | 'equipment';
          if (id) {
            pendingDeleteId = id;
            pendingDeleteKind = kind;
            document.getElementById('delete-modal')?.classList.add('open');
          }
        });
      });
    }

    function refresh() {
      const experiments = experimentStorage.list(
        currentSearch ? { target: currentSearch } : undefined,
        currentSort
      );
      const equipments = equipmentStorage.list(
        currentSearch ? { search: currentSearch } : undefined
      );
      const items: ListItem[] = [
        ...experiments.map((r) => ({ ...r, kind: 'experiment' as const })),
        ...equipments.map((r) => ({ ...r, kind: 'equipment' as const })),
      ];
      items.sort((a, b) => b.dateTime.localeCompare(a.dateTime));
      renderTable(items);
    }

    experimentStorage.init();
    refresh();


    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    let searchDebounce: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(searchDebounce);
      searchDebounce = setTimeout(() => {
        currentSearch = (e.target as HTMLInputElement).value.trim();
        refresh();
      }, 200);
    });

    const sortField = document.getElementById('sort-field') as HTMLSelectElement;
    sortField?.addEventListener('change', () => {
      currentSort.field = sortField.value as any;
      refresh();
    });

    const sortDirBtn = document.getElementById('sort-direction');
    sortDirBtn?.addEventListener('click', () => {
      currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
      sortDirBtn.style.transform = currentSort.direction === 'asc' ? 'rotate(180deg)' : 'rotate(0deg)';
      refresh();
    });

    document.getElementById('export-btn')?.addEventListener('click', () => {
      const experiments = experimentStorage.list(undefined, { field: 'dateTime', direction: 'desc' });
      const equipments = equipmentStorage.list(undefined, { field: 'dateTime', direction: 'desc' });

      const lines: string[] = [];
      lines.push('实验与设备记录');
      lines.push(`导出时间: ${new Date().toLocaleString('zh-CN')}`);
      lines.push('========================================');
      lines.push('');

      if (experiments.length > 0) {
        lines.push('【实验记录】');
        lines.push('');
        experiments.forEach((r, i) => {
          lines.push(`--- 记录 ${i + 1} ---`);
          lines.push(`日期时间: ${formatDateTime(r.dateTime)}`);
          lines.push(`记录人: ${r.user}`);
          lines.push(`样品性能: ${r.performanceOk === true ? '符合预期' : r.performanceOk === false ? '不符合预期' : '未确认'}`);
          lines.push(`靶材批次: ${r.targetBatch}`);
          lines.push(`计量比: ${r.targetRatio}`);
          lines.push(`气压 (Pa): ${r.pressure}`);
          lines.push(`闸板阀: ${r.gateValve}`);
          lines.push(`生长温度 (°C): ${r.growthTemp}`);
          lines.push(`退火温度 (°C): ${r.annealingTemp}`);
          lines.push(`样品高度 (mm): ${r.sampleHeight}`);
          lines.push(`样品厚度 (μm): ${r.sampleThickness}`);
          lines.push(`剩磁 (T): ${r.remanence}`);
          lines.push(`矫顽力 (T): ${r.coercivity}`);
          lines.push(`饱和磁化 (T): ${r.saturationMagnetization}`);
          if (r.notes) lines.push(`备注: ${r.notes}`);
          lines.push('');
        });
      }

      if (equipments.length > 0) {
        lines.push('【设备故障】');
        lines.push('');
        equipments.forEach((r, i) => {
          lines.push(`--- 记录 ${i + 1} ---`);
          lines.push(`日期时间: ${formatDateTime(r.dateTime)}`);
          lines.push(`记录人: ${r.user}`);
          lines.push(`故障概述: ${r.summary}`);
          if (r.details) lines.push(`故障详情: ${r.details}`);
          lines.push('');
        });
      }

      const txt = lines.join('\n');
      const blob = new Blob([txt], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `records-${new Date().toISOString().slice(0, 10)}.txt`;
      a.click();
      URL.revokeObjectURL(url);
      showToast('导出成功');
    });

    function escapeMd(text: string | undefined | null): string {
      if (text == null) return '';
      return text.replace(/([*_`\[\]#])/g, '\\$1');
    }

    document.getElementById('export-md-btn')?.addEventListener('click', () => {
      const experiments = experimentStorage.list(undefined, { field: 'dateTime', direction: 'desc' });
      const equipments = equipmentStorage.list(undefined, { field: 'dateTime', direction: 'desc' });
      const allItems: ListItem[] = [
        ...experiments.map((r) => ({ ...r, kind: 'experiment' as const })),
        ...equipments.map((r) => ({ ...r, kind: 'equipment' as const })),
      ];
      allItems.sort((a, b) => b.dateTime.localeCompare(a.dateTime));

      if (allItems.length === 0) {
        showToast('暂无记录可导出', 'error');
        return;
      }

      const lines: string[] = [];
      lines.push('# 实验与设备记录');
      lines.push('');
      lines.push(`> 导出时间：${new Date().toLocaleString('zh-CN')}`);
      lines.push(`> 共 ${allItems.length} 条记录`);
      lines.push('');

      allItems.forEach((r, i) => {
        if (r.kind === 'equipment') {
          lines.push(`## 记录 ${i + 1} · 设备故障`);
          lines.push('');
          lines.push(`- **日期时间**：${formatDateTime(r.dateTime)}`);
          lines.push(`- **记录人**：${escapeMd(r.user)}`);
          lines.push(`- **故障概述**：${escapeMd(r.summary)}`);
          if (r.details && r.details.trim()) {
            lines.push(`- **故障详情**：${escapeMd(r.details)}`);
          }
        } else {
          lines.push(`## 记录 ${i + 1} · 实验记录`);
          lines.push('');
          lines.push(`- **日期时间**：${formatDateTime(r.dateTime)}`);
          lines.push(`- **记录人**：${escapeMd(r.user)}`);
          const perfLabel = r.performanceOk === true ? '✅ 符合预期' : r.performanceOk === false ? '⚠️ 不符合预期' : '未确认';
          lines.push(`- **样品性能**：${perfLabel}`);
          lines.push(`- **靶材批次**：${escapeMd(r.targetBatch)}`);
          lines.push(`- **靶材成分计量比**：${escapeMd(r.targetRatio)}`);
          lines.push(`- **气压 (Pa)**：${r.pressure}`);
          lines.push(`- **闸板阀**：${escapeMd(r.gateValve)}`);
          lines.push(`- **生长温度 (°C)**：${r.growthTemp ?? '-'}`);
          lines.push(`- **退火温度 (°C)**：${r.annealingTemp ?? '-'}`);
          lines.push(`- **样品高度 (mm)**：${r.sampleHeight ?? '-'}`);
          lines.push(`- **样品厚度 (μm)**：${r.sampleThickness ?? '-'}`);
          lines.push(`- **剩磁 (T)**：${r.remanence ?? '-'}`);
          lines.push(`- **矫顽力 (T)**：${r.coercivity ?? '-'}`);
          lines.push(`- **饱和磁化强度 (T)**：${r.saturationMagnetization ?? '-'}`);
          if (r.notes && r.notes.trim()) {
            lines.push(`- **备注**：${escapeMd(r.notes)}`);
          }
        }
        lines.push('');
        lines.push('---');
        lines.push('');
      });

      const mdContent = lines.join('\n');
      const blob = new Blob([mdContent], { type: 'text/markdown;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `records-${new Date().toISOString().slice(0, 10)}.md`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      showToast('Markdown 导出成功');
    });

    const importFile = document.getElementById('import-file') as HTMLInputElement;
    document.getElementById('import-btn')?.addEventListener('click', () => {
      importFile?.click();
    });
    importFile?.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        const text = ev.target?.result as string;
        const expResult = experimentStorage.importFromJSON(text);
        const eqResult = equipmentStorage.importFromJSON(text);
        const totalSuccess = expResult.success + eqResult.success;
        const totalFailed = expResult.failed + eqResult.failed;
        if (totalFailed > 0) {
          showToast(`导入 ${totalSuccess} 条记录，${totalFailed} 条失败`, 'error');
        } else {
          showToast(`成功导入 ${totalSuccess} 条记录`);
        }
        refresh();
      };
      reader.readAsText(file);
      importFile.value = '';
    });

    // Delete modal handlers
    function closeDeleteModal() {
      document.getElementById('delete-modal')?.classList.remove('open');
      pendingDeleteId = null;
      pendingDeleteKind = null;
    }
    document.getElementById('delete-backdrop')?.addEventListener('click', closeDeleteModal);
    document.getElementById('delete-close')?.addEventListener('click', closeDeleteModal);
    document.getElementById('delete-cancel')?.addEventListener('click', closeDeleteModal);
    document.getElementById('delete-confirm')?.addEventListener('click', () => {
      if (pendingDeleteId) {
        if (pendingDeleteKind === 'equipment') {
          equipmentStorage.remove(pendingDeleteId);
        } else {
          experimentStorage.remove(pendingDeleteId);
        }
        showToast('记录已删除');
        refresh();
      }
      closeDeleteModal();
    });
  </script>

  <style is:global>
    .experiments-page {
      min-height: 100vh;
      padding: calc(var(--header-height) + 2rem) 0 4rem;
      background: var(--bg-primary);
    }

    /* Header */
