---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="正则测试 - Maxwell.Science"
  description="在线测试正则表达式，实时匹配高亮"
>
  <section class="regex-tool">
    <div class="container">
      <header class="header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span>工具箱</span>
        </a>
        <h1 class="title">正则测试</h1>
        <p class="desc">在线测试正则表达式，实时匹配高亮</p>
      </header>

      <!-- Regex Input -->
      <div class="card">
        <div class="regex-input-row">
          <span class="slash">/</span>
          <input type="text" id="regex-pattern" placeholder="输入正则表达式..." spellcheck="false" />
          <span class="slash">/</span>
          <input type="text" id="regex-flags" value="g" placeholder="flags" spellcheck="false" class="flags-input" />
        </div>
        <div class="quick-flags">
          <label class="flag-btn"><input type="checkbox" value="g" checked /><span>Global</span></label>
          <label class="flag-btn"><input type="checkbox" value="i" /><span>Case-insensitive</span></label>
          <label class="flag-btn"><input type="checkbox" value="m" /><span>Multiline</span></label>
          <label class="flag-btn"><input type="checkbox" value="s" /><span>DotAll</span></label>
        </div>
        <div class="error-msg" id="regex-error"></div>
      </div>

      <!-- Test String -->
      <div class="card">
        <div class="card-head">
          <span class="card-title">测试文本</span>
          <div class="card-actions">
            <button class="btn-sm" id="clear-btn">清空</button>
          </div>
        </div>
        <textarea id="test-text" rows="6" placeholder="输入要匹配的文本..."></textarea>
      </div>

      <!-- Match Results -->
      <div class="card">
        <div class="card-head">
          <span class="card-title">匹配结果</span>
          <span class="match-count" id="match-count">0 个匹配</span>
        </div>
        <div class="highlight-box" id="highlight-box">
          <span class="placeholder-text">匹配结果将高亮显示在这里...</span>
        </div>
      </div>

      <!-- Match Groups -->
      <div class="card" id="groups-card" style="display:none;">
        <div class="card-head">
          <span class="card-title">匹配详情</span>
        </div>
        <div class="groups-list" id="groups-list"></div>
      </div>

      <!-- Common Patterns -->
      <div class="card">
        <div class="card-head">
          <span class="card-title">常用正则</span>
        </div>
        <div class="pattern-grid">
          <button class="pattern-btn" data-pattern="^https?://[\\w\\-]+(\\.[\\w\\-]+)+[/#?]?.*$" data-flags="i">URL</button>
          <button class="pattern-btn" data-pattern="^[\\w.-]+@[\\w.-]+\\.\\w+$" data-flags="i">Email</button>
          <button class="pattern-btn" data-pattern="^1[3-9]\\d{9}$" data-flags="">手机号</button>
          <button class="pattern-btn" data-pattern="^\\d{4}[-/]\\d{2}[-/]\\d{2}$" data-flags="">日期</button>
          <button class="pattern-btn" data-pattern="^[\\u4e00-\\u9fa5]{2,4}$" data-flags="">中文姓名</button>
          <button class="pattern-btn" data-pattern="\\d+\\.\\d+\\.\\d+\\.\\d+" data-flags="">IP 地址</button>
          <button class="pattern-btn" data-pattern="^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}$" data-flags="i">Email (严格)</button>
          <button class="pattern-btn" data-pattern="^[0-9a-fA-F]{32}$|^[0-9a-fA-F]{40}$|^[0-9a-fA-F]{64}$" data-flags="">Hash</button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .regex-tool { min-height: 100vh; padding: calc(var(--header-total-height) + var(--space-4)) var(--space-4) var(--space-16); }
  .container { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--space-4); }

  .header { margin-bottom: var(--space-4); }
  .back-link { display: inline-flex; align-items: center; gap: var(--space-1); color: var(--text-tertiary); font-size: var(--text-sm); margin-bottom: var(--space-4); }
  .back-link:hover { color: var(--text-secondary); }
  .title { font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--text-primary); margin-bottom: var(--space-1); }
  .desc { font-size: var(--text-sm); color: var(--text-secondary); }

  .card { background: var(--bg-secondary); border: 1px solid var(--border-primary); border-radius: var(--radius-xl); padding: var(--space-5); }
  .card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-4); }
  .card-title { font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--text-primary); }
  .card-actions { display: flex; gap: var(--space-2); }

  .regex-input-row { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-3); }
  .slash { font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--text-tertiary); font-family: var(--font-mono); }
  .regex-input-row input { flex: 1; padding: var(--space-3); background: var(--bg-tertiary); border: 1px solid var(--border-primary); border-radius: var(--radius-lg); color: var(--text-primary); font-size: var(--text-sm); font-family: var(--font-mono); }
  .regex-input-row input:focus { outline: none; border-color: var(--color-accent-blue); }
  .flags-input { max-width: 60px; flex: none !important; }

  .quick-flags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-2); }
  .flag-btn { display: flex; align-items: center; gap: var(--space-1); padding: var(--space-1) var(--space-2); background: var(--bg-tertiary); border-radius: var(--radius-md); font-size: var(--text-xs); color: var(--text-secondary); cursor: pointer; }
  .flag-btn input { display: none; }
  .flag-btn:has(input:checked) { background: var(--text-primary); color: var(--bg-primary); }

  .error-msg { font-size: var(--text-xs); color: #ef4444; min-height: 1.2em; }

  textarea { width: 100%; padding: var(--space-3); background: var(--bg-tertiary); border: 1px solid var(--border-primary); border-radius: var(--radius-lg); color: var(--text-primary); font-size: var(--text-sm); font-family: var(--font-mono); resize: vertical; line-height: 1.6; }
  textarea:focus { outline: none; border-color: var(--color-accent-blue); }

  .btn-sm { padding: var(--space-1) var(--space-3); background: var(--bg-tertiary); border: 1px solid var(--border-primary); border-radius: var(--radius-md); font-size: var(--text-xs); color: var(--text-secondary); cursor: pointer; }
  .btn-sm:hover { color: var(--text-primary); }

  .match-count { font-size: var(--text-xs); color: var(--text-tertiary); }
  .placeholder-text { color: var(--text-tertiary); font-size: var(--text-sm); }

  .highlight-box { padding: var(--space-3); background: var(--bg-tertiary); border-radius: var(--radius-lg); font-family: var(--font-mono); font-size: var(--text-sm); line-height: 1.8; white-space: pre-wrap; word-break: break-all; min-height: 60px; color: var(--text-primary); }
  .highlight-box mark { background: rgba(59, 130, 246, 0.25); color: var(--text-primary); border-radius: 2px; padding: 1px 0; }

  .groups-list { display: flex; flex-direction: column; gap: var(--space-2); }
  .group-item { display: flex; gap: var(--space-3); padding: var(--space-2) var(--space-3); background: var(--bg-tertiary); border-radius: var(--radius-md); font-size: var(--text-xs); font-family: var(--font-mono); }
  .group-idx { color: var(--text-tertiary); min-width: 20px; }
  .group-val { color: var(--text-primary); word-break: break-all; }

  .pattern-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .pattern-btn { padding: var(--space-2) var(--space-3); background: var(--bg-tertiary); border: 1px solid var(--border-primary); border-radius: var(--radius-md); font-size: var(--text-xs); color: var(--text-primary); cursor: pointer; transition: all var(--duration-fast) var(--ease-default); }
  .pattern-btn:hover { border-color: var(--border-hover); }
</style>

<script>
  const patternInput = document.getElementById('regex-pattern') as HTMLInputElement;
  const flagsInput = document.getElementById('regex-flags') as HTMLInputElement;
  const testText = document.getElementById('test-text') as HTMLTextAreaElement;
  const highlightBox = document.getElementById('highlight-box')!;
  const matchCount = document.getElementById('match-count')!;
  const regexError = document.getElementById('regex-error')!;
  const groupsCard = document.getElementById('groups-card')!;
  const groupsList = document.getElementById('groups-list')!;

  function escapeHtml(text: string): string {
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function runMatch() {
    const pattern = patternInput.value;
    const flags = flagsInput.value;
    const text = testText.value;

    if (!pattern || !text) {
      highlightBox.innerHTML = '<span class="placeholder-text">匹配结果将高亮显示在这里...</span>';
      matchCount.textContent = '0 个匹配';
      groupsCard.style.display = 'none';
      regexError.textContent = '';
      return;
    }

    try {
      const regex = new RegExp(pattern, flags);
      regexError.textContent = '';

      if (!flags.includes('g')) {
        const m = text.match(regex);
        if (m) {
          const idx = m.index || 0;
          const before = escapeHtml(text.slice(0, idx));
          const matched = escapeHtml(m[0]);
          const after = escapeHtml(text.slice(idx + m[0].length));
          highlightBox.innerHTML = before + '<mark>' + matched + '</mark>' + after;
          matchCount.textContent = '1 个匹配';
          showGroups([m]);
        } else {
          highlightBox.textContent = text;
          matchCount.textContent = '0 个匹配';
          groupsCard.style.display = 'none';
        }
        return;
      }

      const matches: RegExpMatchArray[] = [];
      let m: RegExpMatchArray | null;
      let safeCounter = 0;
      while ((m = regex.exec(text)) !== null && safeCounter < 5000) {
        matches.push(m);
        if (m[0].length === 0) regex.lastIndex++;
        safeCounter++;
      }

      if (matches.length === 0) {
        highlightBox.textContent = text;
        matchCount.textContent = '0 个匹配';
        groupsCard.style.display = 'none';
        return;
      }

      // Build highlighted text
      let result = '';
      let lastIdx = 0;
      for (const match of matches) {
        const start = match.index!;
        result += escapeHtml(text.slice(lastIdx, start));
        result += '<mark>' + escapeHtml(match[0]) + '</mark>';
        lastIdx = start + match[0].length;
      }
      result += escapeHtml(text.slice(lastIdx));
      highlightBox.innerHTML = result;
      matchCount.textContent = `${matches.length} 个匹配`;
      showGroups(matches);
    } catch (e) {
      regexError.textContent = (e as Error).message;
      highlightBox.textContent = text;
      matchCount.textContent = '0 个匹配';
      groupsCard.style.display = 'none';
    }
  }

  function showGroups(matches: RegExpMatchArray[]) {
    if (matches.length === 0 || (matches.length === 1 && matches[0].length <= 1)) {
      groupsCard.style.display = 'none';
      return;
    }
    groupsCard.style.display = 'block';
    const limit = Math.min(matches.length, 50);
    groupsList.innerHTML = matches.slice(0, limit).map((m, i) => {
      const groups = [m[0], ...m.slice(1)].map((g, gi) =>
        `<span class="group-idx">${gi === 0 ? 'Full' : `$${gi}`}</span><span class="group-val">${escapeHtml(g || '(undefined)')}</span>`
      ).join('');
      return `<div class="group-item"><span class="group-idx">#${i + 1}</span>${groups}</div>`;
    }).join('') + (matches.length > limit ? `<div class="group-item"><span class="group-idx">...${matches.length - limit} more</span></div>` : '');
  }

  patternInput.addEventListener('input', runMatch);
  flagsInput.addEventListener('input', runMatch);
  testText.addEventListener('input', runMatch);

  // Flag checkboxes
  document.querySelectorAll('.flag-btn input').forEach(el => {
    const cb = el as HTMLInputElement;
    cb.addEventListener('change', () => {
      let flags = '';
      document.querySelectorAll('.flag-btn input:checked').forEach(c => { flags += (c as HTMLInputElement).value; });
      flagsInput.value = flags;
      runMatch();
    });
  });

  // Common patterns
  document.querySelectorAll('.pattern-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      patternInput.value = (btn as HTMLElement).dataset.pattern || '';
      flagsInput.value = (btn as HTMLElement).dataset.flags || 'g';
      // Sync checkboxes
      document.querySelectorAll('.flag-btn input').forEach(el => {
        const cb = el as HTMLInputElement;
        cb.checked = flagsInput.value.includes(cb.value);
      });
      runMatch();
    });
  });

  document.getElementById('clear-btn')?.addEventListener('click', () => {
    testText.value = '';
    runMatch();
  });
</script>
