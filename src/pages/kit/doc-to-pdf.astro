---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '文档转PDF';
const toolDesc = '将文本/Markdown文档转换为PDF';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span>点击或拖拽上传文件</span>
          <span class="hint">支持 TXT, MD 文件</span>
          <input type="file" id="file-input" accept=".txt,.md">
        </div>

        <div id="file-info" class="file-info" style="display:none;">
          <div class="info-row">
            <span class="info-label">文件名</span>
            <span class="info-value" id="file-name"></span>
          </div>
        </div>

        <div class="settings" id="settings" style="display:none;">
          <div class="setting-group">
            <label class="setting-label">页面尺寸</label>
            <div class="format-options" id="page-size-options">
              <button class="format-btn active" data-size="a4">A4</button>
              <button class="format-btn" data-size="letter">Letter</button>
            </div>
          </div>
          <div class="setting-group">
            <label class="setting-label">页边距: <span id="margin-value">50</span>px</label>
            <input type="range" id="margin" min="20" max="100" value="50" style="width:100%;">
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="convert-btn">生成 PDF</button>
          </div>
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">生成中...</div>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">PDF 已生成</div>
          <div class="result-stats">
            <div class="stat">
              <span class="stat-label">页数</span>
              <span class="stat-value" id="page-count"></span>
            </div>
            <div class="stat">
              <span class="stat-label">文件大小</span>
              <span class="stat-value" id="pdf-size"></span>
            </div>
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="download-btn">下载 PDF</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-main { overflow: auto; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var uploadArea = document.getElementById('upload-area');
    var fileInput = document.getElementById('file-input');
    var fileInfo = document.getElementById('file-info');
    var settings = document.getElementById('settings');
    var progressArea = document.getElementById('progress-area');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var resultArea = document.getElementById('result-area');
    var pageSizeBtns = document.querySelectorAll('#page-size-options .format-btn');
    var marginSlider = document.getElementById('margin');
    var marginValue = document.getElementById('margin-value');
    var convertBtn = document.getElementById('convert-btn');
    var downloadBtn = document.getElementById('download-btn');
    var fileContent = '';
    var originalFileName = '';
    var pdfBlob = null;
    var pageSize = 'a4';

    uploadArea.addEventListener('click', function() { fileInput.click(); });
    uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); });
    uploadArea.addEventListener('drop', function(e) { e.preventDefault(); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files.length) handleFile(fileInput.files[0]); });
    marginSlider.addEventListener('input', function() { marginValue.textContent = marginSlider.value; });
    pageSizeBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        pageSizeBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        pageSize = btn.getAttribute('data-size');
      });
    });

    function handleFile(file) {
      var reader = new FileReader();
      reader.onload = function(e) {
        fileContent = e.target.result;
        originalFileName = file.name.replace(/\.[^.]+$/, '');
        document.getElementById('file-name').textContent = file.name;
        fileInfo.style.display = 'block';
        settings.style.display = 'flex';
        resultArea.style.display = 'none';
      };
      reader.readAsText(file);
    }

    convertBtn.addEventListener('click', function() {
      if (!fileContent) return;
      progressArea.style.display = 'block';
      progressFill.style.width = '20%';
      progressText.textContent = '生成 PDF...';
      setTimeout(function() {
        var dims = pageSize === 'a4' ? [595.28, 841.89] : [612, 792];
        var margin = parseInt(marginSlider.value) * 0.75;
        var textW = dims[0] - margin * 2;
        var textH = dims[1] - margin * 2;
        var fontSize = 11;
        var lineHeight = fontSize * 1.5;
        var linesPerPage = Math.floor(textH / lineHeight);
        var lines = [];
        var paragraphs = fileContent.split('\n');
        for (var p = 0; p < paragraphs.length; p++) {
          if (paragraphs[p].trim() === '') { lines.push(''); continue; }
          var words = paragraphs[p].split(' ');
          var line = '';
          for (var w = 0; w < words.length; w++) {
            var testLen = (line + words[w] + ' ').length * fontSize * 0.55;
            if (testLen > textW && line) { lines.push(line.trim()); line = words[w] + ' '; }
            else { line += words[w] + ' '; }
          }
          if (line.trim()) lines.push(line.trim());
        }
        var pages = [];
        for (var i = 0; i < lines.length; i += linesPerPage) {
          pages.push(lines.slice(i, i + linesPerPage));
        }
        if (pages.length === 0) pages.push(['']);
        pdfBlob = buildPDF(pages, dims, margin, fontSize, lineHeight);
        document.getElementById('page-count').textContent = pages.length;
        document.getElementById('pdf-size').textContent = (pdfBlob.size / 1024).toFixed(1) + ' KB';
        progressFill.style.width = '100%';
        progressText.textContent = '完成!';
        resultArea.style.display = 'block';
        setTimeout(function() { progressArea.style.display = 'none'; }, 800);
      }, 50);
    });

    function buildPDF(pages, dims, margin, fontSize, lineHeight) {
      var objects = [];
      var objId = 0;
      function addObj(c) { objId++; objects.push({ id: objId, content: c }); return objId; }
      addObj('<< /Type /Catalog /Pages 2 0 R >>');
      var kids = [];
      for (var p = 0; p < pages.length; p++) {
        var stream = 'BT /F1 ' + fontSize + ' Tf ' + margin.toFixed(1) + ' ' + (dims[1] - margin - fontSize).toFixed(1) + ' Td\n';
        for (var l = 0; l < pages[p].length; l++) {
          var line = pages[p][l].replace(/[()\\]/g, '\\$&');
          if (l > 0) stream += '0 -' + lineHeight.toFixed(1) + ' Td\n';
          stream += '(' + line + ') Tj\n';
        }
        stream += 'ET';
        var sb = new Uint8Array(stream.length);
        for (var i = 0; i < stream.length; i++) sb[i] = stream.charCodeAt(i);
        var cid = addObj(null);
        objects[cid - 1].content = '<< /Length ' + sb.length + ' >>';
        objects[cid - 1].stream = sb;
        var pid = addObj('<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ' + dims[0].toFixed(2) + ' ' + dims[1].toFixed(2) + '] /Contents ' + cid + ' 0 R /Resources << /Font << /F1 5 0 R >> >> >>');
        kids.push(pid + ' 0 R');
      }
      addObj('<< /Type /Pages /Kids [' + kids.join(' ') + '] /Count ' + pages.length + ' >>');
      addObj('<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>');
      var parts = ['%PDF-1.4\n'];
      var offsets = [];
      for (var i = 0; i < objects.length; i++) {
        offsets.push(parts.join('').length);
        parts.push(objects[i].id + ' 0 obj\n' + objects[i].content);
        if (objects[i].stream) { parts.push('\nstream\n'); for (var j = 0; j < objects[i].stream.length; j++) parts.push(String.fromCharCode(objects[i].stream[j])); parts.push('\nendstream\n'); }
        parts.push('\nendobj\n');
      }
      var xrefOffset = parts.join('').length;
      parts.push('xref\n0 ' + (objects.length + 1) + '\n0000000000 65535 f \n');
      for (var i = 0; i < offsets.length; i++) parts.push(('0000000000' + offsets[i]).slice(-10) + ' 00000 n \n');
      parts.push('trailer\n<< /Size ' + (objects.length + 1) + ' /Root 1 0 R >>\nstartxref\n' + xrefOffset + '\n%%EOF');
      var pdfStr = parts.join('');
      var pdfBytes = new Uint8Array(pdfStr.length);
      for (var i = 0; i < pdfStr.length; i++) pdfBytes[i] = pdfStr.charCodeAt(i) & 0xff;
      return new Blob([pdfBytes], { type: 'application/pdf' });
    }

    downloadBtn.addEventListener('click', function() {
      if (!pdfBlob) return;
      var url = URL.createObjectURL(pdfBlob);
      var a = document.createElement('a');
      a.href = url;
      a.download = originalFileName + '.pdf';
      a.click();
      URL.revokeObjectURL(url);
    });
  });
</script>
