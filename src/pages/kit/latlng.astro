---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '经纬度查询/转换';
const toolDesc = '地址转经纬度、DMS与十进制坐标互转';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div class="tab-buttons" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                  <button id="tab-geo" class="hao-press-btn hao-press-btn--primary" data-tab="geo">坐标查询</button>
                  <button id="tab-convert" class="hao-press-btn hao-press-btn--secondary" data-tab="convert">坐标转换</button>
                </div>

                <div id="panel-geo">
                  <div class="input-group" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                    <input id="address-input" type="text" class="hao-input" placeholder="输入地址，如 北京市天安门" style="flex:1;padding:0.3rem 0.4rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:15px;color:var(--color-text);font-size:0.28rem;outline:none;">
                    <button id="search-btn" class="hao-press-btn hao-press-btn--primary">查询</button>
                  </div>
                  <div id="geo-result" class="hao-result" style="display:none;">
                    <div class="result-header">查询结果</div>
                    <div class="file-info" id="geo-info"></div>
                  </div>
                </div>

                <div id="panel-convert" style="display:none;">
                  <div class="settings">
                    <div class="setting-group">
                      <span class="setting-label">十进制转DMS (度分秒)</span>
                      <div style="display:flex;gap:0.2rem;flex-wrap:wrap;margin-top:0.2rem;">
                        <input id="dec-lat" type="number" step="any" placeholder="纬度 (如 39.9042)" style="flex:1;padding:0.25rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:10px;color:var(--color-text);font-size:0.28rem;">
                        <input id="dec-lng" type="number" step="any" placeholder="经度 (如 116.4074)" style="flex:1;padding:0.25rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:10px;color:var(--color-text);font-size:0.28rem;">
                        <button id="dec-to-dms" class="hao-press-btn hao-press-btn--primary">转换</button>
                      </div>
                      <div id="dms-result" style="margin-top:0.2rem;padding:0.3rem;background:var(--color-background-one);border-radius:10px;color:var(--font-color-solid);font-size:0.28rem;display:none;"></div>
                    </div>
                    <div class="setting-group">
                      <span class="setting-label">DMS转十进制</span>
                      <div style="display:flex;gap:0.2rem;flex-wrap:wrap;margin-top:0.2rem;">
                        <input id="dms-lat" type="text" placeholder="纬度 度,分,秒 (如 39,54,15)" style="flex:1;padding:0.25rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:10px;color:var(--color-text);font-size:0.28rem;">
                        <input id="dms-lng" type="text" placeholder="经度 度,分,秒 (如 116,24,27)" style="flex:1;padding:0.25rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:10px;color:var(--color-text);font-size:0.28rem;">
                        <button id="dms-to-dec" class="hao-press-btn hao-press-btn--primary">转换</button>
                      </div>
                      <div id="dec-result" style="margin-top:0.2rem;padding:0.3rem;background:var(--color-background-one);border-radius:10px;color:var(--font-color-solid);font-size:0.28rem;display:none;"></div>
                    </div>
                  </div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
