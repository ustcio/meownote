---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '视频音量调节';
const toolDesc = '调整视频音频音量并导出';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传视频</span>
                <span class="hint">支持 MP4, WebM, OGG 格式</span>
                <input type="file" id="file-input" accept="video/*">
              </div>

              <div id="file-info" class="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">时长</span>
                  <span class="info-value" id="duration"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">音量: <span id="volume-value">1.0</span>x</label>
                  <input type="range" id="volume" min="0" max="300" value="100" style="width:100%;">
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="preview-btn">预览效果</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重置</button>
                </div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">预览</div>
                <video id="preview-video" controls style="width:100%;border-radius:10px;max-height:50vh;"></video>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">原始音量</span>
                    <span class="stat-value">1.0x</span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">调整后</span>
                    <span class="stat-value" id="new-volume"></span>
                  </div>
                </div>
                <div class="hao-btn-group" style="margin-top:0.3rem;">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载视频</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
