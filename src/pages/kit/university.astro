        </tr>`).join('')}</tbody></table>`;
    }

    function filter() {
      const keyword = searchInput.value.trim().toLowerCase();
      const type = filterType.value;
      const province = filterProvince.value;
      let filtered = universities.filter(u => {
        if (keyword && !u.name.toLowerCase().includes(keyword)) return false;
        if (type !== 'all' && u.type !== type) return false;
        if (province !== 'all' && u.province !== province) return false;
        return true;
      });
      renderTable(filtered);
    }

    searchInput.addEventListener('input', filter);
    filterType.addEventListener('change', filter);
    filterProvince.addEventListener('change', filter);
    renderTable(universities);
  });
</script>
