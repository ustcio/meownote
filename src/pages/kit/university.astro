---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '高校查询';
const toolDesc = '查询全国高校信息';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="tool-content" id="tool-content">
          <div style="display:flex;gap:0.2rem;margin-bottom:0.4rem;flex-wrap:wrap;">
            <input id="search-input" type="text" class="form-input" placeholder="搜索大学名称" style="flex:1;min-width:150px;padding:0.3rem 0.4rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:15px;color:var(--color-text);font-size:0.28rem;outline:none;">
            <select id="filter-type" class="setting-select" style="padding:0.3rem;">
              <option value="all">全部类型</option>
              <option value="985">985工程</option>
              <option value="211">211工程</option>
              <option value="双一流">双一流</option>
            </select>
            <select id="filter-province" class="setting-select" style="padding:0.3rem;">
              <option value="all">全部省份</option>
            </select>
          </div>
          <div id="count-info" style="font-size:0.22rem;color:var(--color-tm-text);margin-bottom:0.3rem;"></div>
          <div id="table-container" style="overflow-x:auto;"></div>
        </div>
      </main>
    </div>
  </section>
</Layout>

