---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'AI智能抠图';
const toolDesc = '智能选择背景颜色并去除';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传图片</span>
                <span class="hint">支持 PNG, JPG, WebP 格式</span>
                <input type="file" id="file-input" accept="image/*">
              </div>

              <div id="file-info" class="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">尺寸</span>
                  <span class="info-value" id="file-size"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">要去除的背景颜色</label>
                  <div class="format-options" id="preset-colors">
                    <button class="format-btn active" data-color="#00ff00" style="background:#00ff00;color:#000;">绿色</button>
                    <button class="format-btn" data-color="#0000ff" style="background:#0000ff;color:#fff;">蓝色</button>
                    <button class="format-btn" data-color="#ffffff" style="background:#ffffff;color:#000;">白色</button>
                    <button class="format-btn" data-color="#000000" style="background:#000000;color:#fff;">黑色</button>
                    <button class="format-btn" data-color="#ff0000" style="background:#ff0000;color:#fff;">红色</button>
                    <button class="format-btn" data-color="custom">自定义</button>
                  </div>
                </div>
                <div class="setting-group" id="custom-color-group" style="display:none;">
                  <label class="setting-label">自定义颜色</label>
                  <input type="color" id="custom-color" value="#00ff00" style="width:3rem;height:2rem;border:none;cursor:pointer;">
                </div>
                <div class="setting-group">
                  <label class="setting-label">容差: <span id="tolerance-value">40</span></label>
                  <input type="range" id="tolerance" min="1" max="100" value="40" style="width:100%;">
                </div>
                <div class="setting-group">
                  <label class="setting-label">边缘柔化: <span id="feather-value">2</span>px</label>
                  <input type="range" id="feather" min="0" max="10" value="2" style="width:100%;">
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="process-btn">智能抠图</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重置</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">处理中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">抠图结果</div>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">原始尺寸</span>
                    <span class="stat-value" id="orig-size"></span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">透明区域</span>
                    <span class="stat-value" id="transparent-pct"></span>
                  </div>
                </div>
                <canvas id="result-canvas" style="width:100%;border-radius:10px;background-image:linear-gradient(45deg,#ccc 25%,transparent 25%),linear-gradient(-45deg,#ccc 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#ccc 75%),linear-gradient(-45deg,transparent 75%,#ccc 75%);background-size:16px 16px;background-position:0 0,0 8px,8px -8px,-8px 0;"></canvas>
                <div class="hao-btn-group" style="margin-top:0.3rem;">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载 PNG</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
