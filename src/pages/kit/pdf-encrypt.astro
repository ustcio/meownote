---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'PDF加密';
const toolDesc = '为PDF添加密码保护';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传PDF</span>
                <span class="hint">支持 PDF 文件</span>
                <input type="file" id="file-input" accept=".pdf">
              </div>

              <div id="file-info" class="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">文件大小</span>
                  <span class="info-value" id="file-size"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">用户密码</label>
                  <input type="password" id="user-password" placeholder="输入打开密码" class="setting-select" style="width:100%;padding:0.2rem;">
                </div>
                <div class="setting-group">
                  <label class="setting-label">所有者密码</label>
                  <input type="password" id="owner-password" placeholder="输入权限密码（可选）" class="setting-select" style="width:100%;padding:0.2rem;">
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="encrypt-btn">加密PDF</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">加密中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">加密完成</div>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">原始大小</span>
                    <span class="stat-value" id="before-size"></span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">加密后</span>
                    <span class="stat-value" id="after-size"></span>
                  </div>
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载加密PDF</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
