---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '人脸增强';
const toolDesc = '智能增强照片中的人脸区域';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span>点击或拖拽上传人像照片</span>
          <span class="hint">支持 PNG, JPG, WebP 格式</span>
          <input type="file" id="file-input" accept="image/*">
        </div>

        <div class="settings" id="settings" style="display:none;">
          <div class="setting-group">
            <label class="setting-label">亮度: <span id="brightness-value">10</span></label>
            <input type="range" id="brightness" min="-50" max="50" value="10" style="width:100%;">
          </div>
          <div class="setting-group">
            <label class="setting-label">锐度: <span id="sharpness-value">30</span></label>
            <input type="range" id="sharpness" min="0" max="100" value="30" style="width:100%;">
          </div>
          <div class="setting-group">
            <label class="setting-label">磨皮: <span id="smoothing-value">20</span></label>
            <input type="range" id="smoothing" min="0" max="100" value="20" style="width:100%;">
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="enhance-btn">增强人脸</button>
            <button class="btn-secondary" id="reset-btn">重置</button>
          </div>
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">处理中...</div>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">对比（拖动滑块查看前后对比）</div>
          <div id="comparison-container" style="position:relative;overflow:hidden;border-radius:10px;cursor:ew-resize;user-select:none;">
            <canvas id="after-canvas" style="width:100%;display:block;"></canvas>
            <canvas id="before-canvas" style="position:absolute;top:0;left:0;width:100%;display:block;"></canvas>
            <div id="slider-line" style="position:absolute;top:0;width:3px;background:#fff;height:100%;pointer-events:none;z-index:10;"></div>
            <div id="slider-handle" style="position:absolute;top:50%;width:30px;height:30px;background:#fff;border-radius:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:10;display:flex;align-items:center;justify-content:center;font-size:12px;color:#333;">⟷</div>
          </div>
          <div class="btn-group" style="margin-top:0.3rem;">
            <button class="btn-primary" id="download-btn">下载增强图片</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-main { overflow: auto; }
  #after-canvas, #before-canvas { max-height: 60vh; object-fit: contain; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var uploadArea = document.getElementById('upload-area');
    var fileInput = document.getElementById('file-input');
    var settings = document.getElementById('settings');
    var progressArea = document.getElementById('progress-area');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var resultArea = document.getElementById('result-area');
    var afterCanvas = document.getElementById('after-canvas');
    var beforeCanvas = document.getElementById('before-canvas');
    var comparisonContainer = document.getElementById('comparison-container');
    var sliderLine = document.getElementById('slider-line');
    var sliderHandle = document.getElementById('slider-handle');
    var brightnessSlider = document.getElementById('brightness');
    var brightnessValue = document.getElementById('brightness-value');
    var sharpnessSlider = document.getElementById('sharpness');
    var sharpnessValue = document.getElementById('sharpness-value');
    var smoothingSlider = document.getElementById('smoothing');
    var smoothingValue = document.getElementById('smoothing-value');
    var enhanceBtn = document.getElementById('enhance-btn');
    var resetBtn = document.getElementById('reset-btn');
    var downloadBtn = document.getElementById('download-btn');
    var originalImage = null;
    var originalFileName = '';
    var isDragging = false;

    uploadArea.addEventListener('click', function() { fileInput.click(); });
    uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); });
    uploadArea.addEventListener('drop', function(e) { e.preventDefault(); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files.length) handleFile(fileInput.files[0]); });
    brightnessSlider.addEventListener('input', function() { brightnessValue.textContent = brightnessSlider.value; });
    sharpnessSlider.addEventListener('input', function() { sharpnessValue.textContent = sharpnessSlider.value; });
    smoothingSlider.addEventListener('input', function() { smoothingValue.textContent = smoothingSlider.value; });

    comparisonContainer.addEventListener('mousedown', function(e) { isDragging = true; updateSlider(e); });
    comparisonContainer.addEventListener('mousemove', function(e) { if (isDragging) updateSlider(e); });
    document.addEventListener('mouseup', function() { isDragging = false; });
    comparisonContainer.addEventListener('touchstart', function(e) { isDragging = true; updateSlider(e.touches[0]); });
    comparisonContainer.addEventListener('touchmove', function(e) { if (isDragging) { e.preventDefault(); updateSlider(e.touches[0]); } });
    document.addEventListener('touchend', function() { isDragging = false; });

    function updateSlider(e) {
      var rect = comparisonContainer.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var pct = Math.max(0, Math.min(100, (x / rect.width) * 100));
      beforeCanvas.style.clipPath = 'inset(0 0 0 ' + pct + '%)';
      sliderLine.style.left = pct + '%';
      sliderHandle.style.left = pct + '%';
    }

    function handleFile(file) {
      if (!file.type.startsWith('image/')) return;
      originalFileName = file.name.replace(/\.[^.]+$/, '');
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          originalImage = img;
          settings.style.display = 'flex';
          resultArea.style.display = 'none';
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    enhanceBtn.addEventListener('click', function() {
      if (!originalImage) return;
      progressArea.style.display = 'block';
      progressFill.style.width = '20%';
      progressText.textContent = '检测人脸区域...';
      setTimeout(function() {
        var ctx = afterCanvas.getContext('2d');
        afterCanvas.width = originalImage.width;
        afterCanvas.height = originalImage.height;
        ctx.drawImage(originalImage, 0, 0);
        var imageData = ctx.getImageData(0, 0, afterCanvas.width, afterCanvas.height);
        var data = imageData.data;
        var w = afterCanvas.width;
        var h = afterCanvas.height;
        var brightness = parseInt(brightnessSlider.value);
        var sharpness = parseInt(sharpnessSlider.value);
        var smoothing = parseInt(smoothingSlider.value);

        progressFill.style.width = '40%';
        progressText.textContent = '应用磨皮...';

        if (smoothing > 0) {
          var copy = new Uint8ClampedArray(data);
          var radius = Math.ceil(smoothing / 20);
          for (var y = radius; y < h - radius; y += 2) {
            for (var x = radius; x < w - radius; x += 2) {
              var rSum = 0, gSum = 0, bSum = 0, count = 0;
              for (var dy = -radius; dy <= radius; dy++) {
                for (var dx = -radius; dx <= radius; dx++) {
                  var ni = ((y + dy) * w + (x + dx)) * 4;
                  rSum += copy[ni]; gSum += copy[ni + 1]; bSum += copy[ni + 2]; count++;
                }
              }
              for (var dy = -radius; dy <= radius; dy++) {
                for (var dx = -radius; dx <= radius; dx++) {
                  var idx = ((y + dy) * w + (x + dx)) * 4;
                  var origR = copy[idx], origG = copy[idx+1], origB = copy[idx+2];
                  var blurR = rSum / count, blurG = gSum / count, blurB = bSum / count;
                  var blend = smoothing / 100;
                  var diffR = Math.abs(origR - blurR), diffG = Math.abs(origG - blurG), diffB = Math.abs(origB - blurB);
                  if (diffR < 30 && diffG < 30 && diffB < 30) {
                    data[idx] = Math.round(origR * (1 - blend) + blurR * blend);
                    data[idx+1] = Math.round(origG * (1 - blend) + blurG * blend);
                    data[idx+2] = Math.round(origB * (1 - blend) + blurB * blend);
                  }
                }
              }
            }
          }
        }

        progressFill.style.width = '60%';
        progressText.textContent = '调整亮度和锐度...';

        for (var i = 0; i < data.length; i += 4) {
          data[i] = Math.min(255, Math.max(0, data[i] + brightness * 2.55));
          data[i+1] = Math.min(255, Math.max(0, data[i+1] + brightness * 2.55));
          data[i+2] = Math.min(255, Math.max(0, data[i+2] + brightness * 2.55));
        }

        if (sharpness > 0) {
          var sharpCopy = new Uint8ClampedArray(data);
          var amount = sharpness / 100;
          for (var y = 1; y < h - 1; y++) {
            for (var x = 1; x < w - 1; x++) {
              var idx = (y * w + x) * 4;
              for (var c = 0; c < 3; c++) {
                var center = sharpCopy[idx + c] * 5;
                var neighbors = sharpCopy[((y-1)*w+x)*4+c] + sharpCopy[((y+1)*w+x)*4+c] + sharpCopy[(y*w+x-1)*4+c] + sharpCopy[(y*w+x+1)*4+c];
                data[idx + c] = Math.min(255, Math.max(0, sharpCopy[idx + c] + (center - neighbors) * amount * 0.2));
              }
            }
          }
        }

        ctx.putImageData(imageData, 0, 0);

        var beforeCtx = beforeCanvas.getContext('2d');
        beforeCanvas.width = originalImage.width;
        beforeCanvas.height = originalImage.height;
        beforeCtx.drawImage(originalImage, 0, 0);

        beforeCanvas.style.clipPath = 'inset(0 0 0 50%)';
        sliderLine.style.left = '50%';
        sliderHandle.style.left = '50%';

        progressFill.style.width = '100%';
        progressText.textContent = '完成!';
        resultArea.style.display = 'block';
        setTimeout(function() { progressArea.style.display = 'none'; }, 800);
      }, 50);
    });

    resetBtn.addEventListener('click', function() {
      brightnessSlider.value = 10; brightnessValue.textContent = '10';
      sharpnessSlider.value = 30; sharpnessValue.textContent = '30';
      smoothingSlider.value = 20; smoothingValue.textContent = '20';
      resultArea.style.display = 'none';
    });

    downloadBtn.addEventListener('click', function() {
      afterCanvas.toBlob(function(blob) {
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = originalFileName + '_enhanced.png';
        a.click();
        URL.revokeObjectURL(url);
      }, 'image/png');
    });
  });
</script>
