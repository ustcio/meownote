---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Base64 编解码 - Maxwell.Science"
  description="文本和图片的 Base64 编码与解码工具"
>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          <span>工具箱</span>
        </a>
        <h1>Base64 编解码</h1>
        <p class="tool-desc">文本和图片的 Base64 编码与解码，支持双向转换</p>
      </header>

      <div class="tool-main">
        <div class="tabs">
          <button class="tab active" data-tab="text">文本编解码</button>
          <button class="tab" data-tab="image">图片转Base64</button>
        </div>

        <!-- Text Tab -->
        <div class="tab-content active" id="text-tab">
          <div class="converter">
            <div class="converter-section">
              <div class="section-header">
                <span>原文</span>
                <button class="btn-sm" id="text-clear">清空</button>
              </div>
              <textarea id="text-input" placeholder="输入要编码的文本..."></textarea>
            </div>

            <div class="converter-actions">
              <button class="btn-icon" id="encode-btn" title="编码 →">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
              <button class="btn-icon" id="decode-btn" title="← 解码">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
            </div>

            <div class="converter-section">
              <div class="section-header">
                <span>Base64</span>
                <button class="btn-sm" id="base64-copy">复制</button>
              </div>
              <textarea id="base64-output" placeholder="Base64 编码结果..."></textarea>
            </div>
          </div>
        </div>

        <!-- Image Tab -->
        <div class="tab-content" id="image-tab">
          <div class="image-converter">
            <div class="upload-area" id="upload-area">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              <span>点击或拖拽上传图片</span>
              <span class="hint">支持 PNG, JPG, GIF, WebP</span>
              <input type="file" id="image-input" accept="image/*" hidden />
            </div>

            <div class="image-preview" id="image-preview" style="display: none;">
              <img id="preview-img" alt="预览" />
              <div class="image-info" id="image-info"></div>
            </div>

            <div class="base64-output-section">
              <div class="section-header">
                <span>Base64 Data URI</span>
                <button class="btn-sm" id="img-base64-copy">复制</button>
              </div>
              <textarea id="img-base64-output" placeholder="图片的 Base64 编码将显示在这里..." readonly></textarea>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .tool-page {
    min-height: 100vh;
    padding: calc(var(--header-height) + 2rem) 0 4rem;
  }

  .tool-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .tool-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-tertiary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .tool-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .tool-desc {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tab {
    padding: 0.6rem 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .tab:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .tab.active {
    background: #171412;
    color: white;
    border-color: #171412;
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  .converter {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .converter {
      grid-template-columns: 1fr auto 1fr;
      align-items: stretch;
    }
  }

  .converter-section {
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.06);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--bg-secondary);
    border-bottom: 1px solid rgba(71, 57, 44, 0.08);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .btn-sm {
    padding: 0.3rem 0.6rem;
    background: transparent;
    border: 1px solid rgba(71, 57, 44, 0.15);
    border-radius: 0.35rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-sm:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .converter-section textarea {
    width: 100%;
    min-height: 180px;
    padding: 1rem;
    border: none;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text-primary);
    background: transparent;
    resize: vertical;
  }

  .converter-section textarea:focus {
    outline: none;
  }

  .converter-actions {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 768px) {
    .converter-actions {
      flex-direction: column;
    }
  }

  .btn-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-secondary);
    border: 1px solid rgba(71, 57, 44, 0.15);
    border-radius: 50%;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-icon:hover {
    background: #d97757;
    color: white;
    border-color: #d97757;
  }

  /* Image Tab */
  .upload-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 2rem;
    background: #fff;
    border: 2px dashed rgba(71, 57, 44, 0.2);
    border-radius: 1rem;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .upload-area:hover {
    border-color: #d97757;
    color: #d97757;
  }

  .upload-area .hint {
    font-size: 0.8rem;
    color: var(--text-quaternary);
  }

  .image-preview {
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .image-preview img {
    max-width: 100%;
    max-height: 300px;
    display: block;
    margin: 0 auto;
  }

  .image-info {
    padding: 0.75rem 1rem;
    background: var(--bg-secondary);
    font-size: 0.8rem;
    color: var(--text-secondary);
    border-top: 1px solid rgba(71, 57, 44, 0.08);
  }

  .base64-output-section {
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1rem;
    overflow: hidden;
  }

  .base64-output-section textarea {
    width: 100%;
    min-height: 120px;
    padding: 1rem;
    border: none;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--text-primary);
    background: transparent;
    resize: vertical;
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll('.tab');
  const tabContents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.getAttribute('data-tab') + '-tab';
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      tabContents.forEach(c => c.classList.remove('active'));
      document.getElementById(targetId)?.classList.add('active');
    });
  });

  // Text encoding/decoding
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const base64Output = document.getElementById('base64-output') as HTMLTextAreaElement;
  const encodeBtn = document.getElementById('encode-btn');
  const decodeBtn = document.getElementById('decode-btn');
  const textClearBtn = document.getElementById('text-clear');
  const base64CopyBtn = document.getElementById('base64-copy');

  function encodeBase64(text: string): string {
    try {
      return btoa(unescape(encodeURIComponent(text)));
    } catch {
      return btoa(text);
    }
  }

  function decodeBase64(base64: string): string {
    try {
      return decodeURIComponent(escape(atob(base64)));
    } catch {
      try {
        return atob(base64);
      } catch {
        return '解码失败：无效的 Base64 字符串';
      }
    }
  }

  encodeBtn?.addEventListener('click', () => {
    const text = textInput?.value;
    if (text && base64Output) {
      base64Output.value = encodeBase64(text);
    }
  });

  decodeBtn?.addEventListener('click', () => {
    const base64 = base64Output?.value.trim();
    if (base64 && textInput) {
      textInput.value = decodeBase64(base64);
    }
  });

  textClearBtn?.addEventListener('click', () => {
    if (textInput) textInput.value = '';
    if (base64Output) base64Output.value = '';
  });

  base64CopyBtn?.addEventListener('click', async () => {
    const text = base64Output?.value;
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      base64CopyBtn.textContent = '已复制';
      setTimeout(() => base64CopyBtn.textContent = '复制', 1500);
    } catch {}
  });

  // Real-time encoding
  textInput?.addEventListener('input', () => {
    if (textInput.value && base64Output) {
      base64Output.value = encodeBase64(textInput.value);
    }
  });

  // Image to Base64
  const uploadArea = document.getElementById('upload-area');
  const imageInput = document.getElementById('image-input') as HTMLInputElement;
  const imagePreview = document.getElementById('image-preview');
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const imageInfo = document.getElementById('image-info');
  const imgBase64Output = document.getElementById('img-base64-output') as HTMLTextAreaElement;
  const imgBase64CopyBtn = document.getElementById('img-base64-copy');

  uploadArea?.addEventListener('click', () => imageInput?.click());

  uploadArea?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('dragover');
  });

  uploadArea?.addEventListener('dragleave', () => {
    uploadArea.classList.remove('dragover');
  });

  uploadArea?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) {
      processImage(file);
    }
  });

  imageInput?.addEventListener('change', () => {
    const file = imageInput.files?.[0];
    if (file) processImage(file);
  });

  function processImage(file: File): void {
    const reader = new FileReader();
    reader.onload = (e) => {
      const base64 = e.target?.result as string;

      if (previewImg) previewImg.src = base64;
      if (imagePreview) imagePreview.style.display = 'block';
      if (imgBase64Output) imgBase64Output.value = base64;

      const sizeKB = (file.size / 1024).toFixed(1);
      const base64Length = (base64.length / 1024).toFixed(1);
      if (imageInfo) {
        imageInfo.innerHTML = `<strong>${file.name}</strong> · ${sizeKB} KB · Base64: ${base64Length} KB`;
      }
    };
    reader.readAsDataURL(file);
  }

  imgBase64CopyBtn?.addEventListener('click', async () => {
    const text = imgBase64Output?.value;
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      imgBase64CopyBtn.textContent = '已复制';
      setTimeout(() => imgBase64CopyBtn.textContent = '复制', 1500);
    } catch {}
  });
</script>
