---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '彩票开奖查询';
const toolDesc = '查询彩票开奖结果';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-tool-content" id="tool-content">
                <div class="hao-tab-buttons" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                  <button id="tab-ssq" class="hao-press-btn hao-press-btn--primary" data-tab="ssq">双色球</button>
                  <button id="tab-dlt" class="hao-press-btn hao-press-btn--secondary" data-tab="dlt">大乐透</button>
                </div>
                <div id="lottery-result"></div>
                <div style="margin-top:0.4rem;padding:0.3rem;background:var(--color-background-one);border-radius:15px;font-size:0.22rem;color:var(--color-tm-text);text-align:center;">
                  * 数据为模拟演示，实时开奖信息请访问 <a href="https://www.cwl.gov.cn/" target="_blank" style="color:var(--top-color);">中国福利彩票</a>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
