---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '去除摩尔纹';
const toolDesc = '通过高斯模糊和锐化减少图片摩尔纹';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传图片</span>
                <span class="hint">支持 PNG, JPG, WebP 格式</span>
                <input type="file" id="file-input" accept="image/*">
              </div>

              <div id="file-info" class="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">尺寸</span>
                  <span class="info-value" id="file-dimensions"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">模糊强度: <span id="blur-value">2</span></label>
                  <input type="range" id="blur" min="1" max="10" value="2" step="0.5" style="width:100%;">
                </div>
                <div class="setting-group">
                  <label class="setting-label">锐化强度: <span id="sharpen-value">1</span></label>
                  <input type="range" id="sharpen" min="0" max="5" value="1" step="0.5" style="width:100%;">
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="process-btn">去除摩尔纹</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重置</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">处理中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">处理结果</div>
                <canvas id="result-canvas" style="width:100%;border-radius:10px;"></canvas>
                <div class="hao-btn-group" style="margin-top:0.3rem;">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载图片</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
