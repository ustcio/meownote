---
import Layout from '@layouts/Layout.astro';

const toolName = '视频提取音频';
const toolDesc = '从视频中提取音频轨道，支持WAV和WebM/Opus格式';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polygon points="23 7 16 12 23 17 23 7"></polygon>
            <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
          </svg>
          <span>点击或拖拽上传视频文件</span>
          <span class="hint">支持 MP4, WebM, MOV, AVI, MKV</span>
          <input type="file" id="video-input" accept="video/*" hidden>
        </div>

        <div class="file-info" id="file-info" style="display:none;">
          <div class="info-row">
            <span class="info-label">文件名</span>
            <span class="info-value" id="file-name"></span>
          </div>
          <div class="info-row">
            <span class="info-label">原始大小</span>
            <span class="info-value" id="file-size"></span>
          </div>
          <div class="info-row">
            <span class="info-label">时长</span>
            <span class="info-value" id="file-duration"></span>
          </div>
          <div class="info-row">
            <span class="info-label">分辨率</span>
            <span class="info-value" id="file-resolution"></span>
          </div>
        </div>

        <div class="settings" id="settings" style="display:none;">
          <div class="setting-group">
            <label class="setting-label">音频格式</label>
            <div class="format-options">
              <button class="format-btn active" data-format="wav">WAV</button>
              <button class="format-btn" data-format="webm">WebM/Opus</button>
            </div>
          </div>
          <button class="btn-primary" id="extract-btn">开始提取</button>
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
          <span class="progress-text" id="progress-text">处理中...</span>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">
            <span>提取结果</span>
          </div>
          <div class="result-stats">
            <div class="stat">
              <span class="stat-label">音频大小</span>
              <span class="stat-value" id="result-size"></span>
            </div>
            <div class="stat">
              <span class="stat-label">音频格式</span>
              <span class="stat-value" id="result-format"></span>
            </div>
          </div>
          <audio id="result-audio" controls class="result-audio"></audio>
          <div class="btn-group">
            <button class="btn-primary" id="download-btn">下载音频</button>
            <button class="btn-secondary" id="reset-btn">重新上传</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-page {
    min-height: 100vh;
    padding: calc(var(--header-total-height) + var(--space-6)) var(--space-4) var(--space-16);
    background: var(--bg-primary);
  }

  .tool-container {
    max-width: 700px;
    margin: 0 auto;
  }

  .tool-header {
    margin-bottom: var(--space-6);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
    transition: color var(--duration-fast) var(--ease-default);
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .tool-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .tool-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .tool-main {
    background: var(--bg-secondary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    min-height: 400px;
  }

  .upload-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-8);
    border: 2px dashed var(--border-primary);
    border-radius: var(--radius-xl);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    color: var(--text-tertiary);
  }

  .upload-area:hover {
    border-color: var(--color-accent-blue);
    color: var(--color-accent-blue);
    background: var(--bg-tertiary);
  }

  .upload-area svg {
    margin-bottom: var(--space-3);
  }

  .upload-area .hint {
    font-size: var(--text-xs);
    color: var(--text-quaternary);
    margin-top: var(--space-1);
  }

  .upload-area input[type="file"] {
    display: none;
  }

  .file-info {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-primary);
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--border-primary);
  }

  .info-row:last-child {
    border-bottom: none;
  }

  .info-label {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .info-value {
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
  }

  .settings {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .setting-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .setting-label {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }

  .format-options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .format-btn {
    padding: var(--space-2) var(--space-3);
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .format-btn:hover {
    border-color: var(--color-accent-blue);
    color: var(--text-primary);
  }

  .format-btn.active {
    background: var(--color-accent-blue);
    border-color: var(--color-accent-blue);
    color: white;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border: none;
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
    background: var(--color-accent-blue);
    color: white;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .btn-secondary:hover {
    background: var(--bg-hover);
  }

  .btn-group {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .progress-area {
    margin-top: var(--space-4);
    text-align: center;
  }

  .progress-bar {
    height: 8px;
    background: var(--bg-primary);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: var(--space-2);
  }

  .progress-fill {
    height: 100%;
    background: var(--color-accent-blue);
    border-radius: var(--radius-full);
    transition: width 0.3s ease;
    width: 0%;
  }

  .progress-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .result-area {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-primary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-primary);
  }

  .result-header {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .result-stats {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .stat {
    flex: 1;
    text-align: center;
    padding: var(--space-3);
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
  }

  .stat-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin-bottom: var(--space-1);
  }

  .stat-value {
    display: block;
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--text-primary);
  }

  .result-audio {
    width: 100%;
    margin-bottom: var(--space-4);
    border-radius: var(--radius-md);
  }

  @media (max-width: 768px) {
    .tool-main {
      padding: var(--space-4);
    }

    .btn-group {
      flex-direction: column;
    }

    .btn-group .btn-primary,
    .btn-group .btn-secondary {
      width: 100%;
    }

    .result-stats {
      flex-direction: column;
    }
  }
</style>

<script is:inline>
  (function() {
    var uploadArea = document.getElementById('upload-area');
    var videoInput = document.getElementById('video-input');
    var fileInfo = document.getElementById('file-info');
    var settings = document.getElementById('settings');
    var progressArea = document.getElementById('progress-area');
    var resultArea = document.getElementById('result-area');
    var extractBtn = document.getElementById('extract-btn');
    var downloadBtn = document.getElementById('download-btn');
    var resetBtn = document.getElementById('reset-btn');
    var resultAudio = document.getElementById('result-audio');

    var originalFile = null;
    var videoDuration = 0;
    var videoWidth = 0;
    var videoHeight = 0;
    var selectedFormat = 'wav';
    var audioBlob = null;

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    function formatDuration(seconds) {
      var mins = Math.floor(seconds / 60);
      var secs = Math.floor(seconds % 60);
      return mins + ':' + secs.toString().padStart(2, '0');
    }

    uploadArea?.addEventListener('click', function() { videoInput?.click(); });

    uploadArea?.addEventListener('dragover', function(e) {
      e.preventDefault();
      uploadArea.style.borderColor = 'var(--color-accent-blue)';
      uploadArea.style.background = 'var(--bg-tertiary)';
    });

    uploadArea?.addEventListener('dragleave', function() {
      uploadArea.style.borderColor = '';
      uploadArea.style.background = '';
    });

    uploadArea?.addEventListener('drop', function(e) {
      e.preventDefault();
      uploadArea.style.borderColor = '';
      uploadArea.style.background = '';
      var file = e.dataTransfer?.files[0];
      if (file && file.type.startsWith('video/')) {
        loadFile(file);
      }
    });

    videoInput?.addEventListener('change', function() {
      var file = videoInput.files?.[0];
      if (file) loadFile(file);
    });

    document.querySelectorAll('.format-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.format-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        selectedFormat = btn.dataset.format;
      });
    });

    function loadFile(file) {
      originalFile = file;
      var video = document.createElement('video');
      video.preload = 'metadata';
      video.muted = true;
      video.onloadedmetadata = function() {
        videoDuration = video.duration;
        videoWidth = video.videoWidth;
        videoHeight = video.videoHeight;
        document.getElementById('file-name').textContent = file.name;
        document.getElementById('file-size').textContent = formatSize(file.size);
        document.getElementById('file-duration').textContent = formatDuration(videoDuration);
        document.getElementById('file-resolution').textContent = videoWidth + 'x' + videoHeight;
        uploadArea.style.display = 'none';
        fileInfo.style.display = 'block';
        settings.style.display = 'flex';
        URL.revokeObjectURL(video.src);
      };
      video.onerror = function() {
        alert('无法加载视频文件，请尝试其他格式');
      };
      video.src = URL.createObjectURL(file);
    }

    extractBtn?.addEventListener('click', async function() {
      if (!originalFile) return;

      extractBtn.disabled = true;
      extractBtn.textContent = '提取中...';
      progressArea.style.display = 'block';
      resultArea.style.display = 'none';

      try {
        var audioContext = new (window.AudioContext || window.webkitAudioContext)();
        var arrayBuffer = await originalFile.arrayBuffer();
        var audioBuffer = await audioContext.decodeAudioData(arrayBuffer);

        if (selectedFormat === 'wav') {
          audioBlob = bufferToWav(audioBuffer);
        } else {
          var dest = audioContext.createMediaStreamDestination();
          var source = audioContext.createBufferSource();
          source.buffer = audioBuffer;
          source.connect(dest);

          var mimeType = 'audio/webm;codecs=opus';
          if (!MediaRecorder.isTypeSupported(mimeType)) {
            mimeType = 'audio/webm';
          }

          var recorder = new MediaRecorder(dest.stream, { mimeType: mimeType });
          var chunks = [];
          recorder.ondataavailable = function(e) {
            if (e.data.size > 0) chunks.push(e.data);
          };

          var done = new Promise(function(resolve) {
            recorder.onstop = resolve;
          });

          recorder.start(100);
          source.start();

          var progressInterval = setInterval(function() {
            var progress = Math.min((audioContext.currentTime / audioBuffer.duration) * 100, 95);
            document.getElementById('progress-fill').style.width = progress + '%';
            document.getElementById('progress-text').textContent = '处理中 ' + Math.round(progress) + '%...';
          }, 100);

          source.onended = function() {
            clearInterval(progressInterval);
            setTimeout(function() {
              recorder.stop();
            }, 200);
          };

          await done;
          audioBlob = new Blob(chunks, { type: mimeType.split(';')[0] });
        }

        document.getElementById('progress-fill').style.width = '100%';
        document.getElementById('progress-text').textContent = '完成!';

        document.getElementById('result-size').textContent = formatSize(audioBlob.size);
        document.getElementById('result-format').textContent = selectedFormat.toUpperCase();

        var url = URL.createObjectURL(audioBlob);
        resultAudio.src = url;

        settings.style.display = 'none';
        progressArea.style.display = 'none';
        resultArea.style.display = 'block';

        audioContext.close();
      } catch (err) {
        alert('提取失败: ' + err.message);
        progressArea.style.display = 'none';
      }

      extractBtn.disabled = false;
      extractBtn.textContent = '开始提取';
    });

    downloadBtn?.addEventListener('click', function() {
      if (!audioBlob) return;
      var url = URL.createObjectURL(audioBlob);
      var ext = selectedFormat === 'wav' ? 'wav' : 'webm';
      var a = document.createElement('a');
      a.href = url;
      a.download = originalFile.name.replace(/\.[^.]+$/, '') + '_audio.' + ext;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    resetBtn?.addEventListener('click', function() {
      originalFile = null;
      audioBlob = null;
      uploadArea.style.display = 'flex';
      fileInfo.style.display = 'none';
      settings.style.display = 'none';
      progressArea.style.display = 'none';
      resultArea.style.display = 'none';
      videoInput.value = '';
    });

    function bufferToWav(buffer) {
      var numChannels = buffer.numberOfChannels;
      var sampleRate = buffer.sampleRate;
      var bitDepth = 16;

      var result;
      if (numChannels === 2) {
        result = interleave(buffer.getChannelData(0), buffer.getChannelData(1));
      } else {
        result = buffer.getChannelData(0);
      }

      var dataLength = result.length * (bitDepth / 8);
      var headerLength = 44;
      var totalLength = headerLength + dataLength;

      var arrayBuffer = new ArrayBuffer(totalLength);
      var view = new DataView(arrayBuffer);

      writeString(view, 0, 'RIFF');
      view.setUint32(4, totalLength - 8, true);
      writeString(view, 8, 'WAVE');
      writeString(view, 12, 'fmt ');
      view.setUint32(16, 16, true);
      view.setUint16(20, 1, true);
      view.setUint16(22, numChannels, true);
      view.setUint32(24, sampleRate, true);
      view.setUint32(28, sampleRate * numChannels * (bitDepth / 8), true);
      view.setUint16(32, numChannels * (bitDepth / 8), true);
      view.setUint16(34, bitDepth, true);
      writeString(view, 36, 'data');
      view.setUint32(40, dataLength, true);

      var offset = 44;
      for (var i = 0; i < result.length; i++) {
        var sample = Math.max(-1, Math.min(1, result[i]));
        view.setInt16(offset, sample < 0 ? sample * 0x8000 : sample * 0x7FFF, true);
        offset += 2;
      }

      return new Blob([arrayBuffer], { type: 'audio/wav' });
    }

    function interleave(left, right) {
      var length = left.length + right.length;
      var result = new Float32Array(length);
      var inputIndex = 0;
      for (var i = 0; i < length;) {
        result[i++] = left[inputIndex];
        result[i++] = right[inputIndex];
        inputIndex++;
      }
      return result;
    }

    function writeString(view, offset, string) {
      for (var i = 0; i < string.length; i++) {
        view.setUint8(offset + i, string.charCodeAt(i));
      }
    }
  })();
</script>
