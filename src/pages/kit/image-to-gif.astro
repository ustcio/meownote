---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '图片转GIF';
const toolDesc = '将多张图片合成为GIF动图';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span>点击或拖拽上传多张图片</span>
          <span class="hint">按顺序上传，支持 PNG, JPG</span>
          <input type="file" id="file-input" accept="image/*" multiple>
        </div>

        <div id="frame-list" class="file-info" style="display:none;">
          <div class="result-header">已上传帧 (<span id="frame-count">0</span>帧)</div>
          <div id="frame-thumbnails" style="display:flex;gap:0.2rem;flex-wrap:wrap;margin-top:0.2rem;"></div>
        </div>

        <div class="settings" id="settings" style="display:none;">
          <div class="setting-group">
            <label class="setting-label">帧率: <span id="fps-value">5</span> FPS</label>
            <input type="range" id="fps" min="1" max="10" value="5" style="width:100%;">
          </div>
          <div class="setting-group">
            <label class="setting-label">循环次数 (0=无限)</label>
            <input type="number" id="loop-count" value="0" min="0" max="100" class="setting-select" style="width:4rem;">
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="generate-btn">生成 GIF</button>
            <button class="btn-secondary" id="reset-btn">重置</button>
          </div>
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">编码中...</div>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">GIF 预览</div>
          <div class="result-stats">
            <div class="stat">
              <span class="stat-label">帧数</span>
              <span class="stat-value" id="gif-frames"></span>
            </div>
            <div class="stat">
              <span class="stat-label">文件大小</span>
              <span class="stat-value" id="gif-size"></span>
            </div>
          </div>
          <img id="gif-preview" style="width:100%;border-radius:10px;max-height:50vh;object-fit:contain;">
          <div class="btn-group" style="margin-top:0.3rem;">
            <button class="btn-primary" id="download-btn">下载 GIF</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-main { overflow: auto; }
  #frame-thumbnails img { max-width: 80px; max-height: 80px; border-radius: 8px; object-fit: cover; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var uploadArea = document.getElementById('upload-area');
    var fileInput = document.getElementById('file-input');
    var frameList = document.getElementById('frame-list');
    var frameThumbnails = document.getElementById('frame-thumbnails');
    var settings = document.getElementById('settings');
    var progressArea = document.getElementById('progress-area');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var resultArea = document.getElementById('result-area');
    var gifPreview = document.getElementById('gif-preview');
    var fpsSlider = document.getElementById('fps');
    var fpsValue = document.getElementById('fps-value');
    var loopCount = document.getElementById('loop-count');
    var generateBtn = document.getElementById('generate-btn');
    var resetBtn = document.getElementById('reset-btn');
    var downloadBtn = document.getElementById('download-btn');
    var frames = [];
    var gifBlob = null;

    uploadArea.addEventListener('click', function() { fileInput.click(); });
    uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); });
    uploadArea.addEventListener('drop', function(e) { e.preventDefault(); if (e.dataTransfer.files.length) handleFiles(e.dataTransfer.files); });
    fileInput.addEventListener('change', function() { if (fileInput.files.length) handleFiles(fileInput.files); });
    fpsSlider.addEventListener('input', function() { fpsValue.textContent = fpsSlider.value; });

    function handleFiles(files) {
      frames = [];
      frameThumbnails.innerHTML = '';
      var loaded = 0;
      var total = 0;
      for (var i = 0; i < files.length; i++) {
        if (!files[i].type.startsWith('image/')) continue;
        total++;
        (function(file, idx) {
          var reader = new FileReader();
          reader.onload = function(e) {
            var img = new Image();
            img.onload = function() {
              frames.push(img);
              loaded++;
              var thumb = document.createElement('img');
              thumb.src = e.target.result;
              thumb.title = 'Frame ' + (idx + 1);
              frameThumbnails.appendChild(thumb);
              if (loaded === total) {
                document.getElementById('frame-count').textContent = frames.length;
                frameList.style.display = 'block';
                settings.style.display = 'flex';
                resultArea.style.display = 'none';
              }
            };
            img.src = e.target.result;
          };
          reader.readAsDataURL(file);
        })(files[i], i);
      }
    }

    generateBtn.addEventListener('click', function() {
      if (frames.length < 2) return;
      progressArea.style.display = 'block';
      progressFill.style.width = '10%';
      progressText.textContent = '编码 GIF...';
      setTimeout(function() {
        var fps = parseInt(fpsSlider.value);
        var loops = parseInt(loopCount.value);
        var delay = Math.round(100 / fps);
        var gifData = encodeGIF(frames, delay, loops);
        gifBlob = new Blob([gifData], { type: 'image/gif' });
        var url = URL.createObjectURL(gifBlob);
        gifPreview.src = url;
        document.getElementById('gif-frames').textContent = frames.length;
        document.getElementById('gif-size').textContent = (gifBlob.size / 1024).toFixed(1) + ' KB';
        progressFill.style.width = '100%';
        progressText.textContent = '完成!';
        resultArea.style.display = 'block';
        setTimeout(function() { progressArea.style.display = 'none'; }, 800);
      }, 50);
    });

    resetBtn.addEventListener('click', function() {
      frames = [];
      frameThumbnails.innerHTML = '';
      frameList.style.display = 'none';
      settings.style.display = 'none';
      resultArea.style.display = 'none';
      fileInput.value = '';
    });

    downloadBtn.addEventListener('click', function() {
      if (!gifBlob) return;
      var url = URL.createObjectURL(gifBlob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'animation.gif';
      a.click();
      URL.revokeObjectURL(url);
    });

    function encodeGIF(images, delay, loops) {
      var w = images[0].width;
      var h = images[0].height;
      var frames = [];
      for (var i = 0; i < images.length; i++) {
        var c = document.createElement('canvas');
        c.width = w;
        c.height = h;
        var ctx = c.getContext('2d');
        ctx.drawImage(images[i], 0, 0, w, h);
        frames.push(ctx.getImageData(0, 0, w, h).data);
      }
      var globalPalette = buildPalette(frames, 256);
      var out = [];
      out.push(0x47, 0x49, 0x46);
      out.push(0x38, 0x39, 0x61);
      out.push(w & 0xff, (w >> 8) & 0xff);
      out.push(h & 0xff, (h >> 8) & 0xff);
      out.push(0xf7, 0x00, 0x00);
      for (var i = 0; i < 256; i++) {
        out.push(globalPalette[i][0], globalPalette[i][1], globalPalette[i][2]);
      }
      if (loops >= 0) {
        out.push(0x21, 0xff, 0x0b);
        out.push(0x4e, 0x45, 0x54, 0x53, 0x43, 0x41, 0x50, 0x45, 0x32, 0x2e, 0x30);
        out.push(0x03, 0x01);
        out.push(loops & 0xff, (loops >> 8) & 0xff);
        out.push(0x00);
      }
      for (var f = 0; f < frames.length; f++) {
        var indexed = quantizeFrame(frames[f], globalPalette);
        out.push(0x21, 0xf9, 0x04);
        out.push(0x00);
        out.push(delay & 0xff, (delay >> 8) & 0xff);
        out.push(0x00, 0x00);
        out.push(0x2c);
        out.push(0x00, 0x00, 0x00, 0x00);
        out.push(w & 0xff, (w >> 8) & 0xff);
        out.push(h & 0xff, (h >> 8) & 0xff);
        out.push(0x00);
        var lzw = lzwEncode(indexed, 8);
        out = out.concat(lzw);
      }
      out.push(0x3b);
      return new Uint8Array(out);
    }

    function buildPalette(frames, maxColors) {
      var colorCount = {};
      var step = Math.max(1, Math.floor(frames[0].length / 4 / 50000));
      for (var f = 0; f < frames.length; f++) {
        var data = frames[f];
        for (var i = 0; i < data.length; i += 4 * step) {
          var key = (data[i] >> 3) + ',' + (data[i+1] >> 3) + ',' + (data[i+2] >> 3);
          colorCount[key] = (colorCount[key] || 0) + 1;
        }
      }
      var sorted = Object.keys(colorCount).sort(function(a, b) { return colorCount[b] - colorCount[a]; });
      var palette = [];
      for (var i = 0; i < Math.min(maxColors, sorted.length); i++) {
        var parts = sorted[i].split(',');
        palette.push([parseInt(parts[0]) << 3, parseInt(parts[1]) << 3, parseInt(parts[2]) << 3]);
      }
      while (palette.length < maxColors) palette.push([0, 0, 0]);
      return palette;
    }

    function quantizeFrame(data, palette) {
      var result = new Uint8Array(data.length / 4);
      for (var i = 0; i < data.length; i += 4) {
        var minDist = Infinity, minIdx = 0;
        for (var j = 0; j < palette.length; j++) {
          var dr = data[i] - palette[j][0];
          var dg = data[i+1] - palette[j][1];
          var db = data[i+2] - palette[j][2];
          var dist = dr*dr + dg*dg + db*db;
          if (dist < minDist) { minDist = dist; minIdx = j; }
        }
        result[i / 4] = minIdx;
      }
      return result;
    }

    function lzwEncode(data, minCodeSize) {
      var clearCode = 1 << minCodeSize;
      var eoiCode = clearCode + 1;
      var codeSize = minCodeSize + 1;
      var nextCode = eoiCode + 1;
      var output = [];
      var bits = [];

      function writeCode(code, size) {
        for (var i = 0; i < size; i++) {
          bits.push((code >> i) & 1);
        }
      }

      function flushBits() {
        while (bits.length >= 8) {
          var byte = 0;
          for (var i = 0; i < 8; i++) {
            byte |= (bits.shift() << i);
          }
          output.push(byte);
        }
      }

      writeCode(clearCode, codeSize);
      flushBits();

      var dict = {};
      for (var i = 0; i < clearCode; i++) {
        dict[String(i)] = i;
      }

      var w = String(data[0]);
      for (var i = 1; i < data.length; i++) {
        var k = String(data[i]);
        var wk = w + ',' + k;
        if (dict[wk] !== undefined) {
          w = wk;
        } else {
          if (nextCode < 4096) {
            dict[wk] = nextCode;
            nextCode++;
            if (nextCode > (1 << codeSize) && codeSize < 12) {
              codeSize++;
            }
          } else {
            writeCode(clearCode, codeSize);
            flushBits();
            dict = {};
            for (var j = 0; j < clearCode; j++) dict[String(j)] = j;
            nextCode = eoiCode + 1;
            codeSize = minCodeSize + 1;
          }
          writeCode(dict[w], codeSize);
          flushBits();
          w = k;
        }
      }
      writeCode(dict[w], codeSize);
      writeCode(eoiCode, codeSize);
      flushBits();

      var result = [minCodeSize];
      var idx = 0;
      while (idx < output.length) {
        var blockSize = Math.min(255, output.length - idx);
        result.push(blockSize);
        for (var i = 0; i < blockSize; i++) {
          result.push(output[idx++]);
        }
      }
      result.push(0x00);
      return result;
    }
  });
</script>
