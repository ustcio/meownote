---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '音频调速';
const toolDesc = '改变音频播放速度（不改变音调）';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div class="upload-zone" id="upload-zone">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                  </svg>
                  <p class="upload-text">点击或拖拽上传音频文件</p>
                  <p class="upload-hint">支持 MP3、WAV、OGG、FLAC、WebM 等格式</p>
                  <input type="file" id="file-input" accept="audio/*" />
                </div>

                <div class="file-info hidden" id="file-info">
                  <div class="file-info-header">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M9 18V5l12-2v13"></path>
                      <circle cx="6" cy="18" r="3"></circle>
                      <circle cx="18" cy="16" r="3"></circle>
                    </svg>
                    <div class="file-details">
                      <span class="file-name" id="file-name"></span>
                      <span class="file-meta">
                        <span id="file-size"></span>
                        <span class="separator">·</span>
                        <span id="file-duration"></span>
                      </span>
                    </div>
                    <button class="btn-icon" id="remove-file" title="移除文件">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </button>
                  </div>
                </div>

                <div class="settings-panel hidden" id="settings-panel">
                  <div class="hao-form-group">
                    <label class="hao-label">播放速度</label>
                    <div class="speed-buttons" id="speed-buttons">
                      <button class="speed-btn" data-speed="0.5">0.5x</button>
                      <button class="speed-btn" data-speed="0.75">0.75x</button>
                      <button class="speed-btn active" data-speed="1">1x</button>
                      <button class="speed-btn" data-speed="1.25">1.25x</button>
                      <button class="speed-btn" data-speed="1.5">1.5x</button>
                      <button class="speed-btn" data-speed="2">2x</button>
                      <button class="speed-btn" data-speed="3">3x</button>
                    </div>
                  </div>
                  <div class="speed-preview">
                    <span class="preview-label">新时长: </span>
                    <span class="preview-value" id="new-duration"></span>
                  </div>
                </div>

                <div class="actions hidden" id="actions">
                  <button class="hao-press-btn hao-press-btn--primary" id="speed-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                    </svg>
                    开始调速
                  </button>
                </div>

                <div class="progress-container hidden" id="progress-container">
                  <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill"></div>
                  </div>
                  <span class="progress-text" id="progress-text">处理中...</span>
                </div>

                <div class="result hidden" id="result">
                  <div class="result-header">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                      <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    <span>调速完成</span>
                  </div>
                  <div class="result-info">
                    <span>WAV</span>
                    <span class="separator">·</span>
                    <span id="result-size"></span>
                    <span class="separator">·</span>
                    <span id="result-duration"></span>
                    <span class="separator">·</span>
                    <span id="result-speed"></span>
                  </div>
                  <audio class="audio-player" id="audio-player" controls></audio>
                  <div class="hao-btn-group">
                    <button class="hao-press-btn hao-press-btn--primary" id="download-btn">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                      </svg>
                      下载文件
                    </button>
                    <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重新上传</button>
                  </div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
