---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '全国油价查询';
const toolDesc = '查询全国各省市最新油价信息';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="tool-content" id="tool-content">
          <div class="settings" style="margin-bottom:0.4rem;">
            <div class="setting-group">
              <span class="setting-label">选择省份</span>
              <select id="province-select" class="setting-select" style="width:100%;padding:0.3rem;margin-top:0.2rem;"></select>
            </div>
          </div>
          <div id="result-area" class="result-area">
            <div class="result-header" id="result-title">油价信息</div>
            <div class="file-info" id="oil-info"></div>
            <div id="trend-info" style="margin-top:0.3rem;text-align:center;font-size:0.28rem;color:var(--color-tm-text);"></div>
          </div>
          <div style="margin-top:0.4rem;padding:0.3rem;background:var(--color-background-one);border-radius:15px;font-size:0.22rem;color:var(--color-tm-text);">
            * 数据仅供参考，实际价格以当地加油站为准。更新时间: <span id="update-time"></span>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const oilData = {
      '北京': { '92#': 7.98, '95#': 8.49, '98#': 9.47, '0#': 7.65, trend: 'up', change: 0.08 },
      '上海': { '92#': 7.95, '95#': 8.46, '98#': 9.44, '0#': 7.62, trend: 'up', change: 0.06 },
      '广东': { '92#': 8.02, '95#': 8.54, '98#': 9.52, '0#': 7.68, trend: 'up', change: 0.10 },
      '江苏': { '92#': 7.96, '95#': 8.47, '98#': 9.45, '0#': 7.63, trend: 'down', change: -0.05 },
      '浙江': { '92#': 7.96, '95#': 8.48, '98#': 9.46, '0#': 7.64, trend: 'up', change: 0.07 },
      '山东': { '92#': 7.94, '95#': 8.45, '98#': 9.43, '0#': 7.60, trend: 'down', change: -0.03 },
      '四川': { '92#': 8.08, '95#': 8.60, '98#': 9.58, '0#': 7.72, trend: 'up', change: 0.09 },
      '湖北': { '92#': 7.99, '95#': 8.50, '98#': 9.48, '0#': 7.66, trend: 'up', change: 0.05 },
      '湖南': { '92#': 8.00, '95#': 8.51, '98#': 9.49, '0#': 7.67, trend: 'down', change: -0.04 },
      '河南': { '92#': 7.97, '95#': 8.48, '98#': 9.46, '0#': 7.64, trend: 'up', change: 0.06 },
      '河北': { '92#': 7.97, '95#': 8.48, '98#': 9.46, '0#': 7.64, trend: 'up', change: 0.07 },
      '福建': { '92#': 7.95, '95#': 8.46, '98#': 9.44, '0#': 7.62, trend: 'down', change: -0.02 },
      '安徽': { '92#': 7.95, '95#': 8.47, '98#': 9.45, '0#': 7.63, trend: 'up', change: 0.05 },
      '辽宁': { '92#': 7.93, '95#': 8.44, '98#': 9.42, '0#': 7.59, trend: 'down', change: -0.06 },
      '陕西': { '92#': 8.05, '95#': 8.56, '98#': 9.54, '0#': 7.70, trend: 'up', change: 0.08 },
      '重庆': { '92#': 8.04, '95#': 8.55, '98#': 9.53, '0#': 7.69, trend: 'up', change: 0.07 },
      '云南': { '92#': 8.12, '95#': 8.64, '98#': 9.62, '0#': 7.76, trend: 'up', change: 0.10 },
      '贵州': { '92#': 8.10, '95#': 8.62, '98#': 9.60, '0#': 7.74, trend: 'down', change: -0.03 },
      '海南': { '92#': 8.15, '95#': 8.67, '98#': 9.65, '0#': 7.79, trend: 'up', change: 0.12 },
      '西藏': { '92#': 8.20, '95#': 8.72, '98#': 9.70, '0#': 7.84, trend: 'up', change: 0.08 },
      '黑龙江': { '92#': 7.92, '95#': 8.43, '98#': 9.41, '0#': 7.58, trend: 'down', change: -0.05 },
      '吉林': { '92#': 7.93, '95#': 8.44, '98#': 9.42, '0#': 7.59, trend: 'up', change: 0.04 },
      '内蒙古': { '92#': 7.94, '95#': 8.45, '98#': 9.43, '0#': 7.60, trend: 'up', change: 0.06 },
      '新疆': { '92#': 7.90, '95#': 8.41, '98#': 9.39, '0#': 7.56, trend: 'down', change: -0.04 },
      '甘肃': { '92#': 7.98, '95#': 8.49, '98#': 9.47, '0#': 7.65, trend: 'up', change: 0.07 },
      '宁夏': { '92#': 7.96, '95#': 8.47, '98#': 9.45, '0#': 7.63, trend: 'up', change: 0.05 },
      '青海': { '92#': 8.02, '95#': 8.54, '98#': 9.52, '0#': 7.68, trend: 'down', change: -0.02 },
      '山西': { '92#': 7.95, '95#': 8.46, '98#': 9.44, '0#': 7.62, trend: 'up', change: 0.06 },
      '天津': { '92#': 7.97, '95#': 8.48, '98#': 9.46, '0#': 7.64, trend: 'up', change: 0.07 },
      '广西': { '92#': 8.04, '95#': 8.55, '98#': 9.53, '0#': 7.69, trend: 'up', change: 0.08 },
      '江西': { '92#': 7.96, '95#': 8.47, '98#': 9.45, '0#': 7.63, trend: 'down', change: -0.03 }
    };

    const select = document.getElementById('province-select');
    const oilInfo = document.getElementById('oil-info');
    const trendInfo = document.getElementById('trend-info');
    const resultTitle = document.getElementById('result-title');
    const updateTime = document.getElementById('update-time');

    Object.keys(oilData).sort().forEach(p => {
      const opt = document.createElement('option');
      opt.value = p; opt.textContent = p;
      select.appendChild(opt);
    });

    updateTime.textContent = new Date().toLocaleDateString('zh-CN');

    function updateOil(province) {
      const data = oilData[province];
      if (!data) return;
      oilInfo.innerHTML = `
        <div class="info-row"><span class="info-label">92# 汽油</span><span class="info-value">¥${data['92#'].toFixed(2)}/升</span></div>
        <div class="info-row"><span class="info-label">95# 汽油</span><span class="info-value">¥${data['95#'].toFixed(2)}/升</span></div>
        <div class="info-row"><span class="info-label">98# 汽油</span><span class="info-value">¥${data['98#'].toFixed(2)}/升</span></div>
        <div class="info-row"><span class="info-label">0# 柴油</span><span class="info-value">¥${data['0#'].toFixed(2)}/升</span></div>`;
      const arrow = data.trend === 'up' ? '📈 上涨' : '📉 下跌';
      const color = data.trend === 'up' ? '#ff6b6b' : '#4ecdc4';
      trendInfo.innerHTML = `最新调价: <span style="color:${color};font-weight:500;">${arrow} ${Math.abs(data.change).toFixed(2)} 元/升</span>`;
      resultTitle.textContent = `${province} 油价`;
    }

    select.addEventListener('change', (e) => updateOil(e.target.value));
    updateOil(select.value);
  });
</script>
