---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '图片去水印';
const toolDesc = '框选水印区域并智能去除';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span>点击或拖拽上传图片</span>
          <span class="hint">支持 PNG, JPG, WebP 格式</span>
          <input type="file" id="file-input" accept="image/*">
        </div>

        <div id="file-info" class="file-info" style="display:none;">
          <div class="info-row">
            <span class="info-label">文件名</span>
            <span class="info-value" id="file-name"></span>
          </div>
          <div class="info-row">
            <span class="info-label">尺寸</span>
            <span class="info-value" id="file-dimensions"></span>
          </div>
        </div>

        <div class="settings" id="settings" style="display:none;">
          <p class="setting-label" style="color:var(--color-tm-text);font-size:0.25rem;">在预览图上拖拽框选水印区域，然后点击"去除水印"</p>
          <div class="setting-group">
            <label class="setting-label">修复半径: <span id="radius-value">10</span>px</label>
            <input type="range" id="radius" min="2" max="50" value="10" style="width:100%;">
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="process-btn">去除水印</button>
            <button class="btn-secondary" id="reset-btn">重置</button>
          </div>
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">处理中...</div>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">处理结果（拖拽框选水印区域）</div>
          <div style="position:relative;display:inline-block;width:100%;">
            <canvas id="preview-canvas" style="width:100%;border-radius:10px;cursor:crosshair;display:block;"></canvas>
            <div id="selection-box" style="position:absolute;border:2px dashed #ff4444;display:none;pointer-events:none;"></div>
          </div>
          <div class="btn-group" style="margin-top:0.3rem;">
            <button class="btn-primary" id="download-btn">下载图片</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-main { overflow: auto; }
  #preview-canvas { max-height: 60vh; object-fit: contain; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var uploadArea = document.getElementById('upload-area');
    var fileInput = document.getElementById('file-input');
    var fileInfo = document.getElementById('file-info');
    var settings = document.getElementById('settings');
    var progressArea = document.getElementById('progress-area');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var resultArea = document.getElementById('result-area');
    var previewCanvas = document.getElementById('preview-canvas');
    var selectionBox = document.getElementById('selection-box');
    var radiusSlider = document.getElementById('radius');
    var radiusValue = document.getElementById('radius-value');
    var processBtn = document.getElementById('process-btn');
    var resetBtn = document.getElementById('reset-btn');
    var downloadBtn = document.getElementById('download-btn');
    var originalImage = null;
    var originalFileName = '';
    var isSelecting = false;
    var startX, startY, endX, endY;

    uploadArea.addEventListener('click', function() { fileInput.click(); });
    uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); });
    uploadArea.addEventListener('drop', function(e) { e.preventDefault(); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files.length) handleFile(fileInput.files[0]); });
    radiusSlider.addEventListener('input', function() { radiusValue.textContent = radiusSlider.value; });

    function handleFile(file) {
      if (!file.type.startsWith('image/')) return;
      originalFileName = file.name.replace(/\.[^.]+$/, '');
      document.getElementById('file-name').textContent = file.name;
      fileInfo.style.display = 'block';
      settings.style.display = 'flex';
      resultArea.style.display = 'none';
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          originalImage = img;
          var ctx = previewCanvas.getContext('2d');
          previewCanvas.width = img.width;
          previewCanvas.height = img.height;
          ctx.drawImage(img, 0, 0);
          document.getElementById('file-dimensions').textContent = img.width + 'x' + img.height;
          resultArea.style.display = 'block';
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    previewCanvas.addEventListener('mousedown', function(e) {
      isSelecting = true;
      var rect = previewCanvas.getBoundingClientRect();
      var scaleX = previewCanvas.width / rect.width;
      var scaleY = previewCanvas.height / rect.height;
      startX = Math.floor((e.clientX - rect.left) * scaleX);
      startY = Math.floor((e.clientY - rect.top) * scaleY);
      selectionBox.style.display = 'block';
      selectionBox.style.left = (e.clientX - rect.left) + 'px';
      selectionBox.style.top = (e.clientY - rect.top) + 'px';
      selectionBox.style.width = '0px';
      selectionBox.style.height = '0px';
    });

    previewCanvas.addEventListener('mousemove', function(e) {
      if (!isSelecting) return;
      var rect = previewCanvas.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      var w = x - parseFloat(selectionBox.style.left);
      var h = y - parseFloat(selectionBox.style.top);
      selectionBox.style.width = Math.abs(w) + 'px';
      selectionBox.style.height = Math.abs(h) + 'px';
      if (w < 0) selectionBox.style.left = x + 'px';
      if (h < 0) selectionBox.style.top = y + 'px';
    });

    previewCanvas.addEventListener('mouseup', function(e) {
      if (!isSelecting) return;
      isSelecting = false;
      var rect = previewCanvas.getBoundingClientRect();
      var scaleX = previewCanvas.width / rect.width;
      var scaleY = previewCanvas.height / rect.height;
      endX = Math.floor((e.clientX - rect.left) * scaleX);
      endY = Math.floor((e.clientY - rect.top) * scaleY);
    });

    processBtn.addEventListener('click', function() {
      if (!originalImage || startX === undefined) return;
      progressArea.style.display = 'block';
      progressFill.style.width = '10%';
      progressText.textContent = '修复中...';

      setTimeout(function() {
        var canvas = previewCanvas;
        var ctx = canvas.getContext('2d');
        var x1 = Math.min(startX, endX);
        var y1 = Math.min(startY, endY);
        var x2 = Math.max(startX, endX);
        var y2 = Math.max(startY, endY);
        var w = x2 - x1;
        var h = y2 - y1;
        if (w < 2 || h < 2) { progressArea.style.display = 'none'; return; }
        var radius = parseInt(radiusSlider.value);
        var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        var data = imageData.data;
        var cw = canvas.width;

        for (var y = y1; y < y2; y++) {
          for (var x = x1; x < x2; x++) {
            var idx = (y * cw + x) * 4;
            var rSum = 0, gSum = 0, bSum = 0, count = 0;
            for (var dy = -radius; dy <= radius; dy++) {
              for (var dx = -radius; dx <= radius; dx++) {
                var nx = x + dx;
                var ny = y + dy;
                if (nx < x1 || nx >= x2 || ny < y1 || ny >= y2) {
                  if (nx >= 0 && nx < cw && ny >= 0 && ny < canvas.height) {
                    var ni = (ny * cw + nx) * 4;
                    var dist = Math.sqrt(dx * dx + dy * dy);
                    var weight = 1 / (1 + dist);
                    rSum += data[ni] * weight;
                    gSum += data[ni + 1] * weight;
                    bSum += data[ni + 2] * weight;
                    count += weight;
                  }
                }
              }
            }
            if (count > 0) {
              data[idx] = Math.round(rSum / count);
              data[idx + 1] = Math.round(gSum / count);
              data[idx + 2] = Math.round(bSum / count);
            }
          }
        }
        ctx.putImageData(imageData, 0, 0);
        selectionBox.style.display = 'none';
        progressFill.style.width = '100%';
        progressText.textContent = '完成!';
        setTimeout(function() { progressArea.style.display = 'none'; }, 800);
      }, 50);
    });

    resetBtn.addEventListener('click', function() {
      if (!originalImage) return;
      var ctx = previewCanvas.getContext('2d');
      previewCanvas.width = originalImage.width;
      previewCanvas.height = originalImage.height;
      ctx.drawImage(originalImage, 0, 0);
      selectionBox.style.display = 'none';
    });

    downloadBtn.addEventListener('click', function() {
      previewCanvas.toBlob(function(blob) {
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = originalFileName + '_no_watermark.png';
        a.click();
        URL.revokeObjectURL(url);
      }, 'image/png');
    });
  });
</script>
