---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '视频格式转换';
const toolDesc = '将视频转换为不同格式（WebM/VP8, WebM/VP9等）';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polygon points="23 7 16 12 23 17 23 7"></polygon>
                  <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                </svg>
                <span>点击或拖拽上传视频文件</span>
                <span class="hint">支持 MP4, WebM, MOV, AVI, MKV</span>
                <input type="file" id="video-input" accept="video/*" hidden>
              </div>

              <div class="file-info" id="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">原始大小</span>
                  <span class="info-value" id="file-size"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">时长</span>
                  <span class="info-value" id="file-duration"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">分辨率</span>
                  <span class="info-value" id="file-resolution"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">目标格式</label>
                  <div class="format-options" id="format-options">
                    <button class="format-btn" data-mime="video/webm;codecs=vp8" data-ext="webm">WebM/VP8</button>
                    <button class="format-btn active" data-mime="video/webm;codecs=vp9" data-ext="webm">WebM/VP9</button>
                  </div>
                </div>
                <button class="hao-press-btn hao-press-btn--primary" id="convert-btn">开始转换</button>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar">
                  <div class="progress-fill" id="progress-fill"></div>
                </div>
                <span class="progress-text" id="progress-text">处理中...</span>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">
                  <span>转换结果</span>
                </div>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">输出大小</span>
                    <span class="stat-value" id="result-size"></span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">输出格式</span>
                    <span class="stat-value" id="result-format"></span>
                  </div>
                </div>
                <video id="result-video" controls class="result-video"></video>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载转换后的视频</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重新上传</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
