---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '网站综合查询';
const toolDesc = '查询网站状态、响应时间等信息';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div class="input-group" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                  <input id="url-input" type="text" class="hao-input" placeholder="输入网址，如 https://example.com" style="flex:1;padding:0.3rem 0.4rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:15px;color:var(--color-text);font-size:0.28rem;outline:none;">
                  <button id="check-btn" class="hao-press-btn hao-press-btn--primary">检测</button>
                </div>
                <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">检测中...</div>
                <div id="error" style="display:none;text-align:center;padding:1rem;color:#ff6b6b;"></div>
                <div id="hao-result" style="display:none;">
                  <div class="hao-result" style="margin-bottom:0.3rem;">
                    <div class="result-header">网站状态</div>
                    <div class="file-info" id="status-info"></div>
                  </div>
                  <div class="hao-result" style="margin-bottom:0.3rem;">
                    <div class="result-header">SSL信息</div>
                    <div class="file-info" id="ssl-info"></div>
                  </div>
                  <div class="hao-result">
                    <div class="result-header">技术栈检测</div>
                    <div class="file-info" id="tech-info"></div>
                  </div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
