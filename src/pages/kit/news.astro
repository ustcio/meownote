---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '每日早报';
const toolDesc = '每日新闻早报资讯';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-tool-content" id="tool-content">
                <div class="hao-tab-buttons" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;flex-wrap:wrap;">
                  <button class="hao-news-tab btn-primary" data-tab="domestic">国内</button>
                  <button class="hao-news-tab btn-secondary" data-tab="international">国际</button>
                  <button class="hao-news-tab btn-secondary" data-tab="tech">科技</button>
                  <button class="hao-news-tab btn-secondary" data-tab="finance">财经</button>
                </div>
                <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">加载中...</div>
                <div id="news-list"></div>
                <div style="margin-top:0.4rem;text-align:center;">
                  <button id="refresh-btn" class="hao-press-btn hao-press-btn--secondary" style="font-size:0.22rem;">🔄 刷新</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
