---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '图片工具';
const toolDesc = '图片压缩、格式转换、尺寸调整';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
<section >
    <div class="hao-section-container">
      <header class="hao-tool-header">
        <a href="/kit" class="hao-back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span>工具箱</span>
        </a>
        <h1 class="hao-tool-title">图片工具</h1>
        <p class="desc">图片压缩、格式转换、尺寸调整</p>
      </header>

      <!-- Upload -->
      <div class="card upload-card" id="upload-area">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
        <span>点击或拖拽上传图片</span>
        <span class="hint">支持 PNG, JPG, GIF, WebP, BMP</span>
        <input type="file" id="image-input" accept="image/*" hidden />
      </div>

      <!-- Preview & Info -->
      <div class="hao-card" id="info-card" style="display:none;">
        <div class="card-head">
          <span class="card-title">原始图片</span>
          <span class="info-text" id="original-info"></span>
        </div>
        <div class="hao-preview-box">
          <img id="preview-img" alt="预览" />
        </div>
      </div>

      <!-- Options -->
      <div class="hao-card" id="options-card" style="display:none;">
        <div class="card-head">
          <span class="card-title">调整选项</span>
        </div>
        <div class="options-grid">
          <div class="option-group">
            <label class="lbl">输出格式</label>
            <select id="output-format">
              <option value="image/png">PNG</option>
              <option value="image/jpeg" selected>JPEG</option>
              <option value="image/webp">WebP</option>
            </select>
          </div>
          <div class="option-group">
            <label class="lbl">质量 <span id="quality-val">80</span>%</label>
            <input type="range" id="quality-slider" min="10" max="100" value="80" />
          </div>
          <div class="option-group">
            <label class="lbl">宽度 (px)</label>
            <input type="number" id="resize-width" placeholder="自动" />
          </div>
          <div class="option-group">
            <label class="lbl">高度 (px)</label>
            <input type="number" id="resize-height" placeholder="自动" />
          </div>
        </div>
        <div class="lock-row">
          <label class="lock-label">
            <input type="checkbox" id="lock-ratio" checked />
            <span>锁定宽高比</span>
          </label>
        </div>
        <button class="hao-press-btn hao-press-btn--primary" id="process-btn">处理图片</button>
      </div>

      <!-- Result -->
      <div class="hao-card" id="result-card" style="display:none;">
        <div class="card-head">
          <span class="card-title">处理结果</span>
          <span class="info-text" id="result-info"></span>
        </div>
        <div class="hao-preview-box">
          <img id="result-img" alt="结果" />
        </div>
        <div class="result-actions">
          <button class="hao-btn-download" id="download-btn">下载图片</button>
          <span class="savings" id="savings-text"></span>
        </div>
      </div>
    </div>
  </section>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
  const uploadArea = document.getElementById('upload-area');
  const imageInput = document.getElementById('image-input');
  const infoCard = document.getElementById('info-card');
  const optionsCard = document.getElementById('options-card');
  const resultCard = document.getElementById('result-card');
  const previewImg = document.getElementById('preview-img');
  const resultImg = document.getElementById('result-img');
  const originalInfo = document.getElementById('original-info');
  const resultInfo = document.getElementById('result-info');
  const outputFormat = document.getElementById('output-format');
  const qualitySlider = document.getElementById('quality-slider');
  const qualityVal = document.getElementById('quality-val');
  const resizeWidth = document.getElementById('resize-width');
  const resizeHeight = document.getElementById('resize-height');
  const lockRatio = document.getElementById('lock-ratio');
  const processBtn = document.getElementById('process-btn');
  const downloadBtn = document.getElementById('download-btn');
  const savingsText = document.getElementById('savings-text');

  let originalFile = null;
  let originalWidth = 0;
  let originalHeight = 0;
  let resultBlobUrl = '';

  uploadArea.addEventListener('click', () => imageInput.click());
  uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.classList.add('dragover'); });
  uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith('image/')) loadImage(file);
  });
  imageInput.addEventListener('change', () => {
    const file = imageInput.files?.[0];
    if (file) loadImage(file);
  });

  function loadImage(file) {
    originalFile = file;
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => {
      originalWidth = img.naturalWidth;
      originalHeight = img.naturalHeight;
      previewImg.src = url;
      originalInfo.textContent = `${originalWidth} × ${originalHeight} · ${(file.size / 1024).toFixed(1)} KB · ${file.type.split('/')[1].toUpperCase()}`;
      resizeWidth.placeholder = originalWidth.toString();
      resizeHeight.placeholder = originalHeight.toString();
      infoCard.style.display = 'block';
      optionsCard.style.display = 'block';
      resultCard.style.display = 'none';
    };
    img.src = url;
  }

  qualitySlider.addEventListener('input', () => {
    qualityVal.textContent = qualitySlider.value;
  });

  // Lock aspect ratio
  resizeWidth.addEventListener('input', () => {
    if (lockRatio.checked && originalWidth) {
      const w = parseInt(resizeWidth.value);
      if (!isNaN(w)) {
        resizeHeight.value = Math.round(w * originalHeight / originalWidth).toString();
      }
    }
  });
  resizeHeight.addEventListener('input', () => {
    if (lockRatio.checked && originalHeight) {
      const h = parseInt(resizeHeight.value);
      if (!isNaN(h)) {
        resizeWidth.value = Math.round(h * originalWidth / originalHeight).toString();
      }
    }
  });

  processBtn.addEventListener('click', () => {
    if (!originalFile) return;
    const img = new Image();
    img.onload = () => {
      let w = parseInt(resizeWidth.value) || img.naturalWidth;
      let h = parseInt(resizeHeight.value) || img.naturalHeight;

      const canvas = document.createElement('canvas');
      canvas.width = w;
      canvas.height = h;
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, w, h);

      const quality = parseInt(qualitySlider.value) / 100;
      const format = outputFormat.value;

      canvas.toBlob((blob) => {
        if (!blob) return;
        if (resultBlobUrl) URL.revokeObjectURL(resultBlobUrl);
        resultBlobUrl = URL.createObjectURL(blob);
        resultImg.src = resultBlobUrl;
        resultInfo.textContent = `${w} × ${h} · ${(blob.size / 1024).toFixed(1)} KB · ${format.split('/')[1].toUpperCase()}`;

        const diff = blob.size - (originalFile?.size || 0);
        const pct = ((diff / (originalFile?.size || 1)) * 100).toFixed(1);
        if (diff < 0) {
          savingsText.textContent = `减小 ${Math.abs(parseFloat(pct))}%`;
          savingsText.className = 'savings positive';
        } else {
          savingsText.textContent = `增大 ${pct}%`;
          savingsText.className = 'savings negative';
        }
        resultCard.style.display = 'block';
      }, format, quality);
    };
    img.src = previewImg.src;
  });

  downloadBtn.addEventListener('click', () => {
    if (!resultBlobUrl) return;
    const ext = outputFormat.value.split('/')[1];
    const a = document.createElement('a');
    a.href = resultBlobUrl;
    a.download = `image-processed.${ext}`;
    a.click();
  });
</script>
