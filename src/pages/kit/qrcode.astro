---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="二维码生成器 - Maxwell.Science"
  description="在线生成自定义二维码，支持Logo、颜色设置"
>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          <span>工具箱</span>
        </a>
        <h1>二维码生成器</h1>
        <p class="tool-desc">输入文本或链接，生成自定义样式的二维码</p>
      </header>

      <div class="tool-main">
        <div class="input-section">
          <div class="input-group">
            <label>内容</label>
            <textarea id="qr-input" placeholder="输入文本、链接或任意内容..." rows="3"></textarea>
          </div>

          <div class="options-grid">
            <div class="option-group">
              <label>尺寸</label>
              <select id="qr-size">
                <option value="128">128 × 128</option>
                <option value="200" selected>200 × 200</option>
                <option value="300">300 × 300</option>
                <option value="400">400 × 400</option>
              </select>
            </div>

            <div class="option-group">
              <label>前景色</label>
              <input type="color" id="qr-dark" value="#171412" />
            </div>

            <div class="option-group">
              <label>背景色</label>
              <input type="color" id="qr-light" value="#ffffff" />
            </div>

            <div class="option-group">
              <label>容错级别</label>
              <select id="qr-level">
                <option value="L">L - 7%</option>
                <option value="M" selected>M - 15%</option>
                <option value="Q">Q - 25%</option>
                <option value="H">H - 30%</option>
              </select>
            </div>
          </div>

          <button class="btn-primary" id="generate-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
            </svg>
            生成二维码
          </button>
        </div>

        <div class="output-section">
          <div class="qr-preview" id="qr-preview">
            <div class="qr-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
              </svg>
              <span>二维码预览</span>
            </div>
          </div>
          <button class="btn-secondary" id="download-btn" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            下载 PNG
          </button>
        </div>
      </div>
    </div>
  <script is:inline>
  (function loadQRTool() {
    var qrInput = document.getElementById('qr-input');
    var qrSize = document.getElementById('qr-size');
    var qrDark = document.getElementById('qr-dark');
    var qrLight = document.getElementById('qr-light');
    var qrLevel = document.getElementById('qr-level');
    var generateBtn = document.getElementById('generate-btn');
    var downloadBtn = document.getElementById('download-btn');
    var qrPreview = document.getElementById('qr-preview');
    var currentDataUrl = '';

    function generateQRCode(text, size, dark, light, level) {
      if (typeof QRCode === 'undefined') {
        qrPreview.innerHTML = '<span class="qr-placeholder" style="color: #e88a6a;">QR 库正在加载，请稍后重试...</span>';
        return;
      }
      var canvas = document.createElement('canvas');
      QRCode.toCanvas(canvas, text, {
        width: size, margin: 2,
        color: { dark: dark, light: light },
        errorCorrectionLevel: level
      }, function(error) {
        if (error) {
          qrPreview.innerHTML = '<span class="qr-placeholder" style="color: #e88a6a;">生成失败: ' + error.message + '</span>';
          return;
        }
        currentDataUrl = canvas.toDataURL('image/png');
        qrPreview.innerHTML = '';
        canvas.style.maxWidth = '100%';
        qrPreview.appendChild(canvas);
        if (downloadBtn) downloadBtn.disabled = false;
      });
    }

    generateBtn.addEventListener('click', function() {
      var text = qrInput.value.trim();
      if (!text) { qrInput.focus(); return; }
      generateQRCode(text, parseInt(qrSize.value || '200'), qrDark.value || '#171412', qrLight.value || '#ffffff', qrLevel.value || 'M');
    });

    downloadBtn.addEventListener('click', function() {
      if (!currentDataUrl) return;
      var a = document.createElement('a');
      a.download = 'qrcode.png';
      a.href = currentDataUrl;
      a.click();
    });

    var debounce;
    qrInput.addEventListener('input', function() {
      clearTimeout(debounce);
      debounce = setTimeout(function() { if (qrInput.value.trim()) generateBtn.click(); }, 300);
    });

    function loadLib() {
      if (window.QRCode) return;
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js';
      s.async = true;
      s.onerror = function() {
        qrPreview.innerHTML = '<span class="qr-placeholder" style="color: #e88a6a;">QR 库加载失败，请刷新重试</span>';
      };
      document.head.appendChild(s);
    }
    loadLib();
  })();
  </script>
  </section>
</Layout>

<style>
  .tool-page {
    min-height: 100vh;
    padding: calc(var(--header-height) + 2rem) 0 4rem;
  }

  .tool-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .tool-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-tertiary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .tool-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .tool-desc {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .tool-main {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .tool-main {
      grid-template-columns: 1fr 280px;
      align-items: start;
    }
  }

  .input-section {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.25rem;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.06);
  }

  .input-group label,
  .option-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .input-group textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(71, 57, 44, 0.15);
    border-radius: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-primary);
    background: var(--bg-secondary);
    resize: vertical;
    font-family: inherit;
  }

  .input-group textarea:focus {
    outline: none;
    border-color: #d97757;
    box-shadow: 0 0 0 3px rgba(217, 119, 87, 0.15);
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .option-group select,
  .option-group input[type="color"] {
    width: 100%;
    padding: 0.6rem 0.8rem;
    border: 1px solid rgba(71, 57, 44, 0.15);
    border-radius: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-primary);
    background: var(--bg-secondary);
  }

  .option-group input[type="color"] {
    height: 42px;
    padding: 4px;
    cursor: pointer;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: #171412;
    color: white;
    border: none;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-primary:hover {
    background: #333;
  }

  .output-section {
    display: grid;
    gap: 1rem;
  }

  .qr-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.25rem;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.06);
  }

  .qr-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }

  #qr-canvas {
    max-width: 100%;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid rgba(71, 57, 44, 0.15);
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-secondary:hover:not(:disabled) {
    background: var(--bg-tertiary);
    border-color: rgba(71, 57, 44, 0.25);
  }

  .btn-secondary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
