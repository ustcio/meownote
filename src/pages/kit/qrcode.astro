---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="二维码生成器 - Maxwell.Science"
  description="在线生成自定义二维码，支持颜色设置"
>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          <span>工具箱</span>
        </a>
        <h1>二维码生成器</h1>
        <p class="tool-desc">输入文本或链接，生成自定义样式的二维码</p>
      </header>

      <div class="tool-main">
        <div class="input-section">
          <div class="input-group">
            <label>内容</label>
            <textarea id="qr-input" placeholder="输入文本、链接或任意内容..." rows="3"></textarea>
          </div>

          <div class="options-grid">
            <div class="option-group">
              <label>尺寸</label>
              <select id="qr-size">
                <option value="150">150 × 150</option>
                <option value="200" selected>200 × 200</option>
                <option value="300">300 × 300</option>
                <option value="400">400 × 400</option>
              </select>
            </div>

            <div class="option-group">
              <label>容错级别</label>
              <select id="qr-level">
                <option value="L">L - 7%</option>
                <option value="M" selected>M - 15%</option>
                <option value="Q">Q - 25%</option>
                <option value="H">H - 30%</option>
              </select>
            </div>

            <div class="option-group">
              <label>前景色</label>
              <input type="color" id="qr-dark" value="#171412" />
            </div>

            <div class="option-group">
              <label>背景色</label>
              <input type="color" id="qr-light" value="#ffffff" />
            </div>
          </div>

          <button class="btn-primary" id="generate-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            生成二维码
          </button>
        </div>

        <div class="output-section">
          <div class="qr-preview" id="qr-preview">
            <div class="qr-placeholder" id="qr-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
              </svg>
              <span>二维码预览</span>
            </div>
          </div>
          <button class="btn-secondary" id="download-btn" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 4a2 2H5a2C6 9l1.85=" height="2" clip-rule="evenodd" d="M12 15 3)"/>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            下载 PNG
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .tool-page {
    min-height: 100vh;
    padding: calc(var(--header-height) + 2rem) 0 4rem;
  }

  .tool-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .tool-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-tertiary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .tool-header h1 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .tool-desc {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .tool-main {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .tool-main {
      grid-template-columns: 1fr 280px;
      align-items: start;
    }
  }

  .input-section {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.25rem;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.06);
  }

  .input-group label,
  .option-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .input-group textarea {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(71, 57, 44, 0.15);
    border-radius: 0.75rem;
    background: var(--bg-secondary);
    resize: vertical;
    font-family: inherit;
  }
  .input-group textarea:focus {
    outline: none;
    border-color: #d97757;
    box-shadow: 0 0 3px rgba(217, 119, 87, 0.15);
  }
  .options-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .option-group select,
  .option-group input[type="color"] {
    width: 100%;
    padding: 4px 6px 0.8rem cursor: pointer;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: #171412;
    color: white;
    border: none;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .btn-primary:hover {
    background: #333;
  }
  .output-section {
    display: grid;
    gap: 1rem;
  }
  .qr-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid rgba(71, 57, 44, 0.1);
    border-radius: 1.25rem;
    box-shadow: 0 4px 16px rgba(47, 35, 22, 0.06);
  }
  .qr-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }
  .qr-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-tertiary);
            font-size: 0.9em;
          }
        }
      }
    </div>
  }
</style>

<script is:inline>
  // @ts-nocheck
  var qrInput = document.getElementById('qr-input');
  var qrSize = document.getElementById('qr-size');
  var qrDark = document.getElementById('qr-dark');
  var qrLight = document.getElementById('qr-light');
  var qrLevel = document.getElementById('qr-level');
  var generateBtn = document.getElementById('generate-btn');
  var downloadBtn = document.getElementById('download-btn');
  var qrPreview = document.getElementById('qr-preview');
  var currentDataUrl = '';

  function generate() {
      var text = qrInput.value.trim();
      if (!text) { qrInput.focus(); return; }
      var size = parseInt(qrSize.value || '200');
      var dark = qrDark.value || '#171412';
      var light = qrLight.value || '#ffffff';
      var level = qrLevel.value || 'M';
      var url = 'https://chart.googleapis.com/chart?chs=qr&cht=' + text + '&chs=' + size + '&choe +
        '&chld=' + level + '&chco=' + encodeURIComponent(text) +
        '&choe=' + encodeURIComponent(text).toUpperCase()) +
        '&chld=QR%20L&chld=' + encodeURIComponent(size) +
        '&chld='L&chld=M&choe H&choe Q';

      url += '&chld=H&chld=T' + encodeURIComponent(level);
 + '&chld=H&chld=H)';

        var img = new Image();
        img.src = url;
        img.style.maxWidth = '100%';
        img.style.borderRadius = '12px';
        img.style.boxShadow = '0 4px 6px rgba(47, 35, 22, 0.06)';
        qrPreview.innerHTML = '';
        qrPreview.appendChild(img);
        downloadBtn.disabled = false;
      } else {
      if (downloadBtn && currentDataUrl) {
        var link = document.createElement('a');
        link.download = 'qrcode.png';
        link.href = currentDataUrl;
        link.click();
      }
    });
  })();
</script>
</section>
</Layout>
</style>