---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '电影票房榜';
const toolDesc = '查看中国电影票房排行';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-tool-content" id="tool-content">
                <div class="hao-tab-buttons" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                  <button id="tab-total" class="hao-press-btn hao-press-btn--primary" data-tab="total">总票房榜</button>
                  <button id="tab-current" class="hao-press-btn hao-press-btn--secondary" data-tab="current">正在热映</button>
                </div>
                <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">加载中...</div>
                <div id="movie-list"></div>
                <div style="margin-top:0.4rem;padding:0.3rem;background:var(--color-background-one);border-radius:15px;font-size:0.22rem;color:var(--color-tm-text);text-align:center;">
                  * 数据仅供参考，实时数据请访问 <a href="https://maoyan.com" target="_blank" style="color:var(--top-color);">猫眼专业版</a>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
