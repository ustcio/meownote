---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '电影票房榜';
const toolDesc = '查看中国电影票房排行';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="tool-content" id="tool-content">
          <div class="tab-buttons" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
            <button id="tab-total" class="btn-primary" data-tab="total">总票房榜</button>
            <button id="tab-current" class="btn-secondary" data-tab="current">正在热映</button>
          </div>
          <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">加载中...</div>
          <div id="movie-list"></div>
          <div style="margin-top:0.4rem;padding:0.3rem;background:var(--color-background-one);border-radius:15px;font-size:0.22rem;color:var(--color-tm-text);text-align:center;">
            * 数据仅供参考，实时数据请访问 <a href="https://maoyan.com" target="_blank" style="color:var(--top-color);">猫眼专业版</a>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabTotal = document.getElementById('tab-total');
    const tabCurrent = document.getElementById('tab-current');
    const movieList = document.getElementById('movie-list');
    const loading = document.getElementById('loading');

    const totalBoxOffice = [
      { rank: 1, name: '长津湖', boxOffice: '57.75亿', total: '57.75亿', rating: 9.5, year: 2021, poster: '🎬' },
      { rank: 2, name: '战狼2', boxOffice: '56.94亿', total: '56.94亿', rating: 9.7, year: 2017, poster: '🎬' },
      { rank: 3, name: '你好，李焕英', boxOffice: '54.13亿', total: '54.13亿', rating: 9.5, year: 2021, poster: '🎬' },
      { rank: 4, name: '哪吒之魔童降世', boxOffice: '50.35亿', total: '50.35亿', rating: 9.6, year: 2019, poster: '🎬' },
      { rank: 5, name: '流浪地球', boxOffice: '46.87亿', total: '46.87亿', rating: 9.3, year: 2019, poster: '🎬' },
      { rank: 6, name: '满江红', boxOffice: '45.44亿', total: '45.44亿', rating: 9.0, year: 2023, poster: '🎬' },
      { rank: 7, name: '流浪地球2', boxOffice: '40.29亿', total: '40.29亿', rating: 9.4, year: 2023, poster: '🎬' },
      { rank: 8, name: '复仇者联盟4', boxOffice: '42.50亿', total: '42.50亿', rating: 9.4, year: 2019, poster: '🎬' },
      { rank: 9, name: '长津湖之水门桥', boxOffice: '40.67亿', total: '40.67亿', rating: 9.2, year: 2022, poster: '🎬' },
      { rank: 10, name: '唐人街探案3', boxOffice: '45.24亿', total: '45.24亿', rating: 8.5, year: 2021, poster: '🎬' }
    ];

    const currentMovies = [
      { rank: 1, name: '哪吒之魔童闹海', boxOffice: '2.5亿', total: '150亿', rating: 9.7, year: 2025, poster: '🎬' },
      { rank: 2, name: '唐探1900', boxOffice: '1.8亿', total: '35亿', rating: 9.0, year: 2025, poster: '🎬' },
      { rank: 3, name: '封神第二部', boxOffice: '1.2亿', total: '28亿', rating: 9.1, year: 2025, poster: '🎬' },
      { rank: 4, name: '蛟龙行动', boxOffice: '0.8亿', total: '12亿', rating: 8.5, year: 2025, poster: '🎬' },
      { rank: 5, name: '熊出没·重启未来', boxOffice: '0.6亿', total: '20亿', rating: 8.8, year: 2025, poster: '🎬' },
      { rank: 6, name: '射雕英雄传', boxOffice: '0.4亿', total: '8亿', rating: 8.2, year: 2025, poster: '🎬' }
    ];

    function renderMovies(movies, showTotal) {
      movieList.innerHTML = movies.map(m => `
        <div class="result-area" style="margin-bottom:0.3rem;">
          <div style="display:flex;align-items:center;gap:0.3rem;">
            <div style="font-size:0.6rem;width:0.8rem;text-align:center;">
              ${m.rank <= 3 ? ['🥇','🥈','🥉'][m.rank - 1] : `<span style="color:var(--color-tm-text);font-size:0.3rem;">${m.rank}</span>`}
            </div>
            <div style="font-size:0.5rem;">${m.poster}</div>
            <div style="flex:1;">
              <div style="font-size:0.35rem;font-weight:500;color:var(--font-color-solid);">${m.name}</div>
              <div style="font-size:0.22rem;color:var(--color-tm-text);margin-top:0.1rem;">${m.year}年 · 评分 ${m.rating}</div>
            </div>
            <div style="text-align:right;">
              <div style="font-size:0.35rem;font-weight:500;color:var(--top-color);">${showTotal ? m.total : m.boxOffice}</div>
              <div style="font-size:0.22rem;color:var(--color-tm-text);">${showTotal ? '总票房' : '日票房'}</div>
            </div>
          </div>
        </div>`).join('');
    }

    tabTotal.addEventListener('click', () => {
      tabTotal.className = 'btn-primary'; tabCurrent.className = 'btn-secondary';
      renderMovies(totalBoxOffice, true);
    });
    tabCurrent.addEventListener('click', () => {
      tabCurrent.className = 'btn-primary'; tabTotal.className = 'btn-secondary';
      renderMovies(currentMovies, false);
    });

    renderMovies(totalBoxOffice, true);
  });
</script>
