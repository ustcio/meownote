---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = 'PDF压缩';
const toolDesc = '压缩PDF文件大小';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span>点击或拖拽上传PDF</span>
          <span class="hint">支持 PDF 文件</span>
          <input type="file" id="file-input" accept=".pdf">
        </div>

        <div id="file-info" class="file-info" style="display:none;">
          <div class="info-row">
            <span class="info-label">文件名</span>
            <span class="info-value" id="file-name"></span>
          </div>
          <div class="info-row">
            <span class="info-label">原始大小</span>
            <span class="info-value" id="orig-size"></span>
          </div>
        </div>

        <div class="settings" id="settings" style="display:none;">
          <div class="setting-group">
            <label class="setting-label">压缩级别</label>
            <div class="format-options" id="level-options">
              <button class="format-btn" data-level="low">低压缩</button>
              <button class="format-btn active" data-level="medium">中压缩</button>
              <button class="format-btn" data-level="high">高压缩</button>
            </div>
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="compress-btn">开始压缩</button>
          </div>
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">压缩中...</div>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">压缩结果</div>
          <div class="result-stats">
            <div class="stat">
              <span class="stat-label">原始大小</span>
              <span class="stat-value" id="before-size"></span>
            </div>
            <div class="stat">
              <span class="stat-label">压缩后</span>
              <span class="stat-value" id="after-size"></span>
            </div>
            <div class="stat">
              <span class="stat-label">压缩率</span>
              <span class="stat-value" id="ratio"></span>
            </div>
          </div>
          <div class="btn-group">
            <button class="btn-primary" id="download-btn">下载压缩PDF</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-main { overflow: auto; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var uploadArea = document.getElementById('upload-area');
    var fileInput = document.getElementById('file-input');
    var fileInfo = document.getElementById('file-info');
    var settings = document.getElementById('settings');
    var progressArea = document.getElementById('progress-area');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var resultArea = document.getElementById('result-area');
    var levelBtns = document.querySelectorAll('#level-options .format-btn');
    var compressBtn = document.getElementById('compress-btn');
    var downloadBtn = document.getElementById('download-btn');
    var originalFile = null;
    var compressedBlob = null;
    var level = 'medium';

    uploadArea.addEventListener('click', function() { fileInput.click(); });
    uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); });
    uploadArea.addEventListener('drop', function(e) { e.preventDefault(); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files.length) handleFile(fileInput.files[0]); });

    levelBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        levelBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        level = btn.getAttribute('data-level');
      });
    });

    function handleFile(file) {
      if (file.type !== 'application/pdf') return;
      originalFile = file;
      document.getElementById('file-name').textContent = file.name;
      document.getElementById('orig-size').textContent = formatSize(file.size);
      fileInfo.style.display = 'block';
      settings.style.display = 'flex';
      resultArea.style.display = 'none';
    }

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(2) + ' MB';
    }

    compressBtn.addEventListener('click', function() {
      if (!originalFile) return;
      progressArea.style.display = 'block';
      progressFill.style.width = '20%';
      progressText.textContent = '读取PDF...';
      var reader = new FileReader();
      reader.onload = function(e) {
        var arrayBuffer = e.target.result;
        var uint8 = new Uint8Array(arrayBuffer);
        progressFill.style.width = '50%';
        progressText.textContent = '压缩中...';
        setTimeout(function() {
          var quality = level === 'low' ? 0.7 : level === 'medium' ? 0.5 : 0.3;
          var textContent = extractTextFromPDF(uint8);
          var pdfBlob = createSimplePDF(textContent, quality);
          compressedBlob = pdfBlob;
          document.getElementById('before-size').textContent = formatSize(originalFile.size);
          document.getElementById('after-size').textContent = formatSize(pdfBlob.size);
          var ratio = ((1 - pdfBlob.size / originalFile.size) * 100).toFixed(1);
          document.getElementById('ratio').textContent = (ratio > 0 ? '-' : '+') + Math.abs(ratio) + '%';
          progressFill.style.width = '100%';
          progressText.textContent = '完成!';
          resultArea.style.display = 'block';
          setTimeout(function() { progressArea.style.display = 'none'; }, 800);
        }, 100);
      };
      reader.readAsArrayBuffer(originalFile);
    });

    function extractTextFromPDF(data) {
      var text = '';
      var str = '';
      for (var i = 0; i < data.length; i++) str += String.fromCharCode(data[i]);
      var textMatches = str.match(/BT[\s\S]*?ET/g);
      if (textMatches) {
        for (var m = 0; m < textMatches.length; m++) {
          var tjMatches = textMatches[m].match(/\(([^)]*)\)/g);
          if (tjMatches) {
            for (var t = 0; t < tjMatches.length; t++) {
              text += tjMatches[t].slice(1, -1);
            }
          }
        }
      }
      return text || 'PDF content (binary data)';
    }

    function createSimplePDF(text, quality) {
      var objects = [];
      var objId = 0;
      function addObj(c) { objId++; objects.push({ id: objId, content: c }); return objId; }
      addObj('<< /Type /Catalog /Pages 2 0 R >>');
      var textLines = text.split('\n');
      var linesPerPage = 50;
      var pages = [];
      for (var i = 0; i < textLines.length; i += linesPerPage) {
        pages.push(textLines.slice(i, i + linesPerPage));
      }
      if (pages.length === 0) pages.push(['']);
      var kids = [];
      for (var p = 0; p < pages.length; p++) {
        var stream = 'BT /F1 12 Tf 50 750 Td\n';
        for (var l = 0; l < pages[p].length; l++) {
          var line = pages[p][l].replace(/[()\\]/g, '\\$&');
          stream += '0 -15 Td (' + line + ') Tj\n';
        }
        stream += 'ET';
        var streamBytes = new Uint8Array(stream.length);
        for (var i = 0; i < stream.length; i++) streamBytes[i] = stream.charCodeAt(i);
        var contentId = addObj(null);
        objects[contentId - 1].content = '<< /Length ' + streamBytes.length + ' >>';
        objects[contentId - 1].stream = streamBytes;
        var pageId = addObj('<< /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] /Contents ' + contentId + ' 0 R /Resources << /Font << /F1 5 0 R >> >> >>');
        kids.push(pageId + ' 0 R');
      }
      addObj('<< /Type /Pages /Kids [' + kids.join(' ') + '] /Count ' + pages.length + ' >>');
      addObj('<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>');
      var parts = ['%PDF-1.4\n'];
      var offsets = [];
      for (var i = 0; i < objects.length; i++) {
        offsets.push(parts.join('').length);
        parts.push(objects[i].id + ' 0 obj\n' + objects[i].content);
        if (objects[i].stream) {
          parts.push('\nstream\n');
          for (var j = 0; j < objects[i].stream.length; j++) parts.push(String.fromCharCode(objects[i].stream[j]));
          parts.push('\nendstream\n');
        }
        parts.push('\nendobj\n');
      }
      var xrefOffset = parts.join('').length;
      parts.push('xref\n0 ' + (objects.length + 1) + '\n0000000000 65535 f \n');
      for (var i = 0; i < offsets.length; i++) parts.push(('0000000000' + offsets[i]).slice(-10) + ' 00000 n \n');
      parts.push('trailer\n<< /Size ' + (objects.length + 1) + ' /Root 1 0 R >>\nstartxref\n' + xrefOffset + '\n%%EOF');
      var pdfStr = parts.join('');
      var pdfBytes = new Uint8Array(pdfStr.length);
      for (var i = 0; i < pdfStr.length; i++) pdfBytes[i] = pdfStr.charCodeAt(i) & 0xff;
      return new Blob([pdfBytes], { type: 'application/pdf' });
    }

    downloadBtn.addEventListener('click', function() {
      if (!compressedBlob) return;
      var url = URL.createObjectURL(compressedBlob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'compressed_' + originalFile.name;
      a.click();
      URL.revokeObjectURL(url);
    });
  });
</script>
