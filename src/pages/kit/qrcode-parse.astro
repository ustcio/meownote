---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '二维码解析';
const toolDesc = '解析二维码图片内容';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="upload-area" id="upload-area">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <span>点击或拖拽上传二维码图片</span>
          <span class="hint">支持 PNG, JPG 格式的二维码</span>
          <input type="file" id="file-input" accept="image/*">
        </div>

        <div class="progress-area" id="progress-area" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">解析中...</div>
        </div>

        <div class="result-area" id="result-area" style="display:none;">
          <div class="result-header">解析结果</div>
          <div class="result-stats">
            <div class="stat">
              <span class="stat-label">内容类型</span>
              <span class="stat-value" id="content-type"></span>
            </div>
            <div class="stat">
              <span class="stat-label">内容长度</span>
              <span class="stat-value" id="content-length"></span>
            </div>
          </div>
          <div id="qr-result" style="background:var(--color-background-one);border-radius:10px;padding:0.3rem;margin-bottom:0.3rem;word-break:break-all;font-size:0.28rem;color:var(--color-text);max-height:200px;overflow:auto;"></div>
          <div class="btn-group">
            <button class="btn-primary" id="copy-btn">复制到剪贴板</button>
            <button class="btn-secondary" id="open-btn">打开链接</button>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<style>
  .tool-main { overflow: auto; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var uploadArea = document.getElementById('upload-area');
    var fileInput = document.getElementById('file-input');
    var progressArea = document.getElementById('progress-area');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var resultArea = document.getElementById('result-area');
    var qrResult = document.getElementById('qr-result');
    var contentType = document.getElementById('content-type');
    var contentLength = document.getElementById('content-length');
    var copyBtn = document.getElementById('copy-btn');
    var openBtn = document.getElementById('open-btn');
    var decodedContent = '';

    uploadArea.addEventListener('click', function() { fileInput.click(); });
    uploadArea.addEventListener('dragover', function(e) { e.preventDefault(); });
    uploadArea.addEventListener('drop', function(e) { e.preventDefault(); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
    fileInput.addEventListener('change', function() { if (fileInput.files.length) handleFile(fileInput.files[0]); });

    function handleFile(file) {
      if (!file.type.startsWith('image/')) return;
      progressArea.style.display = 'block';
      progressFill.style.width = '20%';
      progressText.textContent = '分析二维码...';
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          progressFill.style.width = '50%';
          progressText.textContent = '检测定位图案...';
          setTimeout(function() {
            var canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            var ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0);
            var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            var result = decodeQR(imageData, canvas.width, canvas.height);
            if (result) {
              decodedContent = result;
              displayResult(result);
            } else {
              progressText.textContent = '未检测到有效二维码';
              setTimeout(function() { progressArea.style.display = 'none'; }, 2000);
            }
          }, 100);
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    function decodeQR(imageData, w, h) {
      var data = imageData.data;
      var gray = new Uint8Array(w * h);
      for (var i = 0; i < w * h; i++) {
        gray[i] = Math.round(0.299 * data[i*4] + 0.587 * data[i*4+1] + 0.114 * data[i*4+2]);
      }
      var threshold = 128;
      var sum = 0;
      var step = Math.max(1, Math.floor(gray.length / 10000));
      for (var i = 0; i < gray.length; i += step) sum += gray[i];
      threshold = Math.round(sum / (gray.length / step));

      var binary = new Uint8Array(w * h);
      for (var i = 0; i < w * h; i++) binary[i] = gray[i] < threshold ? 1 : 0;

      var finderPatterns = findFinderPatterns(binary, w, h);
      if (finderPatterns.length < 2) return null;

      var text = extractDataFromQR(binary, w, h, finderPatterns);
      return text || 'QR code detected but content could not be fully decoded. Image may be damaged.';
    }

    function findFinderPatterns(binary, w, h) {
      var patterns = [];
      var ratio = [1, 1, 3, 1, 1];
      for (var y = 0; y < h; y++) {
        for (var x = 0; x < w - 6; x++) {
          if (isFinderPatternRow(binary, w, x, y)) {
            var cx = x + 3, cy = y;
            var found = false;
            for (var p = 0; p < patterns.length; p++) {
              if (Math.abs(patterns[p].x - cx) < 5 && Math.abs(patterns[p].y - cy) < 5) { found = true; break; }
            }
            if (!found) patterns.push({ x: cx, y: cy });
          }
        }
      }
      return patterns.slice(0, 3);
    }

    function isFinderPatternRow(binary, w, x, y) {
      var runs = [];
      var current = binary[y * w + x];
      var count = 1;
      for (var i = 1; i < 7 && x + i < w; i++) {
        if (binary[y * w + x + i] === current) count++;
        else { runs.push(count); count = 1; current = binary[y * w + x + i]; }
      }
      runs.push(count);
      if (runs.length !== 5) return false;
      var total = 0;
      for (var i = 0; i < 5; i++) total += runs[i];
      var moduleSize = total / 7;
      for (var i = 0; i < 5; i++) {
        if (Math.abs(runs[i] - ratio[i] * moduleSize) > moduleSize * 0.5) return false;
      }
      return true;
    }

    function extractDataFromQR(binary, w, h, patterns) {
      var moduleSize = 7;
      if (patterns.length >= 2) {
        var dx = patterns[1].x - patterns[0].x;
        var dy = patterns[1].y - patterns[0].y;
        var dist = Math.sqrt(dx * dx + dy * dy);
        moduleSize = Math.round(dist / 7);
      }
      if (moduleSize < 2) moduleSize = 7;
      var startX = patterns[0].x - 3 * moduleSize;
      var startY = patterns[0].y - 3 * moduleSize;
      var version = Math.round((w / moduleSize - 17) / 4);
      if (version < 1 || version > 40) version = 2;
      var size = 17 + version * 4;
      var modules = [];
      for (var y = 0; y < size; y++) {
        modules[y] = [];
        for (var x = 0; x < size; x++) {
          var px = Math.round(startX + x * moduleSize);
          var py = Math.round(startY + y * moduleSize);
          if (px >= 0 && px < w && py >= 0 && py < h) {
            modules[y][x] = binary[py * w + px];
          } else {
            modules[y][x] = 0;
          }
        }
      }
      var bits = '';
      for (var y = 0; y < size; y++) {
        for (var x = 0; x < size; x++) {
          if (!isFunctionPattern(x, y, size)) {
            bits += modules[y][x] ? '1' : '0';
          }
        }
      }
      var result = '';
      for (var i = 0; i < bits.length - 7; i += 8) {
        var byte = 0;
        for (var b = 0; b < 8; b++) byte = (byte << 1) | parseInt(bits[i + b]);
        if (byte === 0) break;
        if (byte >= 32 && byte < 127) result += String.fromCharCode(byte);
        else if (byte === 10 || byte === 13) result += '\n';
      }
      return result;
    }

    function isFunctionPattern(x, y, size) {
      if (x < 8 && y < 8) return true;
      if (x >= size - 7 && y < 8) return true;
      if (x < 8 && y >= size - 7) return true;
      if (size >= 2) {
        if (x >= size - 11 && x < size - 4 && y >= size - 11 && y < size - 4) return true;
      }
      if (size >= 2 && y === 6) {
        var ax = size - 9;
        if (x >= ax - 2 && x <= ax + 2) return true;
      }
      if (size >= 2 && x === 6) {
        var ay = size - 9;
        if (y >= ay - 2 && y <= ay + 2) return true;
      }
      return false;
    }

    function displayResult(text) {
      qrResult.textContent = text;
      contentLength.textContent = text.length;
      if (text.match(/^https?:\/\//i)) {
        contentType.textContent = 'URL';
        openBtn.style.display = 'inline-flex';
      } else if (text.match(/^mailto:/i)) {
        contentType.textContent = 'Email';
        openBtn.style.display = 'inline-flex';
      } else if (text.match(/^tel:/i)) {
        contentType.textContent = 'Phone';
        openBtn.style.display = 'inline-flex';
      } else if (text.match(/^WIFI:/i)) {
        contentType.textContent = 'WiFi';
        openBtn.style.display = 'none';
      } else {
        contentType.textContent = 'Text';
        openBtn.style.display = 'none';
      }
      progressFill.style.width = '100%';
      progressText.textContent = '完成!';
      resultArea.style.display = 'block';
      setTimeout(function() { progressArea.style.display = 'none'; }, 800);
    }

    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(decodedContent).then(function() {
        copyBtn.textContent = '已复制!';
        setTimeout(function() { copyBtn.textContent = '复制到剪贴板'; }, 2000);
      });
    });

    openBtn.addEventListener('click', function() {
      if (decodedContent.match(/^https?:\/\//i)) window.open(decodedContent, '_blank');
      else if (decodedContent.match(/^mailto:/i)) window.location.href = decodedContent;
      else if (decodedContent.match(/^tel:/i)) window.location.href = decodedContent;
    });
  });
</script>
