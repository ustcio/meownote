---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'SVG预览';
const toolDesc = '预览和编辑SVG代码';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-4);">
                  <div class="hao-form-group">
                    <label class="hao-label" for="svg-input">SVG代码</label>
                    <textarea id="svg-input" class="hao-input" style="min-height:400px;" placeholder='<svg width="100" height="100">&#10;  <circle cx="50" cy="50" r="40" fill="#D97757"/>&#10;</svg>'></textarea>
                  </div>
                  <div class="hao-form-group">
                    <label class="hao-label">预览</label>
                    <div id="preview" style="padding:var(--space-4);background:var(--bg-primary);border:1px solid var(--border-primary);border-radius:var(--radius-lg);min-height:400px;display:flex;align-items:center;justify-content:center;"></div>
                  </div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
    const svgInput = document.getElementById('svg-input');
    const preview = document.getElementById('preview');

    svgInput.addEventListener('input', () => {
      preview.innerHTML = svgInput.value;
    });
  });
</script>
