---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'GIF编辑';
const toolDesc = '编辑GIF动图的帧和播放设置';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传GIF</span>
                <span class="hint">支持 GIF 文件</span>
                <input type="file" id="file-input" accept=".gif">
              </div>

              <div id="file-info" class="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">帧数</span>
                  <span class="info-value" id="frame-count"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">帧延迟: <span id="delay-value">10</span> (1/100s)</label>
                  <input type="range" id="delay" min="2" max="100" value="10" style="width:100%;">
                </div>
                <div class="setting-group">
                  <label class="setting-label">循环次数 (0=无限)</label>
                  <input type="number" id="loop-count" value="0" min="0" max="100" class="setting-select" style="width:4rem;">
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="save-btn">保存GIF</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="add-frame-btn">添加帧</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">处理中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">帧列表</div>
                <div id="frame-list" style="display:flex;gap:0.2rem;flex-wrap:wrap;margin-top:0.2rem;"></div>
                <div class="hao-btn-group" style="margin-top:0.3rem;">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载GIF</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
