---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '手机号码归属地查询';
const toolDesc = '查询中国大陆手机号码归属地信息';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div class="input-group" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                  <input id="phone-input" type="text" class="hao-input" placeholder="输入11位手机号码" maxlength="11" style="flex:1;padding:0.3rem 0.4rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:15px;color:var(--color-text);font-size:0.28rem;outline:none;">
                  <button id="query-btn" class="hao-press-btn hao-press-btn--primary">查询</button>
                </div>
                <div id="error" style="display:none;text-align:center;padding:1rem;color:#ff6b6b;"></div>
                <div id="hao-result" class="hao-result" style="display:none;">
                  <div class="result-header">查询结果</div>
                  <div class="file-info" id="result-info"></div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
