      }
      tableContainer.innerHTML = `<table style="width:100%;border-collapse:collapse;font-size:0.28rem;">
        <thead><tr style="border-bottom:2px solid var(--color-border);">
          <th style="padding:0.2rem;text-align:left;color:var(--color-tm-text);">城市</th>
