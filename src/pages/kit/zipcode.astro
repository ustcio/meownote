    function renderTable(data) {
      countInfo.textContent = `共 ${data.length} 条记录`;
      if (data.length === 0) {
        tableContainer.innerHTML = '<div style="text-align:center;padding:1rem;color:var(--color-tm-text);">无匹配结果</div>';
