        </tr>`).join('')}</tbody></table>`;
    }

    searchInput.addEventListener('input', () => {
      const keyword = searchInput.value.trim().toLowerCase();
      if (!keyword) { renderTable(zipData); return; }
      const filtered = zipData.filter(d =>
        d.city.includes(keyword) || d.district.includes(keyword) || d.code.includes(keyword)
      );
      renderTable(filtered);
    });

