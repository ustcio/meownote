---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '全球IP查询';
const toolDesc = '查询IP地址归属地信息';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="tool-content" id="tool-content">
          <div class="input-group" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;flex-wrap:wrap;">
            <input id="ip-input" type="text" class="form-input" placeholder="输入IP地址，如 8.8.8.8" style="flex:1;min-width:200px;padding:0.3rem 0.4rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:15px;color:var(--color-text);font-size:0.28rem;outline:none;">
            <button id="query-btn" class="btn-primary">查询</button>
            <button id="my-ip-btn" class="btn-secondary">查询我的IP</button>
          </div>
          <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">查询中...</div>
          <div id="error" style="display:none;text-align:center;padding:1rem;color:#ff6b6b;"></div>
          <div id="result-area" class="result-area" style="display:none;">
            <div class="result-header">查询结果</div>
            <div class="file-info" id="result-info"></div>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const ipInput = document.getElementById('ip-input');
    const queryBtn = document.getElementById('query-btn');
    const myIpBtn = document.getElementById('my-ip-btn');
    const loading = document.getElementById('loading');
    const error = document.getElementById('error');
    const resultArea = document.getElementById('result-area');
    const resultInfo = document.getElementById('result-info');

    function showInfo(data) {
      const fields = [
        ['IP 地址', data.ip],
        ['城市', data.city],
        ['地区', data.region],
        ['国家', data.country_name],
        ['运营商', data.org],
        ['经度', data.longitude],
        ['纬度', data.latitude],
        ['时区', data.timezone]
      ];
      resultInfo.innerHTML = fields.map(([label, value]) =>
        `<div class="info-row"><span class="info-label">${label}</span><span class="info-value">${value || '-'}</span></div>`
      ).join('');
      resultArea.style.display = 'block';
    }

    async function queryIP(ip) {
      loading.style.display = 'block';
      error.style.display = 'none';
      resultArea.style.display = 'none';
      try {
        const res = await fetch(`https://ipapi.co/${ip}/json/`);
        if (!res.ok) throw new Error('查询失败');
        const data = await res.json();
        if (data.error) throw new Error(data.reason || '查询失败');
        showInfo(data);
      } catch (e) {
        try {
          const res = await fetch(`https://ip-api.com/json/${ip}`);
          const data = await res.json();
          if (data.status === 'fail') throw new Error(data.message);
          showInfo({
            ip: data.query,
            city: data.city,
            region: data.regionName,
            country_name: data.country,
            org: data.isp,
            longitude: data.lon,
            latitude: data.lat,
            timezone: data.timezone
          });
        } catch (e2) {
          error.textContent = '查询失败: ' + e2.message;
          error.style.display = 'block';
        }
      } finally {
        loading.style.display = 'none';
      }
    }

    queryBtn.addEventListener('click', () => {
      const ip = ipInput.value.trim();
      if (!ip) { error.textContent = '请输入IP地址'; error.style.display = 'block'; return; }
      queryIP(ip);
    });

    myIpBtn.addEventListener('click', () => queryIP(''));

    ipInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') queryBtn.click(); });
  });
</script>
