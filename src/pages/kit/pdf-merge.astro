---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'PDF合并';
const toolDesc = '合并多个PDF文件为一个';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传多个PDF</span>
                <span class="hint">按上传顺序合并</span>
                <input type="file" id="file-input" accept=".pdf" multiple>
              </div>

              <div id="file-list" class="file-info" style="display:none;">
                <div class="result-header">已上传文件 (<span id="file-count">0</span>个)</div>
                <div id="file-items" style="margin-top:0.2rem;"></div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="merge-btn">合并PDF</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重置</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">合并中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">合并完成</div>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">文件数</span>
                    <span class="stat-value" id="merged-count"></span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">总大小</span>
                    <span class="stat-value" id="merged-size"></span>
                  </div>
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载合并PDF</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
