---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '图片拼接';
const toolDesc = '将多张图片水平或垂直拼接';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传多张图片</span>
                <span class="hint">支持 PNG, JPG, WebP 格式，可多选</span>
                <input type="file" id="file-input" accept="image/*" multiple>
              </div>

              <div id="image-list" class="file-info" style="display:none;">
                <div class="result-header">已上传图片 (<span id="image-count">0</span>张)</div>
                <div id="thumbnails" style="display:flex;gap:0.2rem;flex-wrap:wrap;margin-top:0.2rem;"></div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">拼接方向</label>
                  <div class="format-options" id="direction-options">
                    <button class="format-btn active" data-dir="horizontal">水平拼接</button>
                    <button class="format-btn" data-dir="vertical">垂直拼接</button>
                  </div>
                </div>
                <div class="setting-group">
                  <label class="setting-label">间距: <span id="spacing-value">0</span>px</label>
                  <input type="range" id="spacing" min="0" max="50" value="0" style="width:100%;">
                </div>
                <div class="setting-group">
                  <label class="setting-label">背景颜色</label>
                  <input type="color" id="bg-color" value="#000000" style="width:3rem;height:2rem;border:none;cursor:pointer;">
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="stitch-btn">开始拼接</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="reset-btn">重置</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">处理中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">拼接结果</div>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">输出尺寸</span>
                    <span class="stat-value" id="output-size"></span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">图片数量</span>
                    <span class="stat-value" id="stitch-count"></span>
                  </div>
                </div>
                <canvas id="result-canvas" style="width:100%;border-radius:10px;"></canvas>
                <div class="hao-btn-group" style="margin-top:0.3rem;">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载图片</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
