---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '天气预报';
const toolDesc = '查看全球城市天气预报';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div class="input-group" style="display:flex;gap:0.2rem;margin-bottom:0.4rem;">
                  <input id="city-input" type="text" class="hao-input" placeholder="输入城市名称，如 Beijing" style="flex:1;padding:0.3rem 0.4rem;background:var(--color-background-one);border:1px solid var(--color-border);border-radius:15px;color:var(--color-text);font-size:0.28rem;outline:none;">
                  <button id="search-btn" class="hao-press-btn hao-press-btn--primary">搜索</button>
                </div>
                <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">查询中...</div>
                <div id="error" style="display:none;text-align:center;padding:1rem;color:#ff6b6b;"></div>
                <div id="hao-result" style="display:none;">
                  <div id="current-weather" class="hao-result" style="margin-bottom:0.4rem;"></div>
                  <div class="result-header">未来3天预报</div>
                  <div id="forecast" style="display:flex;gap:0.3rem;flex-wrap:wrap;"></div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
