---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="颜色转换器 - Maxwell.Science"
  description="HEX、RGB、HSL 颜色格式互转工具"
>
  <section class="color-tool">
    <div class="container">
      <header class="header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span>工具箱</span>
        </a>
        <h1 class="title">颜色转换器</h1>
        <p class="desc">HEX、RGB、HSL 颜色格式互转</p>
      </header>

      <!-- Preview -->
      <div class="card preview-card">
        <div class="color-preview" id="color-preview" style="background: #d97757;"></div>
        <input type="color" id="native-picker" value="#d97757" />
      </div>

      <!-- Formats -->
      <div class="card">
        <div class="format-row">
          <div class="format-group">
            <label class="lbl">HEX</label>
            <div class="input-row">
              <input type="text" id="hex-input" value="#d97757" spellcheck="false" />
              <button class="copy-sm" data-copy="hex-input">复制</button>
            </div>
          </div>
        </div>

        <div class="format-row">
          <div class="format-group">
            <label class="lbl">RGB</label>
            <div class="input-row">
              <input type="text" id="rgb-input" value="rgb(217, 119, 87)" spellcheck="false" />
              <button class="copy-sm" data-copy="rgb-input">复制</button>
            </div>
          </div>
        </div>

        <div class="format-row">
          <div class="format-group">
            <label class="lbl">HSL</label>
            <div class="input-row">
              <input type="text" id="hsl-input" value="hsl(16, 65%, 60%)" spellcheck="false" />
              <button class="copy-sm" data-copy="hsl-input">复制</button>
            </div>
          </div>
        </div>

        <div class="format-row">
          <div class="format-group">
            <label class="lbl">RGBA</label>
            <div class="input-row">
              <input type="text" id="rgba-input" value="rgba(217, 119, 87, 1)" spellcheck="false" />
              <button class="copy-sm" data-copy="rgba-input">复制</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Slider controls -->
      <div class="card">
        <div class="slider-group">
          <label class="lbl">R <span id="r-val">217</span></label>
          <input type="range" id="r-slider" min="0" max="255" value="217" class="slider r-slider" />
        </div>
        <div class="slider-group">
          <label class="lbl">G <span id="g-val">119</span></label>
          <input type="range" id="g-slider" min="0" max="255" value="119" class="slider g-slider" />
        </div>
        <div class="slider-group">
          <label class="lbl">B <span id="b-val">87</span></label>
          <input type="range" id="b-slider" min="0" max="255" value="87" class="slider b-slider" />
        </div>
        <div class="slider-group">
          <label class="lbl">A <span id="a-val">1</span></label>
          <input type="range" id="a-slider" min="0" max="100" value="100" class="slider a-slider" />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .color-tool { min-height: 100vh; padding: calc(var(--header-total-height) + var(--space-4)) var(--space-4) var(--space-16); }
  .container { max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--space-4); }

  .header { margin-bottom: var(--space-4); }
  .back-link { display: inline-flex; align-items: center; gap: var(--space-1); color: var(--text-tertiary); font-size: var(--text-sm); margin-bottom: var(--space-4); }
  .back-link:hover { color: var(--text-secondary); }
  .title { font-size: var(--text-2xl); font-weight: var(--font-bold); color: var(--text-primary); margin-bottom: var(--space-1); }
  .desc { font-size: var(--text-sm); color: var(--text-secondary); }

  .card { background: var(--bg-secondary); border: 1px solid var(--border-primary); border-radius: var(--radius-xl); padding: var(--space-5); }

  .preview-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-4); padding: var(--space-8); }
  .color-preview { width: 120px; height: 120px; border-radius: var(--radius-xl); border: 3px solid var(--border-primary); transition: background-color 0.15s ease; }
  #native-picker { width: 60px; height: 36px; border: none; border-radius: var(--radius-md); cursor: pointer; }

  .format-row { margin-bottom: var(--space-3); }
  .format-group { display: flex; flex-direction: column; gap: var(--space-1); }
  .lbl { font-size: var(--text-xs); color: var(--text-tertiary); font-weight: var(--font-medium); }
  .input-row { display: flex; gap: var(--space-2); }
  .input-row input { flex: 1; padding: var(--space-2) var(--space-3); background: var(--bg-tertiary); border: 1px solid var(--border-primary); border-radius: var(--radius-md); color: var(--text-primary); font-size: var(--text-sm); font-family: var(--font-mono); }
  .input-row input:focus { outline: none; border-color: var(--color-accent-blue); }
  .copy-sm { padding: var(--space-2) var(--space-3); background: var(--bg-tertiary); border: 1px solid var(--border-primary); border-radius: var(--radius-md); font-size: var(--text-xs); color: var(--text-secondary); cursor: pointer; transition: all var(--duration-fast) var(--ease-default); }
  .copy-sm:hover { color: var(--text-primary); border-color: var(--border-hover); }

  .slider-group { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3); }
  .slider-group .lbl { min-width: 48px; text-align: right; }
  .slider { flex: 1; height: 6px; -webkit-appearance: none; appearance: none; border-radius: var(--radius-full); outline: none; }
  .slider::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%; cursor: pointer; border: 2px solid white; box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
  .r-slider { background: linear-gradient(to right, #000, #f00); }
  .r-slider::-webkit-slider-thumb { background: #ef4444; }
  .g-slider { background: linear-gradient(to right, #000, #0f0); }
  .g-slider::-webkit-slider-thumb { background: #22c55e; }
  .b-slider { background: linear-gradient(to right, #000, #00f); }
  .b-slider::-webkit-slider-thumb { background: #3b82f6; }
  .a-slider { background: linear-gradient(to right, transparent, var(--text-primary)); }
  .a-slider::-webkit-slider-thumb { background: var(--text-primary); }
</style>

<script>
  const hexInput = document.getElementById('hex-input') as HTMLInputElement;
  const rgbInput = document.getElementById('rgb-input') as HTMLInputElement;
  const hslInput = document.getElementById('hsl-input') as HTMLInputElement;
  const rgbaInput = document.getElementById('rgba-input') as HTMLInputElement;
  const nativePicker = document.getElementById('native-picker') as HTMLInputElement;
  const colorPreview = document.getElementById('color-preview') as HTMLElement;
  const rSlider = document.getElementById('r-slider') as HTMLInputElement;
  const gSlider = document.getElementById('g-slider') as HTMLInputElement;
  const bSlider = document.getElementById('b-slider') as HTMLInputElement;
  const aSlider = document.getElementById('a-slider') as HTMLInputElement;
  const rVal = document.getElementById('r-val');
  const gVal = document.getElementById('g-val');
  const bVal = document.getElementById('b-val');
  const aVal = document.getElementById('a-val');

  let r = 217, g = 119, b = 87, a = 1;

  function clamp(v: number, min: number, max: number) { return Math.min(max, Math.max(min, v)); }

  function rgbToHex(r: number, g: number, b: number): string {
    return '#' + [r, g, b].map(c => clamp(Math.round(c), 0, 255).toString(16).padStart(2, '0')).join('');
  }

  function hexToRgb(hex: string): [number, number, number] | null {
    const m = hex.replace('#', '').match(/^([0-9a-f]{2})([0-9a-f]{2})([0-9a-f]{2})$/i);
    if (!m) return null;
    return [parseInt(m[1], 16), parseInt(m[2], 16), parseInt(m[3], 16)];
  }

  function rgbToHsl(r: number, g: number, b: number): [number, number, number] {
    r /= 255; g /= 255; b /= 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h = 0, s = 0;
    const l = (max + min) / 2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
      else if (max === g) h = ((b - r) / d + 2) / 6;
      else h = ((r - g) / d + 4) / 6;
    }
    return [Math.round(h * 360), Math.round(s * 100), Math.round(l * 100)];
  }

  function updateAll(source: string) {
    const hex = rgbToHex(r, g, b);
    const [h, s, l] = rgbToHsl(r, g, b);
    const rgb = `rgb(${r}, ${g}, ${b})`;
    const hsl = `hsl(${h}, ${s}%, ${l}%)`;
    const rgbaVal = `rgba(${r}, ${g}, ${b}, ${a})`;

    if (source !== 'hex') hexInput.value = hex;
    if (source !== 'rgb') rgbInput.value = rgb;
    if (source !== 'hsl') hslInput.value = hsl;
    if (source !== 'rgba') rgbaInput.value = rgbaVal;

    if (source !== 'slider') {
      rSlider.value = r.toString();
      gSlider.value = g.toString();
      bSlider.value = b.toString();
      aSlider.value = Math.round(a * 100).toString();
    }

    rVal!.textContent = r.toString();
    gVal!.textContent = g.toString();
    bVal!.textContent = b.toString();
    aVal!.textContent = a.toFixed(2);

    colorPreview.style.backgroundColor = rgbaVal;
    nativePicker.value = hex;
  }

  // Slider events
  [rSlider, gSlider, bSlider, aSlider].forEach(slider => {
    slider.addEventListener('input', () => {
      r = parseInt(rSlider.value);
      g = parseInt(gSlider.value);
      b = parseInt(bSlider.value);
      a = parseInt(aSlider.value) / 100;
      updateAll('slider');
    });
  });

  // Native color picker
  nativePicker.addEventListener('input', () => {
    const rgb = hexToRgb(nativePicker.value);
    if (rgb) {
      [r, g, b] = rgb;
      updateAll('picker');
    }
  });

  // Text input events
  hexInput.addEventListener('input', () => {
    const rgb = hexToRgb(hexInput.value);
    if (rgb) { [r, g, b] = rgb; updateAll('hex'); }
  });

  rgbInput.addEventListener('change', () => {
    const m = rgbInput.value.match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
    if (m) { r = clamp(parseInt(m[1]), 0, 255); g = clamp(parseInt(m[2]), 0, 255); b = clamp(parseInt(m[3]), 0, 255); updateAll('rgb'); }
  });

  hslInput.addEventListener('change', () => {
    const m = hslInput.value.match(/(\d+)\s*,\s*(\d+)%?\s*,\s*(\d+)%?/);
    if (m) {
      const [h, s, l] = [parseInt(m[1]), parseInt(m[2]), parseInt(m[3])];
      // HSL to RGB
      const sN = s / 100, lN = l / 100;
      const c = (1 - Math.abs(2 * lN - 1)) * sN;
      const x = c * (1 - Math.abs((h / 60) % 2 - 1));
      const m1 = lN - c / 2;
      let r1 = 0, g1 = 0, b1 = 0;
      if (h < 60) { r1 = c; g1 = x; }
      else if (h < 120) { r1 = x; g1 = c; }
      else if (h < 180) { g1 = c; b1 = x; }
      else if (h < 240) { g1 = x; b1 = c; }
      else if (h < 300) { r1 = x; b1 = c; }
      else { r1 = c; b1 = x; }
      r = Math.round((r1 + m1) * 255);
      g = Math.round((g1 + m1) * 255);
      b = Math.round((b1 + m1) * 255);
      updateAll('hsl');
    }
  });

  // Copy buttons
  document.querySelectorAll('.copy-sm').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.copy;
      if (!targetId) return;
      const input = document.getElementById(targetId) as HTMLInputElement;
      if (input) {
        navigator.clipboard.writeText(input.value);
        btn.textContent = '已复制';
        setTimeout(() => btn.textContent = '复制', 1500);
      }
    });
  });

  updateAll('init');
</script>
