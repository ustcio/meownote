---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';

const toolName = '定位查询';
const toolDesc = '获取当前设备位置信息并反向地理编码';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page">
    <div class="tool-container">
      <header class="tool-header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          返回工具箱
        </a>
        <h1 class="tool-title">{toolName}</h1>
        <p class="tool-description">{toolDesc}</p>
      </header>

      <main class="tool-main">
        <div class="tool-content" id="tool-content">
          <div style="text-align:center;margin-bottom:0.4rem;">
            <button id="locate-btn" class="btn-primary" style="font-size:0.3rem;padding:0.4rem 0.6rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
              </svg>
              获取我的位置
            </button>
          </div>
          <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">正在获取位置...</div>
          <div id="error" style="display:none;text-align:center;padding:1rem;color:#ff6b6b;"></div>
          <div id="result-area" style="display:none;">
            <div class="result-area" style="margin-bottom:0.4rem;">
              <div class="result-header">坐标信息</div>
              <div class="file-info" id="coord-info"></div>
            </div>
            <div class="result-area">
              <div class="result-header">地址信息</div>
              <div class="file-info" id="address-info"></div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </section>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const locateBtn = document.getElementById('locate-btn');
    const loading = document.getElementById('loading');
    const error = document.getElementById('error');
    const resultArea = document.getElementById('result-area');
    const coordInfo = document.getElementById('coord-info');
    const addressInfo = document.getElementById('address-info');

    locateBtn.addEventListener('click', () => {
      if (!navigator.geolocation) {
        error.textContent = '浏览器不支持地理定位';
        error.style.display = 'block';
        return;
      }
      loading.style.display = 'block';
      error.style.display = 'none';
      resultArea.style.display = 'none';

      navigator.geolocation.getCurrentPosition(
        async (pos) => {
          const { latitude, longitude, accuracy, altitude, altitudeAccuracy, heading, speed } = pos.coords;
          coordInfo.innerHTML = `
            <div class="info-row"><span class="info-label">纬度</span><span class="info-value">${latitude.toFixed(6)}</span></div>
            <div class="info-row"><span class="info-label">经度</span><span class="info-value">${longitude.toFixed(6)}</span></div>
            <div class="info-row"><span class="info-label">精度</span><span class="info-value">${accuracy ? accuracy.toFixed(0) + ' 米' : '未知'}</span></div>
            <div class="info-row"><span class="info-label">海拔</span><span class="info-value">${altitude ? altitude.toFixed(1) + ' 米' : '未知'}</span></div>
            <div class="info-row"><span class="info-label">海拔精度</span><span class="info-value">${altitudeAccuracy ? altitudeAccuracy.toFixed(0) + ' 米' : '未知'}</span></div>
            <div class="info-row"><span class="info-label">方向</span><span class="info-value">${heading ? heading.toFixed(0) + '°' : '未知'}</span></div>
            <div class="info-row"><span class="info-label">速度</span><span class="info-value">${speed ? speed.toFixed(1) + ' m/s' : '未知'}</span></div>
            <div class="info-row"><span class="info-label">地图</span><span class="info-value"><a href="https://www.openstreetmap.org/?mlat=${latitude}&mlon=${longitude}#map=17/${latitude}/${longitude}" target="_blank" style="color:var(--top-color);">在地图上查看</a></span></div>`;

          try {
            const res = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${latitude}&lon=${longitude}&format=json&accept-language=zh-CN`);
            const data = await res.json();
            const addr = data.address || {};
            addressInfo.innerHTML = `
              <div class="info-row"><span class="info-label">完整地址</span><span class="info-value">${data.display_name || '未知'}</span></div>
              <div class="info-row"><span class="info-label">国家</span><span class="info-value">${addr.country || '-'}</span></div>
              <div class="info-row"><span class="info-label">省份</span><span class="info-value">${addr.state || '-'}</span></div>
              <div class="info-row"><span class="info-label">城市</span><span class="info-value">${addr.city || addr.town || addr.county || '-'}</span></div>
              <div class="info-row"><span class="info-label">区县</span><span class="info-value">${addr.suburb || addr.county || '-'}</span></div>
              <div class="info-row"><span class="info-label">道路</span><span class="info-value">${addr.road || '-'}</span></div>
              <div class="info-row"><span class="info-label">邮编</span><span class="info-value">${addr.postcode || '-'}</span></div>`;
          } catch (e) {
            addressInfo.innerHTML = `<div style="color:var(--color-tm-text);">反向地理编码失败: ${e.message}</div>`;
          }

          resultArea.style.display = 'block';
          loading.style.display = 'none';
        },
        (err) => {
          loading.style.display = 'none';
          const msgs = { 1: '用户拒绝了定位请求', 2: '无法获取位置信息', 3: '定位请求超时' };
          error.textContent = msgs[err.code] || '定位失败';
          error.style.display = 'block';
        },
        { enableHighAccuracy: true, timeout: 10000 }
      );
    });
  });
</script>
