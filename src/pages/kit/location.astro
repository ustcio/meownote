---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = '定位查询';
const toolDesc = '获取当前设备位置信息并反向地理编码';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
                <div style="text-align:center;margin-bottom:0.4rem;">
                  <button id="locate-btn" class="hao-press-btn hao-press-btn--primary" style="font-size:0.3rem;padding:0.4rem 0.6rem;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="3"></circle>
                      <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
                    </svg>
                    获取我的位置
                  </button>
                </div>
                <div id="loading" style="display:none;text-align:center;padding:1rem;color:var(--color-cale-text);">正在获取位置...</div>
                <div id="error" style="display:none;text-align:center;padding:1rem;color:#ff6b6b;"></div>
                <div id="hao-result" style="display:none;">
                  <div class="hao-result" style="margin-bottom:0.4rem;">
                    <div class="result-header">坐标信息</div>
                    <div class="file-info" id="coord-info"></div>
                  </div>
                  <div class="hao-result">
                    <div class="result-header">地址信息</div>
                    <div class="file-info" id="address-info"></div>
                  </div>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
