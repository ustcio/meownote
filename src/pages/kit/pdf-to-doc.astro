---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'PDF转文档';
const toolDesc = '从PDF中提取文本内容';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="hao-upload-area" id="upload-area">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="17 8 12 3 7 8"></polyline>
                  <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>点击或拖拽上传PDF</span>
                <span class="hint">支持 PDF 文件</span>
                <input type="file" id="file-input" accept=".pdf">
              </div>

              <div id="file-info" class="file-info" style="display:none;">
                <div class="info-row">
                  <span class="info-label">文件名</span>
                  <span class="info-value" id="file-name"></span>
                </div>
                <div class="info-row">
                  <span class="info-label">文件大小</span>
                  <span class="info-value" id="file-size"></span>
                </div>
              </div>

              <div class="settings" id="settings" style="display:none;">
                <div class="setting-group">
                  <label class="setting-label">输出格式</label>
                  <div class="format-options" id="format-options">
                    <button class="format-btn active" data-fmt="txt">TXT</button>
                    <button class="format-btn" data-fmt="doc">DOC</button>
                  </div>
                </div>
                <div class="hao-btn-group">
                  <button class="hao-press-btn hao-press-btn--primary" id="extract-btn">提取文本</button>
                </div>
              </div>

              <div class="progress-area" id="progress-area" style="display:none;">
                <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
                <div class="progress-text" id="progress-text">提取中...</div>
              </div>

              <div class="hao-result" id="hao-result" style="display:none;">
                <div class="result-header">提取结果</div>
                <div class="hao-result-stats">
                  <div class="stat">
                    <span class="stat-label">字符数</span>
                    <span class="stat-value" id="char-count"></span>
                  </div>
                  <div class="stat">
                    <span class="stat-label">行数</span>
                    <span class="stat-value" id="line-count"></span>
                  </div>
                </div>
                <textarea id="extracted-text" readonly style="width:100%;min-height:200px;background:var(--color-background-one);color:var(--color-text);border:1px solid var(--color-border);border-radius:10px;padding:0.3rem;font-size:0.28rem;resize:vertical;font-family:monospace;"></textarea>
                <div class="hao-btn-group" style="margin-top:0.3rem;">
                  <button class="hao-press-btn hao-press-btn--primary" id="download-btn">下载文档</button>
                  <button class="hao-press-btn hao-press-btn--secondary" id="copy-btn">复制文本</button>
                </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
</script>
