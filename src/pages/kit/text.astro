---
import Layout from '@layouts/Layout.astro';
import '@styles/hao-design.css';
---

<Layout
  title="文本工具 - Maxwell.Science"
  description="字数统计、大小写转换、文本差异对比"
>
  <section class="text-tool">
    <div class="container">
      <header class="header">
        <a href="/kit" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span>工具箱</span>
        </a>
        <h1 class="title">文本工具</h1>
        <p class="desc">字数统计、大小写转换、去重、排版</p>
      </header>

      <!-- Input -->
      <div class="card">
        <div class="card-head">
          <span class="card-title">输入文本</span>
          <div class="card-actions">
            <button class="btn-sm" id="paste-btn">粘贴</button>
            <button class="btn-sm" id="clear-btn">清空</button>
          </div>
        </div>
        <textarea id="text-input" rows="8" placeholder="在此输入或粘贴文本..."></textarea>
      </div>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-val" id="stat-chars">0</span>
          <span class="stat-lbl">字符数</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="stat-chars-no-space">0</span>
          <span class="stat-lbl">不含空格</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="stat-words">0</span>
          <span class="stat-lbl">词数</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="stat-lines">0</span>
          <span class="stat-lbl">行数</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="stat-bytes">0</span>
          <span class="stat-lbl">字节数</span>
        </div>
        <div class="stat-card">
          <span class="stat-val" id="stat-chinese">0</span>
          <span class="stat-lbl">中文字数</span>
        </div>
      </div>

      <!-- Transform buttons -->
      <div class="card">
        <div class="card-head">
          <span class="card-title">文本转换</span>
        </div>
        <div class="btn-grid">
          <button class="btn" id="to-upper">转为大写</button>
          <button class="btn" id="to-lower">转为小写</button>
          <button class="btn" id="to-capitalize">首字母大写</button>
          <button class="btn" id="to-title">标题格式</button>
          <button class="btn" id="trim-lines">去除行首尾空格</button>
          <button class="btn" id="remove-blank-lines">删除空行</button>
          <button class="btn" id="remove-dup-lines">去除重复行</button>
          <button class="btn" id="sort-lines">行排序</button>
          <button class="btn" id="reverse-lines">行倒序</button>
          <button class="btn" id="reverse-text">文本反转</button>
          <button class="btn" id="to-fullwidth">全角转换</button>
          <button class="btn" id="to-halfwidth">半角转换</button>
        </div>
      </div>

      <!-- Output -->
      <div class="card">
        <div class="card-head">
          <span class="card-title">转换结果</span>
          <button class="btn-sm" id="copy-output">复制结果</button>
        </div>
        <textarea id="text-output" rows="8" readonly placeholder="转换结果将显示在这里..."></textarea>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Inherits from hao-design.css */
</style>

<script>
  const textInput = document.getElementById('text-input');
  const textOutput = document.getElementById('text-output');

  function updateStats() {
    const text = textInput.value;
    const el = (id: string) => document.getElementById(id);
    el('stat-chars')!.textContent = text.length.toString();
    el('stat-chars-no-space')!.textContent = text.replace(/\s/g, '').length.toString();
    el('stat-words')!.textContent = text.trim() ? text.trim().split(/\s+/).length.toString() : '0';
    el('stat-lines')!.textContent = text ? text.split('\n').length.toString() : '0';
    el('stat-bytes')!.textContent = new Blob([text]).size.toString();
    el('stat-chinese')!.textContent = (text.match(/[\u4e00-\u9fff]/g) || []).length.toString();
  }

  textInput.addEventListener('input', updateStats);

  document.getElementById('paste-btn')?.addEventListener('click', async () => {
    try {
      textInput.value = await navigator.clipboard.readText();
      updateStats();
    } catch {}
  });

  document.getElementById('clear-btn')?.addEventListener('click', () => {
    textInput.value = '';
    textOutput.value = '';
    updateStats();
  });

  function transform(fn: (text: string) => string) {
    textOutput.value = fn(textInput.value);
  }

  document.getElementById('to-upper')?.addEventListener('click', () => transform(t => t.toUpperCase()));
  document.getElementById('to-lower')?.addEventListener('click', () => transform(t => t.toLowerCase()));
  document.getElementById('to-capitalize')?.addEventListener('click', () => transform(t => t.replace(/\b\w/g, c => c.toUpperCase())));
  document.getElementById('to-title')?.addEventListener('click', () => transform(t => t.toLowerCase().replace(/(?:^|\s)\w/g, c => c.toUpperCase())));
  document.getElementById('trim-lines')?.addEventListener('click', () => transform(t => t.split('\n').map(l => l.trim()).join('\n')));
  document.getElementById('remove-blank-lines')?.addEventListener('click', () => transform(t => t.split('\n').filter(l => l.trim()).join('\n')));
  document.getElementById('remove-dup-lines')?.addEventListener('click', () => transform(t => [...new Set(t.split('\n'))].join('\n')));
  document.getElementById('sort-lines')?.addEventListener('click', () => transform(t => t.split('\n').sort().join('\n')));
  document.getElementById('reverse-lines')?.addEventListener('click', () => transform(t => t.split('\n').reverse().join('\n')));
  document.getElementById('reverse-text')?.addEventListener('click', () => transform(t => [...t].reverse().join('')));
  document.getElementById('to-fullwidth')?.addEventListener('click', () => transform(t => t.replace(/[!-~]/g, c => String.fromCharCode(c.charCodeAt(0) + 0xfee0))));
  document.getElementById('to-halfwidth')?.addEventListener('click', () => transform(t => t.replace(/[！-～]/g, c => String.fromCharCode(c.charCodeAt(0) - 0xfee0))));

  document.getElementById('copy-output')?.addEventListener('click', () => {
    const text = textOutput.value;
    if (!text) return;
    navigator.clipboard.writeText(text);
    const btn = document.getElementById('copy-output');
    if (btn) { btn.textContent = '已复制'; setTimeout(() => btn.textContent = '复制结果', 1500); }
  });
</script>
