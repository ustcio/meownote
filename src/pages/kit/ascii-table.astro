---
import Layout from '@layouts/Layout.astro';
import KitToolWrapper from '@components/vue/KitToolWrapper.vue';

const toolName = 'ASCII码表';
const toolDesc = '完整的ASCII字符编码对照表';
---

<Layout title={`${toolName} - 工具箱 - Maxwell.Science`} description={toolDesc}>
  <section class="tool-page-hao">
    <KitToolWrapper title={toolName} description={toolDesc} client:load>
      <div class="tool-content" id="tool-content">
        <div class="search-bar">
          <input type="text" id="search" class="hao-input" placeholder="搜索字符或编码...">
        </div>
        <div class="table-wrapper">
          <table class="data-table" id="data-table">
            <thead>
              <tr><th>十进制</th><th>十六进制</th><th>八进制</th><th>字符</th><th>描述</th></tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
              </div>
    </KitToolWrapper>
  </section>
</Layout>

<style>
  .tool-page-hao {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 4rem;
    min-height: 100vh;
  }
  @media (max-width: 767px) {
    .tool-page-hao { padding-top: calc(var(--header-height) + 1rem); }
  }
</style>

<script is:inline>
