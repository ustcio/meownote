---
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="title-line">{t('hero.title.word1', lang)}</span>
        <span class="title-line">{t('hero.title.word2', lang)}</span>
        <span class="title-line title-highlight">{t('hero.title.word3', lang)}</span>
      </h1>
      
      <p class="hero-description">
        {t('hero.subtitle', lang)}
      </p>
      
      <div class="hero-actions">
        <a href="/chatbot" class="btn-primary">
          {t('hero.cta.primary', lang)}
        </a>
        <a href="#features" class="btn-secondary">
          {t('hero.cta.secondary', lang)}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: calc(var(--header-height) + var(--space-16)) var(--space-6) var(--space-16);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding: calc(var(--header-height) + var(--space-24)) var(--space-8) var(--space-24);
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: calc(var(--header-height) + var(--space-32)) var(--space-12) var(--space-32);
    }
  }

  .hero-container {
    width: 100%;
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .hero-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
    color: var(--text-primary);
  }

  @media (min-width: 768px) {
    .hero-title {
      margin-bottom: var(--space-8);
    }
  }

  .title-line {
    display: block;
  }

  .title-highlight {
    color: var(--color-primary);
    font-style: italic;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 auto var(--space-8);
    max-width: 560px;
  }

  @media (min-width: 768px) {
    .hero-description {
      font-size: var(--text-xl);
      margin-bottom: var(--space-10);
    }
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      gap: var(--space-4);
    }
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: 500;
    color: white;
    background: var(--color-primary);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 140px;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
    background: transparent;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 140px;
  }

  .btn-secondary:hover {
    background: var(--bg-secondary);
    border-color: var(--border-hover);
  }
</style>
