---
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);
const currentYear = new Date().getFullYear();

const stats = [
  { value: "500K+", label: "Active Users" },
  { value: "10M+", label: "Conversations" },
  { value: "99.9%", label: "Uptime" }
];

const features = [
  { icon: "brain", title: "Deep Reasoning", desc: "Advanced analysis & problem solving" },
  { icon: "code", title: "Code Generation", desc: "Write, debug & explain code" },
  { icon: "shield", title: "Privacy First", desc: "Your data stays secure" }
];
---

<section class="hero">
  <!-- Decorative background elements -->
  <div class="hero-bg">
    <div class="bg-circle bg-circle-1"></div>
  </div>

  <div class="hero-container">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      <span class="eyebrow-text">AI Companion</span>
    </div>

    <h1 class="hero-title hero-title-accent">
      The AI that actually does things
    </h1>

    <p class="hero-description">
      MaxMin.dev is an AI assistant built to help you think deeper,
      work smarter, and create freely. No shortcuts, just genuine intelligence.
    </p>

    <div class="hero-actions">
      <a href="/chatbot" class="btn-primary">
        Start chatting
        <svg class="btn-arrow" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#features" class="btn-secondary">
        Explore features
      </a>
    </div>

    <!-- Feature highlights -->
    <div class="hero-features">
      {features.map((feature) => (
        <div class="feature-item">
          <div class="feature-icon">
            {feature.icon === 'brain' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-2.04z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-2.04z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {feature.icon === 'code' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {feature.icon === 'shield' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <div class="feature-text">
            <span class="feature-title">{feature.title}</span>
            <span class="feature-desc">{feature.desc}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Stats -->
    <div class="hero-stats">
      {stats.map((stat) => (
        <div class="stat-item">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>

    <div class="hero-divider">
      <span class="divider-line"></span>
      <span class="divider-text">Since 2024</span>
      <span class="divider-line"></span>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-indicator">
      <div class="scroll-dot"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: #F0E9DC;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 5.5rem var(--space-4) var(--space-10);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .hero {
      padding: 5rem var(--space-5) var(--space-10);
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding: 4rem var(--space-6) var(--space-16);
      min-height: auto;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      min-height: 100vh;
      padding-top: 6rem;
    }
  }

  /* Background decoration */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.12;
  }

  .bg-circle-1 {
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, #5B7E6A 0%, transparent 70%);
    top: -50px;
    left: -50px;
  }

  @media (min-width: 768px) {
    .bg-circle-1 {
      width: 400px;
      height: 400px;
      top: -100px;
      left: -100px;
    }
  }

  .hero-container {
    max-width: 896px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
    padding: var(--space-6) 0;
  }

  @media (min-width: 768px) {
    .hero-container {
      padding: var(--space-10) 0;
    }
  }

  @media (min-width: 1024px) {
    .hero-container {
      padding: var(--space-16) 0;
    }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  @media (min-width: 768px) {
    .hero-eyebrow {
      margin-bottom: var(--space-6);
    }
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .eyebrow-text {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: var(--font-medium);
    color: #7A6A52;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    .eyebrow-text {
      font-size: var(--text-xs);
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: var(--font-normal);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #1A1207;
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 1.05;
      margin-bottom: var(--space-8);
    }
  }

  .hero-title-accent {
    color: #C06B3E;
  }

  .hero-description {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--font-normal);
    color: #6B5C42;
    line-height: 1.75;
    max-width: 640px;
    margin: 0 auto var(--space-12);
    padding: 0 var(--space-4);
  }

  @media (min-width: 768px) {
    .hero-description {
      font-size: var(--text-xl);
      line-height: 1.7;
      margin-bottom: var(--space-16);
      padding: 0;
    }
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-5);
      margin-bottom: var(--space-16);
    }
  }

  .btn-primary {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    padding: 1rem 2rem;
    background: #1A1207;
    color: #F0E9DC;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 48px;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 640px) {
    .btn-primary {
      padding: 1rem 2.5rem;
    }
  }

  .btn-primary:hover {
    background: #2C2210;
    transform: translateY(-1px);
  }

  .btn-arrow {
    width: 18px;
    height: 18px;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-secondary {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    padding: 1rem 2rem;
    color: #1A1207;
    border: 1.5px solid #C4B9A5;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 640px) {
    .btn-secondary {
      padding: 1rem 2.5rem;
    }
  }

  .btn-secondary:hover {
    border-color: #1A1207;
    background: rgba(26, 18, 7, 0.03);
  }

  /* Feature highlights */
  .hero-features {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
    padding: 0 var(--space-2);
  }

  @media (min-width: 480px) {
    .hero-features {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-4);
    }
  }

  @media (min-width: 768px) {
    .hero-features {
      gap: var(--space-6);
      margin-bottom: var(--space-16);
      padding: 0;
    }
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid #D6CCBB;
    border-radius: 16px;
    padding: var(--space-4);
    min-width: 0;
    width: 100%;
    max-width: 280px;
    transition: all var(--duration-normal) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 480px) {
    .feature-item {
      width: auto;
      max-width: none;
      flex: 1;
    }
  }

  @media (min-width: 768px) {
    .feature-item {
      gap: var(--space-4);
      padding: var(--space-5);
    }
  }

  .feature-item:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .feature-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-hover));
    border-radius: 10px;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .feature-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
    }
  }

  .feature-icon svg {
    width: 18px;
    height: 18px;
    color: #F0E9DC;
  }

  @media (min-width: 768px) {
    .feature-icon svg {
      width: 20px;
      height: 20px;
    }
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    text-align: left;
    gap: 2px;
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: #1A1207;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .feature-title {
      font-size: var(--text-base);
    }
  }

  .feature-desc {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #7A6A52;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .feature-desc {
      font-size: var(--text-sm);
    }
  }

  /* Stats */
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
    padding: var(--space-6) var(--space-4);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .hero-stats {
      gap: var(--space-16);
      margin-bottom: var(--space-16);
      padding: var(--space-8);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    min-width: 80px;
  }

  .stat-value {
    font-family: var(--font-number);
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: #1A1207;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: var(--text-3xl);
    }
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #7A6A52;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--font-medium);
  }

  @media (min-width: 768px) {
    .stat-label {
      font-size: var(--text-sm);
    }
  }

  .hero-divider {
    margin-top: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    justify-content: center;
    opacity: 0.4;
  }

  @media (min-width: 768px) {
    .hero-divider {
      margin-top: var(--space-10);
      gap: var(--space-5);
    }
  }

  .divider-line {
    height: 1px;
    width: 3rem;
    background: #A89880;
  }

  @media (min-width: 768px) {
    .divider-line {
      width: 6rem;
    }
  }

  .divider-text {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #7A6A52;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.3;
    display: none;
  }

  @media (min-width: 768px) {
    .hero-scroll {
      display: block;
    }
  }

  .scroll-indicator {
    width: 24px;
    height: 36px;
    border: 1px solid #A89880;
    border-radius: var(--radius-full);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 6px;
  }

  .scroll-dot {
    width: 4px;
    height: 6px;
    background: #A89880;
    border-radius: var(--radius-full);
    animation: bounce 1.5s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Dark theme */
  [data-theme="dark"] .hero {
    background: #1A1207;
  }

  [data-theme="dark"] .hero-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .hero-title-accent {
    color: #F0E9DC;
  }

  [data-theme="dark"] .hero-description {
    color: #A89880;
  }

  [data-theme="dark"] .eyebrow-text {
    color: #A89880;
  }

  [data-theme="dark"] .feature-item {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(240, 233, 220, 0.15);
  }

  [data-theme="dark"] .feature-title {
    color: #F0E9DC;
  }

  [data-theme="dark"] .feature-desc {
    color: #A89880;
  }

  [data-theme="dark"] .stat-value {
    color: #F0E9DC;
  }

  [data-theme="dark"] .stat-label {
    color: #A89880;
  }

  [data-theme="dark"] .divider-line {
    background: #A89880;
  }

  [data-theme="dark"] .scroll-indicator {
    border-color: rgba(240, 233, 220, 0.3);
  }

  [data-theme="dark"] .scroll-dot {
    background: #A89880;
  }
</style>
