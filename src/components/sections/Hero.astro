---
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);
const currentYear = new Date().getFullYear();

const stats = [
  { value: "500K+", label: "Active Users" },
  { value: "10M+", label: "Conversations" },
  { value: "99.9%", label: "Uptime" }
];

const features = [
  { icon: "brain", title: "Deep Reasoning", desc: "Advanced analysis & problem solving" },
  { icon: "code", title: "Code Generation", desc: "Write, debug & explain code" },
  { icon: "shield", title: "Privacy First", desc: "Your data stays secure" }
];
---

<section class="hero">
  <!-- Decorative background elements -->
  <div class="hero-bg">
    <div class="bg-circle bg-circle-1"></div>
    <div class="bg-circle bg-circle-2"></div>
    <div class="bg-grid"></div>
  </div>
  
  <div class="hero-container">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      <span class="eyebrow-text">AI Companion</span>
    </div>
    
    <h1 class="hero-title hero-title-accent">
      The AI that actually does things
    </h1>
    
    <p class="hero-description">
      LiveClaw is an AI assistant built to help you think deeper, 
      work smarter, and create freely. No shortcuts, just genuine intelligence.
    </p>
    
    <div class="hero-actions">
      <a href="/chatbot" class="btn-primary">
        Start chatting
        <svg class="btn-arrow" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#features" class="btn-secondary">
        Explore features
      </a>
    </div>

    <!-- Feature highlights -->
    <div class="hero-features">
      {features.map((feature) => (
        <div class="feature-item">
          <div class="feature-icon">
            {feature.icon === 'brain' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-2.04z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-2.04z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {feature.icon === 'code' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {feature.icon === 'shield' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <div class="feature-text">
            <span class="feature-title">{feature.title}</span>
            <span class="feature-desc">{feature.desc}</span>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Stats -->
    <div class="hero-stats">
      {stats.map((stat) => (
        <div class="stat-item">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
    
    <div class="hero-divider">
      <span class="divider-line"></span>
      <span class="divider-text">Since 2024</span>
      <span class="divider-line"></span>
    </div>
  </div>
  
  <div class="hero-scroll">
    <div class="scroll-indicator">
      <div class="scroll-dot"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: #F0E9DC;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem var(--space-4) var(--space-12);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 4rem var(--space-6) var(--space-16);
    }
  }

  /* Background decoration */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
  }

  .bg-circle-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, #C06B3E 0%, transparent 70%);
    top: -200px;
    right: -100px;
  }

  .bg-circle-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #5B7E6A 0%, transparent 70%);
    bottom: -100px;
    left: -100px;
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(192, 107, 62, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(192, 107, 62, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-container {
    max-width: 896px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
    padding: var(--space-8) 0;
  }

  @media (min-width: 768px) {
    .hero-container {
      padding: var(--space-16) 0;
    }
  }

  @media (min-width: 1024px) {
    .hero-container {
      padding: var(--space-20) 0;
    }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-eyebrow {
      margin-bottom: var(--space-8);
    }
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .eyebrow-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-normal);
    color: #7A6A52;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 6vw, 3.5rem);
    font-weight: var(--font-normal);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #1A1207;
    margin-bottom: var(--space-5);
  }

  @media (min-width: 768px) {
    .hero-title {
      line-height: 1.15;
      margin-bottom: var(--space-6);
    }
  }

  .hero-title-accent {
    color: #C06B3E;
  }

  .hero-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    color: #6B5C42;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto var(--space-8);
    padding: 0 var(--space-2);
  }

  @media (min-width: 768px) {
    .hero-description {
      font-size: var(--text-lg);
      line-height: 1.7;
      margin-bottom: var(--space-10);
      padding: 0;
    }
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 640px) {
    .hero-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn-primary {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    padding: 0.875rem 2rem;
    background: #1A1207;
    color: #F0E9DC;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--duration-normal) var(--ease-default);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .btn-primary:hover {
    background: #2C2210;
  }

  .btn-arrow {
    width: 16px;
    height: 16px;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(3px);
  }

  .btn-secondary {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    padding: 0.875rem 2rem;
    color: #1A1207;
    border: 1px solid #C4B9A5;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .btn-secondary:hover {
    border-color: #1A1207;
  }

  /* Feature highlights */
  .hero-features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .hero-features {
      gap: var(--space-6);
      margin-bottom: var(--space-10);
    }
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid #D6CCBB;
    border-radius: 12px;
    padding: var(--space-3) var(--space-4);
  }

  .feature-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #C06B3E;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .feature-icon svg {
    width: 16px;
    height: 16px;
    color: #F0E9DC;
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: #1A1207;
    line-height: 1.2;
  }

  .feature-desc {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #7A6A52;
    line-height: 1.2;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
    padding: var(--space-6) var(--space-4);
    background: rgba(255, 255, 255, 0.3);
    border-radius: 16px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .hero-stats {
      margin-bottom: var(--space-10);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-number);
    font-size: var(--text-xl);
    font-weight: var(--font-normal);
    color: #1A1207;
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: var(--text-2xl);
    }
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #7A6A52;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-divider {
    margin-top: var(--space-8);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    justify-content: center;
    opacity: 0.4;
  }

  @media (min-width: 768px) {
    .hero-divider {
      margin-top: var(--space-16);
      gap: var(--space-6);
    }
  }

  .divider-line {
    height: 1px;
    width: 4rem;
    background: #A89880;
  }

  @media (min-width: 768px) {
    .divider-line {
      width: 8rem;
    }
  }

  .divider-text {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #7A6A52;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.4;
  }

  .scroll-indicator {
    width: 20px;
    height: 32px;
    border: 1px solid #A89880;
    border-radius: var(--radius-full);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4px;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: #A89880;
    border-radius: var(--radius-full);
    animation: bounce 1s infinite;
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }
</style>
