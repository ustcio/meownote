---
const quickActions = [
  { label: 'Write clearly', href: '/chatbot' },
  { label: 'Plan a project', href: '/workspace' },
  { label: 'Research a topic', href: '/research' },
];
---

<section class="home-hero">
  <div class="container home-hero__grid">
    <div class="home-hero__copy">
      <span class="claude-kicker">Thoughtful AI for serious work</span>
      <h1 class="home-hero__title">
        Bring calm,
        <br />
        capable AI into
        <br />
        your day.
      </h1>
      <p class="home-hero__lead">
        Maxwell helps you think through messy problems, draft stronger writing,
        and move work forward without turning your tools into a circus.
      </p>

      <form class="home-hero__composer" action="/chatbot">
        <input
          type="text"
          name="q"
          value=""
          placeholder="Ask Maxwell to outline a launch plan, clean up a draft, or explain a concept"
          aria-label="Prompt"
        />
        <button type="submit">Open chat</button>
      </form>

      <div class="home-hero__chips">
        {quickActions.map((action) => (
          <a href={action.href} class="claude-chip">
            {action.label}
          </a>
        ))}
      </div>
    </div>

    <div class="home-hero__visual">
      <div class="hero-illustration">
        <svg viewBox="0 0 620 520" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="380" cy="140" r="62" fill="#D97757" />
          <path d="M558 84C512 84 482 117 474 152C468 178 452 196 420 214" stroke="#161311" stroke-width="18" stroke-linecap="round"/>
          <path d="M250 318C266 250 292 196 320 196C346 196 342 256 318 314" stroke="#161311" stroke-width="18" stroke-linecap="round"/>
          <path d="M292 318C310 246 338 190 366 190C392 190 388 254 362 318" stroke="#161311" stroke-width="18" stroke-linecap="round"/>
          <path d="M334 320C354 250 386 194 416 194C438 194 442 232 428 266" stroke="#161311" stroke-width="18" stroke-linecap="round"/>
          <path d="M420 214C370 214 334 242 314 280C302 302 304 330 330 342C354 352 382 342 402 324C420 308 436 278 474 278" stroke="#161311" stroke-width="18" stroke-linecap="round"/>
        </svg>
      </div>

      <article class="hero-spotlight claude-editorial-card">
        <span class="hero-spotlight__eyebrow">New on Maxwell</span>
        <h2>One place for drafting, planning, and execution.</h2>
        <p>
          Move from a vague prompt to a clear plan, then keep going in chat,
          workspace, or research mode without changing mental gears.
        </p>
        <a href="/workspace" class="hero-spotlight__link">Explore workspace</a>
      </article>
    </div>
  </div>
</section>

<style>
  .home-hero {
    padding: calc(var(--header-height) + 5.5rem) 0 5rem;
  }

  .home-hero__grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1100px) {
    .home-hero__grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: 3.5rem;
    }
  }

  .home-hero__copy {
    display: grid;
    gap: 1.5rem;
    max-width: 38rem;
    padding-top: 1rem;
  }

  .home-hero__title {
    max-width: 12ch;
  }

  .home-hero__lead {
    font-size: 1.18rem;
    max-width: 33rem;
    margin: 0;
  }

  .home-hero__composer {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.9rem;
    max-width: 38rem;
    padding: 0.7rem;
    border-radius: 1.65rem;
    border: 1px solid var(--card-border);
    background: rgba(255, 253, 249, 0.9);
    box-shadow: var(--card-shadow);
  }

  @media (min-width: 700px) {
    .home-hero__composer {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }
  }

  .home-hero__composer input {
    border: none;
    background: transparent;
    padding: 0.9rem 1rem;
    box-shadow: none;
  }

  .home-hero__composer button {
    min-height: 3rem;
    padding: 0.8rem 1.15rem;
    border-radius: 999px;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-size: 0.96rem;
    font-weight: 500;
    box-shadow: var(--btn-primary-shadow);
  }

  .home-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .home-hero__visual {
    position: relative;
    min-height: 420px;
    display: grid;
    align-items: end;
  }

  .hero-illustration {
    width: min(100%, 42rem);
    margin-left: auto;
    opacity: 0.98;
  }

  .hero-illustration svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-spotlight {
    position: absolute;
    right: 0;
    bottom: 1rem;
    width: min(21rem, 90%);
    padding: 1.4rem;
    display: grid;
    gap: 0.8rem;
    background: rgba(255, 253, 249, 0.96);
  }

  .hero-spotlight__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .hero-spotlight h2 {
    font-size: 2rem;
  }

  .hero-spotlight p {
    font-size: 0.98rem;
  }

  .hero-spotlight__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    min-height: 2.5rem;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: #171412;
    color: #fffdf9;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .hero-spotlight__link:hover {
    color: #fffdf9;
    background: #26211c;
  }

  @media (max-width: 1099px) {
    .home-hero {
      padding: calc(var(--header-height) + 4rem) 0 4rem;
    }

    .home-hero__title {
      max-width: none;
    }

    .home-hero__visual {
      min-height: auto;
      padding-bottom: 14rem;
    }

    .hero-illustration {
      width: 100%;
      max-width: 34rem;
      margin: 0 auto;
    }

    .hero-spotlight {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .home-hero {
      padding: calc(var(--header-height) + 3rem) 0 3rem;
    }

    .home-hero__grid {
      gap: 2rem;
    }

    .home-hero__copy {
      gap: 1.2rem;
    }

    .home-hero__lead {
      font-size: 1rem;
    }

    .home-hero__composer {
      padding: 0.6rem;
    }

    .home-hero__composer input {
      padding: 0.75rem 0.8rem;
      font-size: 0.95rem;
    }

    .home-hero__compiler button {
      min-height: 2.8rem;
      width: 100%;
    }

    .home-hero__chips {
      gap: 0.5rem;
    }

    .claude-chip {
      padding: 0.5rem 0.8rem;
      font-size: 0.85rem;
    }

    .home-hero__visual {
      padding-bottom: 10rem;
      min-height: auto;
    }

    .hero-illustration {
      max-width: 24rem;
    }

    .hero-spotlight {
      width: min(18rem, calc(100vw - 2rem));
      padding: 1.1rem;
    }

    .hero-spotlight h2 {
      font-size: 1.5rem;
    }

    .hero-spotlight p {
      font-size: 0.88rem;
    }

    .hero-spotlight__link {
      width: 100%;
      justify-content: center;
    }
  }
</style>
