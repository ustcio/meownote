---
const stats = [
  { value: "500K+", label: "Active Users" },
  { value: "10M+", label: "Conversations" },
  { value: "99.9%", label: "Uptime" }
];

const features = [
  { icon: "brain", title: "Deep Reasoning", desc: "Advanced analysis & problem solving" },
  { icon: "code", title: "Code Generation", desc: "Write, debug & explain code" },
  { icon: "shield", title: "Privacy First", desc: "Your data stays secure" }
];
---

<section class="hero">
  <div class="hero-bg">
    <div class="bg-circle"></div>
  </div>

  <div class="hero-container">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      <span class="eyebrow-text">AI Companion</span>
    </div>

    <h1 class="hero-title">
      The AI that actually<br />does things
    </h1>

    <p class="hero-description">
      MaxMin.dev is an AI assistant built to help you think deeper,
      work smarter, and create freely. No shortcuts, just genuine intelligence.
    </p>

    <div class="hero-actions">
      <a href="/chatbot" class="btn-hero-primary">
        Start chatting
        <svg class="btn-arrow" viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#features" class="btn-hero-secondary">
        Explore features
      </a>
    </div>

    <div class="hero-features">
      {features.map((feature) => (
        <div class="feature-item">
          <div class="feature-icon">
            {feature.icon === 'brain' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-2.04z" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-2.04z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {feature.icon === 'code' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {feature.icon === 'shield' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <div class="feature-text">
            <span class="feature-title">{feature.title}</span>
            <span class="feature-desc">{feature.desc}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="hero-stats">
      {stats.map((stat) => (
        <div class="stat-item">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>

    <div class="hero-divider">
      <span class="divider-line"></span>
      <span class="divider-text">Since 2024</span>
      <span class="divider-line"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--bg-primary);
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem var(--space-5) var(--space-16);
    position: relative;
    overflow: hidden;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  @media (min-width: 768px) {
    .hero {
      padding: 8rem var(--space-8) var(--space-20);
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-circle {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-primary-light) 0%, transparent 70%);
    top: -200px;
    right: -150px;
    opacity: 0.5;
  }

  @media (min-width: 768px) {
    .bg-circle {
      width: 700px;
      height: 700px;
      top: -250px;
      right: -200px;
    }
  }

  .hero-container {
    max-width: 896px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
    padding: var(--space-8) 0;
  }

  @media (min-width: 768px) {
    .hero-container {
      padding: var(--space-16) 0;
    }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary-light);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .hero-eyebrow {
      margin-bottom: var(--space-10);
    }
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .eyebrow-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-primary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: var(--font-bold);
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: clamp(3.5rem, 6vw, 5rem);
      line-height: 1.05;
      margin-bottom: var(--space-8);
    }
  }

  .hero-description {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--font-normal);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto var(--space-10);
    padding: 0 var(--space-4);
  }

  @media (min-width: 768px) {
    .hero-description {
      font-size: var(--text-xl);
      margin-bottom: var(--space-12);
      padding: 0;
    }
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-4);
    }
  }

  .btn-hero-primary {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    padding: 0.875rem 1.75rem;
    background: var(--text-primary);
    color: var(--bg-primary);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-height: 48px;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-hero-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
    color: var(--bg-primary);
  }

  .btn-arrow {
    width: 16px;
    height: 16px;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .btn-hero-primary:hover .btn-arrow {
    transform: translateX(3px);
  }

  .btn-hero-secondary {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    padding: 0.875rem 1.75rem;
    color: var(--text-secondary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-hero-secondary:hover {
    border-color: var(--border-hover);
    background: var(--btn-secondary-hover-bg);
    color: var(--text-primary);
  }

  .hero-features {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-16);
    padding: 0 var(--space-2);
  }

  @media (min-width: 480px) {
    .hero-features {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-4);
    }
  }

  @media (min-width: 768px) {
    .hero-features {
      gap: var(--space-5);
      padding: 0;
    }
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    min-width: 0;
    width: 100%;
    max-width: 260px;
    transition: all var(--duration-normal) var(--ease-default);
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 480px) {
    .feature-item {
      width: auto;
      max-width: none;
      flex: 1;
    }
  }

  @media (min-width: 768px) {
    .feature-item {
      gap: var(--space-4);
      padding: var(--space-5);
    }
  }

  .feature-item:hover {
    border-color: var(--card-border-hover);
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }

  .feature-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .feature-icon {
      width: 40px;
      height: 40px;
    }
  }

  .feature-icon svg {
    width: 18px;
    height: 18px;
    color: white;
  }

  @media (min-width: 768px) {
    .feature-icon svg {
      width: 20px;
      height: 20px;
    }
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    text-align: left;
    gap: 2px;
  }

  .feature-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .feature-title {
      font-size: var(--text-base);
    }
  }

  .feature-desc {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .feature-desc {
      font-size: var(--text-sm);
    }
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-10);
    padding: var(--space-8) 0;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .hero-stats {
      gap: var(--space-16);
      padding: var(--space-10) 0;
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    min-width: 80px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: var(--text-3xl);
    }
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--font-medium);
  }

  .hero-divider {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    justify-content: center;
    opacity: 0.4;
  }

  @media (min-width: 768px) {
    .hero-divider {
      gap: var(--space-5);
    }
  }

  .divider-line {
    height: 1px;
    width: 3rem;
    background: var(--text-quaternary);
  }

  @media (min-width: 768px) {
    .divider-line {
      width: 5rem;
    }
  }

  .divider-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
