---
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);
const currentYear = new Date().getFullYear();
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      <span class="eyebrow-text">AI Companion</span>
    </div>
    
    <h1 class="hero-title">
      The AI that <em class="hero-emphasis">actually</em> does things
    </h1>
    
    <p class="hero-description">
      LiveClaw is an AI assistant built to help you think deeper, 
      work smarter, and create freely. No shortcuts, just genuine intelligence.
    </p>
    
    <div class="hero-actions">
      <a href="/chatbot" class="btn-primary">
        Start chatting
      </a>
      <a href="#features" class="btn-secondary">
        Explore features
      </a>
    </div>
    
    <div class="hero-divider">
      <span class="divider-line"></span>
      <span class="divider-text">Est. 2024</span>
      <span class="divider-line"></span>
    </div>
  </div>
  
  <div class="hero-scroll">
    <div class="scroll-indicator">
      <div class="scroll-dot"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: #F0E9DC;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem var(--space-6) var(--space-16);
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 896px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
    padding: var(--space-16) 0;
  }

  @media (min-width: 768px) {
    .hero-container {
      padding: var(--space-20) 0;
    }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .eyebrow-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-normal);
    color: #7A6A52;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: var(--font-normal);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: #1A1207;
    margin-bottom: var(--space-6);
  }

  .hero-emphasis {
    font-style: normal;
    color: #C06B3E;
  }

  .hero-description {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--font-normal);
    color: #6B5C42;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto var(--space-10);
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .hero-actions {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn-primary {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    padding: 0.875rem 2rem;
    background: #1A1207;
    color: #F0E9DC;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .btn-primary:hover {
    background: #2C2210;
  }

  .btn-secondary {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    padding: 0.875rem 2rem;
    color: #1A1207;
    border: 1px solid #C4B9A5;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .btn-secondary:hover {
    border-color: #1A1207;
  }

  .hero-divider {
    margin-top: var(--space-16);
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-content: center;
    opacity: 0.4;
  }

  .divider-line {
    height: 1px;
    width: 8rem;
    background: #A89880;
  }

  .divider-text {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #7A6A52;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.4;
  }

  .scroll-indicator {
    width: 20px;
    height: 32px;
    border: 1px solid #A89880;
    border-radius: var(--radius-full);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4px;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: #A89880;
    border-radius: var(--radius-full);
    animation: bounce 1s infinite;
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }
</style>
