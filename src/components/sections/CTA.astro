---
import { t, getLangFromUrl } from '@i18n';
const lang = getLangFromUrl(Astro.url);
---

<section class="home-cta">
  <div class="container home-cta__inner">
    <div class="home-cta__copy">
      <span class="cta-kicker">Ready?</span>
      <h2>{t('cta.title', lang)}</h2>
      <p>{t('cta.subtitle', lang)}</p>
      <div class="home-cta__actions">
        <a href="/chatbot" class="cta-btn cta-btn--primary">{t('cta.primary', lang)}</a>
        <a href="/about" class="cta-btn cta-btn--ghost">{t('cta.secondary', lang)}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .home-cta {
    padding: 5rem 0;
    background: #171412;
    color: #fbf9f5;
  }

  .home-cta__inner {
    max-width: 36rem;
    text-align: center;
  }

  .home-cta__copy {
    display: grid;
    gap: 0.65rem;
  }

  .cta-kicker {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(251, 249, 245, 0.38);
  }

  .home-cta h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .home-cta p {
    color: rgba(251, 249, 245, 0.55);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 28rem;
    font-size: 0.92rem;
  }

  .home-cta__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
    padding-top: 0.2rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    font-weight: var(--font-medium);
    transition:
      background var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      transform var(--duration-fast) var(--ease-default);
  }

  .cta-btn--primary {
    background: var(--color-primary);
    color: #FFFFFF;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .cta-btn--primary:hover {
    background: var(--color-primary-hover);
    color: #FFFFFF;
    transform: translateY(-1px);
  }

  .cta-btn--ghost {
    background: transparent;
    color: rgba(251, 249, 245, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .cta-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.18);
    color: #fbf9f5;
  }
</style>
