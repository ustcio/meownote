---
import { t, getLangFromUrl } from '@i18n';
const lang = getLangFromUrl(Astro.url);
---

<section class="home-cta">
  <div class="container home-cta__inner">
    <div class="home-cta__copy">
      <span class="cta-kicker">Ready to try it</span>
      <h2>{t('cta.title', lang)}</h2>
      <p>{t('cta.subtitle', lang)}</p>
      <div class="home-cta__actions">
        <a href="/chatbot" class="cta-btn cta-btn--primary">{t('cta.primary', lang)}</a>
        <a href="/workspace" class="cta-btn cta-btn--ghost">{t('cta.secondary', lang)}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .home-cta {
    padding: 4.5rem 0;
    background: #171412;
    color: #fbf9f5;
  }

  .home-cta__inner {
    max-width: 36rem;
    text-align: center;
  }

  .home-cta__copy {
    display: grid;
    gap: 0.8rem;
  }

  .cta-kicker {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(251, 249, 245, 0.45);
  }

  .home-cta h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .home-cta p {
    color: rgba(251, 249, 245, 0.6);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 28rem;
  }

  .home-cta__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    padding-top: 0.2rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    font-weight: var(--font-medium);
    transition:
      background var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      transform var(--duration-fast) var(--ease-default);
  }

  .cta-btn--primary {
    background: #d4755a;
    color: #fffefb;
    box-shadow: 0 8px 18px rgba(212, 117, 90, 0.25);
  }

  .cta-btn--primary:hover {
    background: #c4644a;
    color: #fffefb;
    transform: translateY(-1px);
  }

  .cta-btn--ghost {
    background: transparent;
    color: rgba(251, 249, 245, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .cta-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fbf9f5;
  }
</style>
