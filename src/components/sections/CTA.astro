---
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);
---

<section class="home-cta">
  <div class="container home-cta__inner">
    <div class="home-cta__copy">
      <span class="claude-kicker">Ready to try it</span>
      <h2>{t('cta.title', lang)}</h2>
      <p>{t('cta.subtitle', lang)}</p>
    </div>
    <div class="home-cta__actions">
      <a href="/chatbot" class="claude-button">{t('cta.primary', lang)}</a>
      <a href="/workspace" class="claude-button-secondary">{t('cta.secondary', lang)}</a>
    </div>
  </div>
</section>

<style>
  .home-cta {
    padding: 4.5rem 0;
    background: #171412;
    color: #fffdf9;
  }

  .home-cta__inner {
    display: grid;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .home-cta__inner {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 2rem;
    }
  }

  .home-cta .claude-kicker {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.08);
    color: rgba(255, 250, 245, 0.65);
  }

  .home-cta h2,
  .home-cta p {
    color: #fffdf9;
  }

  .home-cta p {
    color: rgba(255, 250, 245, 0.72);
    margin-top: 0.9rem;
    max-width: 32rem;
  }

  .home-cta__copy {
    display: grid;
    gap: 1rem;
  }

  .home-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .home-cta .claude-button-secondary {
    color: #fffdf9;
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.04);
  }
</style>
