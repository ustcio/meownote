---
const features = [
  {
    lottie: '/animations/lottie/Hand-Link.lottie',
    label: 'Connect',
    title: 'Link ideas across your research.',
    desc: 'MoonSun weaves connections between papers, notes, and datasets — surfacing relationships you might otherwise miss.'
  },
  {
    lottie: '/animations/lottie/Object-CodeCheck.lottie',
    label: 'Verify',
    title: 'Trust every result.',
    desc: 'Cross-check derivations, validate code output, and catch subtle errors before they propagate through your workflow.'
  },
  {
    lottie: '/animations/lottie/Hand-Eye.lottie',
    label: 'Discover',
    title: 'See what the data hides.',
    desc: 'Spot patterns in noisy measurements that would take hours of manual inspection to uncover.'
  },
  {
    lottie: '/animations/lottie/Node-LineChart.lottie',
    label: 'Track',
    title: 'Follow the trend, not the noise.',
    desc: 'Monitor experiments, visualize trajectories, and let the data guide your next hypothesis.'
  },
];
---

<section class="lottie-showcase">
  <div class="lottie-showcase__container">
    <div class="lottie-showcase__layout">
      
      <!-- Left: Text Content -->
      <div class="lottie-showcase__copy">
        <span class="lottie-showcase__kicker">How it works</span>
        <h2 class="lottie-showcase__title">Four modes.<br/>One steady partner.</h2>
        <p class="lottie-showcase__subtitle">MoonSun adapts to the way you work — connecting, verifying, discovering, and tracking.</p>
        
        <div class="lottie-showcase__steps">
          {features.map((feature, i) => (
            <div class="lottie-showcase__step" data-index={i}>
              <span class="lottie-showcase__step-label">{feature.label}</span>
              <h3 class="lottie-showcase__step-title">{feature.title}</h3>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Animation Stage -->
      <div class="lottie-showcase__stage">
        <div class="lottie-showcase__viewport">
          {features.map((feature, i) => (
            <div class="lottie-showcase__slide" data-slide={i} data-src={feature.lottie}>
              <div class="lottie-showcase__anim-container" id={`lottie-slide-${i}`}></div>
              <span class="lottie-showcase__slide-label">{feature.label}</span>
            </div>
          ))}
        </div>
        <div class="lottie-showcase__progress">
          {features.map((_, i) => (
            <div class="lottie-showcase__progress-dot" data-dot={i}></div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const ANIMATION_DURATION = 3000;
  const TRANSITION_DURATION = 600;
  const TOTAL_SLIDES = 4;

  let currentSlide = 0;
  let animationInstances = [];
  let autoplayTimer = null;
  let isTransitioning = false;

  function initLottieSlides() {
    var slides = document.querySelectorAll('.lottie-showcase__slide');
    
    slides.forEach(function(slide, index) {
      var container = document.getElementById('lottie-slide-' + index);
      if (!container) return;

      var lottieSrc = slide.getAttribute('data-src');
      if (!lottieSrc) return;

      var isDotLottie = lottieSrc.endsWith('.lottie');

      if (isDotLottie && window.customElements && window.customElements.get('dotlottie-player')) {
        var player = document.createElement('dotlottie-player');
        player.setAttribute('src', lottieSrc);
        player.setAttribute('autoplay', 'true');
        player.setAttribute('loop', 'true');
        player.style.width = '100%';
        player.style.height = '100%';
        container.appendChild(player);
        animationInstances[index] = player;
      } else if (!isDotLottie && window.lottie) {
        var anim = window.lottie.loadAnimation({
          container: container,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path: lottieSrc,
        });
        animationInstances[index] = anim;
      }
    });

    showSlide(0);
    startAutoplay();
  }

  function showSlide(index) {
    if (isTransitioning) return;
    isTransitioning = true;

    var slides = document.querySelectorAll('.lottie-showcase__slide');
    var dots = document.querySelectorAll('.lottie-showcase__progress-dot');
    var steps = document.querySelectorAll('.lottie-showcase__step');

    slides.forEach(function(slide, i) {
      if (i === index) {
        slide.classList.add('is-active');
        slide.classList.remove('is-exit');
      } else if (slide.classList.contains('is-active')) {
        slide.classList.add('is-exit');
        slide.classList.remove('is-active');
      }
    });

    dots.forEach(function(dot, i) {
      if (i === index) {
        dot.classList.add('is-active');
      } else {
        dot.classList.remove('is-active');
      }
    });

    steps.forEach(function(step, i) {
      if (i === index) {
        step.classList.add('is-active');
      } else {
        step.classList.remove('is-active');
      }
    });

    currentSlide = index;

    setTimeout(function() {
      isTransitioning = false;
    }, TRANSITION_DURATION);
  }

  function nextSlide() {
    var next = (currentSlide + 1) % TOTAL_SLIDES;
    showSlide(next);
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayTimer = setInterval(nextSlide, ANIMATION_DURATION);
  }

  function stopAutoplay() {
    if (autoplayTimer) {
      clearInterval(autoplayTimer);
      autoplayTimer = null;
    }
  }

  function waitForLottie(callback, retries) {
    if (retries === undefined) retries = 0;
    var hasLottie = window.lottie;
    var hasDotLottie = window.customElements && window.customElements.get('dotlottie-player');
    if ((hasLottie && hasDotLottie) || retries > 50) {
      callback();
      return;
    }
    setTimeout(function() {
      waitForLottie(callback, retries + 1);
    }, 100);
  }

  function loadDotLottiePlayer(callback) {
    if (window.customElements && window.customElements.get('dotlottie-player')) {
      callback();
      return;
    }
    var script = document.createElement('script');
    script.src = '/animations/libs/dotlottie-player.js';
    script.onload = callback;
    script.onerror = callback;
    document.head.appendChild(script);
  }

  document.addEventListener('DOMContentLoaded', function() {
    loadDotLottiePlayer(function() {
      waitForLottie(function() {
        setTimeout(initLottieSlides, 200);
      });
    });
  });

  document.addEventListener('astro:page-load', function() {
    loadDotLottiePlayer(function() {
      waitForLottie(function() {
        setTimeout(initLottieSlides, 200);
      });
    });
  });
</script>

<style>
  .lottie-showcase {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
    overflow: hidden;
  }

  .lottie-showcase__container {
    max-width: var(--container-lg, 1120px);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  .lottie-showcase__layout {
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 900px) {
    .lottie-showcase__layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  /* ===== Left: Copy ===== */
  .lottie-showcase__copy {
    display: flex;
    flex-direction: column;
  }

  .lottie-showcase__kicker {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-3);
  }

  .lottie-showcase__title {
    font-family: var(--font-editorial);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.08;
    font-weight: var(--font-normal);
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .lottie-showcase__subtitle {
    font-size: clamp(0.95rem, 1.6vw, 1.05rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    max-width: 28rem;
  }

  .lottie-showcase__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .lottie-showcase__step {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    border-left: 3px solid transparent;
    transition: all 0.4s var(--ease-default);
    opacity: 0.4;
    cursor: default;
  }

  .lottie-showcase__step.is-active {
    opacity: 1;
    border-left-color: var(--color-primary);
    background: var(--bg-secondary);
  }

  .lottie-showcase__step-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    color: var(--color-primary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: var(--font-semibold);
    display: block;
    margin-bottom: 3px;
  }

  .lottie-showcase__step-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: 0;
    letter-spacing: var(--tracking-tight);
    line-height: 1.3;
  }

  /* ===== Right: Stage ===== */
  .lottie-showcase__stage {
    position: relative;
  }

  .lottie-showcase__viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
  }

  .lottie-showcase__viewport::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(var(--border-primary) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.3;
    pointer-events: none;
    z-index: 1;
  }

  .lottie-showcase__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.92);
    transition: opacity 0.5s var(--ease-out),
                transform 0.5s var(--ease-out);
    pointer-events: none;
  }

  .lottie-showcase__slide.is-active {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  .lottie-showcase__slide.is-exit {
    opacity: 0;
    transform: scale(0.92);
  }

  .lottie-showcase__anim-container {
    width: 80%;
    height: 80%;
    position: relative;
    z-index: 2;
  }

  .lottie-showcase__anim-container :global(svg) {
    width: 100%;
    height: 100%;
  }

  .lottie-showcase__slide-label {
    position: absolute;
    bottom: var(--space-5);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--text-tertiary);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: var(--font-semibold);
    z-index: 3;
    opacity: 0;
    transition: opacity 0.4s var(--ease-default) 0.2s;
  }

  .lottie-showcase__slide.is-active .lottie-showcase__slide-label {
    opacity: 1;
  }

  .lottie-showcase__progress {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: var(--space-4);
  }

  .lottie-showcase__progress-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border-primary);
    transition: all 0.3s var(--ease-default);
  }

  .lottie-showcase__progress-dot.is-active {
    background: var(--color-primary);
    transform: scale(1.4);
  }

  /* ===== Responsive ===== */
  @media (max-width: 767px) {
    .lottie-showcase {
      padding-top: var(--space-8);
      padding-bottom: var(--space-8);
    }

    .lottie-showcase__layout {
      gap: var(--space-6);
    }

    .lottie-showcase__viewport {
      aspect-ratio: 4 / 3;
    }

    .lottie-showcase__subtitle {
      margin-bottom: var(--space-6);
    }

    .lottie-showcase__step {
      padding: var(--space-3) var(--space-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lottie-showcase__slide,
    .lottie-showcase__step,
    .lottie-showcase__step-desc {
      transition: none;
    }
  }
</style>
