---
const faqs = [
  {
    q: 'What is your research focus?',
    a: 'My PhD work centers on quantum transport and optoelectronic properties in topological quantum materials — specifically layered compounds like CoNb₃S₆, ZrAs₂, and Nb₃I₈. I combine Hall effect measurements, phonon analysis, and detector development to understand how electrons behave in these systems.',
  },
  {
    q: 'What techniques do you use?',
    a: 'I work with transport measurements (Hall effect, magnetoresistance), optoelectronic characterization (photoconductivity, spectral response), and first-principles calculations. I also design and test radiation detectors based on novel van der Waals materials.',
  },
  {
    q: 'Why does this matter?',
    a: 'Topological materials could enable next-generation electronics — faster, more efficient, and more robust. Understanding their transport and optical properties is a key step toward practical devices like quantum sensors and low-power transistors.',
  },
  {
    q: 'Are you open to collaboration?',
    a: 'Yes! I am interested in collaborations on quantum materials, detector development, and interdisciplinary applications. Feel free to reach out — I am always happy to discuss ideas over coffee or a video call.',
  },
  {
    q: 'What tools do you build here?',
    a: 'This site hosts a collection of 170+ daily-use tools — file converters, text utilities, image processors, and more. I built them as a practical side project while doing research. They are free to use and open to suggestions.',
  },
];
---

<section class="faq-section">
  <div class="container">
    <div class="faq-header">
      <span class="faq-kicker">Common questions</span>
      <h2>Questions. Answered.</h2>
    </div>

    <div class="faq-list" role="list">
      {faqs.map((faq, i) => (
        <details class="faq-item" role="listitem" id={`faq-${i}`}
  on:toggle={(e) => {
    const details = e.currentTarget;
    const body = details.querySelector('.faq-answer') as HTMLElement;
    const chevron = details.querySelector('.faq-chevron') as SVGElement;
    if (details.open) {
      body.style.gridTemplateRows = '1fr';
      body.style.opacity = '1';
      chevron.style.transform = 'rotate(180deg)';
    } else {
      body.style.gridTemplateRows = '0fr';
      body.style.opacity = '0';
      chevron.style.transform = 'rotate(0deg)';
    }
  }}
>
          <summary class="faq-question-btn" aria-expanded="false" aria-controls={`faq-body-${i}`}>
            <span class="faq-question-text">{faq.q}</span>
            <svg class="faq-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="faq-answer" id={`faq-body-${i}`}>
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    background: var(--bg-primary);
  }

  .faq-header {
    text-align: center;
    margin-bottom: clamp(1.5rem, 3vw, 2.25rem);
  }

  .faq-kicker {
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .faq-kicker::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  .faq-header h2 {
    margin-top: 0.4rem;
  }

  .faq-list {
    max-width: 44rem;
    margin: 0 auto;
  }

  .faq-item {
    border-top: 1px solid var(--border-primary);
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--border-primary);
  }

  .faq-question-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.1rem 0;
    cursor: pointer;
    list-style: none;
    color: var(--text-primary);
    font-size: 0.95rem;
    font-weight: var(--font-medium);
    line-height: 1.5;
    transition: color var(--duration-normal) var(--ease-default);
  }

  .faq-question-btn:hover {
    color: var(--color-primary);
  }

  .faq-question-btn::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-default);
    color: var(--text-tertiary);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s var(--ease-default), opacity 0.3s var(--ease-default);
    opacity: 0;
  }

  .faq-item[open] > .faq-answer {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .faq-answer > * {
    overflow: hidden;
  }

  .faq-answer p {
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
    font-size: 0.92rem;
  }

  @media (max-width: 640px) {
    .faq-section { padding: 2.5rem 0; }
    .faq-question-btn { padding: 1rem 0; font-size: 0.92rem; }
    .faq-answer p { font-size: 0.88rem; }
  }
</style>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    item.addEventListener('toggle', () => {
      const btn = item.querySelector('.faq-question-btn');
      if (btn) btn.setAttribute('aria-expanded', item.open.toString());
    });
  });
</script>
