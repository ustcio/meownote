</style>

<script is:inline define:vars={{ API_BASE }}>
  const DEFAULT_MODEL = 'qwen3.6-plus';
  const MODEL_META = {
    'qwen3.6-plus': { name: 'Qwen 3.6 Plus', badge: '默认', avatar: '/claude-favicon.png' },
    'minimax-2.7': { name: 'MiniMax 2.7', badge: '独立 API', avatar: '/claude-favicon.png' },
  };
  let currentConversationId = null;
  let isGenerating = false;
  let abortController = null;
  const chatPage = document.querySelector('.claude-chat-page');

  // DOM 元素
  const elements = {
    sidebar: document.getElementById('sidebar'),
    sidebarOverlay: document.getElementById('sidebar-overlay'),
    menuToggle: document.getElementById('menu-toggle'),
    newChatBtn: document.getElementById('new-chat-btn'),
    conversationsList: document.getElementById('conversations-list'),
    messagesContainer: document.getElementById('messages-container'),
    messagesList: document.getElementById('messages-list'),
    welcomeScreen: document.getElementById('welcome-screen'),
    messageInput: document.getElementById('message-input'),
    sendBtn: document.getElementById('send-btn'),
    stopBtn: document.getElementById('stop-btn'),
    modelBtn: document.getElementById('model-btn'),
    modelDropdown: document.getElementById('model-dropdown'),
    modelName: document.getElementById('model-name'),
    inputStatus: document.getElementById('input-status'),
  };

  function formatTime(date = new Date()) {
    return new Intl.DateTimeFormat('zh-CN', {
      hour: '2-digit',
      minute: '2-digit',
    }).format(date);
  }

  function setComposerState(status = 'idle') {
    if (!elements.stopBtn || !elements.sendBtn || !elements.inputStatus) return;

    const isBusy = status === 'generating';
    elements.stopBtn.hidden = !isBusy;
    elements.sendBtn.hidden = isBusy;
    elements.inputStatus.textContent = isBusy
      ? '正在生成回复，点击停止可中断'
      : 'Enter 发送，Shift + Enter 换行';
  }

  function setViewState(mode = 'welcome') {
    const isWelcome = mode === 'welcome';
    chatPage?.classList.toggle('is-welcome', isWelcome);

    if (elements.welcomeScreen) {
      elements.welcomeScreen.style.display = isWelcome ? 'flex' : 'none';
    }

    if (elements.messagesList) {
      elements.messagesList.style.display = isWelcome ? 'none' : 'block';
    }

    if (elements.messageInput) {
      elements.messageInput.placeholder = isWelcome ? 'How can I help you today?' : 'Reply...';
    }
  }

  function hydratePromptFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const prompt = params.get('q')?.trim();
    const autorun = params.get('autorun') === '1';

    if (!prompt || !elements.messageInput) return;

    elements.messageInput.value = prompt;
    elements.messageInput.dispatchEvent(new Event('input'));

    // Clear the query so a manual refresh won't resend the same prompt.
    window.history.replaceState({}, '', window.location.pathname);

    if (autorun) {
      window.setTimeout(() => {
        sendMessage();
      }, 0);
    } else {
      elements.messageInput.focus();
    }
  }

  // 侧边栏控制
  function openSidebar() {
    const wasOpen = elements.sidebar?.classList.contains('open');
    elements.sidebar?.classList.add('open');
    elements.sidebarOverlay?.classList.add('show');
    if (!wasOpen) window.__meownoteBodyScrollLock?.lock?.();
  }

  function closeSidebar() {
    const wasOpen = elements.sidebar?.classList.contains('open');
    elements.sidebar?.classList.remove('open');
    elements.sidebarOverlay?.classList.remove('show');
    if (wasOpen) window.__meownoteBodyScrollLock?.unlock?.();
  }

  elements.menuToggle?.addEventListener('click', openSidebar);
  elements.sidebarOverlay?.addEventListener('click', closeSidebar);

  // 新建对话
  elements.newChatBtn?.addEventListener('click', () => {
    currentConversationId = null;
    elements.messagesList.innerHTML = '';
    setViewState('welcome');
    elements.messageInput.value = '';
    elements.messageInput.style.height = 'auto';
    elements.sendBtn.disabled = true;
    setComposerState('idle');
    closeSidebar();
  });

  // 模型选择
  elements.modelBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    elements.modelDropdown?.classList.toggle('show');
  });

  document.querySelectorAll('.model-option').forEach(option => {
    option.addEventListener('click', () => {
      document.querySelectorAll('.model-option').forEach(o => o.classList.remove('active'));
      option.classList.add('active');
      const model = option.dataset.model;
      const name = option.querySelector('.model-option-name').textContent;
      elements.modelName.textContent = name;
      elements.modelDropdown?.classList.remove('show');
      if (MODEL_META[model]) {
        localStorage.setItem('selected_model', model);
      }
    });
  });

  document.addEventListener('click', () => {
    elements.modelDropdown?.classList.remove('show');
  });

  // 输入框自动调整高度
  elements.messageInput?.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 200) + 'px';
    elements.sendBtn.disabled = !this.value.trim();
  });

  // 发送消息
  async function sendMessage() {
    const content = elements.messageInput.value.trim();
    if (!content || isGenerating) return;

    setViewState('chat');

    // 添加用户消息
    appendMessage('user', content);
    
    // 清空输入框
    elements.messageInput.value = '';
    elements.messageInput.style.height = 'auto';
    elements.sendBtn.disabled = true;

    // 显示加载状态
    isGenerating = true;
    setComposerState('generating');
    const typingIndicator = appendTyping();

    try {
      abortController = new AbortController();
      
      const response = await fetch(`${API_BASE}/api/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: content,
          model: MODEL_META[localStorage.getItem('selected_model')] ? localStorage.getItem('selected_model') : DEFAULT_MODEL,
          conversation_id: currentConversationId,
        }),
        signal: abortController.signal,
      });
      const data = await response.json();
      if (!response.ok || !data.success) {
        throw new Error(data.message || '请求失败');
      }
      
      // 移除加载指示器
      typingIndicator?.remove();
      
      // 添加 AI 回复
      appendMessage('assistant', data.reply);
      
      // 更新会话 ID
      if (data.conversation_id) {
        currentConversationId = data.conversation_id;
      }

    } catch (error) {
      typingIndicator?.remove();
      if (error.name !== 'AbortError') {
        appendMessage('assistant', `抱歉，出现了错误：${error.message || '请稍后重试。'}`);
      } else {
        appendMessage('assistant', '已停止本次回复。你可以继续追问，或换个说法再试一次。');
      }
    } finally {
      isGenerating = false;
      abortController = null;
      setComposerState('idle');
    }
  }

  // 获取 Astro 的 scoped CSS 属性（用于动态创建的元素）
  const scopedEl = document.querySelector('[data-astro-cid-z4rfljly]');
  const hasAstroScoped = !!scopedEl;
  function applyAstroScoped(el) {
    if (hasAstroScoped) {
      el.setAttribute('data-astro-cid-z4rfljly', '');
      el.querySelectorAll('*').forEach(child => child.setAttribute('data-astro-cid-z4rfljly', ''));
    }
    return el;
  }

  // 添加消息到列表
  function appendMessage(role, content) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `message message-${role}`;
    const timestamp = formatTime();
    applyAstroScoped(messageDiv);

    let inner = '';
    if (role === 'assistant') {
      const activeModel = MODEL_META[localStorage.getItem('selected_model')] ? localStorage.getItem('selected_model') : DEFAULT_MODEL;
      const assistantMeta = MODEL_META[activeModel];
      inner += `
        <div class="message-header">
          <div class="message-avatar"><img src="${assistantMeta.avatar}" alt="AI" /></div>
          <div class="message-meta">
            <div class="message-role">${assistantMeta.name}</div>
            <div class="message-time">${timestamp}</div>
          </div>
        </div>
      `;
    } else {
      inner += `
        <div class="message-header">
          <div class="message-meta">
            <div class="message-time">${timestamp}</div>
          </div>
        </div>
      `;
    }
    inner += `
      <div class="message-shell">
        <div class="message-toolbar">
          <button class="message-tool-btn" type="button" data-copy-message title="复制消息" aria-label="复制消息">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span>复制</span>
          </button>
        </div>
        <div class="message-bubble">
          <div class="message-content">${formatContent(content)}</div>
        </div>
      </div>
    `;

    messageDiv.innerHTML = inner;
    applyAstroScoped(messageDiv);
    elements.messagesList?.appendChild(messageDiv);
    scrollToBottom();
  }

  // 添加加载指示器
  function appendTyping() {
    const activeModel = MODEL_META[localStorage.getItem('selected_model')] ? localStorage.getItem('selected_model') : DEFAULT_MODEL;
    const assistantMeta = MODEL_META[activeModel];
    const typingDiv = document.createElement('div');
    typingDiv.className = 'message message-assistant';
    typingDiv.innerHTML = `
      <div class="message-header">
        <div class="message-avatar"><img src="${assistantMeta.avatar}" alt="AI" /></div>
        <div class="message-meta">
          <div class="message-role">${assistantMeta.name}</div>
          <div class="message-time">思考中</div>
        </div>
      </div>
      <div class="message-shell">
        <div class="message-bubble">
          <div class="typing-indicator">
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
          </div>
        </div>
      </div>
    `;
    applyAstroScoped(typingDiv);
    elements.messagesList?.appendChild(typingDiv);
    scrollToBottom();
    return typingDiv;
  }

  // 格式化内容
  function formatContent(text) {
    const escapeHtml = (value) => value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    const formatInline = (value) => escapeHtml(value)
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g, '<em>$1</em>');

    const lines = text.replace(/\r\n/g, '\n').split('\n');
    const blocks = [];
    let paragraph = [];
    let listType = null;
    let listItems = [];
    let inCodeBlock = false;
    let codeLines = [];

    const flushParagraph = () => {
      if (!paragraph.length) return;
      const html = paragraph.map(line => formatInline(line)).join('<br>');
      blocks.push(`<p>${html}</p>`);
      paragraph = [];
    };

    const flushList = () => {
      if (!listItems.length || !listType) return;
      const tag = listType === 'ol' ? 'ol' : 'ul';
      blocks.push(`<${tag}>${listItems.map(item => `<li>${formatInline(item)}</li>`).join('')}</${tag}>`);
      listItems = [];
      listType = null;
    };

    const flushCode = () => {
      if (!codeLines.length) return;
      blocks.push(`<pre><code>${escapeHtml(codeLines.join('\n'))}</code></pre>`);
      codeLines = [];
    };

    for (const rawLine of lines) {
      const line = rawLine.trimEnd();
      const trimmed = line.trim();

      if (trimmed.startsWith('```')) {
        flushParagraph();
        flushList();
        if (inCodeBlock) {
          flushCode();
          inCodeBlock = false;
        } else {
          inCodeBlock = true;
        }
        continue;
      }

      if (inCodeBlock) {
        codeLines.push(rawLine);
        continue;
      }

      if (!trimmed) {
        flushParagraph();
        flushList();
        continue;
      }

      const headingMatch = trimmed.match(/^(#{1,3})\s+(.+)$/);
      if (headingMatch) {
        flushParagraph();
        flushList();
        const level = Math.min(headingMatch[1].length, 3);
        blocks.push(`<h${level}>${formatInline(headingMatch[2])}</h${level}>`);
        continue;
      }

      if (/^---+$/.test(trimmed) || /^\*\*\*+$/.test(trimmed)) {
        flushParagraph();
        flushList();
        blocks.push('<hr>');
        continue;
      }

      const quoteMatch = trimmed.match(/^>\s?(.*)$/);
      if (quoteMatch) {
        flushParagraph();
        flushList();
        blocks.push(`<blockquote><p>${formatInline(quoteMatch[1])}</p></blockquote>`);
        continue;
      }

      const orderedMatch = trimmed.match(/^\d+\.\s+(.+)$/);
      if (orderedMatch) {
        flushParagraph();
        if (listType && listType !== 'ol') flushList();
        listType = 'ol';
        listItems.push(orderedMatch[1]);
        continue;
      }

      const unorderedMatch = trimmed.match(/^[-*]\s+(.+)$/);
      if (unorderedMatch) {
        flushParagraph();
        if (listType && listType !== 'ul') flushList();
        listType = 'ul';
        listItems.push(unorderedMatch[1]);
        continue;
      }

      if (listType) flushList();
      paragraph.push(trimmed);
    }

    flushParagraph();
    flushList();
    if (inCodeBlock) flushCode();

    return blocks.join('');
  }

  // 滚动到底部
  function scrollToBottom() {
    if (elements.messagesContainer) {
      elements.messagesContainer.scrollTop = elements.messagesContainer.scrollHeight;
    }
  }

  // 事件监听
  elements.sendBtn?.addEventListener('click', sendMessage);
  elements.stopBtn?.addEventListener('click', () => window.stopGeneration());
  
  elements.messageInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // 建议卡片点击
  document.querySelectorAll('.suggestion-card').forEach(card => {
    card.addEventListener('click', () => {
      const prompt = card.dataset.prompt;
      if (prompt) {
        elements.messageInput.value = prompt;
        elements.messageInput.dispatchEvent(new Event('input'));
        sendMessage();
      }
    });
  });

  // 停止生成
  window.stopGeneration = function() {
    if (abortController) {
      abortController.abort();
    }
  };

  elements.messagesList?.addEventListener('click', async (event) => {
    const button = event.target.closest('[data-copy-message]');
    if (!button) return;

    const message = button.closest('.message');
    const content = message?.querySelector('.message-content')?.textContent?.trim();
    if (!content) return;

    try {
      await navigator.clipboard.writeText(content);
      const oldTitle = button.getAttribute('title');
      button.setAttribute('title', '已复制');
      setTimeout(() => button.setAttribute('title', oldTitle || '复制消息'), 1200);
    } catch (error) {
      console.warn('Copy failed:', error);
    }
  });

  // 初始化
  const savedModel = localStorage.getItem('selected_model');
  if (savedModel) {
    const option = document.querySelector(`.model-option[data-model="${savedModel}"]`);
    if (option) {
      option.click();
    }
  } else {
    localStorage.setItem('selected_model', DEFAULT_MODEL);
  }

  if (!MODEL_META[localStorage.getItem('selected_model')]) {
    localStorage.setItem('selected_model', DEFAULT_MODEL);
    document.querySelector(`.model-option[data-model="${DEFAULT_MODEL}"]`)?.click();
  }

  setComposerState('idle');
  setViewState('welcome');
  hydratePromptFromUrl();
</script>
