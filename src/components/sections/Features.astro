---
import Icon from '@components/ui/Icon.astro';
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    icon: 'message-circle',
    title: t('features.chat.title', lang),
    description: t('features.chat.desc', lang),
    link: '/chatbot',
    color: 'orange'
  },
  {
    icon: 'server',
    title: t('claw.feature.agent.title', lang),
    description: t('claw.feature.agent.desc', lang),
    link: '/claw',
    color: 'blue',
    badge: 'New'
  },
  {
    icon: 'box',
    title: t('kit.title', lang),
    description: t('kit.subtitle', lang),
    link: '/kit',
    color: 'teal'
  },
  {
    icon: 'shield',
    title: t('features.privacy.title', lang),
    description: t('features.privacy.desc', lang),
    link: '/about',
    color: 'green'
  },
];
---

<section class="features" id="features">
  <div class="features-container">
    <div class="features-header">
      <h2 class="features-title">
        {t('features.title', lang)}
        <span class="title-highlight">{t('features.title.highlight', lang)}</span>
      </h2>
      <p class="features-subtitle">{t('features.subtitle', lang)}</p>
    </div>
    
    <div class="features-grid">
      {features.map((feature, index) => (
        <a href={feature.link} class="feature-card" style={`--delay: ${index * 0.1}s`}>
          <div class={`feature-icon feature-icon--${feature.color}`}>
            <Icon name={feature.icon} size={22} />
          </div>
          {feature.badge && (
            <span class="feature-badge">{feature.badge}</span>
          )}
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
          <span class="feature-link">
            Learn more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-24) var(--space-6);
    background: var(--bg-primary);
  }

  @media (min-width: 768px) {
    .features {
      padding: var(--space-32) var(--space-8);
    }
  }

  .features-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .features-header {
      margin-bottom: var(--space-20);
    }
  }

  .features-title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .title-highlight {
    color: var(--color-primary);
    font-style: italic;
  }

  .features-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .features-subtitle {
      font-size: var(--text-xl);
    }
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }
  }

  .feature-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all 0.2s ease;
    animation: fadeInUp 0.5s ease backwards;
    animation-delay: var(--delay);
  }

  @media (min-width: 768px) {
    .feature-card {
      padding: var(--space-8);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .feature-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--card-hover-shadow);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-bottom: var(--space-5);
    border-radius: var(--radius-lg);
    color: white;
  }

  .feature-icon--orange {
    background: linear-gradient(135deg, #D97757, #B4533E);
  }

  .feature-icon--blue {
    background: linear-gradient(135deg, #3B82F6, #1D4ED8);
  }

  .feature-icon--teal {
    background: linear-gradient(135deg, #14B8A6, #0D9488);
  }

  .feature-icon--green {
    background: linear-gradient(135deg, #10B981, #059669);
  }

  .feature-badge {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    padding: 4px 10px;
    background: var(--color-primary);
    color: white;
    font-size: 11px;
    font-weight: 500;
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
  }

  .feature-title {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .feature-description {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    flex-grow: 1;
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    transition: gap 0.2s ease;
  }

  .feature-card:hover .feature-link {
    gap: var(--space-3);
  }

  .feature-link svg {
    transition: transform 0.2s ease;
  }

  .feature-card:hover .feature-link svg {
    transform: translateX(2px);
  }
</style>
