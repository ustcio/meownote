---
const products = [
  {
    name: 'Chat',
    eyebrow: 'Everyday collaboration',
    description: 'Draft, reframe, and think things through — in a conversation that feels like working with a thoughtful colleague.',
    points: ['Clearer writing', 'Better summaries', 'Faster iteration'],
  },
  {
    name: 'Workspace',
    eyebrow: 'Long-form thinking',
    description: 'Quick chats become living documents. Keep notes, briefs, and drafts in one place you can come back to.',
    points: ['Living notes', 'Reusable briefs', 'Organised context'],
  },
  {
    name: 'Research',
    eyebrow: 'Deeper exploration',
    description: 'Pull threads, compare findings, and turn scattered research into something structured enough to act on.',
    points: ['Evidence-first', 'Structured output', 'Fewer tabs open'],
  },
];
---

<section id="features" class="claude-section">
  <div class="container">
    <div class="claude-section-heading">
      <span class="claude-kicker">Built for the work behind the work</span>
      <h2>Three surfaces. One steady workflow.</h2>
      <p>
        Every block on this page has one job. Fewer tricks, better pacing, more room for the actual message.
      </p>
    </div>

    <div class="models-layout">
      <div class="models-grid">
        {products.map((product) => (
          <article class="model-card claude-editorial-card">
            <span class="model-card__eyebrow">{product.eyebrow}</span>
            <h3>{product.name}</h3>
            <p>{product.description}</p>
            <ul>
              {product.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <aside class="models-aside claude-editorial-card">
        <span class="models-aside__label">Why this design</span>
        <p>
          Softer contrast, larger editorial headings, restrained colour, and cards that read like product notes instead of dashboard tiles.
        </p>
        <div class="models-aside__actions">
          <a href="/chatbot" class="claude-button">Try chat</a>
          <a href="/workspace" class="claude-button-secondary">Workspace</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .models-layout {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 1100px) {
    .models-layout {
      grid-template-columns: minmax(0, 1.3fr) minmax(16rem, 0.7fr);
      align-items: start;
    }
  }

  .models-grid {
    display: grid;
    gap: 0.9rem;
  }

  @media (min-width: 700px) {
    .models-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .model-card {
    padding: 1.5rem;
    display: grid;
    gap: 0.75rem;
    min-height: 100%;
  }

  .model-card__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .model-card h3 {
    font-size: var(--text-2xl);
  }

  .model-card p {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.55;
  }

  .model-card ul {
    list-style: none;
    display: grid;
    gap: 0.5rem;
    padding-top: 0.3rem;
  }

  .model-card li {
    position: relative;
    padding-left: 0.95rem;
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .model-card li::before {
    content: '';
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .models-aside {
    padding: 1.5rem;
    display: grid;
    gap: 0.8rem;
    background: var(--card-bg-cream);
  }

  .models-aside__label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .models-aside p {
    font-size: var(--text-base);
    margin: 0;
    line-height: 1.55;
  }

  .models-aside__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
</style>
