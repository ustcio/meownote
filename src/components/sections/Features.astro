---
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    title: 'Thoughtful conversations',
    description: 'Engage in meaningful dialogue with an AI that remembers context and understands nuance.'
  },
  {
    title: 'Your data, your rules',
    description: 'Built with privacy at its core. Your conversations stay private, always.'
  },
  {
    title: 'Instant responses',
    description: 'Get answers in milliseconds, not minutes. Stay in your flow.'
  },
  {
    title: 'Built for makers',
    description: 'From code to prose, tools that adapt to how you work best.'
  },
];
---

<section class="features" id="features">
  <div class="features-container">
    <div class="features-header">
      <h2 class="features-title">
        Everything you need,<br />nothing you don't
      </h2>
    </div>
    
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-item">
          <h3 class="feature-item-title">{feature.title}</h3>
          <p class="feature-item-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-24) var(--space-6);
    background: var(--bg-secondary);
  }

  @media (min-width: 768px) {
    .features {
      padding: var(--space-32) var(--space-8);
    }
  }

  .features-container {
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .features-header {
      margin-bottom: var(--space-20);
    }
  }

  .features-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl));
    font-weight: var(--font-normal);
    line-height: 1.2;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    max-width: var(--container-wide);
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-12) var(--space-8);
    }
  }

  .feature-item {
    text-align: center;
  }

  @media (min-width: 640px) {
    .feature-item {
      text-align: left;
    }
  }

  .feature-item-title {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .feature-item-description {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 320px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .feature-item-description {
      margin: 0;
    }
  }
</style>
