---
import Icon from '@components/ui/Icon.astro';
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    icon: 'message-circle',
    title: t('features.chat.title', lang),
    description: t('features.chat.desc', lang),
    link: '/chatbot',
    linkText: t('hero.cta.primary', lang)
  },
  {
    icon: 'server',
    title: t('claw.feature.deploy.title', lang),
    description: t('claw.feature.deploy.desc', lang),
    link: '/claw',
    linkText: t('hero.cta.primary', lang)
  },
  {
    icon: 'box',
    title: t('kit.title', lang),
    description: t('kit.subtitle', lang),
    link: '/kit',
    linkText: t('hero.cta.primary', lang)
  },
  {
    icon: 'shield',
    title: t('features.privacy.title', lang),
    description: t('features.privacy.desc', lang),
    link: '/about',
    linkText: t('hero.cta.secondary', lang)
  },
];
---

<section class="features" id="features">
  <div class="features-container">
    <div class="features-header">
      <span class="features-label">{t('features.label', lang)}</span>
      <h2 class="features-title">
        {t('features.title', lang)}
        <span class="highlight">{t('features.title.highlight', lang)}</span>
      </h2>
      <p class="features-subtitle">{t('features.subtitle', lang)}</p>
    </div>
    
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card hover-lift">
          <div class="feature-icon">
            <Icon name={feature.icon} size={24} />
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
          <a href={feature.link} class="feature-link">
            <span>{feature.linkText}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-16) var(--space-4);
    background: var(--bg-elevated);
  }

  @media (min-width: 768px) {
    .features {
      padding: var(--space-20) var(--space-4);
    }
  }

  .features-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .features-label {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--claude-cream);
    border: 1px solid rgba(217, 119, 87, 0.2);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .features-title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    line-height: 1.2;
  }

  .features-title .highlight {
    color: var(--color-primary);
  }

  .features-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .feature-card {
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    transition: transform var(--duration-normal) var(--ease-default),
                box-shadow var(--duration-normal) var(--ease-default),
                border-color var(--duration-normal) var(--ease-default);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-hover-shadow);
    border-color: var(--border-hover);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: var(--space-4);
    background: linear-gradient(135deg, var(--color-primary), var(--claude-orange-dark));
    border-radius: var(--radius-lg);
    color: white;
  }

  .feature-title {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .feature-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-primary);
    text-decoration: none;
    transition: gap var(--duration-fast) var(--ease-default);
  }

  .feature-link:hover {
    gap: var(--space-3);
  }

  .feature-link svg {
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .feature-link:hover svg {
    transform: translateX(2px);
  }
</style>
