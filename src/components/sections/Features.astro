---
const products = [
  {
    id: 1,
    name: "LiveChat",
    badge: "Most Popular",
    badgeColor: "#C06B3E",
    description: "Our most capable conversational model. Exceptional at complex analysis, coding, and nuanced dialogue with thoughtful responses.",
    capabilities: ["Advanced reasoning", "Code generation", "Long context", "Vision"]
  },
  {
    id: 2,
    name: "LiveFlash",
    badge: "Fastest",
    badgeColor: "#5B7E6A",
    description: "Near-instant responsiveness with strong performance for lightweight tasks and high-volume applications.",
    capabilities: ["Instant responses", "Cost-efficient", "Real-time tasks", "Summarization"]
  },
  {
    id: 3,
    name: "LivePro",
    badge: "Most Powerful",
    badgeColor: "#4A5E8A",
    description: "Highest-capability model for navigating complex problems, research-grade analysis, and open-ended creative work.",
    capabilities: ["Top intelligence", "Complex tasks", "Research-grade", "Deep analysis"]
  }
];
---

<section id="features" class="products">
  <div class="products-container">
    <div class="products-header">
      <div class="header-label">
        <span class="label-dot"></span>
        <span class="label-text">Products</span>
      </div>
      <h2 class="products-title">
        Meet <em>Claude</em>,<br />our family of AI models
      </h2>
      <p class="products-description">
        LiveClaw models are designed to be safe, accurate, and genuinely helpful for a wide range of tasks.
      </p>
    </div>

    <div class="products-grid">
      {products.map((product) => (
        <div class="product-card">
          <div class="product-header">
            <div class="product-icon">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 4L19.5 18H4.5L12 4Z" fill="#F0E9DC" />
              </svg>
            </div>
            <span class="product-badge" style={`color: ${product.badgeColor}; background: ${product.badgeColor}18;`}>
              {product.badge}
            </span>
          </div>
          
          <div class="product-content">
            <h3 class="product-name">{product.name}</h3>
            <p class="product-description">{product.description}</p>
          </div>
          
          <div class="product-tags">
            {product.capabilities.map((cap) => (
              <span class="product-tag">{cap}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="products-cta">
      <div class="cta-content">
        <h3 class="cta-title">Build with the LiveClaw API</h3>
        <p class="cta-description">
          Access LiveClaw models through our API and build powerful AI-native applications with enterprise-grade safety and reliability.
        </p>
      </div>
      <div class="cta-actions">
        <a href="#" class="cta-primary">Get API access</a>
        <a href="#" class="cta-secondary">View docs</a>
      </div>
    </div>
  </div>
</section>

<style>
  .products {
    background: #F0E9DC;
    padding: var(--space-28) var(--space-6);
  }

  @media (min-width: 768px) {
    .products {
      padding: var(--space-28) var(--space-10);
    }
  }

  .products-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .products-header {
    max-width: 640px;
    margin-bottom: var(--space-16);
  }

  .header-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .label-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #7A6A52;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .products-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: var(--font-normal);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1A1207;
    margin-bottom: var(--space-5);
  }

  .products-title em {
    font-style: italic;
  }

  .products-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: #6B5C42;
    line-height: 1.7;
  }

  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .product-card {
    border: 1px solid #D0C4B0;
    border-radius: 16px;
    background: #EDE5D4;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    transition: border-color var(--duration-normal) var(--ease-default);
    cursor: pointer;
  }

  .product-card:hover {
    border-color: #C4B9A5;
  }

  .product-card:hover .product-name {
    color: #C06B3E;
  }

  .product-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .product-icon {
    width: 40px;
    height: 40px;
    background: #1A1207;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-icon svg {
    width: 20px;
    height: 20px;
  }

  .product-badge {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .product-content {
    flex: 1;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: var(--font-normal);
    letter-spacing: -0.01em;
    color: #1A1207;
    margin-bottom: var(--space-2);
    transition: color var(--duration-normal) var(--ease-default);
  }

  .product-description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #6B5C42;
    line-height: 1.65;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }

  .product-tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #7A6A52;
    border: 1px solid #C4B9A5;
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-2);
  }

  .products-cta {
    background: #1A1207;
    border-radius: 20px;
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .products-cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 3.5rem;
    }
  }

  .cta-content {
    max-width: 512px;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: var(--font-normal);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #F0E9DC;
    margin-bottom: var(--space-3);
  }

  .cta-description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #A89880;
    line-height: 1.65;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .cta-actions {
      flex-direction: row;
    }
  }

  .cta-primary {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: 0.75rem 1.75rem;
    background: #C06B3E;
    color: #F0E9DC;
    border-radius: var(--radius-full);
    text-decoration: none;
    text-align: center;
    white-space: nowrap;
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .cta-primary:hover {
    background: #A85A32;
  }

  .cta-secondary {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: 0.75rem 1.75rem;
    color: #F0E9DC;
    border: 1px solid rgba(240, 233, 220, 0.2);
    border-radius: var(--radius-full);
    text-decoration: none;
    text-align: center;
    white-space: nowrap;
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .cta-secondary:hover {
    border-color: rgba(240, 233, 220, 0.5);
  }
</style>
