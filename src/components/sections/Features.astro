---
const products = [
  {
    name: 'Chat',
    eyebrow: 'Everyday collaboration',
    description: 'Use a warm, conversational interface for drafting, reframing, and thinking in public before you commit.',
    points: ['Clearer writing', 'Better summaries', 'Fast iteration'],
  },
  {
    name: 'Workspace',
    eyebrow: 'Long-form thinking',
    description: 'Move from quick answers to documents, notes, and project scaffolds you can keep refining over time.',
    points: ['Living notes', 'Reusable briefs', 'Organized context'],
  },
  {
    name: 'Research',
    eyebrow: 'Deeper exploration',
    description: 'Pull threads, compare options, and turn scattered findings into something coherent enough to act on.',
    points: ['Evidence-first', 'Structured output', 'Less context switching'],
  },
];
---

<section id="features" class="claude-section">
  <div class="container">
    <div class="claude-section-heading">
      <span class="claude-kicker">Built for the work behind the work</span>
      <h2>Three surfaces, one steady workflow.</h2>
      <p>
        Claude’s product pages feel editorial because every block has one job.
        Maxwell now follows the same rule: fewer gimmicks, better pacing, and
        more room for the actual message.
      </p>
    </div>

    <div class="models-layout">
      <div class="models-grid">
        {products.map((product) => (
          <article class="model-card claude-editorial-card">
            <span class="model-card__eyebrow">{product.eyebrow}</span>
            <h3>{product.name}</h3>
            <p>{product.description}</p>
            <ul>
              {product.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <aside class="models-aside claude-editorial-card">
        <span class="models-aside__label">Why this feels closer to Claude</span>
        <p>
          Softer contrast, larger editorial headings, restrained color, and
          cards that read like product notes instead of dashboard tiles.
        </p>
        <div class="models-aside__actions">
          <a href="/chatbot" class="claude-button">Try chat</a>
          <a href="/workspace" class="claude-button-secondary">Open workspace</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .models-layout {
    display: grid;
    gap: 1.2rem;
  }

  @media (min-width: 1100px) {
    .models-layout {
      grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.7fr);
      align-items: start;
    }
  }

  .models-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 760px) {
    .models-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .model-card,
  .models-aside {
    padding: 1.5rem;
  }

  .model-card {
    display: grid;
    gap: 0.9rem;
    min-height: 100%;
  }

  .model-card__eyebrow,
  .models-aside__label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .model-card h3 {
    font-size: 1.75rem;
  }

  .model-card p,
  .models-aside p {
    font-size: 0.98rem;
    margin: 0;
  }

  .model-card ul {
    list-style: none;
    display: grid;
    gap: 0.6rem;
    margin-top: 0.35rem;
  }

  .model-card li {
    position: relative;
    padding-left: 1rem;
    color: var(--text-secondary);
    font-size: 0.94rem;
  }

  .model-card li::before {
    content: '';
    position: absolute;
    top: 0.62rem;
    left: 0;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .models-aside {
    display: grid;
    gap: 1rem;
    background: var(--card-bg-cream);
  }

  .models-aside__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
