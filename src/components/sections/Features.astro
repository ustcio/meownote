---
import Icon from '@components/ui/Icon.astro';
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);

const features = [
  {
    icon: 'message-circle',
    title: t('features.chat.title', lang),
    description: t('features.chat.desc', lang),
    link: '/chatbot',
    linkText: t('hero.cta.primary', lang),
    color: 'orange'
  },
  {
    icon: 'server',
    title: t('claw.feature.deploy.title', lang),
    description: t('claw.feature.deploy.desc', lang),
    link: '/claw',
    linkText: t('hero.cta.primary', lang),
    color: 'blue',
    badge: 'New'
  },
  {
    icon: 'box',
    title: t('kit.title', lang),
    description: t('kit.subtitle', lang),
    link: '/kit',
    linkText: t('hero.cta.primary', lang),
    color: 'purple'
  },
  {
    icon: 'shield',
    title: t('features.privacy.title', lang),
    description: t('features.privacy.desc', lang),
    link: '/about',
    linkText: t('hero.cta.secondary', lang),
    color: 'green'
  },
];
---

<section class="features" id="features">
  <div class="features-container">
    <div class="features-header">
      <h2 class="features-title">
        {t('features.title', lang)}
      </h2>
      <p class="features-subtitle">{t('features.subtitle', lang)}</p>
    </div>
    
    <div class="features-grid">
      {features.map((feature, index) => (
        <a href={feature.link} class="feature-card" style={`--delay: ${index * 0.1}s`}>
          <div class={`feature-icon feature-icon--${feature.color}`}>
            <Icon name={feature.icon} size={24} />
          </div>
          {feature.badge && (
            <span class="feature-badge">{feature.badge}</span>
          )}
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
          <span class="feature-link">
            <span>{feature.linkText}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: var(--space-16) var(--space-4);
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-elevated) 100%);
  }

  @media (min-width: 768px) {
    .features {
      padding: var(--space-24) var(--space-6);
    }
  }

  .features-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .features-title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    line-height: 1.2;
  }

  .features-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }
  }

  .feature-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
    animation: fadeInUp 0.5s var(--ease-out) backwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-hover-shadow);
    border-color: var(--border-hover);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
    border-radius: var(--radius-lg);
    color: white;
  }

  .feature-icon--orange {
    background: linear-gradient(135deg, var(--color-primary), var(--claude-orange-dark));
  }

  .feature-icon--blue {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
  }

  .feature-icon--purple {
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
  }

  .feature-icon--green {
    background: linear-gradient(135deg, #10b981, #059669);
  }

  .feature-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: 2px 8px;
    background: var(--color-primary);
    color: white;
    font-size: 10px;
    font-weight: var(--font-semibold);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .feature-title {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .feature-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    flex-grow: 1;
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-primary);
    transition: gap var(--duration-fast) var(--ease-default);
  }

  .feature-card:hover .feature-link {
    gap: var(--space-3);
  }

  .feature-link svg {
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .feature-card:hover .feature-link svg {
    transform: translateX(2px);
  }
</style>
