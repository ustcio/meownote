---
const researchAreas = [
  {
    icon: '⚛️',
    title: 'Quantum Transport',
    desc: 'Topological materials, edge states, and quantum Hall effects in novel 2D systems.',
  },
  {
    icon: '🔬',
    title: 'Optoelectronic Properties',
    desc: 'Photoelectric response, phonon dynamics, and carrier dynamics in layered compounds.',
  },
  {
    icon: '📡',
    title: 'Detector Development',
    desc: 'Nb₃I₈-based radiation detectors with enhanced sensitivity and stability.',
  },
  {
    icon: '🧮',
    title: 'Computational Methods',
    desc: 'First-principles calculations, DFT+U, and transport simulations for complex materials.',
  },
];

const publications = [
  { year: '2025', title: 'Phonon-mediated transport in CoNb₃S₆', venue: 'Phys. Rev. B' },
  { year: '2024', title: 'Hall effect anomalies in ZrAs₂ thin films', venue: 'Adv. Mater.' },
  { year: '2024', title: 'Nb₃I₈ detector response characterization', venue: 'Appl. Phys. Lett.' },
  { year: '2023', title: 'Topological signatures in layered arsenides', venue: 'Nat. Commun.' },
];
---

<section class="social-proof">
  <div class="container">
    <div class="sp-heading">
      <span class="sp-kicker">Research Focus</span>
      <h2>What I work on.</h2>
      <p>
        Condensed matter physics — from quantum transport measurements to detector engineering.
      </p>
    </div>

    <div class="sp-grid">
      {researchAreas.map((area) => (
        <article class="sp-card">
          <span class="sp-card-icon">{area.icon}</span>
          <h3>{area.title}</h3>
          <p>{area.desc}</p>
        </article>
      ))}
    </div>

    <div class="sp-pubs">
      <span class="sp-pubs-label">Selected Publications</span>
      <div class="sp-pubs-list">
        {publications.map((pub) => (
          <div class="sp-pub-item">
            <span class="sp-pub-year">{pub.year}</span>
            <span class="sp-pub-title">{pub.title}</span>
            <span class="sp-pub-venue">{pub.venue}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .social-proof {
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-secondary);
  }

  .sp-heading {
    text-align: center;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }

  .sp-kicker {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .sp-kicker::before {
    content: '';
    width: 0.36rem; height: 0.36rem;
    border-radius: 50%;
    background: var(--color-primary);
    margin-right: 0.5rem;
  }

  .sp-heading h2 {
    margin-top: 0.4rem;
  }

  .sp-heading p {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .sp-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  @media (min-width: 640px) {
    .sp-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 960px) {
    .sp-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  .sp-card {
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: var(--card-bg);
    border: 1px solid var(--border-secondary);
    display: grid;
    gap: 0.65rem;
    transition:
      border-color var(--duration-normal) var(--ease-default),
      box-shadow var(--duration-normal) var(--ease-default),
      transform var(--duration-normal) var(--ease-default);
  }

  .sp-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .sp-card-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.2rem;
  }

  .sp-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    letter-spacing: -0.02em;
  }

  .sp-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  /* publications */
  .sp-pubs {
    max-width: 40rem;
    margin: 0 auto;
  }

  .sp-pubs-label {
    display: block;
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .sp-pubs-list {
    display: grid;
    gap: 0.6rem;
  }

  .sp-pub-item {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background: var(--card-bg);
    border: 1px solid var(--border-secondary);
    transition: border-color var(--duration-fast) var(--ease-default);
  }

  .sp-pub-item:hover {
    border-color: var(--border-hover);
  }

  .sp-pub-year {
    font-size: 0.78rem;
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    font-family: var(--font-display);
  }

  .sp-pub-title {
    font-size: 0.9rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .sp-pub-venue {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-style: italic;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .sp-pub-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
    .sp-pub-venue {
      font-size: 0.72rem;
    }
  }
</style>
