---
/**
 * Claude 风格 Hero 组件
 * 
 * 设计特点:
 * - 温暖的奶油色/白色背景
 * - 柔和的阴影和圆角
 * - 大字体、清晰的标题
 * - 简洁专业的排版
 * - 温暖的橙色强调色
 */
export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  showStats?: boolean;
}

const {
  title = '构建安全的 AI，造福人类',
  subtitle = 'Claude AI',
  description = '我们致力于构建安全、可靠、有益的 AI 系统，让技术真正服务于人类。',
  ctaText = '开始对话',
  ctaHref = '/chatbot',
  secondaryCtaText = '了解更多',
  secondaryCtaHref = '/about',
  showStats = true,
} = Astro.props;
---

<section class="claude-hero">
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">
        <svg class="badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        <span class="badge-text">{subtitle}</span>
      </div>
      
      <h1 class="hero-title">{title}</h1>
      
      <p class="hero-description">{description}</p>
      
      <div class="hero-actions">
        <a href={ctaHref} class="btn btn-primary">
          {ctaText}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href={secondaryCtaHref} class="btn btn-secondary">
          {secondaryCtaText}
        </a>
      </div>
      
      {showStats && (
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-value">100K+</div>
            <div class="stat-label">活跃用户</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-value">99.9%</div>
            <div class="stat-label">可用性</div>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <div class="stat-value">50M+</div>
            <div class="stat-label">API 调用</div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .claude-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #FFFFFF;
    padding: 80px 20px;
  }

  .hero-container {
    max-width: 900px;
    width: 100%;
  }

  .hero-content {
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: #F9F9F9;
    border: 1px solid #E5E5E5;
    border-radius: 100px;
    margin-bottom: 32px;
  }

  .badge-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .badge-text {
    font-size: 14px;
    font-weight: 500;
    color: #4A4A4A;
  }

  .hero-title {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1A1A1A;
    margin-bottom: 24px;
  }

  .hero-description {
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.6;
    color: #6A6A6A;
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 64px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: #D97757;
    color: #FFFFFF;
    box-shadow: 0 2px 8px rgba(217, 119, 87, 0.2);
  }

  .btn-primary:hover {
    background: #C46A4A;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(217, 119, 87, 0.3);
  }

  .btn-secondary {
    background: #FFFFFF;
    color: #1A1A1A;
    border: 1px solid #E5E5E5;
  }

  .btn-secondary:hover {
    background: #F9F9F9;
    border-color: #D4D4D4;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    padding: 24px;
    background: #F9F9F9;
    border: 1px solid #E5E5E5;
    border-radius: 16px;
  }

  .stat {
    text-align: center;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 700;
    color: #D97757;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 14px;
    color: #8A8A8A;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: #E5E5E5;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .claude-hero {
      padding: 60px 16px;
      min-height: auto;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .hero-stats {
      flex-direction: column;
      gap: 16px;
    }

    .stat-divider {
      width: 40px;
      height: 1px;
    }
  }
</style>
