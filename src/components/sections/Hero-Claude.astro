---
---

<section class="hero-claude">
  <div class="hero-claude-container">
    <div class="hero-claude-content">
      <div class="hero-claude-badge">
        <span class="badge-dot"></span>
        <span>AI 驱动的未来体验</span>
      </div>
      
      <h1 class="hero-claude-title">
        数据之梦觉醒
      </h1>
      
      <p class="hero-claude-subtitle">
        探索机器智能与人类想象力的交汇点。我们打造沉浸式 AI 体验，让数据化为流动的艺术。
      </p>
      
      <div class="hero-claude-actions">
        <a href="/chatbot" class="hero-claude-btn-primary">
          <span>开始探索</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href="#features" class="hero-claude-btn-secondary">
          <span>了解更多</span>
        </a>
      </div>
      
      <div class="hero-claude-stats">
        <div class="stat-claude-item">
          <span class="stat-claude-number">50+</span>
          <span class="stat-claude-label">AI 模型</span>
        </div>
        <div class="stat-claude-divider"></div>
        <div class="stat-claude-item">
          <span class="stat-claude-number">100K+</span>
          <span class="stat-claude-label">用户</span>
        </div>
        <div class="stat-claude-divider"></div>
        <div class="stat-claude-item">
          <span class="stat-claude-number">99%</span>
          <span class="stat-claude-label">满意度</span>
        </div>
      </div>
    </div>
    
    <div class="hero-claude-visual">
      <div class="visual-claude-container">
        <div class="claude-shape shape-1"></div>
        <div class="claude-shape shape-2"></div>
        <div class="claude-shape shape-3"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-claude {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    background-color: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .hero-claude {
      padding: 140px 48px 100px;
    }
  }

  .hero-claude-container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 1024px) {
    .hero-claude-container {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 80px;
    }
  }

  .hero-claude-content {
    text-align: center;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 1024px) {
    .hero-claude-content {
      text-align: left;
    }
  }

  .hero-claude-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background-color: var(--color-primary-light);
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 32px;
    animation: fadeInDown 0.6s ease forwards;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background-color: #10B981;
    border-radius: 50%;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-claude-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 24px;
    animation: fadeInUp 0.6s ease 0.1s forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-claude-subtitle {
    font-family: var(--font-sans);
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeInUp 0.6s ease 0.2s forwards;
    opacity: 0;
  }

  @media (min-width: 1024px) {
    .hero-claude-subtitle {
      margin-left: 0;
      margin-right: 0;
    }
  }

  .hero-claude-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    margin-bottom: 48px;
    animation: fadeInUp 0.6s ease 0.3s forwards;
    opacity: 0;
  }

  @media (min-width: 480px) {
    .hero-claude-actions {
      flex-direction: row;
      justify-content: center;
      gap: 16px;
    }
  }

  @media (min-width: 1024px) {
    .hero-claude-actions {
      justify-content: flex-start;
    }
  }

  .hero-claude-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--btn-primary-text);
    background-color: var(--btn-primary-bg);
    border-radius: 8px;
    text-decoration: none;
    transition: all 200ms ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .hero-claude-btn-primary:hover {
    background-color: var(--btn-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .hero-claude-btn-primary svg {
    transition: transform 200ms ease;
  }

  .hero-claude-btn-primary:hover svg {
    transform: translateX(4px);
  }

  .hero-claude-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--btn-secondary-text);
    background-color: transparent;
    border: 1px solid var(--btn-secondary-border);
    border-radius: 8px;
    text-decoration: none;
    transition: all 200ms ease;
  }

  .hero-claude-btn-secondary:hover {
    background-color: var(--btn-secondary-hover-bg);
    border-color: var(--border-hover);
  }

  .hero-claude-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    animation: fadeInUp 0.6s ease 0.4s forwards;
    opacity: 0;
  }

  @media (min-width: 1024px) {
    .hero-claude-stats {
      justify-content: flex-start;
    }
  }

  .stat-claude-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  @media (min-width: 1024px) {
    .stat-claude-item {
      align-items: flex-start;
    }
  }

  .stat-claude-number {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
  }

  .stat-claude-label {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .stat-claude-divider {
    width: 1px;
    height: 32px;
    background-color: var(--border-primary);
  }

  .hero-claude-visual {
    display: none;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 1024px) {
    .hero-claude-visual {
      display: block;
    }
  }

  .visual-claude-container {
    position: relative;
    width: 100%;
    height: 400px;
    animation: fadeIn 0.8s ease 0.5s forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  .claude-shape {
    position: absolute;
    border-radius: 12px;
    opacity: 0.6;
  }

  .shape-1 {
    width: 200px;
    height: 200px;
    background-color: var(--color-primary-light);
    top: 10%;
    left: 10%;
    transform: rotate(-15deg);
  }

  .shape-2 {
    width: 150px;
    height: 150px;
    background-color: var(--color-primary);
    opacity: 0.2;
    top: 30%;
    right: 20%;
    transform: rotate(10deg);
  }

  .shape-3 {
    width: 120px;
    height: 120px;
    background-color: var(--card-bg);
    border: 2px solid var(--border-primary);
    bottom: 20%;
    left: 30%;
    transform: rotate(-5deg);
  }
</style>
