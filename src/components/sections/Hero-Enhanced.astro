---
const quickActions = [
  { label: 'Write', href: '/chatbot', icon: '✏️' },
  { label: 'Plan', href: '/workspace', icon: '📋' },
  { label: 'Research', href: '/research', icon: '🔍' },
  { label: 'Tools', href: '/kit', icon: '🛠️' },
];
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <div class="hero__kicker">
        <span>Thoughtful AI for serious work</span>
      </div>

      <h1 class="hero__title">
        AI that writes, plans, and thinks with you.
      </h1>

      <p class="hero__lead">
        Maxwell helps you draft cleaner writing, untangle messy problems, and move real work forward — without the usual AI theater.
      </p>

      <form class="hero__composer" action="/chatbot">
        <input
          type="text"
          name="q"
          value=""
          placeholder="Ask Maxwell to outline, draft, or explain..."
          aria-label="Prompt"
          autocomplete="off"
        />
        <button type="submit">Start</button>
      </form>

      <div class="hero__chips">
        {quickActions.map((action) => (
          <a href={action.href} class="hero__chip">
            <span class="hero__chip-icon">{action.icon}</span>
            {action.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(var(--header-height) + 7rem);
    padding-bottom: 6.5rem;
    overflow: hidden;
  }

  .hero__inner {
    max-width: 44rem;
    position: relative;
  }

  /* -------- kicker -------- */
  .hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: heroFadeUp 0.6s var(--ease-default) both;
  }

  .hero__kicker::before {
    content: '';
    display: inline-block;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--color-primary);
    margin-right: 0.55rem;
    box-shadow: 0 0 0 4px rgba(212, 117, 90, 0.12);
  }

  /* -------- title -------- */
  .hero__title {
    opacity: 0;
    animation: heroFadeUp 0.7s var(--ease-default) 0.12s both;
  }

  /* -------- lead -------- */
  .hero__lead {
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 34rem;
    margin-top: 1.1rem;
    margin-bottom: 0;
    opacity: 0;
    animation: heroFadeUp 0.7s var(--ease-default) 0.24s both;
  }

  /* -------- composer -------- */
  .hero__composer {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0;
    max-width: 32rem;
    margin-top: 1.8rem;
    padding: 0.35rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-primary);
    background: var(--card-bg);
    box-shadow: var(--shadow-md);
    opacity: 0;
    animation: heroFadeUp 0.7s var(--ease-default) 0.36s both;
    transition:
      box-shadow var(--duration-normal) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default);
  }

  .hero__composer:focus-within {
    box-shadow: 0 0 0 3px var(--input-focus-ring), var(--shadow-md);
    border-color: var(--color-primary);
  }

  .hero__composer input {
    border: none;
    background: transparent;
    padding: 0.8rem 1rem;
    box-shadow: none;
    font-size: 0.92rem;
  }

  .hero__composer input:focus {
    outline: none;
    box-shadow: none;
  }

  .hero__composer button {
    min-height: 2.65rem;
    padding: 0.7rem 1.35rem;
    border-radius: calc(var(--radius-xl) * 0.7);
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-size: 0.875rem;
    font-weight: var(--font-medium);
    letter-spacing: -0.01em;
    box-shadow: var(--btn-primary-shadow);
    transition:
      background var(--duration-fast) var(--ease-default),
      transform var(--duration-fast) var(--ease-default);
  }

  .hero__composer button:hover {
    background: var(--btn-primary-hover);
    transform: translateY(-1px);
  }

  /* -------- chips -------- */
  .hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
    opacity: 0;
    animation: heroFadeUp 0.7s var(--ease-default) 0.48s both;
  }

  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 1.85rem;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-secondary);
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.82rem;
    font-weight: var(--font-medium);
    transition:
      background var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      color var(--duration-fast) var(--ease-default),
      transform var(--duration-fast) var(--ease-default);
  }

  .hero__chip:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-color: var(--border-primary);
    transform: translateY(-1px);
  }

  .hero__chip-icon {
    font-size: 0.9rem;
    line-height: 1;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 639px) {
    .hero {
      padding-top: calc(var(--header-height) + 4rem);
      padding-bottom: 4rem;
    }

    .hero__composer {
      grid-template-columns: 1fr;
    }

    .hero__composer button {
      margin: 0 0.25rem 0.25rem;
    }
  }
</style>
