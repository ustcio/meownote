---
const quickActions = [
  { label: 'Chat', href: '/chatbot' },
  { label: 'Workspace', href: '/workspace' },
  { label: 'Kit', href: '/kit' },
  { label: 'Claw', href: '/claw' },
];
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <div class="hero__kicker">Thoughtful AI for serious work</div>
      <h1 class="hero__title">
        <span class="hero__line">Bring calm, capable AI</span>
        <span class="hero__line hero__line--accent">into your day.</span>
      </h1>
      <p class="hero__lead">
        Maxwell helps you think through messy problems, draft stronger writing, and move work forward — without turning your tools into a circus.
      </p>
      <form class="hero__composer" action="/chatbot">
        <input
          type="text"
          name="q"
          placeholder="Ask Maxwell to outline a plan, clean up a draft, or explain a concept"
          aria-label="Prompt"
        />
        <button type="submit">Start</button>
      </form>
      <div class="hero__chips">
        {quickActions.map((a) => (
          <a href={a.href} class="hero__chip">{a.label}</a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--header-height) + 4.5rem) 0 4rem;
    overflow: hidden;
  }

  .hero__inner {
    max-width: 42rem;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* kicker */
  .hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .hero__kicker::before {
    content: '';
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 6px var(--color-primary-alpha-30);
  }

  /* title */
  .hero__title {
    display: flex;
    flex-direction: column;
    gap: 0;
    line-height: 0.95;
  }

  .hero__line {
    opacity: 0;
    animation: heroFadeUp 0.6s var(--ease-default) both;
  }

  .hero__line:nth-child(1) { animation-delay: 0.08s; }
  .hero__line:nth-child(2) { animation-delay: 0.22s; }

  .hero__line--accent {
    background: linear-gradient(120deg, var(--color-primary) 0%, var(--color-accent-pink) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* lead */
  .hero__lead {
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 30rem;
    margin: 0;
    opacity: 0;
    animation: heroFadeUp 0.6s var(--ease-default) 0.36s both;
  }

  /* composer */
  .hero__composer {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0;
    max-width: 30rem;
    padding: 0.3rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-primary);
    background: var(--card-bg);
    opacity: 0;
    animation: heroFadeUp 0.6s var(--ease-default) 0.5s both;
    transition: border-color var(--duration-fast) var(--ease-default),
                box-shadow var(--duration-fast) var(--ease-default);
  }

  .hero__composer:focus-within {
    box-shadow: 0 0 0 3px var(--input-focus-ring);
    border-color: var(--color-primary);
  }

  .hero__composer input {
    border: none;
    background: transparent;
    padding: 0.7rem 0.9rem;
    font-size: 0.92rem;
    box-shadow: none;
  }

  .hero__composer input:focus { box-shadow: none; }

  .hero__composer button {
    min-height: 2.6rem;
    padding: 0.65rem 1.2rem;
    border-radius: calc(var(--radius-xl) * 0.65);
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-size: 0.85rem;
    font-weight: var(--font-medium);
    box-shadow: var(--btn-primary-shadow);
    transition: background var(--duration-fast) var(--ease-default),
                transform var(--duration-fast) var(--ease-default);
  }

  .hero__composer button:hover {
    background: var(--btn-primary-hover);
    transform: translateY(-1px);
  }

  /* chips */
  .hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
    opacity: 0;
    animation: heroFadeUp 0.6s var(--ease-default) 0.64s both;
  }

  .hero__chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-secondary);
    font-size: 0.82rem;
    font-weight: var(--font-medium);
    color: var(--text-tertiary);
    background: transparent;
    transition: all var(--duration-fast) var(--ease-default);
  }

  .hero__chip:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-color: var(--border-primary);
    transform: translateY(-1px);
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 639px) {
    .hero { padding-top: calc(var(--header-height) + 3rem); padding-bottom: 3rem; }
    .hero__composer { grid-template-columns: 1fr; }
    .hero__composer button { margin: 0 0.2rem 0.2rem; }
  }
</style>
