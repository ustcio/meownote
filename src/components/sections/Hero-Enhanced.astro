---
import AbstractThread from '@components/ui/AbstractThread.astro';
import TextReveal from '@components/ui/TextReveal.astro';

const trustLines = [
  'Trusted by researchers, designers, and students worldwide.',
  'Free to get started · No credit card required · Cancel anytime',
];
---

<section class="hero">
  <!-- ambient background -->
  <div class="hero__ambient" aria-hidden="true">
    <span class="hero__dot" style="--x: 10%; --y: 25%; --s: 4px; --delay: 0s"></span>
    <span class="hero__dot" style="--x: 90%; --y: 20%; --s: 6px; --delay: 0.5s"></span>
    <span class="hero__dot" style="--x: 50%; --y: 70%; --s: 5px; --delay: 1s"></span>
    <span class="hero__dot" style="--x: 80%; --y: 80%; --s: 3px; --delay: 1.5s"></span>
  </div>

  <div class="container">
    <div class="hero__grid">
      <!-- left: copy -->
      <div class="hero__copy">
        <h1 class="hero__title">Meet your<br/>thinking partner</h1>

        <p class="hero__subtitle">Tackle any big, bold, bewildering challenge with Claude.</p>

        <div class="hero__input-container">
          <input type="text" class="hero__input" placeholder="How can I help you today?" />
          <button class="hero__submit">Ask Claude <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg></button>
        </div>

        <div class="hero__chips">
          <button class="hero__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg> Write
          </button>
          <button class="hero__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg> Learn
          </button>
          <button class="hero__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg> Code
          </button>
        </div>
      </div>

      <!-- right: animated abstract thread visualization -->
      <div class="hero__visual" aria-hidden="true">
        <AbstractThread />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 3rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: calc(var(--header-height) + 3rem);
      padding-bottom: 4rem;
    }
  }

  .hero__ambient {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: -1;
  }

  .hero__dot {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.08;
    animation: heroDotFloat 10s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes heroDotFloat {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.08; }
    50% { transform: translateY(-30px) scale(1.5); opacity: 0.15; }
  }

  .hero__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 3rem;
    }
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
  }

  .hero__title {
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    font-weight: 500;
    color: var(--text-primary);
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.1s both;
  }

  .hero__subtitle {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    line-height: 1.5;
    color: var(--text-secondary);
    margin-top: 1.2rem;
    margin-bottom: 2.5rem;
    max-width: 32rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.24s both;
  }

  .hero__input-container {
    display: flex;
    align-items: center;
    background: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 12px;
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    max-width: 36rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.36s both;
  }
  
  [data-theme='dark'] .hero__input-container {
    background: #111;
    border-color: #333;
  }

  .hero__input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1rem;
    color: var(--text-primary);
    outline: none;
    width: 100%;
  }

  .hero__input::placeholder {
    color: #999;
  }

  .hero__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #D97757;
    color: white;
    border: none;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }

  .hero__submit:hover {
    background: #c2674b;
  }

  .hero__chips {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.48s both;
  }

  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #F5F5F5;
    border: 1px solid transparent;
    color: #444;
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  [data-theme='dark'] .hero__chip {
    background: #222;
    color: #CCC;
  }

  .hero__chip:hover {
    background: #EAEAEA;
    border-color: #DDD;
  }

  [data-theme='dark'] .hero__chip:hover {
    background: #333;
    border-color: #444;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero__visual {
    position: relative;
    display: none;
  }

  @media (min-width: 900px) {
    .hero__visual {
      display: block;
    }
  }

  .hero__preview {
    background: var(--card-bg);
    border: 1px solid var(--border-primary);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    opacity: 0;
    animation: heroPreviewIn 0.8s var(--ease-out) 0.4s both;
  }

  @keyframes heroPreviewIn {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .preview__header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-primary);
  }

  .preview__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .preview__dot--red { background: #ff5f57; }
  .preview__dot--yellow { background: #febc2e; }
  .preview__dot--green { background: #28c840; }

  .preview__title {
    margin-left: 8px;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-quaternary);
  }

  .preview__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 220px;
  }

  .preview__msg {
    padding: 10px 12px;
    border-radius: 10px;
    max-width: 85%;
    animation: msgIn 0.5s var(--ease-out) both;
  }

  .preview__msg--user {
    align-self: flex-end;
    background: var(--color-primary-alpha-10);
    animation-delay: 0.8s;
  }

  .preview__msg--ai {
    align-self: flex-start;
    background: var(--bg-secondary);
    animation-delay: 1.6s;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .preview__msg-label {
    display: block;
    font-size: 0.65rem;
    font-weight: var(--font-semibold);
    color: var(--text-quaternary);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .preview__msg p {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-primary);
    margin: 0;
  }

  .preview__typing {
    display: flex;
    gap: 4px;
    padding: 4px 0;
  }

  .preview__typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: typingBounce 1.2s ease-in-out infinite;
    animation-delay: var(--d);
  }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.3; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  .preview__response {
    font-weight: var(--font-medium);
    margin-top: 6px !important;
  }

  .preview__response-list {
    margin: 6px 0 0 0;
    padding-left: 16px;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .preview__response-list li {
    margin-bottom: 2px;
  }

  .hero__float {
    position: absolute;
    z-index: 2;
  }

  .hero__float--card1 {
    top: -12px;
    right: -20px;
    animation: floatCard1 6s ease-in-out infinite;
  }

  .hero__float--card2 {
    bottom: 40px;
    left: -30px;
    animation: floatCard2 7s ease-in-out infinite;
    animation-delay: 1s;
  }

  .hero__float--card3 {
    bottom: -10px;
    right: 40px;
    animation: floatCard3 8s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes floatCard1 {
    0%, 100% { transform: translateY(0) rotate(2deg); }
    50% { transform: translateY(-10px) rotate(-1deg); }
  }

  @keyframes floatCard2 {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-8px) rotate(1deg); }
  }

  @keyframes floatCard3 {
    0%, 100% { transform: translateY(0) rotate(1deg); }
    50% { transform: translateY(-12px) rotate(-2deg); }
  }

  .float-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--card-bg);
    border: 1px solid var(--border-primary);
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .float-card__icon {
    font-size: 1rem;
  }

  [data-theme="dark"] .hero__preview {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  [data-theme="dark"] .float-card {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
</style>
