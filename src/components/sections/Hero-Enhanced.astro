---
const trustLines = [
  'Trusted by researchers, designers, and students worldwide.',
  'Free to get started · No credit card required · Cancel anytime',
];
---

<section class="hero">
  <!-- ambient background -->
  <div class="hero__ambient" aria-hidden="true">
    <span class="hero__dot" style="--x: 10%; --y: 25%; --s: 4px; --delay: 0s"></span>
    <span class="hero__dot" style="--x: 90%; --y: 20%; --s: 6px; --delay: 0.5s"></span>
    <span class="hero__dot" style="--x: 50%; --y: 70%; --s: 5px; --delay: 1s"></span>
    <span class="hero__dot" style="--x: 80%; --y: 80%; --s: 3px; --delay: 1.5s"></span>
  </div>

  <div class="container">
    <div class="hero__grid">
      <!-- left: copy -->
      <div class="hero__copy">
        <span class="hero__badge">
          <span class="hero__badge-dot"></span>
          <span class="hero__badge-text">Now powered by Max AI</span>
        </span>

        <h1 class="hero__title">
          AI that thinks.<br>You decide.
        </h1>

        <p class="hero__subtitle">
          Write clearly. Plan confidently. Research thoroughly — in one calm, capable workspace.
        </p>

        <div class="hero__actions">
          <a href="/chatbot/" class="hero__btn hero__btn--primary">Start free</a>
          <a href="/workspace/" class="hero__btn hero__btn--ghost">Explore workspace</a>
        </div>

        <p class="hero__trust">{trustLines[0]}</p>
      </div>

      <!-- right: animated preview -->
      <div class="hero__visual" aria-hidden="true">
        <div class="hero__preview">
          <!-- fake chat UI -->
          <div class="preview__header">
            <span class="preview__dot preview__dot--red"></span>
            <span class="preview__dot preview__dot--yellow"></span>
            <span class="preview__dot preview__dot--green"></span>
            <span class="preview__title">Maxwell Chat</span>
          </div>
          <div class="preview__body">
            <div class="preview__msg preview__msg--user">
              <span class="preview__msg-label">You</span>
              <p>Summarise the key findings from the latest CoNb₃S₆ transport data.</p>
            </div>
            <div class="preview__msg preview__msg--ai">
              <span class="preview__msg-label">Max</span>
              <p class="preview__typing">
                <span class="preview__typing-dot" style="--d: 0s"></span>
                <span class="preview__typing-dot" style="--d: 0.2s"></span>
                <span class="preview__typing-dot" style="--d: 0.4s"></span>
              </p>
              <p class="preview__response">Three key observations stand out:</p>
              <ul class="preview__response-list">
                <li>Nonlinear Hall signal emerges below 28 K</li>
                <li>Magnetoresistance shows CDW signature</li>
                <li>Anomalous scaling suggests Berry curvature origin</li>
              </ul>
            </div>
          </div>
        </div>
        <!-- floating cards -->
        <div class="hero__float hero__float--card1">
          <div class="float-card">
            <span class="float-card__icon">📝</span>
            <span class="float-card__text">Draft ready</span>
          </div>
        </div>
        <div class="hero__float hero__float--card2">
          <div class="float-card">
            <span class="float-card__icon">🔬</span>
            <span class="float-card__text">12 papers found</span>
          </div>
        </div>
        <div class="hero__float hero__float--card3">
          <div class="float-card">
            <span class="float-card__icon">✨</span>
            <span class="float-card__text">Summary generated</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 3rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: calc(var(--header-height) + 3rem);
      padding-bottom: 4rem;
    }
  }

  /* ambient */
  .hero__ambient {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: -1;
  }

  .hero__dot {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--s);
    height: var(--s);
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.08;
    animation: heroDotFloat 10s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes heroDotFloat {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.08; }
    50% { transform: translateY(-30px) scale(1.5); opacity: 0.15; }
  }

  /* grid layout */
  .hero__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  /* override container flex from hao-design.css */
  .hero > .container {
    display: block;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  @media (min-width: 768px) {
    .hero > .container {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  @media (min-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  /* left copy */
  .hero__copy {
    display: flex;
    flex-direction: column;
  }

  /* badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    background: var(--card-bg);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) both;
  }

  .hero__badge-dot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .hero__badge-text {
    font-size: 0.72rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
  }

  /* title */
  .hero__title {
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    font-weight: var(--font-bold);
    color: var(--text-primary);
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.12s both;
  }

  /* subtitle */
  .hero__subtitle {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 1rem;
    margin-bottom: 0;
    max-width: 34rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.24s both;
  }

  /* actions */
  .hero__actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.36s both;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.72rem 1.45rem;
    border-radius: var(--radius-full);
    font-size: 0.92rem;
    font-weight: var(--font-medium);
    transition: all var(--duration-normal) var(--ease-default);
  }

  .hero__btn--primary {
    background: var(--color-primary);
    color: #FFFFFF;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .hero__btn--primary:hover {
    background: var(--color-primary-active);
    color: #FFFFFF;
    transform: translateY(-1px);
    box-shadow: 0 6px 10px rgba(0, 0, 0, 0.12);
  }

  .hero__btn--ghost {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-primary);
  }

  .hero__btn--ghost:hover {
    background: var(--bg-secondary);
    border-color: var(--border-hover);
  }

  /* trust */
  .hero__trust {
    font-size: 0.75rem;
    color: var(--text-quaternary);
    margin-top: 1.5rem;
    margin-bottom: 0;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.48s both;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* -------- right visual -------- */
  .hero__visual {
    position: relative;
    display: none;
  }

  @media (min-width: 900px) {
    .hero__visual {
      display: block;
    }
  }

  /* chat preview window */
  .hero__preview {
    background: var(--card-bg);
    border: 1px solid var(--border-primary);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    opacity: 0;
    animation: heroPreviewIn 0.8s var(--ease-out) 0.4s both;
  }

  @keyframes heroPreviewIn {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .preview__header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-primary);
  }

  .preview__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .preview__dot--red { background: #ff5f57; }
  .preview__dot--yellow { background: #febc2e; }
  .preview__dot--green { background: #28c840; }

  .preview__title {
    margin-left: 8px;
    font-size: 0.75rem;
    font-weight: var(--font-medium);
    color: var(--text-quaternary);
  }

  .preview__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 220px;
  }

  .preview__msg {
    padding: 10px 12px;
    border-radius: 10px;
    max-width: 85%;
    animation: msgIn 0.5s var(--ease-out) both;
  }

  .preview__msg--user {
    align-self: flex-end;
    background: var(--color-primary-alpha-10);
    animation-delay: 0.8s;
  }

  .preview__msg--ai {
    align-self: flex-start;
    background: var(--bg-secondary);
    animation-delay: 1.6s;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .preview__msg-label {
    display: block;
    font-size: 0.65rem;
    font-weight: var(--font-semibold);
    color: var(--text-quaternary);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .preview__msg p {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-primary);
    margin: 0;
  }

  /* typing indicator */
  .preview__typing {
    display: flex;
    gap: 4px;
    padding: 4px 0;
  }

  .preview__typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: typingBounce 1.2s ease-in-out infinite;
    animation-delay: var(--d);
  }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.3; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  .preview__response {
    font-weight: var(--font-medium);
    margin-top: 6px !important;
  }

  .preview__response-list {
    margin: 6px 0 0 0;
    padding-left: 16px;
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .preview__response-list li {
    margin-bottom: 2px;
  }

  /* floating cards */
  .hero__float {
    position: absolute;
    z-index: 2;
  }

  .hero__float--card1 {
    top: -12px;
    right: -20px;
    animation: floatCard1 6s ease-in-out infinite;
  }

  .hero__float--card2 {
    bottom: 40px;
    left: -30px;
    animation: floatCard2 7s ease-in-out infinite;
    animation-delay: 1s;
  }

  .hero__float--card3 {
    bottom: -10px;
    right: 40px;
    animation: floatCard3 8s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes floatCard1 {
    0%, 100% { transform: translateY(0) rotate(2deg); }
    50% { transform: translateY(-10px) rotate(-1deg); }
  }

  @keyframes floatCard2 {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-8px) rotate(1deg); }
  }

  @keyframes floatCard3 {
    0%, 100% { transform: translateY(0) rotate(1deg); }
    50% { transform: translateY(-12px) rotate(-2deg); }
  }

  .float-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--card-bg);
    border: 1px solid var(--border-primary);
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    font-size: 0.78rem;
    font-weight: var(--font-medium);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .float-card__icon {
    font-size: 1rem;
  }

  /* dark mode adjustments */
  [data-theme="dark"] .hero__preview {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  [data-theme="dark"] .float-card {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
</style>
