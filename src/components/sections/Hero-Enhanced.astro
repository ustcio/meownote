---
const trustLines = [
  'Trusted by researchers, designers, and students worldwide.',
  'Free to get started · No credit card required · Cancel anytime',
];
---

<section class="hero">
  <div class="container hero__inner">
    <span class="hero__badge">
      <span class="hero__badge-dot"></span>
      <span class="hero__badge-text">Now powered by Max AI</span>
    </span>

    <h1 class="hero__title">
      AI that thinks. You decide.
    </h1>

    <p class="hero__subtitle">
      Write clearly. Plan confidently. Research thoroughly — in one calm, capable workspace.
    </p>

    <div class="hero__actions">
      <a href="/chatbot" class="hero__btn hero__btn--primary">Start free</a>
      <a href="/workspace" class="hero__btn hero__btn--ghost">Explore workspace</a>
    </div>

    <p class="hero__trust">{trustLines[0]}</p>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--header-height) + 4.5rem);
    padding-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: calc(var(--header-height) + 7rem);
      padding-bottom: 7rem;
    }
  }

  .hero__inner {
    max-width: 42rem;
  }

  /* badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    background: var(--card-bg);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) both;
  }

  .hero__badge-dot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .hero__badge-text {
    font-size: 0.72rem;
    font-weight: var(--font-medium);
    letter-spacing: 0.02em;
    color: var(--text-secondary);
  }

  /* title */
  .hero__title {
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    line-height: 1.0;
    letter-spacing: -0.045em;
    font-weight: var(--font-bold);
    color: var(--text-primary);
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.12s both;
  }

  /* subtitle */
  .hero__subtitle {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    line-height: 1.55;
    color: var(--text-secondary);
    margin-top: 0.85rem;
    margin-bottom: 0;
    max-width: 30rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.24s both;
  }

  /* actions */
  .hero__actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.36s both;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.72rem 1.45rem;
    border-radius: var(--radius-full);
    font-size: 0.92rem;
    font-weight: var(--font-medium);
    transition: all var(--duration-normal) var(--ease-default);
  }

  .hero__btn--primary {
    background: var(--color-primary);
    color: #FFFFFF;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .hero__btn--primary:hover {
    background: var(--color-primary-active);
    color: #FFFFFF;
    transform: translateY(-1px);
    box-shadow: 0 6px 10px rgba(0 0 0 / 0.12);
  }

  .hero__btn--ghost {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-primary);
  }

  .hero__btn--ghost:hover {
    background: var(--bg-secondary);
    border-color: var(--border-hover);
  }

  /* trust */
  .hero__trust {
    font-size: 0.78rem;
    color: var(--text-quaternary);
    margin-top: 1.75rem;
    margin-bottom: 0;
    opacity: 0;
    animation: heroUp 0.6s var(--ease-out) 0.48s both;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
