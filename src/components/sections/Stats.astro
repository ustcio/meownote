---
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);
---

<section class="stats">
  <div class="stats-container">
    <div class="stats-grid" id="stats-grid">
      <div class="stat-item">
        <div class="stat-value" id="stat-online">--</div>
        <div class="stat-label">{t('stats.online', lang)}</div>
      </div>
      
      <div class="stat-divider"></div>
      
      <div class="stat-item">
        <div class="stat-value" id="stat-today">--</div>
        <div class="stat-label">{t('stats.today', lang)}</div>
      </div>
      
      <div class="stat-divider"></div>
      
      <div class="stat-item">
        <div class="stat-value" id="stat-total">--</div>
        <div class="stat-label">{t('stats.total', lang)}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .stats {
    padding: var(--space-16) var(--space-6);
    background: var(--bg-secondary);
  }

  @media (min-width: 768px) {
    .stats {
      padding: var(--space-20) var(--space-8);
    }
  }

  .stats-container {
    max-width: var(--container-lg);
    margin: 0 auto;
  }

  .stats-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  @media (min-width: 640px) {
    .stats-grid {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-12);
    }
  }

  @media (min-width: 1024px) {
    .stats-grid {
      gap: var(--space-16);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
  }

  .stat-value {
    font-size: var(--text-3xl);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: var(--text-4xl);
    }
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 400;
  }

  .stat-divider {
    display: none;
    width: 1px;
    height: 40px;
    background: var(--border-primary);
  }

  @media (min-width: 640px) {
    .stat-divider {
      display: block;
    }
  }
</style>

<script>
  const API_BASE = 'https://api.ustc.dev';
  const REFRESH_INTERVAL = 60000;
  
  async function recordVisit() {
    try {
      await fetch(`${API_BASE}/stats/visit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ page: window.location.pathname })
      });
    } catch (error) {
      // Silent fail
    }
  }
  
  async function fetchStats() {
    try {
      await recordVisit();
      
      const response = await fetch(`${API_BASE}/stats/visitor`);
      const result = await response.json();
      
      if (result.success) {
        updateStatValue('stat-online', result.online || 0);
        updateStatValue('stat-total', result.total || 0);
        updateStatValue('stat-today', result.today || 0);
      }
    } catch (error) {
      // Silent fail
    }
  }
  
  function updateStatValue(elementId: string, value: number) {
    const element = document.getElementById(elementId);
    if (element) {
      element.textContent = formatNumber(value);
    }
  }
  
  function formatNumber(num: number): string {
    if (num >= 1000000) {
      return (num / 1000000).toFixed(1) + 'M';
    }
    if (num >= 1000) {
      return (num / 1000).toFixed(1) + 'K';
    }
    return num.toLocaleString();
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    fetchStats();
    setInterval(fetchStats, REFRESH_INTERVAL);
  });
</script>
