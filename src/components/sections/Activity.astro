---
const workModes = [
  {
    title: 'Draft with context',
    prompt: 'Turn these meeting notes into a two-paragraph follow-up and a short list of decisions.',
    detail: 'Good for writing, reframing, and giving rough thinking a cleaner shape.',
  },
  {
    title: 'Plan the next move',
    prompt: 'Compare three launch options for a small team. Include tradeoffs, risk, and a recommended next step.',
    detail: 'Useful when the work is ambiguous and the next action is not obvious yet.',
  },
  {
    title: 'Organise the mess',
    prompt: 'Review these files and propose a naming system, folder structure, and what should be archived.',
    detail: 'Closer to the "do the work with me" feeling people associate with Claude.',
  },
];
---

<section class="claude-section claude-section--cream">
  <div class="container">
    <div class="claude-section-heading">
      <span class="claude-kicker">Ways to work</span>
      <h2>From a vague prompt to a useful next step.</h2>
      <p>
        The best pages show the shape of the work, not just a list of features.
      </p>
    </div>

    <div class="work-modes">
      <div class="work-modes__demo">
        <div class="demo-window">
          <span class="demo-window__label">Prompt</span>
          <p>{workModes[0].prompt}</p>
        </div>
        <div class="demo-window demo-window--muted">
          <span class="demo-window__label">Output shape</span>
          <ul>
            <li>Two short paragraphs for the email</li>
            <li>Bullet list of confirmed decisions</li>
            <li>Three questions to unblock next steps</li>
          </ul>
        </div>
      </div>

      <div class="work-modes__list">
        {workModes.map((mode) => (
          <article class="work-mode">
            <h3>{mode.title}</h3>
            <p class="work-mode__prompt">{mode.prompt}</p>
            <p>{mode.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .work-modes {
    display: grid;
    gap: 1rem;
    align-items: stretch;
  }

  @media (min-width: 1000px) {
    .work-modes {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  .work-modes__demo {
    padding: 1rem;
    border-radius: var(--radius-xl);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    display: grid;
    gap: 0.65rem;
    height: 100%;
  }

  @media (min-width: 1000px) {
    .work-modes__demo {
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
    }
  }

  .demo-window {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    border: 1px solid var(--border-secondary);
  }

  @media (min-width: 1000px) {
    .demo-window {
      min-height: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }

  .demo-window--muted {
    background: var(--bg-secondary);
  }

  .demo-window__label {
    display: inline-block;
    margin-bottom: 0.6rem;
    font-size: 0.68rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .demo-window p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .demo-window ul {
    list-style: none;
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
  }

  .demo-window li {
    position: relative;
    padding-left: 0.95rem;
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  .demo-window li::before {
    content: '';
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .work-modes__list {
    display: grid;
    gap: 1.25rem;
    height: 100%;
  }

  @media (min-width: 1000px) {
    .work-modes__list {
      grid-template-rows: repeat(3, minmax(0, 1fr));
    }
  }

  .work-mode {
    padding-top: 1rem;
    border-top: 1px solid var(--border-secondary);
    display: grid;
    gap: 0.4rem;
    align-content: start;
  }

  .work-mode:first-child {
    padding-top: 0;
    border-top: none;
  }

  .work-mode h3 {
    font-size: var(--text-2xl);
    line-height: 1.15;
  }

  .work-mode__prompt {
    color: var(--text-primary);
    font-size: var(--text-base);
    margin-bottom: 0;
  }

  .work-mode p:last-child {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
</style>
