---
const workModes = [
  {
    title: 'Draft with context',
    prompt: 'Turn these meeting notes into a two-paragraph follow-up and a short list of decisions.',
    detail: 'Good for writing, reframing, and giving rough thinking a cleaner shape.',
  },
  {
    title: 'Plan the next move',
    prompt: 'Compare three launch options for a small team. Include tradeoffs, risk, and a recommended next step.',
    detail: 'Useful when the work is ambiguous and the next action is not obvious yet.',
  },
  {
    title: 'Organize the mess',
    prompt: 'Review these files and propose a naming system, folder structure, and what should be archived.',
    detail: 'Closer to the “do the work with me” feeling people associate with Claude.',
  },
];
---

<section class="claude-section claude-section--cream">
  <div class="container">
    <div class="claude-section-heading">
      <span class="claude-kicker">Ways to work</span>
      <h2>From a vague prompt to a useful next step.</h2>
      <p>
        The best Claude pages show the shape of the work, not just a list of
        features. This section does the same with real prompt patterns and a
        calmer presentation.
      </p>
    </div>

    <div class="work-modes">
      <div class="work-modes__demo claude-editorial-card">
        <div class="demo-window">
          <span class="demo-window__label">Prompt</span>
          <p>{workModes[0].prompt}</p>
        </div>
        <div class="demo-window demo-window--muted">
          <span class="demo-window__label">Output shape</span>
          <ul>
            <li>Two short paragraphs for the email</li>
            <li>Bullet list of confirmed decisions</li>
            <li>Three questions to unblock next steps</li>
          </ul>
        </div>
      </div>

      <div class="work-modes__list">
        {workModes.map((mode) => (
          <article class="work-mode">
            <h3>{mode.title}</h3>
            <p class="work-mode__prompt">{mode.prompt}</p>
            <p>{mode.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .work-modes {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  @media (min-width: 1100px) {
    .work-modes {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: 2rem;
    }
  }

  .work-modes__demo {
    padding: 1.4rem;
    display: grid;
    gap: 1rem;
  }

  .demo-window {
    padding: 1.2rem;
    border-radius: 1.15rem;
    background: rgba(255, 253, 249, 0.92);
    border: 1px solid rgba(71, 57, 44, 0.08);
  }

  .demo-window--muted {
    background: rgba(242, 236, 227, 0.72);
  }

  .demo-window__label {
    display: inline-block;
    margin-bottom: 0.75rem;
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .demo-window p,
  .demo-window li {
    font-size: 0.98rem;
    color: var(--text-secondary);
  }

  .demo-window ul {
    list-style: none;
    display: grid;
    gap: 0.55rem;
  }

  .demo-window li {
    position: relative;
    padding-left: 1rem;
  }

  .demo-window li::before {
    content: '';
    position: absolute;
    top: 0.62rem;
    left: 0;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
    background: var(--color-primary);
  }

  .work-modes__list {
    display: grid;
    gap: 1.25rem;
  }

  .work-mode {
    padding-top: 1.1rem;
    border-top: 1px solid var(--border-primary);
    display: grid;
    gap: 0.55rem;
  }

  .work-mode:first-child {
    padding-top: 0;
    border-top: none;
  }

  .work-mode h3 {
    font-size: 1.8rem;
  }

  .work-mode__prompt {
    color: var(--text-primary);
    font-size: 1rem;
  }
</style>
