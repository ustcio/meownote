---
import { t, getLangFromUrl, type Language } from '@i18n';

const lang = getLangFromUrl(Astro.url);

// Contribution Graph Data
const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

const today = new Date();
const currentYear = today.getFullYear();
const startDate = new Date(today);
startDate.setFullYear(startDate.getFullYear() - 1);
startDate.setDate(startDate.getDate() - startDate.getDay());

function getMonthPositions() {
  const positions: { month: number; week: number }[] = [];
  let lastMonth = -1;
  
  const currentDate = new Date(startDate);
  let dayIndex = 0;
  
  while (currentDate <= today) {
    const week = Math.floor(dayIndex / 7);
    const month = currentDate.getMonth();
    if (month !== lastMonth) {
      positions.push({ month, week });
      lastMonth = month;
    }
    currentDate.setDate(currentDate.getDate() + 1);
    dayIndex++;
  }
  
  return positions;
}

const monthPositions = getMonthPositions();
const totalDays = Math.ceil((today.getTime() - startDate.getTime() / (1000 * 60 * 60 * 24)) + 1);
const totalWeeks = Math.ceil(totalDays / 7);
---

<section class="activity">
  <div class="activity-container">
    <!-- Heatmap Section -->
    <div class="contribution-header">
      <div class="header-label">
        <span class="label-dot"></span>
        <span class="label-text">Activity</span>
      </div>
      <h2 class="contribution-title">Activity at a glance</h2>
      <p class="contribution-year">{currentYear}</p>
    </div>
    
    <div class="contribution-graph-wrapper">
      <div class="contribution-graph" id="contribution-graph" data-year={currentYear}>
        <div class="contribution-months">
          {monthPositions.map(({ month, week }) => (
            <span class="contribution-month" style={`--week: ${week}`}>
              {months[month]}
            </span>
          ))}
        </div>
        
        <div class="contribution-body">
          <div class="contribution-days">
            {days.map((day, i) => (
              <span class="contribution-day">{i % 2 === 0 ? day : ''}</span>
            ))}
          </div>
          
          <div class="contribution-grid" id="contribution-grid">
            {Array.from({ length: totalWeeks }).map((_, weekIndex) => (
              <div class="contribution-week">
                {Array.from({ length: 7 }).map((_, dayIndex) => {
                  const dayOffset = weekIndex * 7 + dayIndex;
                  const cellDate = new Date(startDate);
                  cellDate.setDate(cellDate.getDate() + dayOffset);
                  
                  if (cellDate > today) return <div class="contribution-cell empty"></div>;
                  
                  const dateStr = cellDate.toISOString().split('T')[0];
                  const displayDateStr = `${cellDate.getFullYear()}-${String(cellDate.getMonth() + 1).padStart(2, '0')}-${String(cellDate.getDate()).padStart(2, '0')}`;
                  
                  return (
                    <div
                      class="contribution-cell"
                      data-date={dateStr}
                      data-level="0"
                      title={`${displayDateStr} - 0 visits`}
                    ></div>
                  );
                })}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    
    <div class="contribution-legend">
      <span class="legend-text">Less</span>
      <div class="legend-cells">
        {[0, 1, 2, 3, 4].map((level) => (
          <div class="legend-cell" data-level={level}></div>
        ))}
      </div>
      <span class="legend-text">More</span>
    </div>
    
    <!-- Stats Section -->
    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="3" fill="currentColor"/>
          </svg>
        </div>
        <div class="stat-value" id="stat-online">--</div>
        <div class="stat-label">{t('stats.online', lang)}</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon today">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div class="stat-value" id="stat-today">--</div>
        <div class="stat-label">{t('stats.today', lang)}</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon total">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="stat-value" id="stat-total">--</div>
        <div class="stat-label">{t('stats.total', lang)}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .activity {
    background: #F0E9DC;
    padding: var(--space-12) var(--space-4);
  }

  @media (min-width: 768px) {
    .activity {
      padding: var(--space-16) var(--space-8);
    }
  }

  .activity-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  /* Contribution Graph Styles */
  .contribution-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .header-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: rgba(192, 107, 62, 0.1);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
  }

  .label-dot {
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  .label-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contribution-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: var(--font-normal);
    color: #1A1207;
    margin-bottom: var(--space-1);
  }

  .contribution-title em {
    font-style: normal;
    color: var(--color-primary);
  }

  .contribution-year {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #7A6A52;
  }

  .contribution-graph-wrapper {
    display: flex;
    justify-content: center;
    overflow-x: auto;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
  }

  .contribution-graph {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
  }

  .contribution-months {
    display: flex;
    margin-left: 36px;
    margin-bottom: var(--space-2);
    position: relative;
    height: 16px;
  }

  .contribution-month {
    position: absolute;
    left: calc(var(--week) * 14px);
    font-family: var(--font-sans);
    font-size: 10px;
    color: #9A8A72;
  }

  .contribution-body {
    display: flex;
    gap: var(--space-2);
  }

  .contribution-days {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-top: 0;
  }

  .contribution-day {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #9A8A72;
    height: 11px;
    line-height: 11px;
  }

  .contribution-grid {
    display: flex;
    gap: 3px;
  }

  .contribution-week {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .contribution-cell {
    width: 11px;
    height: 11px;
    border-radius: 2px;
    background-color: #E5DDD0;
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .contribution-cell.empty {
    background-color: transparent;
    cursor: default;
  }

  .contribution-cell[data-level="1"] { background-color: #E8C9B5; }
  .contribution-cell[data-level="2"] { background-color: #D9A082; }
  .contribution-cell[data-level="3"] { background-color: #C0785A; }
  .contribution-cell[data-level="4"] { background-color: #A85A32; }

  .contribution-cell:hover {
    transform: scale(1.2);
  }

  .contribution-legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
  }

  .legend-text {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #9A8A72;
  }

  .legend-cells {
    display: flex;
    gap: 3px;
  }

  .legend-cell {
    width: 11px;
    height: 11px;
    border-radius: 2px;
    background-color: #E5DDD0;
  }

  .legend-cell[data-level="1"] { background-color: #E8C9B5; }
  .legend-cell[data-level="2"] { background-color: #D9A082; }
  .legend-cell[data-level="3"] { background-color: #C0785A; }
  .legend-cell[data-level="4"] { background-color: #A85A32; }

  /* Stats Grid - Compact */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    max-width: 480px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .stats-grid {
      gap: var(--space-4);
      max-width: 520px;
    }
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-3);
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(192, 107, 62, 0.2);
    border-radius: var(--radius-lg);
    transition: border-color var(--duration-normal) var(--ease-default);
  }

  .stat-card:hover {
    border-color: var(--color-primary);
  }

  .stat-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(192, 107, 62, 0.1);
    border-radius: var(--radius-md);
    color: var(--color-primary);
  }

  .stat-icon.today {
    background: rgba(91, 126, 106, 0.1);
    color: #5B7E6A;
  }

  .stat-icon.total {
    background: rgba(74, 94, 138, 0.1);
    color: #4A5E8A;
  }

  .stat-value {
    font-family: var(--font-number);
    font-size: var(--text-xl);
    font-weight: var(--font-normal);
    color: #1A1207;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: var(--text-2xl);
    }
  }

  .stat-label {
    font-size: var(--text-xs);
    color: #6B5C42;
    font-weight: 400;
  }
</style>

<script>
  const API_BASE = 'https://api.ustc.dev';
  const REFRESH_INTERVAL = 60000;
  
  // Heatmap
  async function fetchHeatmapData() {
    try {
      const graph = document.getElementById('contribution-graph');
      const year = graph?.getAttribute('data-year') || new Date().getFullYear();
      
      const response = await fetch(`${API_BASE}/stats/heatmap?year=${year}`);
      
      if (!response.ok) return;
      
      const result = await response.json();
      
      let heatmapData: Record<string, number> = {};
      let maxCount = 0;
      
      if (result.data && typeof result.data === 'object') {
        heatmapData = result.data;
        maxCount = result.maxCount || Math.max(...Object.values(heatmapData), 1);
      } else if (typeof result === 'object' && Object.keys(result).length > 0) {
        heatmapData = result;
        maxCount = Math.max(...Object.values(heatmapData), 1);
      }
      
      if (Object.keys(heatmapData).length > 0) {
        updateHeatmap(heatmapData, maxCount, 'visits');
      }
    } catch (error) {
      // Silent fail
    }
  }
  
  function updateHeatmap(data: Record<string, number>, maxCount: number, visitsText: string) {
    const cells = document.querySelectorAll('.contribution-cell[data-date]');
    
    cells.forEach(cell => {
      const date = cell.getAttribute('data-date');
      if (date && data[date]) {
        const count = data[date];
        const level = calculateLevel(count, maxCount);
        cell.setAttribute('data-level', String(level));
        
        const existingTitle = cell.getAttribute('title') || '';
        const baseTitle = existingTitle.split(' - ')[0];
        cell.setAttribute('title', `${baseTitle} - ${count} ${visitsText}`);
      }
    });
  }
  
  function calculateLevel(count: number, maxCount: number): number {
    if (count === 0) return 0;
    if (count <= maxCount * 0.25) return 1;
    if (count <= maxCount * 0.5) return 2;
    if (count <= maxCount * 0.75) return 3;
    return 4;
  }
  
  // Stats
  async function recordVisit() {
    try {
      await fetch(`${API_BASE}/stats/visit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ page: window.location.pathname })
      });
    } catch (error) {
      // Silent fail
    }
  }
  
  async function fetchStats() {
    try {
      await recordVisit();
      
      const response = await fetch(`${API_BASE}/stats/visitor`);
      const result = await response.json();
      
      if (result.success) {
        updateStatValue('stat-online', result.online || 0);
        updateStatValue('stat-total', result.total || 0);
        updateStatValue('stat-today', result.today || 0);
      }
    } catch (error) {
      // Silent fail
    }
  }
  
  function updateStatValue(id: string, value: number) {
    const el = document.getElementById(id);
    if (el) {
      el.textContent = value.toLocaleString();
    }
  }
  
  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    fetchHeatmapData();
    fetchStats();
    setInterval(fetchStats, REFRESH_INTERVAL);
  });
</script>
