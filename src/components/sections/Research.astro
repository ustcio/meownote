---
const projects = [
  {
    num: '01',
    title: 'Chat That Actually Helps',
    desc: 'Use the chat space to rewrite drafts, clarify ideas, summarize long material, and turn rough thoughts into something ready to send.',
    tags: ['Writing', 'Summaries', 'Daily thinking'],
  },
  {
    num: '02',
    title: 'Workspace for Long-Form Work',
    desc: 'Move beyond one-off prompts with persistent notes, evolving drafts, and project context you can return to without starting over.',
    tags: ['Notes', 'Drafts', 'Project context'],
  },
  {
    num: '03',
    title: 'Research With Structure',
    desc: 'Collect scattered information, compare sources, and turn open-ended questions into research you can actually act on.',
    tags: ['Deep research', 'Comparison', 'Structured output'],
  },
  {
    num: '04',
    title: 'Live Gold Tracker',
    desc: 'The toolkit is now intentionally narrow: one dedicated page for domestic and international gold prices, without the clutter of a giant utilities catalog.',
    tags: ['Gold price', 'Market watch', 'Focused tool'],
  },
];
---

<section class="research-section">
  <div class="container">
    <div class="research-heading">
      <span class="research-kicker">What you can do here</span>
      <h2>Four parts of one useful workflow.</h2>
      <p>
        Maxwell.Science is built for real work: think clearly, keep context, research deeply, and solve the small tasks that usually slow everything down.
      </p>
    </div>

    <div class="research-grid">
      {projects.map((p) => (
        <article class="research-card">
          <span class="research-card__num">{p.num}</span>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          <div class="research-card__tags">
            {p.tags.map((tag) => (
              <span class="research-tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .research-section {
    padding: clamp(3rem, 6vw, 5rem) 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-secondary);
    border-bottom: 1px solid var(--border-secondary);
  }

  .research-heading {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
  }

  .research-kicker {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .research-kicker::before {
    content: '';
    width: 0.36rem; height: 0.36rem;
    border-radius: 50%;
    background: var(--color-primary);
    margin-right: 0.5rem;
  }

  .research-heading h2 {
    margin-top: 0.4rem;
  }

  .research-heading p {
    margin-top: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .research-grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 700px) {
    .research-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .research-card {
    padding: 1.75rem;
    border-radius: var(--radius-xl);
    background: var(--card-bg);
    border: 1px solid var(--border-secondary);
    display: grid;
    gap: 0.75rem;
    transition:
      border-color var(--duration-normal) var(--ease-default),
      box-shadow var(--duration-normal) var(--ease-default),
      transform var(--duration-normal) var(--ease-default);
  }

  .research-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .research-card__num {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.1em;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .research-card h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .research-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .research-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.3rem;
  }

  .research-tag {
    font-size: 0.68rem;
    font-weight: var(--font-medium);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-full);
    background: var(--color-primary-subtle);
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }
</style>
