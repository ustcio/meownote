---
const notes = [
  {
    tag: 'Writing',
    title: 'How we tune prompts for clearer first drafts',
    description: 'A quieter interface matters, but better instructions matter more. This note looks at structure over style.',
    href: '/research',
  },
  {
    tag: 'Research',
    title: 'When should AI summarise — and when should it stay out of the way?',
    description: 'How to cut fluff while keeping summaries useful enough to actually decide from.',
    href: '/research',
  },
  {
    tag: 'Workflow',
    title: 'Why a workspace beats a pile of chat threads',
    description: 'Longer projects need a home for notes, intermediate drafts, and all the thinking that doesn\'t fit in one reply.',
    href: '/workspace',
  },
  {
    tag: 'Design',
    title: 'What changed in this redesign',
    description: 'Typeface, pacing, spacing, surfaces, button hierarchy — and a more measured voice across the whole site.',
    href: '/about',
  },
];
---

<section class="claude-section">
  <div class="container">
    <div class="research-section">
      <div class="claude-section-heading">
        <span class="claude-kicker">Recent notes</span>
        <h2>Design, prompts, and product decisions worth keeping.</h2>
        <p>
          Each card is a topic you can read and act on — that's the editorial rhythm.
        </p>
      </div>

      <div class="research-grid">
        {notes.map((note) => (
          <a href={note.href} class="research-card">
            <span class="research-card__tag">{note.tag}</span>
            <h3>{note.title}</h3>
            <p>{note.description}</p>
            <span class="research-card__more">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .research-grid {
    display: grid;
    gap: 1px;
    background: var(--border-secondary);
    border: 1px solid var(--border-secondary);
  }

  @media (min-width: 700px) {
    .research-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .research-card {
    display: grid;
    gap: 0.8rem;
    min-height: 100%;
    padding: 1.75rem;
    background: var(--card-bg);
    transition: background var(--duration-fast) var(--ease-default);
  }

  .research-card:hover {
    background: var(--card-bg-hover);
  }

  .research-card__tag {
    font-size: 0.75rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .research-card h3 {
    font-size: var(--text-2xl);
    line-height: 1.15;
  }

  .research-card p {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.55;
  }

  .research-card__more {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-tertiary);
  }

  .research-card:hover .research-card__more {
    color: var(--text-primary);
  }
</style>
