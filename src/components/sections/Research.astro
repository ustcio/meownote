---
const projects = [
  {
    num: '01',
    title: 'ZrAs₂ Transport',
    desc: 'Anomalous Hall effect and magnetotransport in zirconium diarsenide thin films — revealing a new topological semimetal phase.',
    tags: ['Hall effect', 'Magnetoresistance', 'Thin films'],
  },
  {
    num: '02',
    title: 'CoNb₃S₆ — Hall',
    desc: 'Charge density wave order and unconventional Hall signatures in cobalt niobium trisulfide.',
    tags: ['CDW', 'Nonlinear Hall', 'Layered magnet'],
  },
  {
    num: '03',
    title: 'CoNb₃S₆ — Phonon',
    desc: 'Phonon-mediated transport and electron–phonon coupling analysis from first-principles calculations.',
    tags: ['DFT', 'Phonon dispersion', 'EPC'],
  },
  {
    num: '04',
    title: 'Nb₃I₈ Detector',
    desc: 'Niobium triiodide as a room-temperature radiation detector with high responsivity and low noise.',
    tags: ['Photodetector', 'Van der Waals', 'Optoelectronics'],
  },
];
---

<section class="research-section">
  <div class="container">
    <div class="research-heading">
      <span class="research-kicker">Research</span>
      <h2>Four projects. One thread.</h2>
      <p>
        Each piece contributes to a broader picture: how electrons, phonons, and light interact in materials that break the usual rules.
      </p>
    </div>

    <div class="research-grid">
      {projects.map((p) => (
        <article class="research-card">
          <span class="research-card__num">{p.num}</span>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          <div class="research-card__tags">
            {p.tags.map((tag) => (
              <span class="research-tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .research-section {
    padding: clamp(3rem, 6vw, 5rem) 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-secondary);
    border-bottom: 1px solid var(--border-secondary);
  }

  .research-heading {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
  }

  .research-kicker {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .research-kicker::before {
    content: '';
    width: 0.36rem; height: 0.36rem;
    border-radius: 50%;
    background: var(--color-primary);
    margin-right: 0.5rem;
  }

  .research-heading h2 {
    margin-top: 0.4rem;
  }

  .research-heading p {
    margin-top: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .research-grid {
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 700px) {
    .research-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .research-card {
    padding: 1.75rem;
    border-radius: var(--radius-xl);
    background: var(--card-bg);
    border: 1px solid var(--border-secondary);
    display: grid;
    gap: 0.75rem;
    transition:
      border-color var(--duration-normal) var(--ease-default),
      box-shadow var(--duration-normal) var(--ease-default),
      transform var(--duration-normal) var(--ease-default);
  }

  .research-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .research-card__num {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.1em;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .research-card h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .research-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .research-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.3rem;
  }

  .research-tag {
    font-size: 0.68rem;
    font-weight: var(--font-medium);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-full);
    background: var(--color-primary-subtle);
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }
</style>
