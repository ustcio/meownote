---
const papers = [
  {
    id: 1,
    tag: "Constitutional AI",
    date: "Dec 2024",
    title: "Scalable Oversight via AI-Assisted Debate",
    description: "We explore how AI systems can assist humans in providing scalable oversight, enabling more reliable evaluation of complex AI outputs.",
    readTime: "12 min read"
  },
  {
    id: 2,
    tag: "Interpretability",
    date: "Nov 2024",
    title: "Towards Monosemanticity: Decomposing Language Models",
    description: "A new approach to understanding how transformer models represent information through sparse, interpretable features.",
    readTime: "18 min read"
  },
  {
    id: 3,
    tag: "Alignment",
    date: "Oct 2024",
    title: "Model-Written Evals for Dangerous Capabilities",
    description: "Developing automated evaluation methods to assess potentially concerning capabilities in large language models.",
    readTime: "9 min read"
  },
  {
    id: 4,
    tag: "Policy",
    date: "Sep 2024",
    title: "Responsible Scaling Policy: A Framework for Commitment",
    description: "Our approach to committing in advance to safety measures triggered by specific capability thresholds during model training.",
    readTime: "7 min read"
  }
];
---

<section id="research" class="research">
  <div class="research-container">
    <div class="research-header">
      <div>
        <div class="header-label">
          <span class="label-dot"></span>
          <span class="label-text">Research</span>
        </div>
        <h2 class="research-title">
          Advancing the science<br />of <em>AI safety</em>
        </h2>
      </div>
      <a href="#" class="research-link">
        View all papers →
      </a>
    </div>

    <div class="research-grid">
      {papers.map((paper) => (
        <article class="research-card">
          <div class="card-header">
            <span class="card-tag">{paper.tag}</span>
            <span class="card-date">{paper.date}</span>
          </div>
          <h3 class="card-title">{paper.title}</h3>
          <p class="card-description">{paper.description}</p>
          <span class="card-readtime">{paper.readTime}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .research {
    background: #EDE5D4;
    padding: var(--space-28) var(--space-6);
  }

  @media (min-width: 768px) {
    .research {
      padding: var(--space-28) var(--space-10);
    }
  }

  .research-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .research-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .research-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .header-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .label-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #7A6A52;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .research-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: var(--font-normal);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1A1207;
  }

  .research-title em {
    font-style: italic;
  }

  .research-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #3D3521;
    border-bottom: 1px solid #C4B9A5;
    text-decoration: none;
    padding-bottom: 2px;
    white-space: nowrap;
    transition: border-color var(--duration-normal) var(--ease-default),
                color var(--duration-normal) var(--ease-default);
  }

  .research-link:hover {
    border-color: #1A1207;
    color: #1A1207;
  }

  .research-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    border: 1px solid #D0C4B0;
    background: #D0C4B0;
  }

  @media (min-width: 768px) {
    .research-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .research-card {
    background: #F0E9DC;
    padding: var(--space-8);
    cursor: pointer;
    transition: background-color 300ms var(--ease-default);
  }

  @media (min-width: 768px) {
    .research-card {
      padding: var(--space-10);
    }
  }

  .research-card:hover {
    background: #EDE0CC;
  }

  .research-card:hover .card-title {
    color: #C06B3E;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }

  .card-tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #C06B3E;
    background: rgba(192, 107, 62, 0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .card-date {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #9A8A72;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: var(--font-normal);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: #1A1207;
    margin-bottom: var(--space-3);
    transition: color 300ms var(--ease-default);
  }

  .card-description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #6B5C42;
    line-height: 1.65;
    margin-bottom: var(--space-6);
  }

  .card-readtime {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #9A8A72;
  }
</style>
