---
const notes = [
  {
    tag: 'Writing',
    title: 'How we tune prompts for clearer first drafts',
    description: 'A quieter interface matters, but better instructions matter more. This note looks at structure before style.',
    href: '/research',
  },
  {
    tag: 'Research',
    title: 'When should AI summarize and when should it stay out of the way?',
    description: 'We look at how to reduce fluff and keep summaries useful enough for actual decisions.',
    href: '/research',
  },
  {
    tag: 'Workflow',
    title: 'Why a workspace beats a pile of chat threads',
    description: 'Longer projects need a home for notes, intermediate drafts, and all the thinking that does not fit in one reply.',
    href: '/workspace',
  },
  {
    tag: 'Design',
    title: 'What changed in this Claude-inspired redesign',
    description: 'Typeface, pacing, spacing, surfaces, button hierarchy, and a more measured voice across the whole site.',
    href: '/about',
  },
];
---

<section class="claude-section">
  <div class="container">
    <div class="research-section">
      <div class="claude-section-heading">
        <span class="claude-kicker">Recent notes</span>
        <h2>Design, prompts, and product decisions worth keeping.</h2>
        <p>
          Claude’s product pages mix explanation with examples. These cards do
          the same by framing each topic as something you can read and act on.
        </p>
      </div>

      <div class="research-grid">
        {notes.map((note) => (
          <a href={note.href} class="research-card">
            <span class="research-card__tag">{note.tag}</span>
            <h3>{note.title}</h3>
            <p>{note.description}</p>
            <span class="research-card__link">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .research-grid {
    display: grid;
    gap: 1px;
    border: 1px solid var(--border-primary);
    background: var(--border-primary);
  }

  @media (min-width: 768px) {
    .research-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .research-card {
    display: grid;
    gap: 0.9rem;
    min-height: 100%;
    padding: 1.5rem;
    background: var(--card-bg);
  }

  @media (min-width: 768px) {
    .research-card {
      padding: 2rem;
    }
  }

  .research-card:hover {
    background: var(--card-bg-hover);
  }

  .research-card__tag {
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .research-card h3 {
    font-size: 2rem;
  }

  .research-card p {
    margin: 0;
    font-size: 0.98rem;
  }

  .research-card__link {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text-primary);
  }
</style>
