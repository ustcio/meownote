---
const principles = [
  {
    title: 'Sharper hierarchy',
    description: 'Headings, copy, and controls now guide attention in the same order people actually read the page.',
  },
  {
    title: 'Warmer surfaces',
    description: 'Panels lean on cream, white, and ink rather than loud gradients or dashboard styling.',
  },
  {
    title: 'Measured interactions',
    description: 'Buttons, shadows, and hover states now feel quieter and more deliberate.',
  },
  {
    title: 'Editorial spacing',
    description: 'Each block has more breathing room, fewer competing accents, and a clearer start and stop.',
  },
  {
    title: 'Stronger voice',
    description: 'Text reads less like generic AI marketing and more like a calm product for real work.',
  },
  {
    title: 'System over patchwork',
    description: 'Design tokens now support the look across inner pages instead of only the homepage.',
  },
];
---

<section class="claude-section claude-section--cream">
  <div class="container">
    <div class="claude-section-heading">
      <span class="claude-kicker">Design principles</span>
      <h2>Closer to Claude because the rules are clearer.</h2>
      <p>
        Mimicry is not about copying one button radius. It comes from a whole
        system of type, contrast, pacing, and interaction that feels composed.
      </p>
    </div>

    <div class="principles-grid">
      {principles.map((principle) => (
        <article class="principle-card">
          <h3>{principle.title}</h3>
          <p>{principle.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .principles-grid {
    display: grid;
    gap: 1px;
    border: 1px solid var(--border-primary);
    background: var(--border-primary);
  }

  @media (min-width: 760px) {
    .principles-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .principles-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .principle-card {
    min-height: 100%;
    padding: 1.5rem;
    background: var(--card-bg);
    display: grid;
    gap: 0.75rem;
  }

  .principle-card h3 {
    font-size: 1.65rem;
  }

  .principle-card p {
    margin: 0;
    font-size: 0.96rem;
  }
</style>
