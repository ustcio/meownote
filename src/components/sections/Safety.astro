---
const principles = [
  {
    title: 'Sharper hierarchy',
    description: 'Headings, copy, and controls now guide attention in the order people actually read.',
  },
  {
    title: 'Warmer surfaces',
    description: 'Panels lean on cream, off-white, and ink — not gradients or dashboard styling.',
  },
  {
    title: 'Measured interactions',
    description: 'Buttons, shadows, and hover states feel quieter. Restraint is the point.',
  },
  {
    title: 'Editorial spacing',
    description: 'Each block gets breathing room, fewer accents, and a clear start and stop.',
  },
  {
    title: 'Stronger voice',
    description: 'Reads less like generic marketing and more like a calm product for real work.',
  },
  {
    title: 'System over patchwork',
    description: 'Design tokens support the whole site — inner pages included — not just the homepage.',
  },
];
---

<section class="claude-section claude-section--cream">
  <div class="container">
    <div class="claude-section-heading">
      <span class="claude-kicker">Design principles</span>
      <h2>Restraint is a feature.</h2>
      <p>
        Not about copying one button radius — it's about type, contrast, spacing, and pacing that feel composed.
      </p>
    </div>

    <div class="principles-grid">
      {principles.map((p) => (
        <article class="principle">
          <h3>{p.title}</h3>
          <p>{p.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .principles-grid {
    display: grid;
    gap: 1px;
    background: var(--border-secondary);
    border: 1px solid var(--border-secondary);
  }

  @media (min-width: 680px) {
    .principles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 1000px) {
    .principles-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  .principle {
    padding: 1.5rem;
    background: var(--card-bg);
    display: grid;
    gap: 0.65rem;
  }

  .principle h3 {
    font-size: var(--text-xl);
  }

  .principle p {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.55;
  }
</style>
