---
const pillars = [
  { id: 1, icon: "microscope", title: "Interpretability Research", description: "We work to understand what's happening inside AI models — making their reasoning transparent, predictable, and verifiable." },
  { id: 2, icon: "scale", title: "Constitutional AI", description: "Our Constitutional AI method trains models to be helpful, harmless, and honest using a set of guiding principles." },
  { id: 3, icon: "shield", title: "Red-Teaming & Evals", description: "Rigorous adversarial testing helps us identify vulnerabilities and dangerous capabilities before deployment." },
  { id: 4, icon: "clipboard", title: "Responsible Scaling Policy", description: "Our RSP commits us in advance to specific safety measures triggered at defined capability thresholds." },
  { id: 5, icon: "globe", title: "Policy & Governance", description: "We engage with governments, regulators, and the broader AI community to shape beneficial AI governance." },
  { id: 6, icon: "handshake", title: "Industry Collaboration", description: "We collaborate openly with academic and industrial partners, sharing research to elevate safety standards across the field." },
];

const iconPaths: Record<string, string> = {
  microscope: `<circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4M2 12h4m12 0h4"/><path d="M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/>`,
  scale: `<path d="M12 3v18M5 8l7-5 7 5M5 8v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  clipboard: `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>`,
  globe: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  handshake: `<path d="M6 11l-3 3 3 3M18 11l3 3-3 3M12 6v12M9 9l3-3 3 3"/>`
};
---

<section id="safety" class="safety">
  <div class="safety-container">
    <div class="safety-header">
      <div class="header-label">
        <span class="label-dot"></span>
        <span class="label-text">Safety</span>
      </div>
      <h2 class="safety-title">
        Safety is not a<br />feature — it's our foundation
      </h2>
      <p class="safety-description">
        We believe that powerful AI requires equally powerful safety research. Our multi-layered approach spans technical research, policy, and operations.
      </p>
    </div>

    <div class="safety-grid">
      {pillars.map((pillar) => (
        <div class="safety-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={iconPaths[pillar.icon]} />
            </svg>
          </div>
          <h3 class="card-title">{pillar.title}</h3>
          <p class="card-description">{pillar.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .safety {
    background: #F0E9DC;
    padding: var(--space-16) var(--space-6);
  }

  @media (min-width: 768px) {
    .safety {
      padding: var(--space-20) var(--space-10);
    }
  }

  .safety-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .safety-header {
    max-width: 640px;
    margin-bottom: var(--space-16);
  }

  .header-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C06B3E;
  }

  .label-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #6B5C42;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .safety-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: var(--font-normal);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1A1207;
    margin-bottom: var(--space-5);
  }

  .safety-title em {
    font-style: normal;
    color: #C06B3E;
  }

  .safety-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: #6B5C42;
    line-height: 1.7;
  }

  .safety-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    border: 1px solid #D0C4B0;
    background: #D0C4B0;
  }

  @media (min-width: 640px) {
    .safety-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .safety-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .safety-card {
    background: #F0E9DC;
    padding: var(--space-8);
    cursor: pointer;
    transition: background-color 300ms var(--ease-default);
  }

  .safety-card:hover {
    background: #EDE5D4;
  }

  .safety-card:hover .card-title {
    color: #C06B3E;
  }

  .card-icon {
    width: 40px;
    height: 40px;
    background: rgba(192, 107, 62, 0.15);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-5);
    color: #C06B3E;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .card-icon svg {
    width: 20px;
    height: 20px;
  }

  .safety-card:hover .card-icon {
    background: rgba(192, 107, 62, 0.25);
    transform: scale(1.05);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: var(--font-normal);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: #1A1207;
    margin-bottom: var(--space-3);
    transition: color 300ms var(--ease-default);
  }

  .card-description {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #6B5C42;
    line-height: 1.65;
  }
</style>
