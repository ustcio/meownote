---
import SiteLogo from '@components/ui/SiteLogo.astro';

const currentYear = new Date().getFullYear();

const footerGroups = [
  {
    title: 'Product',
    links: [
      { href: '/chatbot/', label: 'Chat' },
      { href: '/workspace/', label: 'Workspace' },
      { href: '/claw/', label: 'Claw' },
    ],
  },
  {
    title: 'Explore',
    links: [
      { href: '/kit/', label: 'Tools' },
      { href: '/research/', label: 'Research' },
      { href: '/about/', label: 'About' },
    ],
  },
  {
    title: 'Contact',
    links: [
      { href: 'https://github.com/ustcio/meownote', label: 'GitHub' },
      { href: 'mailto:moonsun@ustc.dev', label: 'Email' },
      { href: 'https://ustc.dev', label: 'Token access' },
    ],
  },
];
---

<footer class="site-footer">
  <a class="site-footer__brandmark" href="/" aria-label="MoonSun.ai home">
    <img src="/moonsun-ai-footer-logo.png" alt="MoonSun.ai" width="1983" height="793" loading="lazy" />
  </a>

  <div class="site-footer__inner">
    <div class="site-footer__lead">
      <h2 class="site-footer__title">Think clearly. Keep context. Move work forward.</h2>
      <p class="site-footer__copy">
        MoonSun brings chat, workspace, research, and focused tools into one warm, quiet interface for daily work.
      </p>

      <form class="site-footer__prompt" action="/chatbot/">
        <input
          type="text"
          name="q"
          value=""
          placeholder="Ask MoonSun to draft, plan, or explain"
          aria-label="Prompt"
        />
        <button type="submit">Open chat</button>
      </form>
    </div>

    <div class="site-footer__links">
      {footerGroups.map((group) => (
        <div class="site-footer__group">
          <h3>{group.title}</h3>
          <ul>
            {group.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="site-footer__meta">
    <span>
      © {currentYear}
      <SiteLogo as="span" size="meta" label="MoonSun.ai" />
    </span>
    <span>Designed by 杨浩</span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 5rem 0 2rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-secondary);
  }

  .site-footer__brandmark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(36rem, calc(100% - 3rem));
    aspect-ratio: 3.65 / 1;
    margin: 0 auto 3rem;
    padding: clamp(0.45rem, 1.4vw, 0.7rem);
    border: 1px solid rgba(217, 119, 87, 0.2);
    border-radius: 1.35rem;
    background: rgba(255, 253, 249, 0.72);
    box-shadow: 0 1.25rem 3rem rgba(25, 18, 15, 0.1);
    overflow: hidden;
  }

  .site-footer__brandmark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.95rem;
    background: #000;
  }

  .site-footer__inner,
  .site-footer__meta {
    max-width: var(--container-xl);
    width: calc(100% - (2 * clamp(1.5rem, 1.07rem + 2.14vw, 3rem)));
    margin: 0 auto;
  }

  .site-footer__inner {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 980px) {
    .site-footer__inner {
      grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.95fr);
      align-items: start;
      gap: 5rem;
    }
  }

  .site-footer__lead {
    display: grid;
    gap: 1rem;
    max-width: 38rem;
  }

  .site-footer__title {
    max-width: 13ch;
    font-size: clamp(2rem, 3.4vw, 2.9rem);
    line-height: 1.04;
  }

  .site-footer__copy {
    max-width: 31rem;
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .site-footer__prompt {
    display: grid;
    gap: 0.75rem;
    max-width: 36rem;
    padding: 0.75rem;
    border-radius: 1.75rem;
    background: rgba(255, 253, 249, 0.88);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
  }

  @media (min-width: 720px) {
    .site-footer__prompt {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }
  }

  .site-footer__prompt input {
    min-width: 0;
    border: none;
    background: transparent;
    box-shadow: none;
    padding: 0.85rem 0.95rem;
  }

  .site-footer__prompt button {
    min-height: 3rem;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-size: 0.92rem;
    font-weight: 500;
    box-shadow: var(--btn-primary-shadow);
  }

  .site-footer__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem 2.25rem;
    align-content: start;
  }

  @media (min-width: 720px) {
    .site-footer__links {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .site-footer__group h3 {
    margin-bottom: 0.85rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .site-footer__group ul {
    list-style: none;
    display: grid;
    gap: 0.7rem;
  }

  .site-footer__group a {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .site-footer__group a:hover {
    color: var(--text-primary);
  }

  .site-footer__meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-secondary);
    font-size: 0.84rem;
    color: var(--text-tertiary);
  }

  @media (min-width: 768px) {
    .site-footer__meta {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
