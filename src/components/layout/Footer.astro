---
import { t } from '@i18n/translate';

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: t('nav.home') },
  { href: '/chatbot', label: t('nav.chatbot') },
  { href: '/kit', label: t('nav.kit') },
  { href: '/claw', label: t('nav.claw') },
  { href: '/about', label: t('nav.about') },
];

const socialLinks = [
  { 
    href: 'https://github.com/maxwell-xyz', 
    label: 'GitHub',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`
  },
  { 
    href: 'https://twitter.com', 
    label: 'Twitter',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`
  },
];

const resourceLinks = [
  { href: '/research', label: t('nav.research') },
  { href: '/trading', label: t('nav.trading') },
  { href: '/profile', label: t('profile.title') },
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-content">
      <!-- Brand Section -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-text">MeowClaw</span>
        </a>
        <p class="footer-tagline">{t('meta.description')}</p>
      </div>
      
      <!-- Navigation Links -->
      <div class="footer-section">
        <h4 class="footer-title">{t('footer.navigation')}</h4>
        <nav class="footer-nav">
          {navLinks.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>
      </div>
      
      <!-- Resources -->
      <div class="footer-section">
        <h4 class="footer-title">{t('footer.resources')}</h4>
        <nav class="footer-nav">
          {resourceLinks.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </nav>
      </div>
      
      <!-- Social Links -->
      <div class="footer-section">
        <h4 class="footer-title">{t('footer.connect')}</h4>
        <div class="footer-social">
          {socialLinks.map(link => (
            <a 
              href={link.href} 
              class="social-link" 
              target="_blank" 
              rel="noopener noreferrer"
              aria-label={link.label}
            >
              <Fragment set:html={link.icon} />
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        © {currentYear} 杨 浩. {t('footer.copyright')}.
      </p>
      <div class="footer-legal">
        <a href="/privacy" class="legal-link">{t('footer.privacy')}</a>
        <span class="legal-divider">·</span>
        <a href="/terms" class="legal-link">{t('footer.terms')}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
    margin-top: auto;
  }
  
  .footer-container {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: var(--space-10) var(--space-4) var(--space-6);
  }
  
  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }
  
  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }
  
  @media (max-width: 480px) {
    .footer-content {
      grid-template-columns: 1fr;
    }
  }
  
  .footer-brand {
    grid-column: span 1;
  }
  
  @media (max-width: 768px) {
    .footer-brand {
      grid-column: span 2;
    }
  }
  
  @media (max-width: 480px) {
    .footer-brand {
      grid-column: span 1;
    }
  }
  
  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: var(--space-3);
  }
  
  .logo-text {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    background: linear-gradient(135deg, var(--color-accent-blue), var(--color-accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .footer-tagline {
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    max-width: 280px;
  }
  
  .footer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  
  .footer-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }
  
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  
  .footer-link {
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
  }
  
  .footer-link:hover {
    color: var(--text-primary);
  }
  
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }
  
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--text-tertiary);
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .social-link:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
    transform: translateY(-2px);
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-secondary);
  }
  
  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      gap: var(--space-3);
      text-align: center;
    }
  }
  
  .footer-copyright {
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    font-family: var(--font-number);
  }
  
  .footer-legal {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  
  .legal-link {
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-default);
  }
  
  .legal-link:hover {
    color: var(--text-secondary);
  }
  
  .legal-divider {
    color: var(--text-tertiary);
  }
</style>
