---
const footerLinks = {
  Products: ["LiveChat", "API", "Pricing", "Docs"],
  Company: ["About", "Blog", "Careers", "Contact"],
  Resources: ["Research", "Safety", "Usage Policy"],
};

const legalLinks = ["Privacy Policy", "Terms of Service", "Cookie Settings"];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <div class="logo-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 3L20.5 18H3.5L12 3Z" fill="white" />
            </svg>
          </div>
          <span class="logo-text">MaxMini</span>
        </a>
        <p class="footer-tagline">
          AI companion built to help you think deeper, work smarter, and create freely.
        </p>
      </div>
      
      {Object.entries(footerLinks).map(([category, links]) => (
        <div class="footer-column">
          <h4 class="column-title">{category}</h4>
          <ul class="column-links">
            {links.map((link) => (
              <li><a href="#" class="column-link">{link}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="footer-divider"></div>
    
    <div class="footer-bottom">
      <p class="copyright">© 2026 杨浩. All rights reserved.</p>
      <div class="legal-links">
        {legalLinks.map((item) => (
          <a href="#" class="legal-link">{item}</a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #C06B3E;
    padding: var(--space-20) var(--space-6) var(--space-10);
  }

  @media (min-width: 768px) {
    .footer {
      padding: var(--space-20) var(--space-10) var(--space-10);
    }
  }

  .footer-container {
    max-width: var(--container-xl);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10);
    margin-bottom: var(--space-16);
    padding: var(--space-8);
    background: rgba(0, 0, 0, 0.1);
    border-radius: var(--radius-2xl);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .footer-brand {
    grid-column: span 2;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: var(--space-5);
  }

  .logo-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #C06B3E;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-icon svg {
    width: 16px;
    height: 16px;
  }

  .logo-text {
    font-family: 'Richy', 'Doralice', cursive, var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-normal);
    color: #F0E9DC;
    letter-spacing: -0.01em;
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #F0E9DC;
    line-height: 1.75;
    max-width: 280px;
  }

  .column-title {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--font-normal);
    color: #F0E9DC;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  .column-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .column-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #F0E9DC;
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-default);
  }

  .column-link:hover {
    color: #1A1207;
  }

  .footer-divider {
    height: 1px;
    background: #2C2210;
    margin-bottom: var(--space-8);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .copyright {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #F0E9DC;
  }

  .legal-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .legal-link {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: #F0E9DC;
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-default);
  }

  .legal-link:hover {
    color: #1A1207;
  }
</style>
