---
import SiteLogo from '@components/ui/SiteLogo.astro';

const currentPath = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

const navItems: NavItem[] = [
  { label: 'Chat', href: '/chatbot/' },
  { label: 'Calendar', href: '/calendar/' },
  { label: 'Workspace', href: '/workspace/' },
  {
    label: 'Kit',
    href: '/kit/',
    children: [
      { label: 'Kit 主页', href: '/kit/' },
      { label: '金价追踪', href: '/kit/gold/' },
    ],
  },
  { label: 'About', href: '/about/' },
];

const externalItems = [
  { href: 'https://ustc.dev', label: 'Token', icon: 'lock' },
];

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<header class="site-header">
  <div class="site-header__inner">
    <SiteLogo />

    <nav class="site-nav" aria-label="Primary">
      {navItems.map((item) => (
        item.children ? (
          <div class="nav-dropdown" data-dropdown>
            <a
              href={item.href}
              class:list={['site-nav__link', { active: isActive(item.href) }]}
            >
              {item.label}
            </a>
            <button
              class="nav-dropdown__toggle"
              aria-label={`${item.label} 子菜单`}
              aria-expanded="false"
              data-dropdown-toggle
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </button>
            <div class="nav-dropdown__menu">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={['nav-dropdown__item', { active: isActive(child.href) }]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={['site-nav__link', { active: isActive(item.href) }]}
          >
            {item.label}
          </a>
        )
      ))}
      {externalItems.map((item) => (
        <a href={item.href} class="site-nav__link" target="_blank" rel="noopener">
          {item.icon === 'lock' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; vertical-align: -2px;">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          )}
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header__actions">
      <a href="https://github.com/ustcio/meownote" class="site-utility-link" target="_blank" rel="noopener">GitHub</a>
      <a href="/chatbot/" class="header__cta">Try MoonSun</a>
    </div>

    <button class="mobile-toggle" id="mobile-menu-btn" aria-expanded="false" aria-label="Menu">
      <svg class="mobile-toggle__open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <line x1="4" y1="7.5" x2="20" y2="7.5" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="16.5" x2="20" y2="16.5" />
      </svg>
      <svg class="mobile-toggle__close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
    {navItems.map((item) => (
      item.children ? (
        <div class="mobile-dropdown" data-mobile-dropdown>
          <div class="mobile-dropdown__header">
            <a href={item.href} class:list={['mobile-nav__link', { active: isActive(item.href) }]}>
              {item.label}
            </a>
            <button class="mobile-dropdown__toggle" aria-label={`展开 ${item.label}`} aria-expanded="false">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </button>
          </div>
          <div class="mobile-dropdown__menu">
            {item.children.map((child) => (
              <a
                href={child.href}
                class:list={['mobile-dropdown__item', { active: isActive(child.href) }]}
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a href={item.href} class:list={['mobile-nav__link', { active: isActive(item.href) }]}>
          {item.label}
        </a>
      )
    ))}
    {externalItems.map((item) => (
      <a href={item.href} class="mobile-nav__link" target="_blank" rel="noopener">
        {item.icon === 'lock' && (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px; vertical-align: -3px;">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
        )}
        {item.label}
      </a>
    ))}
    <a href="https://github.com/ustcio/meownote" class="mobile-nav__link" target="_blank" rel="noopener">GitHub</a>
    <a href="/chatbot/" class="mobile-nav__cta">Try MoonSun</a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-fixed);
    background: var(--bg-primary);
  }

  .site-header__inner {
    max-width: var(--container-xl);
    width: calc(100% - (2 * clamp(1.5rem, 1.07rem + 2.14vw, 3rem)));
    min-height: var(--header-height);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-nav {
    display: none;
    align-items: center;
    gap: 1.4rem;
    margin-left: auto;
  }

  @media (min-width: 960px) {
    .site-nav {
      display: flex;
    }
  }

  .site-nav__link {
    padding: 0;
    font-size: 0.95rem;
    font-weight: var(--font-medium);
    color: var(--nav-link);
    transition: color var(--duration-fast) var(--ease-default);
  }

  .site-nav__link:hover,
  .site-nav__link.active {
    color: var(--nav-link-hover);
  }

  /* Dropdown */
  .nav-dropdown {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .nav-dropdown__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border: none;
    background: transparent;
    color: var(--nav-link);
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-default);
    padding: 0;
  }

  .nav-dropdown:hover .nav-dropdown__toggle,
  .nav-dropdown.open .nav-dropdown__toggle {
    color: var(--nav-link-hover);
  }

  .nav-dropdown.open .nav-dropdown__toggle {
    transform: rotate(180deg);
  }

  .nav-dropdown__menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    min-width: 10rem;
    padding: 0.4rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-default),
                transform var(--duration-fast) var(--ease-default);
    z-index: var(--z-dropdown);
  }

  .nav-dropdown:hover .nav-dropdown__menu,
  .nav-dropdown.open .nav-dropdown__menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown__item {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: var(--font-medium);
    color: var(--nav-link);
    white-space: nowrap;
    transition: background var(--duration-fast) var(--ease-default),
                color var(--duration-fast) var(--ease-default);
  }

  .nav-dropdown__item:hover {
    background: var(--bg-secondary);
    color: var(--nav-link-hover);
  }

  .nav-dropdown__item.active {
    color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .header__actions {
    display: none;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 960px) {
    .header__actions {
      display: flex;
    }
  }

  .site-utility-link {
    font-size: 0.95rem;
    font-weight: var(--font-medium);
    color: var(--nav-link);
  }

  .site-utility-link:hover {
    color: var(--nav-link-hover);
  }

  .header__cta,
  .mobile-nav__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.72rem 1rem;
    border-radius: var(--radius-full);
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-size: 0.92rem;
    font-weight: var(--font-medium);
    box-shadow: var(--btn-primary-shadow);
    transition: background var(--duration-fast) var(--ease-default), transform var(--duration-fast) var(--ease-default);
  }

  .header__cta:hover,
  .mobile-nav__cta:hover {
    background: var(--btn-primary-hover);
    color: var(--btn-primary-text);
    transform: translateY(-1px);
  }

  .mobile-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    margin-left: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-primary);
    background: transparent;
    color: var(--text-secondary);
  }

  @media (min-width: 960px) {
    .mobile-toggle {
      display: none;
    }
  }

  .mobile-toggle__open {
    display: block;
  }

  .mobile-toggle__close {
    display: none;
  }

  .mobile-toggle.open .mobile-toggle__open {
    display: none;
  }

  .mobile-toggle.open .mobile-toggle__close {
    display: block;
  }

  .mobile-nav {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    z-index: calc(var(--z-fixed) - 1);
    width: calc(100% - (2 * clamp(1.5rem, 1.07rem + 2.14vw, 3rem)));
    margin: 0 auto;
    padding: 1rem 0 1.5rem;
    background: var(--bg-primary);
    flex-direction: column;
    gap: 0.1rem;
    overflow-y: auto;
  }

  .mobile-nav.open {
    display: flex;
  }

  .mobile-nav__link {
    padding: 0.9rem 0;
    font-size: 1rem;
    font-weight: var(--font-medium);
    color: var(--nav-link);
    border-bottom: 1px solid var(--border-secondary);
  }

  .mobile-nav__link.active {
    color: var(--nav-link-hover);
  }

  .mobile-nav__cta {
    margin-top: 1rem;
    width: fit-content;
  }

  /* Mobile dropdown */
  .mobile-dropdown {
    border-bottom: 1px solid var(--border-secondary);
  }

  .mobile-dropdown__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .mobile-dropdown__header .mobile-nav__link {
    flex: 1;
    border-bottom: none;
  }

  .mobile-dropdown__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    background: transparent;
    color: var(--nav-link);
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .mobile-dropdown__toggle[aria-expanded="true"] {
    transform: rotate(180deg);
  }

  .mobile-dropdown__menu {
    display: none;
    padding: 0 0 0.5rem 1rem;
    flex-direction: column;
    gap: 0.1rem;
  }

  .mobile-dropdown.open .mobile-dropdown__menu {
    display: flex;
  }

  .mobile-dropdown__item {
    padding: 0.6rem 0;
    font-size: 0.95rem;
    font-weight: var(--font-medium);
    color: var(--nav-link);
    border-bottom: 1px solid var(--border-secondary);
    padding-left: 0.75rem;
    border-left: 2px solid var(--border-secondary);
  }

  .mobile-dropdown__item:last-child {
    border-bottom: none;
  }

  .mobile-dropdown__item:hover {
    color: var(--nav-link-hover);
  }

  .mobile-dropdown__item.active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }
</style>

<script is:inline>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const bodyScrollLock = window.__meownoteBodyScrollLock;

  function setMenuState(open) {
    const wasOpen = mobileNav?.classList.contains('open');
    mobileMenuBtn?.classList.toggle('open', open);
    mobileMenuBtn?.setAttribute('aria-expanded', String(open));
    mobileNav?.classList.toggle('open', open);
    if (open && !wasOpen) {
      bodyScrollLock?.lock?.();
    } else if (!open && wasOpen) {
      bodyScrollLock?.unlock?.();
    }
  }

  mobileMenuBtn?.addEventListener('click', () => {
    setMenuState(!mobileNav?.classList.contains('open'));
  });

  document.querySelectorAll('.mobile-nav__link, .mobile-nav__cta').forEach((link) => {
    link.addEventListener('click', () => setMenuState(false));
  });

  // Mobile dropdown toggles
  document.querySelectorAll('[data-mobile-dropdown]').forEach((dropdown) => {
    const toggle = dropdown.querySelector('.mobile-dropdown__toggle');
    toggle?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const isOpen = dropdown.classList.contains('open');
      dropdown.classList.toggle('open', !isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Desktop dropdown click support (for touch devices without hover)
  document.querySelectorAll('[data-dropdown]').forEach((dropdown) => {
    const toggle = dropdown.querySelector('[data-dropdown-toggle]');
    toggle?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const isOpen = dropdown.classList.contains('open');
      // Close other dropdowns
      document.querySelectorAll('[data-dropdown].open').forEach((d) => {
        if (d !== dropdown) d.classList.remove('open');
      });
      dropdown.classList.toggle('open', !isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('[data-dropdown].open').forEach((d) => {
      d.classList.remove('open');
      const toggle = d.querySelector('[data-dropdown-toggle]');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
