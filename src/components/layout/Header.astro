---
import ThemeToggle from '@components/ui/ThemeToggle.astro';
import Icon from '@components/ui/Icon.astro';
import AuthModal from '@components/ui/AuthModal.astro';

const navItems = [
  { href: '/', label: '首页', id: 'home' },
  { href: '/chatbot', label: 'AI 助手', id: 'chatbot' },
  { href: '/kit', label: '工具箱', id: 'kit' },
  { href: '/research', label: '研究', id: 'research' },
  { href: '/about', label: '关于', id: 'about' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="main-header">
  <div class="header-glass"></div>
  <div class="header-container">
    <a href="/" class="logo">
      <video 
        class="logo-video" 
        autoplay 
        loop 
        muted 
        playsinline 
        preload="auto" 
        poster="/favicon-32x32.png"
      >
        <source src="/logo.mp4" type="video/mp4" />
      </video>
      <span class="logo-text">MaoMeme</span>
    </a>
    
    <nav class="nav-desktop" aria-label="桌面端导航">
      <ul class="nav-list">
        {navItems.slice(0, 4).map((item) => (
          <li>
            <a 
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="nav-more-wrapper">
          <button class="nav-more-btn" aria-label="更多菜单" aria-expanded="false">
            <span>更多</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="nav-more-icon">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="nav-more-dropdown">
            <a 
              href="/about"
              class:list={['dropdown-link', { active: currentPath === '/about' }]}
            >
              关于
            </a>
            <a 
              href="/trading"
              class:list={['dropdown-link', 'dropdown-link--admin', { active: currentPath.startsWith('/trading') }]}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
              <span>交易管理</span>
            </a>
          </div>
        </li>
      </ul>
    </nav>
    
    <div class="header-actions">
      <div class="header-utils">
        <ThemeToggle />
        
        <div class="user-menu" id="user-menu">
          <button class="auth-btn" id="auth-btn" aria-label="登录">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </button>
          <div class="user-dropdown" id="user-dropdown">
            <div class="dropdown-header">
              <span class="dropdown-username" id="dropdown-username"></span>
            </div>
            <div class="dropdown-divider"></div>
            <a href="/profile" class="dropdown-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <span>个人资料</span>
            </a>
            <a href="/trading" class="dropdown-item dropdown-item--admin" id="admin-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
              <span>交易管理</span>
            </a>
            <button class="dropdown-item dropdown-item--logout" id="dropdown-logout">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
              </svg>
              <span>退出登录</span>
            </button>
          </div>
        </div>
      </div>
      
      <button
        class="mobile-menu-btn"
        id="mobile-menu-btn"
        aria-label="切换菜单"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
  
  <nav id="mobile-nav" class="mobile-nav" aria-label="移动端导航">
    <div class="mobile-nav-content">
      <ul class="mobile-nav-list">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href}
              class:list={['mobile-nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a 
            href="/trading"
            class:list={['mobile-nav-link', 'mobile-nav-link--admin', { active: currentPath.startsWith('/trading') }]}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <span>交易管理</span>
          </a>
        </li>
      </ul>
      <div class="mobile-nav-footer">
        <button class="mobile-auth-btn" id="mobile-auth-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>登录</span>
        </button>
      </div>
    </div>
  </nav>
</header>

<div class="header-backdrop" id="header-backdrop"></div>

<AuthModal />

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const headerBackdrop = document.getElementById('header-backdrop');
  const authBtn = document.getElementById('auth-btn');
  const mobileAuthBtn = document.getElementById('mobile-auth-btn');
  const userMenu = document.getElementById('user-menu');
  const dropdownLogout = document.getElementById('dropdown-logout');
  const dropdownUsername = document.getElementById('dropdown-username');
  const navMoreBtn = document.querySelector('.nav-more-btn');
  const navMoreDropdown = document.querySelector('.nav-more-dropdown');
  
  function toggleMobileMenu(open: boolean) {
    mobileMenuBtn?.setAttribute('aria-expanded', String(open));
    mobileNav?.classList.toggle('open', open);
    headerBackdrop?.classList.toggle('active', open);
    document.body.style.overflow = open ? 'hidden' : '';
  }
  
  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('open');
    toggleMobileMenu(!isOpen);
  });
  
  headerBackdrop?.addEventListener('click', () => {
    toggleMobileMenu(false);
  });
  
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      toggleMobileMenu(false);
    });
  });
  
  navMoreBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isExpanded = navMoreBtn.getAttribute('aria-expanded') === 'true';
    navMoreBtn.setAttribute('aria-expanded', String(!isExpanded));
    navMoreDropdown?.classList.toggle('open', !isExpanded);
  });
  
  document.addEventListener('click', (e) => {
    if (!navMoreBtn?.contains(e.target as Node)) {
      navMoreBtn?.setAttribute('aria-expanded', 'false');
      navMoreDropdown?.classList.remove('open');
    }
    if (!userMenu?.contains(e.target as Node)) {
      userMenu?.classList.remove('open');
    }
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      toggleMobileMenu(false);
      userMenu?.classList.remove('open');
      navMoreBtn?.setAttribute('aria-expanded', 'false');
      navMoreDropdown?.classList.remove('open');
    }
  });
  
  function openAuthModal() {
    (window as any).openAuthModal?.('login');
  }
  
  authBtn?.addEventListener('click', (e) => {
    const user = localStorage.getItem('user');
    if (user) {
      e.stopPropagation();
      userMenu?.classList.toggle('open');
    } else {
      openAuthModal();
    }
  });
  
  mobileAuthBtn?.addEventListener('click', () => {
    const user = localStorage.getItem('user');
    if (user) {
      window.location.href = '/profile';
    } else {
      toggleMobileMenu(false);
      openAuthModal();
    }
  });
  
  dropdownLogout?.addEventListener('click', () => {
    localStorage.removeItem('auth_token');
    localStorage.removeItem('user');
    window.dispatchEvent(new CustomEvent('auth:logout'));
    window.location.reload();
  });
  
  function updateAuthUI() {
    const user = localStorage.getItem('user');
    const mobileAuthBtnSpan = mobileAuthBtn?.querySelector('span');

    if (user) {
      try {
        const userData = JSON.parse(user);
        if (dropdownUsername) dropdownUsername.textContent = userData.username || '';
        if (mobileAuthBtnSpan) mobileAuthBtnSpan.textContent = userData.username || '';
        userMenu?.classList.add('logged-in');
      } catch (e) {
        console.warn('Failed to parse user data:', e);
        if (dropdownUsername) dropdownUsername.textContent = '';
        userMenu?.classList.remove('logged-in');
      }
    } else {
      if (dropdownUsername) dropdownUsername.textContent = '';
      userMenu?.classList.remove('logged-in');
    }
  }
  
  window.addEventListener('auth:login', updateAuthUI);
  window.addEventListener('auth:logout', updateAuthUI);
  document.addEventListener('DOMContentLoaded', updateAuthUI);
</script>

<style>
  .header {
    position: fixed;
    top: var(--space-3);
    left: var(--space-3);
    right: var(--space-3);
    z-index: var(--z-fixed);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    transition: transform var(--duration-normal) var(--ease-default);
  }
  
  .header-glass {
    position: absolute;
    inset: 0;
    background: var(--liquid-glass-bg);
    backdrop-filter: var(--liquid-glass-blur);
    -webkit-backdrop-filter: var(--liquid-glass-blur);
    border: 1px solid var(--liquid-glass-border);
    box-shadow: var(--liquid-glass-shadow);
    transition: background var(--duration-normal) var(--ease-default),
                border-color var(--duration-normal) var(--ease-default),
                box-shadow var(--duration-normal) var(--ease-default);
  }
  
  .header-glass::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--liquid-glass-highlight);
    pointer-events: none;
  }
  
  .header:hover .header-glass {
    background: var(--liquid-glass-bg-hover);
    border-color: var(--liquid-glass-border);
    box-shadow: var(--liquid-glass-shadow-hover);
  }
  
  @media (min-width: 768px) {
    .header {
      top: var(--space-4);
      left: var(--space-4);
      right: var(--space-4);
    }
  }
  
  @media (min-width: 1024px) {
    .header {
      top: var(--space-5);
      left: var(--space-6);
      right: var(--space-6);
    }
  }
  
  .header-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: var(--space-2) var(--space-3);
    height: var(--header-height);
    gap: var(--space-2);
  }
  
  @media (min-width: 768px) {
    .header-container {
      padding: var(--space-2) var(--space-4);
      gap: var(--space-4);
    }
  }
  
  @media (min-width: 1024px) {
    .header-container {
      padding: var(--space-2) var(--space-5);
      gap: var(--space-6);
    }
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--text-primary);
    flex-shrink: 0;
    z-index: 1;
  }
  
  .logo-video {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    object-position: center;
    transform: scale(1.1);
  }
  
  .logo-text {
    display: none;
    font-family: var(--font-brand);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  
  @media (min-width: 480px) {
    .logo-text {
      display: block;
    }
  }
  
  .nav-desktop {
    display: none;
    flex: 1;
    justify-content: center;
  }
  
  @media (min-width: 1024px) {
    .nav-desktop {
      display: flex;
    }
  }
  
  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    position: relative;
    display: block;
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    text-decoration: none;
    border-radius: var(--radius-xl);
    transition: color var(--duration-fast) var(--ease-default),
                background-color var(--duration-fast) var(--ease-default);
    z-index: 1;
  }
  
  .nav-link:hover {
    color: var(--text-primary);
    background-color: var(--liquid-glass-bg-active);
  }
  
  .nav-link.active {
    color: var(--text-primary);
    background-color: var(--liquid-glass-bg-active);
  }
  
  .nav-more-wrapper {
    position: relative;
    z-index: 1;
  }
  
  .nav-more-btn {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    background: none;
    border: none;
    border-radius: var(--radius-xl);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-default),
                background-color var(--duration-fast) var(--ease-default);
  }
  
  .nav-more-btn:hover {
    color: var(--text-primary);
    background-color: var(--liquid-glass-bg-active);
  }
  
  .nav-more-icon {
    transition: transform var(--duration-fast) var(--ease-default);
  }
  
  .nav-more-btn[aria-expanded="true"] .nav-more-icon {
    transform: rotate(180deg);
  }
  
  .nav-more-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: var(--space-2);
    min-width: 160px;
    padding: var(--space-2);
    background: var(--liquid-glass-bg);
    backdrop-filter: var(--liquid-glass-blur);
    -webkit-backdrop-filter: var(--liquid-glass-blur);
    border: 1px solid var(--liquid-glass-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--liquid-glass-shadow-hover);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px) scale(0.95);
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .nav-more-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }
  
  .dropdown-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .dropdown-link:hover {
    color: var(--text-primary);
    background-color: var(--liquid-glass-bg-active);
  }
  
  .dropdown-link.active {
    color: var(--text-primary);
    background-color: var(--liquid-glass-bg-active);
  }
  
  .dropdown-link--admin {
    color: var(--color-accent-purple);
  }
  
  .dropdown-link--admin:hover {
    background-color: rgba(191, 90, 242, 0.12);
  }
  
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    z-index: 1;
  }
  
  .header-utils {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  
  .auth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--text-tertiary);
    background: transparent;
    border: none;
    border-radius: var(--radius-xl);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-default),
                background-color var(--duration-fast) var(--ease-default);
  }
  
  .auth-btn:hover {
    color: var(--text-primary);
    background-color: var(--liquid-glass-bg-active);
  }
  
  .user-menu {
    position: relative;
  }
  
  .user-menu.logged-in .auth-btn {
    color: var(--color-primary);
  }
  
  .user-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: var(--space-2);
    min-width: 180px;
    padding: var(--space-2);
    background: var(--liquid-glass-bg);
    backdrop-filter: var(--liquid-glass-blur);
    -webkit-backdrop-filter: var(--liquid-glass-blur);
    border: 1px solid var(--liquid-glass-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--liquid-glass-shadow-hover);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px) scale(0.95);
    transition: all var(--duration-fast) var(--ease-default);
    z-index: var(--z-dropdown);
  }
  
  .user-menu:hover .user-dropdown,
  .user-menu.open .user-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }
  
  .dropdown-header {
    padding: var(--space-2) var(--space-3);
  }
  
  .dropdown-username {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
  }
  
  .dropdown-divider {
    height: 1px;
    background: var(--border-primary);
    margin: var(--space-1) 0;
  }
  
  .dropdown-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    border-radius: var(--radius-lg);
    transition: all var(--duration-fast) var(--ease-default);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
  }
  
  .dropdown-item:hover {
    background: var(--liquid-glass-bg-active);
    color: var(--text-primary);
  }
  
  .dropdown-item--logout {
    color: var(--color-error);
  }
  
  .dropdown-item--logout:hover {
    background: rgba(255, 55, 95, 0.1);
  }
  
  .dropdown-item--admin {
    color: var(--color-accent-purple);
  }
  
  .dropdown-item--admin:hover {
    background: rgba(191, 90, 242, 0.1);
  }
  
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: var(--radius-xl);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-default);
  }
  
  .mobile-menu-btn:hover {
    background-color: var(--liquid-glass-bg-active);
  }
  
  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }
  
  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: var(--radius-full);
    transition: all var(--duration-fast) var(--ease-default);
  }
  
  .hamburger-line + .hamburger-line {
    margin-top: 4px;
  }
  
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
  
  .header-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: all var(--duration-normal) var(--ease-default);
    z-index: calc(var(--z-fixed) - 1);
  }
  
  .header-backdrop.active {
    opacity: 1;
    visibility: visible;
  }
  
  @media (min-width: 1024px) {
    .header-backdrop {
      display: none;
    }
  }
  
  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 280px;
    max-width: 85vw;
    background: var(--liquid-glass-bg);
    backdrop-filter: var(--liquid-glass-blur-heavy);
    -webkit-backdrop-filter: var(--liquid-glass-blur-heavy);
    border-left: 1px solid var(--liquid-glass-border);
    box-shadow: var(--liquid-glass-shadow-hover);
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-default);
    z-index: calc(var(--z-fixed) + 1);
    overflow-y: auto;
  }
  
  .mobile-nav.open {
    transform: translateX(0);
  }
  
  @media (min-width: 1024px) {
    .mobile-nav {
      display: none;
    }
  }
  
  .mobile-nav-content {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: var(--space-6) var(--space-4);
  }
  
  .mobile-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
  }
  
  .mobile-nav-link {
    display: flex;
