---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Overview' },
  { href: '/chatbot', label: 'Chat' },
  { href: '/workspace', label: 'Workspace' },
  { href: '/kit', label: 'Tools' },
  { href: '/about', label: 'About' },
];

const utilityItems = [
  { href: '/claw', label: 'Claw' },
  { href: '/research', label: 'Research' },
  { href: '/trading', label: 'Trading' },
];

const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-logo" aria-label="Maxwell.Science home">
      <span class="site-logo__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 4L18.75 17H5.25L12 4Z" fill="currentColor"></path>
        </svg>
      </span>
      <span class="site-logo__wordmark">
        <span class="wordmark-brand">Maxwell</span><span class="wordmark-dot">.</span><span class="wordmark-domain">Science</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href} class:list={['site-nav__link', { active: isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="site-actions">
      <a href="#" class="site-utility-link js-login-trigger">Sign in</a>
      <a href="/chatbot" class="site-header__cta">Open chat</a>
    </div>

    <button class="site-menu-button" id="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open navigation">
      <svg class="menu-icon menu-icon--open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
      <svg class="menu-icon menu-icon--close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="18" y1="6" x2="6" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
    {[...navItems, ...utilityItems].map((item) => (
      <a href={item.href} class:list={['mobile-nav__link', { active: isActive(item.href) }]}>
        {item.label}
      </a>
    ))}
    <div class="mobile-nav__actions">
      <a href="#" class="mobile-nav__link js-login-trigger">Sign in</a>
      <a href="/chatbot" class="site-header__cta mobile-nav__cta">Open chat</a>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');

  function setMenuState(open: boolean) {
    mobileNav?.classList.toggle('open', open);
    mobileMenuBtn?.classList.toggle('open', open);
    mobileMenuBtn?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  mobileMenuBtn?.addEventListener('click', () => {
    setMenuState(!mobileNav?.classList.contains('open'));
  });

  document.querySelectorAll('.mobile-nav__link').forEach((link) => {
    link.addEventListener('click', () => setMenuState(false));
  });

  document.querySelectorAll('.js-login-trigger').forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      (window as any).openAuthModal?.('login');
      setMenuState(false);
    });
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-fixed);
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--nav-border);
  }

  .site-header__inner {
    max-width: var(--container-2xl);
    margin: 0 auto;
    padding: 0 1.2rem;
    min-height: var(--header-height);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .site-header__inner {
      padding: 0 2rem;
    }
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: max-content;
  }

  .site-logo__mark {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: #fffdf9;
    box-shadow: 0 8px 20px rgba(201, 105, 71, 0.18);
  }

  .site-logo__mark svg {
    width: 0.95rem;
    height: 0.95rem;
  }

  .site-logo__wordmark {
    display: inline-flex;
    align-items: baseline;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .wordmark-brand {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .wordmark-dot {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0.02em;
  }

  .wordmark-domain {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
  }

  .site-nav,
  .site-actions {
    display: none;
  }

  @media (min-width: 1024px) {
    .site-nav {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin-left: 1.5rem;
    }

    .site-actions {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 0.85rem;
    }
  }

  .site-nav__link,
  .site-utility-link {
    color: var(--nav-link);
    font-size: 0.92rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    padding: 0.25rem 0;
  }

  .site-nav__link.active,
  .site-utility-link.active,
  .site-nav__link:hover,
  .site-utility-link:hover {
    color: var(--nav-link-hover);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.75rem 1.15rem;
    border-radius: 999px;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    font-size: 0.92rem;
    font-weight: 500;
    box-shadow: var(--btn-primary-shadow);
  }

  .site-header__cta:hover {
    color: var(--btn-primary-text);
    background: var(--btn-primary-hover);
    transform: translateY(-1px);
  }

  .site-menu-button {
    margin-left: auto;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    border: 1px solid var(--border-primary);
    background: rgba(255, 253, 249, 0.78);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .site-menu-button {
      display: none;
    }
  }

  .menu-icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .menu-icon--close {
    display: none;
  }

  .site-menu-button.open .menu-icon--open {
    display: none;
  }

  .site-menu-button.open .menu-icon--close {
    display: block;
  }

  .mobile-nav {
    display: none;
    padding: 0 1.2rem 1.2rem;
    border-top: 1px solid rgba(71, 57, 44, 0.05);
    background: var(--bg-primary);
  }

  .mobile-nav.open {
    display: grid;
    gap: 0.4rem;
  }

  .mobile-nav__link {
    display: flex;
    align-items: center;
    min-height: 3rem;
    padding: 0 0.2rem;
    border-bottom: 1px solid rgba(71, 57, 44, 0.06);
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .mobile-nav__link.active {
    color: var(--text-primary);
  }

  .mobile-nav__actions {
    display: grid;
    gap: 0.75rem;
    padding-top: 0.75rem;
  }

  .mobile-nav__cta {
    width: 100%;
  }
</style>
