---
import { t, getLangFromUrl } from '@i18n';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/chatbot', label: 'Chat' },
  { href: '/workspace', label: 'Workspace' },
  { href: '/trading', label: 'Trading' },
  { href: '/claw', label: 'Claw' },
  { href: '/kit', label: 'Tools' },
  { href: '/about', label: 'About' },
];
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 3L20.5 18H3.5L12 3Z" fill="white" />
        </svg>
      </div>
      <span class="logo-text">MaxMin.dev</span>
    </a>
    
    <nav class="nav-desktop">
      {navItems.map((item) => (
        <a 
          href={item.href}
          class={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'nav-link active' : 'nav-link'}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a href="#" class="nav-link js-login-trigger">Log in</a>
      <a href="/chatbot" class="header-cta">Try LiveChat</a>
    </div>
    
    <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">
      <svg class="icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  
  <nav id="mobile-nav" class="mobile-nav">
    {navItems.map((item) => (
      <a 
        href={item.href}
        class={currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'mobile-link active' : 'mobile-link'}
      >
        {item.label}
      </a>
    ))}
    <div class="mobile-actions">
      <a href="#" class="mobile-login js-login-trigger">Log in</a>
      <a href="/chatbot" class="mobile-cta">Try LiveChat</a>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  
  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('open');
    mobileNav?.classList.toggle('open', !isOpen);
    mobileMenuBtn?.classList.toggle('open', !isOpen);
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });
  
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav?.classList.remove('open');
    mobileMenuBtn?.classList.remove('open');
    document.body.style.overflow = '';
    });
  });

  document.querySelectorAll('.js-login-trigger').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      (window as any).openAuthModal?.('login');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(240, 233, 220, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #D6CCBB;
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 var(--space-5);
    height: 64px;
  }

  @media (min-width: 768px) {
    .header-container {
      padding: 0 var(--space-8);
      height: 72px;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #C06B3E;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .logo:hover .logo-icon {
    transform: scale(1.05);
  }

  .logo-icon svg {
    width: 16px;
    height: 16px;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: var(--font-normal);
    color: #1A1207;
    letter-spacing: -0.01em;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
      gap: var(--space-8);
    }
  }
  
  .nav-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: #3D3521;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color var(--duration-normal) var(--ease-default);
    padding: var(--space-2) 0;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #C06B3E;
  }

  .header-actions {
    display: none;
    align-items: center;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .header-actions {
      display: flex;
      gap: var(--space-4);
    }
  }

  .header-cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    padding: 0.5rem 1.25rem;
    background: #1A1207;
    color: #F0E9DC;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .header-cta:hover {
    background: #2C2210;
    transform: translateY(-1px);
  }

  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #3D3521;
    transition: color var(--duration-normal) var(--ease-default);
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu-btn:hover {
    color: #C06B3E;
  }

  .mobile-menu-btn .icon-menu {
    display: block;
    width: 20px;
    height: 20px;
  }

  .mobile-menu-btn .icon-close {
    display: none;
    width: 20px;
    height: 20px;
  }

  .mobile-menu-btn.open .icon-menu {
    display: none;
  }

  .mobile-menu-btn.open .icon-close {
    display: block;
  }

  .mobile-nav {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: #F0E9DC;
    padding: var(--space-6);
    flex-direction: column;
    gap: var(--space-2);
    overflow-y: auto;
    z-index: 49;
  }

  .mobile-nav.open {
    display: flex;
    animation: slideUp 0.25s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .mobile-nav.open {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    animation: slideDown 0.25s ease-out;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 768px) {
    .mobile-nav {
      display: none !important;
    }
  }

  .mobile-link {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    color: #3D3521;
    text-decoration: none;
    padding: var(--space-4);
    transition: all var(--duration-normal) var(--ease-default);
    border-radius: var(--radius-lg);
  }

  .mobile-link:active {
    background: rgba(192, 107, 62, 0.08);
    color: #C06B3E;
  }

  .mobile-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
    margin-top: auto;
    border-top: 1px solid rgba(208, 196, 176, 0.3);
  }

  .mobile-login {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: #3D3521;
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    text-align: center;
    transition: color var(--duration-normal) var(--ease-default);
  }

  .mobile-login:hover {
    color: #C06B3E;
  }

  .mobile-cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    padding: var(--space-3) var(--space-5);
    background: #1A1207;
    color: #F0E9DC;
    border-radius: var(--radius-full);
    text-decoration: none;
    text-align: center;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .mobile-cta:hover {
    background: #2C2210;
    transform: translateY(-1px);
  }

  [data-theme="dark"] .header {
    background: rgba(26, 18, 7, 0.95);
    border-bottom: 1px solid rgba(240, 233, 220, 0.12);
  }

  [data-theme="dark"] .logo-text {
    color: #F0E9DC;
  }

  [data-theme="dark"] .nav-link {
    color: #A89880;
  }

  [data-theme="dark"] .nav-link:hover,
  [data-theme="dark"] .nav-link.active {
    color: #C06B3E;
  }

  [data-theme="dark"] .header-cta {
    background: #C06B3E;
    color: #F0E9DC;
  }

  [data-theme="dark"] .header-cta:hover {
    background: #A85A32;
  }

  [data-theme="dark"] .mobile-nav {
    background: #1A1207;
    border-top: 1px solid rgba(240, 233, 220, 0.08);
  }

  
  [data-theme="dark"] .mobile-link {
    color: #F0E9DC;
  }
  
  [data-theme="dark"] .mobile-link:active {
    background: rgba(192, 107, 62, 0.15);
    color: #C06B3E;
  }
  
  [data-theme="dark"] .mobile-actions {
    border-top: 1px solid rgba(240, 233, 220, 0.1);
  }
  
  [data-theme="dark"] .mobile-login {
    color: #A89880;
  }
  
  [data-theme="dark"] .mobile-login:hover {
    color: #C06B3E;
  }
  
  [data-theme="dark"] .mobile-cta {
    background: #C06B3E;
    color: #F0E9DC;
  }
  
  [data-theme="dark"] .mobile-cta:hover {
    background: #A85A32;
  }
</style>
