---
interface Props {
  class?: string;
  intensity?: 'low' | 'medium' | 'high';
  colorScheme?: 'dreamscape' | 'ocean' | 'cosmic' | 'nature';
}

const { 
  class: className,
  intensity = 'medium',
  colorScheme = 'dreamscape'
} = Astro.props;

const colorSchemes = {
  dreamscape: {
    colors: ['#00d4ff', '#b829dd', '#ff6b9d', '#06ffa5'],
    background: '#0a0a0f'
  },
  ocean: {
    colors: ['#00d4ff', '#0066cc', '#00f5d4', '#66e0ff'],
    background: '#050a14'
  },
  cosmic: {
    colors: ['#b829dd', '#ff6b9d', '#ff8a5c', '#ffd93d'],
    background: '#0f0a14'
  },
  nature: {
    colors: ['#06ffa5', '#00d4ff', '#7ee787', '#a8e6cf'],
    background: '#0a140f'
  }
};

const scheme = colorSchemes[colorScheme];
---

<div 
  class:list={['fluid-background', `intensity-${intensity}`, className]}
  data-colors={JSON.stringify(scheme.colors)}
  data-background={scheme.background}
>
  <canvas class="fluid-canvas"></canvas>
  <div class="fluid-overlay"></div>
</div>

<style>
  .fluid-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
  }

  .fluid-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .fluid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--gradient-dreamscape);
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0.5;
  }

  /* Intensity variations */
  .intensity-low .fluid-canvas {
    opacity: 0.4;
  }

  .intensity-medium .fluid-canvas {
    opacity: 0.6;
  }

  .intensity-high .fluid-canvas {
    opacity: 0.8;
  }
</style>

<script>
  class FluidSimulation {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    width: number;
    height: number;
    particles: Particle[] = [];
    mouse = { x: 0, y: 0, vx: 0, vy: 0 };
    colors: string[];
    background: string;
    animationId: number = 0;
    time = 0;

    constructor(canvas: HTMLCanvasElement, colors: string[], background: string) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.colors = colors;
      this.background = background;
      
      this.resize();
      this.initParticles();
      this.bindEvents();
      this.animate();
    }

    resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      
      this.canvas.width = this.width * dpr;
      this.canvas.height = this.height * dpr;
      this.canvas.style.width = `${this.width}px`;
      this.canvas.style.height = `${this.height}px`;
      
      this.ctx.scale(dpr, dpr);
    }

    initParticles() {
      const particleCount = Math.min(
        Math.floor((this.width * this.height) / 12000),
        80
      );
      
      this.particles = [];
      
      for (let i = 0; i < particleCount; i++) {
        this.particles.push(new Particle(
          Math.random() * this.width,
          Math.random() * this.height,
          this.colors[Math.floor(Math.random() * this.colors.length)]
        ));
      }
    }

    bindEvents() {
      let lastMouseX = 0;
      let lastMouseY = 0;
      
      window.addEventListener('resize', () => {
        this.resize();
        this.initParticles();
      });

      window.addEventListener('mousemove', (e) => {
        this.mouse.vx = e.clientX - lastMouseX;
        this.mouse.vy = e.clientY - lastMouseY;
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
        lastMouseX = e.clientX;
        lastMouseY = e.clientY;
      });

      // Touch support
      window.addEventListener('touchmove', (e) => {
        const touch = e.touches[0];
        this.mouse.vx = touch.clientX - lastMouseX;
        this.mouse.vy = touch.clientY - lastMouseY;
        this.mouse.x = touch.clientX;
        this.mouse.y = touch.clientY;
        lastMouseX = touch.clientX;
        lastMouseY = touch.clientY;
      }, { passive: true });
    }

    animate() {
      this.time += 0.005;
      
      // Clear with trail effect
      this.ctx.fillStyle = `${this.background}10`;
      this.ctx.fillRect(0, 0, this.width, this.height);

      // Update and draw particles
      this.particles.forEach((particle, i) => {
        particle.update(this.time, this.mouse, this.width, this.height);
        particle.draw(this.ctx);
      });

      // Draw connections
      this.drawConnections();

      // Draw fluid blobs
      this.drawFluidBlobs();

      this.animationId = requestAnimationFrame(() => this.animate());
    }

    drawConnections() {
      const maxDistance = 180;
      
      for (let i = 0; i < this.particles.length; i++) {
        for (let j = i + 1; j < this.particles.length; j++) {
          const dx = this.particles[i].x - this.particles[j].x;
          const dy = this.particles[i].y - this.particles[j].y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < maxDistance) {
            const opacity = (1 - distance / maxDistance) * 0.15;
            const gradient = this.ctx.createLinearGradient(
              this.particles[i].x, this.particles[i].y,
              this.particles[j].x, this.particles[j].y
            );
            gradient.addColorStop(0, this.particles[i].color + Math.floor(opacity * 255).toString(16).padStart(2, '0'));
            gradient.addColorStop(1, this.particles[j].color + Math.floor(opacity * 255).toString(16).padStart(2, '0'));
            
            this.ctx.beginPath();
            this.ctx.strokeStyle = gradient;
            this.ctx.lineWidth = 0.5;
            this.ctx.moveTo(this.particles[i].x, this.particles[i].y);
            this.ctx.lineTo(this.particles[j].x, this.particles[j].y);
            this.ctx.stroke();
          }
        }
      }
    }

    drawFluidBlobs() {
      // Draw large, soft gradient blobs for fluid effect
      const blobCount = 3;
      
      for (let i = 0; i < blobCount; i++) {
        const x = this.width * (0.2 + i * 0.3 + Math.sin(this.time + i) * 0.1);
        const y = this.height * (0.3 + Math.cos(this.time * 0.7 + i) * 0.2);
        const radius = Math.min(this.width, this.height) * (0.25 + Math.sin(this.time * 0.5 + i) * 0.05);
        
        const gradient = this.ctx.createRadialGradient(x, y, 0, x, y, radius);
        const color = this.colors[i % this.colors.colors];
        gradient.addColorStop(0, color + '15');
        gradient.addColorStop(0.5, color + '08');
        gradient.addColorStop(1, 'transparent');
        
        this.ctx.fillStyle = gradient;
        this.ctx.beginPath();
        this.ctx.arc(x, y, radius, 0, Math.PI * 2);
        this.ctx.fill();
      }
    }

    destroy() {
      if (this.animationId) {
        cancelAnimationFrame(this.animationId);
      }
    }
  }

  class Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    radius: number;
    color: string;
    angle: number;
    speed: number;
    amplitude: number;

    constructor(x: number, y: number, color: string) {
      this.x = x;
      this.y = y;
      this.vx = (Math.random() - 0.5) * 0.3;
      this.vy = (Math.random() - 0.5) * 0.3;
      this.radius = Math.random() * 2 + 1;
      this.color = color;
      this.angle = Math.random() * Math.PI * 2;
      this.speed = Math.random() * 0.5 + 0.2;
      this.amplitude = Math.random() * 30 + 20;
    }

    update(time: number, mouse: { x: number; y: number; vx: number; vy: number }, width: number, height: number) {
      // Organic movement using sine waves
      this.angle += this.speed * 0.01;
      this.x += this.vx + Math.sin(time + this.angle) * 0.2;
      this.y += this.vy + Math.cos(time + this.angle) * 0.2;

      // Mouse interaction - gentle repulsion
      const dx = this.x - mouse.x;
      const dy = this.y - mouse.y;
      const distance = Math.sqrt(dx * dx + dy * dy);
      
      if (distance < 150) {
        const force = (150 - distance) / 150;
        this.vx += (dx / distance) * force * 0.02;
        this.vy += (dy / distance) * force * 0.02;
      }

      // Damping
      this.vx *= 0.99;
      this.vy *= 0.99;

      // Boundary wrap
      if (this.x < -50) this.x = width + 50;
      if (this.x > width + 50) this.x = -50;
      if (this.y < -50) this.y = height + 50;
      if (this.y > height + 50) this.y = -50;
    }

    draw(ctx: CanvasRenderingContext2D) {
      // Glow effect
      const gradient = ctx.createRadialGradient(
        this.x, this.y, 0,
        this.x, this.y, this.radius * 4
      );
      gradient.addColorStop(0, this.color + '80');
      gradient.addColorStop(0.5, this.color + '20');
      gradient.addColorStop(1, 'transparent');
      
      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius * 4, 0, Math.PI * 2);
      ctx.fill();

      // Core
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // Initialize fluid backgrounds
  document.querySelectorAll('.fluid-background').forEach(container => {
    const canvas = container.querySelector('.fluid-canvas') as HTMLCanvasElement;
    const colors = JSON.parse(container.getAttribute('data-colors') || '[]');
    const background = container.getAttribute('data-background') || '#0a0a0f';
    
    if (canvas && colors.length > 0) {
      new FluidSimulation(canvas, colors, background);
    }
  });
</script>
