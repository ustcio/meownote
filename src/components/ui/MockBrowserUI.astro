---
// src/components/ui/MockBrowserUI.astro
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={["mock-browser-container", className]} aria-hidden="true">
  <!-- Interactive macOS style UI Mockup -->
  <div class="mock-window">
    
    <!-- Window Header -->
    <div class="window-header">
      <div class="window-controls">
        <span class="control red"></span>
        <span class="control yellow"></span>
        <span class="control green"></span>
      </div>
      <div class="window-title">
        <span class="icon">📁</span>
        Documents
      </div>
      <div class="window-search">
        <span class="search-icon">🔍</span>
        <span class="search-ph">Search</span>
      </div>
    </div>
    
    <!-- Window Body -->
    <div class="window-body">
      <!-- Sidebar -->
      <div class="sidebar">
        <div class="sidebar-section">
          <div class="sidebar-title">Favorites</div>
          <div class="sidebar-item">🕒 Recents</div>
          <div class="sidebar-item">💻 Desktop</div>
          <div class="sidebar-item active">📁 Documents</div>
          <div class="sidebar-item">⬇️ Downloads</div>
        </div>
      </div>
      
      <!-- Main Content Grid -->
      <div class="main-content">
        <div class="folder-grid">
          <div class="folder-item">
            <div class="folder-icon">📁</div>
            <div class="folder-name">Projects</div>
          </div>
          <div class="folder-item">
            <div class="folder-icon">📁</div>
            <div class="folder-name">Analysis</div>
          </div>
          <!-- Target folder for animation -->
          <div class="folder-item target-folder">
            <div class="folder-icon">📁</div>
            <div class="folder-name">Research</div>
          </div>
          <div class="folder-item">
            <div class="folder-icon">📁</div>
            <div class="folder-name">Q4 Planning</div>
          </div>
          <div class="folder-item">
            <div class="folder-icon">📁</div>
            <div class="folder-name">Contracts</div>
          </div>
          <div class="folder-item">
            <div class="folder-icon">📁</div>
            <div class="folder-name">Expenses</div>
          </div>
        </div>
      </div>
    </div>
    
  </div>

  <!-- Animated Cursor over the UI -->
  <div class="animated-cursor">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Standard macOS arrow cursor styling with shadow -->
      <g filter="url(#filter0_d)">
        <path d="M5.5 3L11.5 20.5L14.5 13.5L21.5 10.5L5.5 3Z" fill="white" stroke="black" stroke-width="1.5" stroke-linejoin="round"/>
      </g>
      <defs>
        <filter id="filter0_d" x="0" y="0" width="24" height="24" filterUnits="userSpaceOnUse" color-interpolation-filters="sRGB">
          <feDropShadow dx="1" dy="2" stdDeviation="1" flood-opacity="0.3"/>
        </filter>
      </defs>
    </svg>
  </div>
</div>

<style>
  .mock-browser-container {
    position: relative;
    width: 100%;
    max-width: 600px;
    perspective: 1000px;
    margin: 0 auto;
    padding: var(--space-4);
  }

  /* The actual window */
  .mock-window {
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    overflow: hidden;
    transform: rotateY(-2deg) rotateX(2deg); /* Subtle 3D tilt */
    transition: transform 0.5s ease;
  }
  
  .mock-window:hover {
    transform: rotateY(0deg) rotateX(0deg);
  }

  .window-header {
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-primary);
  }

  .window-controls {
    display: flex;
    gap: 6px;
    width: 60px;
  }

  .control {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .red { background: #ff5f57; }
  .yellow { background: #febc2e; }
  .green { background: #28c840; }

  .window-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .window-search {
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 11px;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 4px;
    width: 80px;
  }

  .window-body {
    display: flex;
    height: 350px;
  }

  .sidebar {
    width: 140px;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-primary);
    padding: 16px 8px;
    font-size: 12px;
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-title {
    color: var(--text-tertiary);
    font-weight: 600;
    padding-left: 8px;
    margin-bottom: 4px;
  }

  .sidebar-item {
    padding: 6px 8px;
    border-radius: 6px;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .sidebar-item.active {
    background: var(--color-primary-alpha-10);
    color: var(--color-primary);
    font-weight: 500;
  }

  .main-content {
    flex: 1;
    padding: 24px;
    background: var(--bg-primary);
  }

  .folder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .folder-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 8px;
    border-radius: 6px;
    transition: background 0.2s;
  }

  .folder-icon {
    font-size: 40px;
    line-height: 1;
    /* Simulate standard macOS folder color */
    filter: sepia(1) hue-rotate(180deg) saturate(3) brightness(1.1);
  }

  .folder-name {
    font-size: 12px;
    color: var(--text-primary);
    text-align: center;
  }

  /* Interaction Animation for the Folder */
  .target-folder {
    animation: folderSelect 6s infinite;
  }

  @keyframes folderSelect {
    0%, 40% { background: transparent; }
    45%, 85% { background: rgba(0,0,0,0.05); } /* selected state */
    90%, 100% { background: transparent; }
  }

  :root[data-theme="dark"] .target-folder {
    animation: folderSelectDark 6s infinite;
  }
  @keyframes folderSelectDark {
    0%, 40% { background: transparent; }
    45%, 85% { background: rgba(255,255,255,0.1); }
    90%, 100% { background: transparent; }
  }

  /* Animated Cursor */
  .animated-cursor {
    position: absolute;
    top: 60%;
    left: 80%;
    z-index: 10;
    pointer-events: none;
    transform-origin: top left;
    animation: moveCursor 6s infinite;
  }

  @keyframes moveCursor {
    /* start bottom right */
    0% { transform: translate(0, 0) scale(1); }
    /* move towards the "Research" folder (calc roughly middle right) */
    35% { transform: translate(-120px, -150px) scale(1); }
    /* Cursor click press down */
    40% { transform: translate(-120px, -150px) scale(0.85); }
    /* Hover click hold */
    45% { transform: translate(-120px, -150px) scale(1); }
    /* Move away */
    70% { transform: translate(-50px, 100px) scale(1); }
    100% { transform: translate(0, 0) scale(1); }
  }
</style>
