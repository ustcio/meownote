---
// src/components/ui/TabsShowcase.astro
interface TabItem {
  id: string;
  label: string;
  icon?: string;
  contentTitle: string;
  contentText: string;
  visualHtml?: string;
}

interface Props {
  class?: string;
  tabs: TabItem[];
  ariaLabel?: string;
}

const {
  class: className = '',
  tabs,
  ariaLabel = 'Workflow surfaces',
} = Astro.props;

const showcaseId = `tabs-${Math.random().toString(36).slice(2, 9)}`;
const visualHtmlByTab = new Map(
  await Promise.all(
    tabs.map(async (tab) => [
      tab.id,
      Astro.slots.has(tab.id) ? await Astro.slots.render(tab.id) : tab.visualHtml || '',
    ])
  )
);
---

<div class:list={["claude-tabs-showcase", className]} id={showcaseId} data-tabs-showcase>
  <div class="tabs-nav" role="tablist" aria-label={ariaLabel}>
    {tabs.map((tab, index) => (
      <button 
        type="button"
        class={`tab-btn ${index === 0 ? 'active' : ''}`} 
        id={`${showcaseId}-${tab.id}-tab`}
        role="tab"
        aria-selected={index === 0 ? 'true' : 'false'}
        aria-controls={`${showcaseId}-${tab.id}-panel`}
        data-target={`${showcaseId}-${tab.id}-panel`}
        tabindex={index === 0 ? '0' : '-1'}
      >
        {tab.icon && <span class="tab-icon" set:html={tab.icon} />}
        <span class="tab-label">{tab.label}</span>
      </button>
    ))}
  </div>
  
  <div class="tabs-content-area claude-surface">
    {tabs.map((tab, index) => (
      <div 
        class={`tab-panel ${index === 0 ? 'active' : ''}`} 
        id={`${showcaseId}-${tab.id}-panel`}
        role="tabpanel"
        aria-labelledby={`${showcaseId}-${tab.id}-tab`}
        hidden={index !== 0}
      >
        <div class="panel-info">
          <h3>{tab.contentTitle}</h3>
          <p>{tab.contentText}</p>
        </div>
        <div class="panel-visual">
          {visualHtmlByTab.get(tab.id) ? (
            <Fragment set:html={visualHtmlByTab.get(tab.id)} />
          ) : (
            <div class="panel-visual-placeholder" aria-hidden="true"></div>
          )}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .claude-tabs-showcase {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    width: 100%;
  }

  .tabs-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    border-bottom: 1px solid var(--border-secondary);
    padding-bottom: var(--space-4);
  }

  .tab-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    background: transparent;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .tab-btn:hover {
    color: var(--text-primary);
    background: var(--bg-secondary);
  }

  .tab-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .tab-btn.active {
    color: var(--text-inverse);
    background: var(--text-primary);
  }

  .tabs-content-area {
    position: relative;
    min-height: 400px;
    overflow: hidden;
    padding: var(--space-8);
  }

  .tab-panel {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: stretch;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .tab-panel.active {
    display: grid;
    /* We use an animation to trigger the opacity transition securely */
    animation: fadeUpIn 0.4s forwards;
  }

  @keyframes fadeUpIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .panel-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }
  
  .panel-info h3 {
    font-size: var(--text-2xl);
  }
  
  .panel-info p {
    font-size: var(--text-base);
    color: var(--text-secondary);
  }

  .panel-visual {
    min-height: 250px;
    display: grid;
    align-items: stretch;
  }

  .panel-visual-placeholder {
    width: 100%;
    min-height: 250px;
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, var(--bg-secondary), var(--bg-tertiary));
    border: 1px solid var(--border-secondary);
  }

  @media (max-width: 768px) {
    .tab-panel {
      grid-template-columns: 1fr;
    }

    .tabs-content-area {
      padding: var(--space-5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tab-panel.active {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function initTabs() {
    const showcases = document.querySelectorAll('[data-tabs-showcase]');
    
    showcases.forEach(showcase => {
      if ((showcase as HTMLElement).dataset.tabsReady === 'true') return;
      (showcase as HTMLElement).dataset.tabsReady = 'true';

      const btns = Array.from(showcase.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
      const panels = Array.from(showcase.querySelectorAll<HTMLElement>('[role="tabpanel"]'));
      
      function activateTab(nextBtn: HTMLButtonElement, shouldFocus = false) {
        btns.forEach(btn => {
          const isActive = btn === nextBtn;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
          btn.tabIndex = isActive ? 0 : -1;

          const panelId = btn.getAttribute('aria-controls');
          if (!panelId) return;

          const panel = panels.find(item => item.id === panelId);
          if (panel) {
            panel.classList.toggle('active', isActive);
            panel.hidden = !isActive;
          }
        });

        if (shouldFocus) {
          nextBtn.focus();
        }
      }

      btns.forEach((btn, index) => {
        btn.addEventListener('click', () => activateTab(btn));

        btn.addEventListener('keydown', (event) => {
          const lastIndex = btns.length - 1;
          let nextIndex = index;

          if (event.key === 'ArrowRight') nextIndex = index === lastIndex ? 0 : index + 1;
          if (event.key === 'ArrowLeft') nextIndex = index === 0 ? lastIndex : index - 1;
          if (event.key === 'Home') nextIndex = 0;
          if (event.key === 'End') nextIndex = lastIndex;

          if (nextIndex !== index) {
            event.preventDefault();
            activateTab(btns[nextIndex], true);
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initTabs);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabs);
  } else {
    initTabs();
  }
</script>
