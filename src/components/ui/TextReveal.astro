---
interface Props {
  text?: string;
  tag?: keyof HTMLElementTagNameMap;
  class?: string;
  delay?: number;
}
const { text, tag: Tag = 'div', class: className = '', delay = 0 } = Astro.props;
---
<Tag class:list={["claude-text-reveal", className]} style={`--reveal-delay: ${delay}ms`}>
  {text ? text.split(' ').map((word, i) => (
    <span class="reveal-word" style={`transition-delay: calc(var(--reveal-delay) + ${i * 40}ms);`}>
      {word}&nbsp;
    </span>
  )) : <slot />}
</Tag>

<style>
  .claude-text-reveal {
    display: inline-block;
  }
  
  .reveal-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    transition: opacity 0.6s cubic-bezier(0.2, 0.7, 0.2, 1), 
                transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
    will-change: opacity, transform;
  }
  
  .claude-text-reveal.is-revealed .reveal-word {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* For nested slot elements (e.g. paragraphs or list items) */
  .claude-text-reveal :global(> *) {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.2, 0.7, 0.2, 1), 
                transform 0.8s cubic-bezier(0.2, 0.7, 0.2, 1);
    will-change: opacity, transform;
  }
  
  .claude-text-reveal.is-revealed :global(> *) {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function setupTextReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          // Unobserve if you want it to trigger only once
          // observer.unobserve(entry.target); 
        }
      });
    }, {
      rootMargin: '0px 0px -10% 0px',
      threshold: 0.1
    });

    document.querySelectorAll('.claude-text-reveal').forEach(el => {
      observer.observe(el);
      
      // If slot is used, stagger its immediate children
      const children = Array.from(el.children);
      if (children.length > 0 && !el.querySelector('.reveal-word')) {
         children.forEach((child, i) => {
           const baseDelay = parseInt(el.getAttribute('style')?.match(/--reveal-delay:\s*(\d+)ms/)?.[1] || '0', 10);
           (child as HTMLElement).style.transitionDelay = `${baseDelay + (i * 120)}ms`;
         });
      }
    });
  }

  document.addEventListener('astro:page-load', setupTextReveal);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupTextReveal);
  } else {
    setupTextReveal();
  }
</script>
