---
// src/components/ui/ChatPreviewMockup.astro
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={["preview-container", className]} aria-hidden="true">
  <div class="hero__preview">
    <!-- fake chat UI -->
    <div class="preview__header">
      <span class="preview__dot preview__dot--red"></span>
      <span class="preview__dot preview__dot--yellow"></span>
      <span class="preview__dot preview__dot--green"></span>
      <span class="preview__title">Maxwell Chat</span>
    </div>
    <div class="preview__body">
      <div class="preview__msg preview__msg--user">
        <span class="preview__msg-label">You</span>
        <p>Summarise the key findings from the latest CoNb₃S₆ transport data.</p>
      </div>
      <div class="preview__msg preview__msg--ai">
        <span class="preview__msg-label">Max</span>
        <p class="preview__typing">
          <span class="preview__typing-dot" style="--d: 0s"></span>
          <span class="preview__typing-dot" style="--d: 0.2s"></span>
          <span class="preview__typing-dot" style="--d: 0.4s"></span>
        </p>
        <p class="preview__response">Three key observations stand out:</p>
        <ul class="preview__response-list">
          <li>Nonlinear Hall signal emerges below 28 K</li>
          <li>Magnetoresistance shows CDW signature</li>
          <li>Anomalous scaling suggests Berry curvature origin</li>
        </ul>
      </div>
    </div>
  </div>
  <!-- floating cards -->
  <div class="hero__float hero__float--card1">
    <div class="float-card">
      <span class="float-card__icon">📝</span>
      <span class="float-card__text">Draft ready</span>
    </div>
  </div>
  <div class="hero__float hero__float--card2">
    <div class="float-card">
      <span class="float-card__icon">🔬</span>
      <span class="float-card__text">12 papers found</span>
    </div>
  </div>
  <div class="hero__float hero__float--card3">
    <div class="float-card">
      <span class="float-card__icon">✨</span>
      <span class="float-card__text">Summary generated</span>
    </div>
  </div>
</div>

<style>
  .preview-container {
    position: relative;
    width: 100%;
    margin: var(--space-4) 0;
  }

  .hero__preview {
    background: var(--card-bg);
    border: 1px solid var(--border-primary);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    opacity: 0;
    animation: heroPreviewIn 0.8s var(--ease-out) 0.4s both;
  }

  @keyframes heroPreviewIn {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .preview__header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-primary);
  }

  .preview__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .preview__dot--red { background: #ff5f57; }
  .preview__dot--yellow { background: #febc2e; }
  .preview__dot--green { background: #28c840; }

  .preview__title {
    margin-left: 8px;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-quaternary);
  }

  .preview__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 220px;
  }

  .preview__msg {
    padding: 10px 12px;
    border-radius: 10px;
    max-width: 85%;
    animation: msgIn 0.5s var(--ease-out) both;
  }

  .preview__msg--user {
    align-self: flex-end;
    background: var(--color-primary-alpha-10);
    animation-delay: 0.8s;
  }

  .preview__msg--ai {
    align-self: flex-start;
    background: var(--bg-secondary);
    animation-delay: 1.6s;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .preview__msg-label {
    display: block;
    font-size: 0.65rem;
    font-weight: var(--font-semibold);
    color: var(--text-quaternary);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .preview__msg p {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-primary);
    margin: 0;
  }

  .preview__typing {
    display: flex;
    gap: 4px;
    padding: 4px 0;
  }

  .preview__typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: typingBounce 1.2s ease-in-out infinite;
    animation-delay: var(--d);
  }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.3; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  .preview__response {
    font-weight: var(--font-medium);
    margin-top: 6px !important;
  }

  .preview__response-list {
    margin: 6px 0 0 0;
    padding-left: 16px;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .preview__response-list li {
    margin-bottom: 2px;
  }

  .hero__float {
    position: absolute;
    z-index: 2;
  }

  .hero__float--card1 {
    top: -12px;
    right: -20px;
    animation: floatCard1 6s ease-in-out infinite;
  }

  .hero__float--card2 {
    bottom: 40px;
    left: -30px;
    animation: floatCard2 7s ease-in-out infinite;
    animation-delay: 1s;
  }

  .hero__float--card3 {
    bottom: -10px;
    right: 40px;
    animation: floatCard3 8s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes floatCard1 {
    0%, 100% { transform: translateY(0) rotate(2deg); }
    50% { transform: translateY(-10px) rotate(-1deg); }
  }

  @keyframes floatCard2 {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-8px) rotate(1deg); }
  }

  @keyframes floatCard3 {
    0%, 100% { transform: translateY(0) rotate(1deg); }
    50% { transform: translateY(-12px) rotate(-2deg); }
  }

  .float-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--card-bg);
    border: 1px solid var(--border-primary);
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .float-card__icon {
    font-size: 1rem;
  }

  [data-theme="dark"] .hero__preview {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  [data-theme="dark"] .float-card {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
</style>
