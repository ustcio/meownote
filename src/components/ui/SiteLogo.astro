---
interface Props {
  href?: string;
  label?: string;
  size?: 'header' | 'footer' | 'meta' | 'mini';
  as?: 'a' | 'span';
  class?: string;
}

const {
  href = '/',
  label = 'MoonSun.ai home',
  size = 'header',
  as = 'a',
  class: className = '',
} = Astro.props as Props;

const classes = ['site-logo', `site-logo--${size}`, className];
---

{as === 'span' ? (
  <span class:list={classes} aria-label={label}>
    <span class="site-logo__wordmark">Moon<span>Sun<span>.ai</span></span></span>
  </span>
) : (
  <a href={href} class:list={classes} aria-label={label}>
    <span class="site-logo__wordmark">Moon<span>Sun<span>.ai</span></span></span>
  </a>
)}

<style>
  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0;
    width: fit-content;
    padding: 0.1rem 0;
    color: inherit;
    text-decoration: none;
  }

  .site-logo--header {
    min-height: var(--header-height);
  }

  .site-logo__wordmark {
    font-family: var(--font-editorial);
    font-size: 1.55rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    white-space: nowrap;
    color: var(--text-primary);
  }

  .site-logo__wordmark > span {
    color: var(--color-primary);
  }

  .site-logo__wordmark > span > span {
    color: var(--text-secondary);
  }

  .site-logo--footer .site-logo__wordmark {
    font-size: 1.55rem;
  }

  .site-logo--meta {
    padding: 0;
    vertical-align: -0.05em;
  }

  .site-logo--meta .site-logo__wordmark {
    font-size: 0.84rem;
  }

  .site-logo--mini {
    padding: 0;
  }

  .site-logo--mini .site-logo__wordmark {
    font-size: 0.95rem;
  }

  @media (max-width: 820px) {
    .site-logo--header .site-logo__wordmark {
      font-size: 1.35rem;
    }
  }
</style>
