---
// src/components/ui/AbstractThread.astro
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={["abstract-thread-wrapper", className]} aria-hidden="true">
  <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js" is:inline></script>
  <lottie-player
    src="https://cdn.prod.website-files.com/6889473510b50328dbb70ae6/68c004190c4e4446cd87c39e_Overview.json"
    background="transparent"
    speed="1"
    style="width: 120%; height: 120%; max-width: 650px; transform: translateX(-5%)"
    loop
    autoplay
  ></lottie-player>
</div>

<style>
  .abstract-thread-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible;
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    /* Optional: Pause or hide animation for reduced motion */
  }
</style>
