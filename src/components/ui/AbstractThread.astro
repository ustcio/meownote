---
// src/components/ui/AbstractThread.astro
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={["abstract-thread-wrapper", className]} aria-hidden="true">
  <!-- The floating terra cotta sphere -->
  <div class="cognitive-sphere"></div>

  <!-- The hand-drawn style SVG path -->
  <svg class="thread-svg" viewBox="0 0 500 600" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
    <!-- Drop shadow for the thread -->
    <filter id="thread-shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="8" stdDeviation="6" flood-color="#000000" flood-opacity="0.08" />
    </filter>
    
    <!-- 
      A complex, squiggly path mimicking hand-drawn thought process 
      Path draws a squiggly line resembling a loose knot or flowing thought
    -->
    <path 
      class="thread-path"
      d="M399.71,94.39 C346.06,108.57,288.72,168.16,290.41,234.61 C291.68,284.45,340.59,298.54,342.36,368.61 C343.83,426.69,271.86,499.71,192.51,515.68 C115.01,531.29,66.62,492.20,68.62,398.81 C70.08,330.41,123.63,222.01,154.67,236.43 C184.28,250.19,165.65,301.62,118.42,319.46 C80.37,333.82,49.52,284.22,78.22,231.22 C114.36,164.49,157.66,323.70,183.08,318.90 C207.24,314.35,178.65,199.19,252.17,215.15 C295.66,224.58,260.67,285.52,217.20,302.26 C166.42,321.75,200.77,370.18,228.46,375.05 C313.25,390.00,323.23,281.38,321.23,230.38"
      fill="none" 
      stroke="var(--text-primary)" 
      stroke-width="14" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      filter="url(#thread-shadow)"
    />
  </svg>
</div>

<style>
  .abstract-thread-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible;
  }

  .cognitive-sphere {
    position: absolute;
    top: 15%;
    left: 65%;
    width: 140px;
    height: 140px;
    background: #D97757; /* Claude Orange / Terra Cotta */
    border-radius: 50%;
    z-index: 1;
    /* Soft shading to make it look 3D */
    box-shadow: 
      inset -15px -15px 30px rgba(0,0,0,0.1),
      0 12px 30px rgba(217, 119, 87, 0.4);
    animation: floatSphere 8s ease-in-out infinite;
  }

  .thread-svg {
    position: absolute;
    width: 110%;
    height: 110%;
    max-width: 600px;
    z-index: 2;
    /* Move svg up a bit so it interacts with sphere nicely */
    transform: translate(-5%, -5%);
  }

  .thread-path {
    /* Define total length approximately (calculated via JS usually, 
       but 3000 is a safe bet for a complex svg path of this size to animate smoothly) */
    stroke-dasharray: 2800;
    stroke-dashoffset: 2800;
    animation: drawThread 4s cubic-bezier(0.4, 0.0, 0.2, 1) forwards,
               undulateThread 10s ease-in-out infinite 4s;
  }

  /* Draw the thread in */
  @keyframes drawThread {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Make the thread feel alive and breathing */
  @keyframes undulateThread {
    0%, 100% {
      stroke-dashoffset: 0;
    }
    50% {
      /* Only pull back a little bit to look like it's breathing */
      stroke-dashoffset: 50;
    }
  }

  @keyframes floatSphere {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-20px) scale(1.02);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .thread-path {
      animation: none;
      stroke-dashoffset: 0;
    }
    .cognitive-sphere {
      animation: none;
    }
  }
</style>
