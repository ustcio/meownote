    "breakpoints": [
      { "name": "sm", "value": "640px", "usage": "Mobile landscape" },
      { "name": "md", "value": "768px", "usage": "Tablet" },
      { "name": "lg", "value": "1024px", "usage": "Desktop" },
      { "name": "xl", "value": "1280px", "usage": "Large desktop" },
      { "name": "2xl", "value": "1440px", "usage": "Extra large desktop" }
    ]
  },
  "designPrinciples": [
    "Clean, minimal aesthetic with warm undertones",
    "Accessibility-first approach (WCAG 2.1 AA)",
    "Mobile-responsive design",
    "Dark mode support",
    "Subtle animations and micro-interactions",
    "High contrast for readability",
    "Consistent spacing and typography scale"
  ],
  "techStack": {
    "framework": "React / Next.js",
    "styling": "Tailwind CSS + CSS Modules",
    "animation": "Framer Motion",
    "stateManagement": "React Context / Zustand",
    "fonts": "Custom (Uncut Sans) + Google Fonts (Inter)"
  },
  "accessibility": {
    "standard": "WCAG 2.1 AA",
    "features": [
      "Semantic HTML5 elements",
      "ARIA labels where needed",
      "Keyboard navigation support",
      "Focus visible states",
      "Color contrast ratio: 4.5:1 minimum",
      "Reduced motion support",
      "Skip links for navigation"
    ]
  },
  "performance": {
    "targets": {
      "FCP": "< 1.5s",
      "LCP": "< 2.5s",
      "TTI": "< 3.5s",
      "CLS": "< 0.1"
    },
    "strategies": [
      "Critical CSS inlined",
      "Fonts preloaded",
      "Images lazy loaded",
      "Code split by route",
      "Service worker for caching"
    ]
  }
}
