{
  "project": "Claude AI Website Design System",
  "version": "1.0.0",
  "extractedAt": "2026-03-16",
  "source": {
    "primary": "https://claude.ai",
    "marketing": "https://www.anthropic.com",
    "documentation": "https://docs.anthropic.com"
  },
  "resources": {
    "css": [
      {
        "filename": "design-tokens.css",
        "description": "CSS custom properties for colors, typography, spacing, shadows, and transitions",
        "usage": "Import first to establish design system variables"
      },
      {
        "filename": "fonts.css",
        "description": "Font-face declarations for Uncut Sans, Inter, and JetBrains Mono",
        "usage": "Import to load custom fonts with proper fallbacks"
      },
      {
        "filename": "components.css",
        "description": "Pre-built component styles for buttons, cards, inputs, navigation, badges, and chat elements",
        "usage": "Import for ready-to-use UI components"
      },
      {
        "filename": "layout.css",
        "description": "Grid system, container utilities, section layouts, and prose styles",
        "usage": "Import for page layout and content styling"
      }
    ],
    "fonts": [
      {
        "family": "Uncut Sans",
        "type": "Primary",
        "weights": [400, 500, 600, 700],
        "usage": "Headlines, UI elements, brand text",
        "source": "Custom font by Anthropic",
        "files": [
          "UncutSans-Regular.woff2",
          "UncutSans-Medium.woff2",
          "UncutSans-Semibold.woff2",
          "UncutSans-Bold.woff2"
        ]
      },
      {
        "family": "Inter",
        "type": "Secondary",
        "weights": [400, 500, 600],
        "usage": "Body text, paragraphs, secondary content",
        "source": "Google Fonts",
        "fallback": "System fonts"
      },
      {
        "family": "JetBrains Mono",
        "type": "Monospace",
        "weights": [400, 500],
        "usage": "Code blocks, technical content, timestamps",
        "source": "Google Fonts / Local",
        "fallback": "SF Mono, Monaco, Courier New"
      }
    ],
    "colors": {
