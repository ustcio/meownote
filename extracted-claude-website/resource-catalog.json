        "file": "components.css"
      },
      {
        "name": "Typing Indicator",
        "animation": "bounce",
        "file": "components.css"
      },
      {
        "name": "Skeleton",
        "animation": "shimmer",
        "usage": "Loading states",
        "file": "components.css"
      },
      {
        "name": "Code Block",
        "features": ["syntax highlighting", "copy button", "header"],
        "file": "components.css"
